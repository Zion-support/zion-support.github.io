        console.error('Error checking tenant admin status:', error);
        setIsTenantAdmin(false);
      } finally {
        setIsLoading(false);
      }
    };

    checkTenantAdminStatus();
  }, [tenantId]);

  return { isTenantAdmin, isLoading };
};
