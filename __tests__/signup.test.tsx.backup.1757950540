function mockFetch(responses: { status: number; body: unknown }[]) {
  global.fetch = vi.fn();
  responses.forEach(({ status, body }) => {
    (global.fetch as any).mockResolvedValueOnce({
      status,
      json: () => Promise.resolve(body)
    });
  });
