{
  "root": true,
  "extends": ["next", "next/core-web-vitals"],
  "ignorePatterns": [
    "database/connection.js",
    "playwright.config.ts",
    "tailwind.config.js",
    "src/app/**",
    "src/components/NewContentPromoBanner.tsx",
    "src/data/updates.ts",
    "src/utils/**",
    "node_modules",
    ".next",
    "out",
    "coverage"
  ],
  "rules": {
    "react/no-unescaped-entities": "off",
    "@next/next/no-html-link-for-pages": "off"
  }
}
