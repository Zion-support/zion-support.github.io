import React from 'react'

type UpdateItem = {
  title: string
  date: string
  summary: string
  href: string
  tag?: 'Announcement' | 'Course' | 'Release' | 'Event'
}

const updates: UpdateItem[] = [
  {
    title: 'Zion AI Platform v2.1 Released',
    date: '2025-09-10',
    summary: 'Major stability and performance improvements, plus new multi-agent orchestration.',
    href: '/updates',
    tag: 'Release',
  },
  {
    title: 'New Course: Advanced Blockchain Development',
    date: '2025-09-05',
    summary: 'A hands-on path covering smart contracts, DeFi, L2, security and audits.',
    href: '/updates',
    tag: 'Course',
  },
  {
    title: 'Community Challenge: Build a DApp',
    date: '2025-09-01',
    summary: 'Join our DApp challenge and win prizes up to $1000 in ZION tokens.',
    href: '/updates',
    tag: 'Event',
  },
  {
    title: 'Research Spotlight: Quantum Neural Networks',
    date: '2025-08-20',
    summary: 'Exploring hybrid quantum-classical architectures for next-gen AI workloads.',
    href: '/research',
    tag: 'Announcement',
  },
]

function TagBadge({ tag }: { tag?: UpdateItem['tag'] }) {
  const styles =
    tag === 'Release'
      ? 'bg-purple-600/20 text-purple-300'
      : tag === 'Course'
      ? 'bg-blue-600/20 text-blue-300'
      : tag === 'Event'
      ? 'bg-green-600/20 text-green-300'
      : 'bg-gray-600/20 text-gray-300'
  return <span className={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ${styles}`}>{tag}</span>
}

