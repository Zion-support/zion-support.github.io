  const loadAnalytics = async () => {
    try {
      const response = await fetch(`/api/admin/usage-analytics?range=${timeRange}`);
      const result = await response.json();
      setData(result.data || []);
    } catch (error) {
      console.error('Error loading analytics:', error);
    } finally {
      setLoading(false);
