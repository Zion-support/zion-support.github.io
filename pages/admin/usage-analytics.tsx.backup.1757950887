  const avgBounceRate = data.length > 0 ? data.reduce((sum, item) => sum + item.bounceRate, 0) / data.length : 0;
  const avgSessionDuration = data.length > 0 ? data.reduce((sum, item) => sum + item.avgSessionDuration, 0) / data.length : 0;

