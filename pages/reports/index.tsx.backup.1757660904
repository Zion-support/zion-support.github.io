type UpdateEntry = {
  slug: string;
  title: string;
};

type ReportsIndexProps = {
  updates: UpdateEntry[];
};

export const getStaticProps: GetStaticProps<ReportsIndexProps> = async () => {
  const updatesDir = path.join(process.cwd(), 'pages', 'reports', 'updates');
  let updates: UpdateEntry[] = [];

  try {
    const files = fs.readdirSync(updatesDir)
      .filter((file) => file.endsWith('.tsx'))
      .sort()
      .reverse();

    updates = files.map((file) => {
      const slug = file.replace(/\.tsx$/, '');
      const prettyTitle = slug
        .replace(/^update-/, 'Autonomous Update — ')
        .replace(/-/g, ': ')
        .replace(/: (\d{4}): (\d{2}): (\d{2})/, ': $1-$2-$3');

      return {
        slug,
        title: prettyTitle
      };
    });
  } catch {
    updates = [];
  }

  return {
    props: {
      updates
    }
  };
};

export default function ReportsIndexPage({ updates }: ReportsIndexProps) {
  return (
    <>
      <Head>
        <title>Reports & Updates | Zion Tech Group</title>
        <meta name="description" content="Browse autonomous platform reports and the latest updates generated by our automation systems." />
