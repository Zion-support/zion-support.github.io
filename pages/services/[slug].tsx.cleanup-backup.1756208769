function toSlug(value: string): string {
	return value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}

export async function getStaticPaths() {
	const services = getAllServices();
	const slugs = new Set<string>();

	for (const s of services) {
		const title = 'title' in s ? s.title : 'name' in s ? s.name : '';
		if (title) {
			const slug = toSlug(title);
			slugs.add(slug);
		}
	}

	const paths = Array.from(slugs).map(slug => ({
		params: { slug }
	}));

	return {
		paths,
		fallback: 'blocking'
	};
}

export async function getStaticProps({ params }: { params: { slug: string } }) {
	const services = getAllServices();
	const service = services.find(s => {
		const title = 'title' in s ? s.title : 'name' in s ? s.name : '';
		return title && toSlug(title) === params.slug;
	});

	if (!service) {
		return {
			notFound: true
		};
	}

	return {
		props: {
			service: JSON.parse(JSON.stringify(service))
		},
		revalidate: 60
	};
}

interface ServicePageProps {
	service: Service;
}

const ServicePage: React.FC<ServicePageProps> = ({ service }) => {
	// Extract service properties with fallbacks
	const title = 'title' in service ? service.title : 'name' in service ? service.name : 'Service';
	const description = 'description' in service ? service.description : '';
	const features = 'features' in service ? service.features : [];
	const benefits = 'benefits' in service ? service.benefits : [];
	const useCases = 'useCases' in service ? service.useCases : [];
	const technology = 'technology' in service ? service.technology : [];
	const tags = 'tags' in service ? service.tags : [];
	const price = 'price' in service ? service.price : '';
