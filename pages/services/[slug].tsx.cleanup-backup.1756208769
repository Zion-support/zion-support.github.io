												</li>
											))}
										</ul>
									</Card>
								)}
							</div>

							{/* Use Cases */}
							{useCases && useCases.length > 0 && (
								<Card className="p-6 mb-8">
									<h3 className="text-2xl font-bold text-cyan-400 mb-4">Use Cases</h3>
									<div className="grid md:grid-cols-2 gap-4">
										{useCases.map((useCase, index) => (
