  const categoryIcons = {
    'AI & Machine Learning': <Brain className="w-5 h-5" />,
    'Quantum Computing': <Zap className="w-5 h-5" />,
    'IoT & Smart Cities': <Cpu className="w-5 h-5" />,
    'Robotics & Automation': <Rocket className="w-5 h-5" />,
