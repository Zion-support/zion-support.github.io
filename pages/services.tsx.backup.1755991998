      { value: '99.99%', label: 'Uptime', color: 'text-green-400' },
      { value: '30 Days', label: 'Free Trial', color: 'text-purple-400' },
      { value: '2500%+', label: 'Average ROI', color: 'text-yellow-400' }
    ]
