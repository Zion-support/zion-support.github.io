{
  "directives": {
    "default-src": [
      "'self'"
    ],
    "script-src": [
      "'self'",
      "'unsafe-inline'"
    ],
    "style-src": [
      "'self'",
      "'unsafe-inline'"
    ],
    "img-src": [
      "'self'",
      "data:",
      "https:"
    ],
    "connect-src": [
      "'self'"
    ],
    "font-src": [
      "'self'"
    ],
    "object-src": [
      "'none'"
    ],
