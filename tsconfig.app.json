{
  "extends": "./tsconfig.json",
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**",
    "tests/**",
    "automation/**",
    "**/*backup*/**",
    "**/backup/**",
    "**/backups/**",
    "**/recovered-branches/**",
    "zion-*/**",
    "src.broken/**",
    "temp_*/**",
    "utils/**",
    "types/**",
    "data/**",
    "providers/**",
    "hooks/**",
    "lib/**",
    "src/**",
    "**/*conflict*",
    "**/*temp*",
    "apps.backup/**",
    "e2e/**"
  ]
}
