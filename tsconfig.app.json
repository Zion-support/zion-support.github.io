{
  "extends": "./tsconfig.json",
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**",
    "tests/**",
    "automation/**",
    "backups/**",
    "backup*/**",
    "**/*backup*",
    "**/*conflict*",
    "**/*temp*",
    "src.broken/**",
    "temp_*/**",
    "recovered-branches/**",
    "apps.backup/**",
    "zion-*/**",
    "app/components/**",
    "pages/**",
    "src/**",
    "utils/**",
    "types/**",
    "e2e/**"
  ]
}
