{
  "extends": "./tsconfig.json",
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "utils/**/*.ts",
    "utils/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "**/backups/**",
    "**/*backup*",
    "**/*conflict*",
    "**/*temp*",
    "apps.backup",
    "recovered-branches",
    "zion-os",
    "zion-website",
    "zion-ai-assistant",
    "tests",
    "__tests__",
    "e2e"
  ]
}
{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "noFallthroughCasesInSwitch": false,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/pages/*": ["./src/pages/*", "./pages/*"],
      "@/api/*": ["./src/api/*"],
      "axios": ["./src/lib/axios.ts"],
      "next": ["../types/next"],
      "next/*": ["../types/next/*"]
    },
    "typeRoots": ["./src/types", "./node_modules/@types"],
    "types": ["node"],
    "composite": true,
    "noEmit": true
  },
  "include": ["src", "pages"],
  "exclude": [
    "node_modules",
    "src/pages_backup/**",
    "**/*backup*/**",
    "**/backup/**",
    "**/backups/**",
    "**/recovered-branches/**",
    "types/**"
  ]
}
