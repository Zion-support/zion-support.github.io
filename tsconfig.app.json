{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**",
    "tests/**",
    "automation/**",
    "app/resources/**",
    "app/blog/**",
    "app/case-studies/**",
    "app/ai-*/**",
    "**/*backup*/**",
    "**/backup/**",
    "**/backups/**",
    "**/recovered-branches/**",
    "zion-*/**",
    "src.broken/**",
    "temp_*/**",
    "lib/**",
    "backup-merge-conflicts/**",
    "backup-problematic-files/**",
    "src/**",
    "apps.backup/**",
    "e2e/**"
  ]
}
