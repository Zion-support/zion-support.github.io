{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmitOnError": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    ".next/types/**/*.ts",
    "app/about/page.tsx",
    "app/accessibility/page.tsx",
    "app/ai-accounting-assistant/page.tsx",
    "app/ai-agricultural-intelligence-pro/page.tsx",
    "app/contact/page.tsx",
    "app/layout.tsx",
    "app/page.tsx",
    "next-env.d.ts",
    "types/**/*.ts",
    "dist/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "corrupted-src-backup",
    "problematic-files-backup",
    "problematic-pages",
    "**/ai-pages-backup/**",
    "**/ai-pages-disabled/**",
    "**/api-backup/**",
    "**/app-disabled-all/**",
    "**/app-disabled/**",
    "**/api-disabled/**",
    "**/ai-customer-support-disabled/**",
    "**/ai-workflow-automation-disabled/**",
    "**/pages.disabled/**",
    "**/lib.disabled/**",
    "**/all-pages-backup/**",
    "**/backup*/**",
    "**/*.backup.*",
    "**/*.bak",
    "**/backup/**",
    "**/clean-build/**",
    "**/apps/**",
    "**/components/api/**",
    "**/contracts/**",
    "**/cypress/**",
    "**/data/**",
    "**/lib/**",
    "**/netlify/**",
    "**/pages_backup/**",
    "**/page_template.tsx",
    "**/pages_minimal/**",
    "**/recovered-branches/**",
    "**/scripts/**",
    "**/services/**",
    "**/security.config.ts",
    "**/src-corrupted/**",
    "**/src.broken/**",
    "**/temp_conflicts/**",
    "**/utils/**",
    "**/tailwind.config.ts",
    "**/vite.config.ts",
    "**/zion-ai-assistant/**",
    "**/zion-os/**",
    "utils/fsdb.ts",
    "**/__tests__/**",
    "**/*-backup.*",
    "**/*-broken*",
    "**/*-fixed.*",
    "**/corrupted-pages/**",
    "**/AdvancedAccessibilityEnhancer.tsx",
    "**/ecommerce-analytics-pro/**",
    "**/edge-computing/**",
    "**/*-broken2.*",
    "**/*-original.*",
    "ai-pages-disabled",
    "corrupted-pages",
    "working-pages",
    "backup-unused-components",
    "components.disabled",
    "api-backup",
    "app-disabled",
    "app-disabled-all",
    "app/components",
    "app/utils",
    "apps",
    "blog"
  ]
}
