{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": false,
    "baseUrl": ".",
    "noEmit": true,
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "data_backup/**",
    "src.corrupted/**",
    "src/data/**",
    "src/**",
    "utils/next-link-shim.tsx",
    "playwright.config.ts",
    "api-backup",
    "api-disabled",
    "api.disabled.temp",
    "pages.disabled",
    "backup-pages",
    "automation/**",
    "scripts/**",
    "src.corrupted/**",
    "deployments/**",
    "deployment/**",
    "backup/**",
    "automation/backups",
    "automation_backup",
    "broken_files_backup",
    "contracts",
    "data",
    "data/**",
    "cypress",
    "temp_working",
    "supabase/functions",
    "**/*.backup",
    "**/*.disabled",
    "cypress_backup",
    "contracts_backup",
    "data_backup",
    "fix_utils_files.ts",
    "hooks/useResponsive.ts",
    "lib_backup",
    "pages-backup",
    "pages.__backup",
    "server",
    "services",
    "src.broken",
    "temp_working",
    "supabase/functions",
    "temp_backup",
    "temp_backup/**",
    "temp_broken_components",
    "temp_broken_components/**",
    "src.corrupted/**"
  ]
}
