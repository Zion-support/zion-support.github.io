{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "jsx": "preserve",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "allowJs": false,
    "incremental": true,
    "types": [
      "node"
    ],
    "typeRoots": [
      "./node_modules/@types",
      "./types"
    ],
    "outDir": "dist",
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "allowSyntheticDefaultImports": true,
    "strictNullChecks": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    ".next/types/**/*.ts",
    "src/**/*",
    "pages/**/*",
    "*.ts",
    "*.tsx"
  ],
  "exclude": [
    "node_modules",
    "api-backup",
    "pages.disabled",
    "backup-pages",
    "temp_working",
    "supabase/functions",
    "src/routes",
    "automation/backups",
    "automation_backup",
    "broken_files_backup",
    "components",
    "contracts",
    "cypress",
    "**/*.backup",
    "**/*.disabled",
    "temp_working",
    "supabase/functions",
    "src/utils/generateRandomListing.ts",
    "src/utils/linkChecker.ts",
    "src/utils/mimeTypeFallback.ts",
    "src/utils/passwordStrength.tsx",
    "src/utils/resourceMonitor.ts",
    "src/utils/seoOptimizer.tsx",
    "src/utils/serviceWorkerRegistration.ts",
    "src/utils/unitConversion.ts",
    "src/utils/withErrorLogging.ts",
    "src/utils/generateRandomBlogPost.ts",
    "src/pages/solutions/EnterpriseSolutions.tsx",
    "src/utils/sitemapGenerator.tsx",
    "src/pages/zion-hire-ai.tsx",
    "src/pages/webinars.tsx",
    "src/routes/*Routes.tsx",
    "src/pages/services/**",
    "src/pages/solutions/**",
    "src/pages/**",
    "src/routes/**",
    "src/services/**",
    "src/types/**",
    "src/utils/**"
  ]
}