{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": [
    "src/main.tsx",
    "src/App.tsx",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".next",
    "out",
    "src/pages",
    "src/components",
    "src/data",
    "src/types",
    "src/utils",
    "src/hooks",
    "src/context",
    "src/layout",
    "src/integrations",
    "src/lib",
    "src/routes",
    "src/store",
    "src/i18n",
    "src_disabled",
    "broken_files_backup",
    "components_backup",
    "tests.disabled",
    "automation",
    "pages",
    "data"
  ]
}
