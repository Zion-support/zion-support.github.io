{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": false,
    "baseUrl": ".",
    "allowJs": true,
    "esModuleInterop": true,
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "scripts/**/*.ts",
    "automation/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "data_backup/**",
    "src.corrupted/**",
    "api-backup",
    "api-disabled",
    "api.disabled.temp",
    "pages.disabled",
    "backup-pages",
    "automation/**",
    "scripts/**",
    "src.corrupted/**",
    "deployments/**",
    "deployment/**",
    "backup/**",
    "automation/backups",
    "automation_backup",
    "broken_files_backup",
    "contracts",
    "data",
    "data/**",
    "cypress",
    "**/*.backup",
    "**/*.disabled",
    "temp_working",
    "supabase/functions",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    ".next",
    "out",
    "dist"
  ]
}