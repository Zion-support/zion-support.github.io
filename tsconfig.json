{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    "out/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "contracts/**/*",
    "dao/**/*",
    "automation/**/*",
    "scripts/**/*",
    "cypress/**/*",
    "cypress.config.ts",
    "deployment/**/*",
    "deployments/**/*",
    "data/**/*",
    "ts-backup/**/*",
    "jest.config.ts",
    "jest.setup.ts",
    "netlify/**/*",
    "pages._quarantine/**/*",
    "pages.bak/**/*",
    "pages.old/**/*",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.ts.disabled",
    "instrumentation.disabled.ts",
    "2024-*.ts",
    "2025-*.ts",
    "2028-*.ts",
    "2029-*.ts",
    "2030-*.ts",
    "revolutionary-*.ts",
    "innovative-*.ts",
    "enterprise-*.ts",
    "emerging-tech-*.ts",
    "zion-*.ts",
    "blockchain-*.ts",
    "cybersecurity-*.ts",
    "space-tech-*.ts",
    "next-gen-*.ts",
    "market-validated-services.ts",
    "real-market-services.ts",
    "real-2025-q4-additions.ts",
    "autonomous-*.ts",
    "enhanced-*.ts",
    "deploy.ts",
    "server.ts",
    "service.ts",
    "services.ts",
    "storage.ts",
    "translation.ts",
    "types.ts",
    "index.ts",
    "proposals.ts",
    "src/utils/*.ts",
    "src/lib/*.ts",
    "src/hooks/*.ts",
    "src/components/*.ts",
    "src/components/*.tsx",
    "use*.ts",
    "*.config.js",
    "*.config.ts"
  ]
}
