{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "zion-website/src/*"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/**",
    ".next",
    "dist",
    "out",
    "coverage",
    "build",
    "public/build",
    "data_backup",
    "backup",
    "backups",
    "apps.backup",
    "corrupted-files-backup",
    "lib_backup",
    "**/*backup*",
    "**/*conflict*",
    "**/*temp*",
    "src",
    "src.*",
    "src_*",
    "src-*/**",
    "src_backup/**",
    "src_backup_temp/**",
    "src.broken/**",
    "src.corrupted/**",
    "src.disabled/**",
    "src.pages.disabled/**",
    "zion-os/**",
    "utils/**",
    "components/**",
    "lib/**",
    "hooks/**",
    "types/**",
    "utils.disabled/**",
    "ts_files_backup/**",
    "tests/**",
    "__tests__/**",
    "test/**",
    "test-results/**",
    "test-reports/**",
    "types/**"
  ]
}
