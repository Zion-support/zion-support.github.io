{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": [
      "jest",
      "node"
    ],
    "baseUrl": ".",
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "data_backup/**",
    "src.corrupted/**",
    "src/data/**",
    "src/**",
    "utils/next-link-shim.tsx",
    "playwright.config.ts",
    "api-backup",
    "pages.disabled",
    "backup-pages",
    "automation/**",
    "scripts/**",
    "src.corrupted/**",
    "deployments/**",
    "deployment/**",
    "backup/**",
    "automation/backups",
    "automation_backup",
    "broken_files_backup",
    "contracts",
    "cypress",
    "temp_working",
    "supabase/functions",
    "**/*.backup",
    "**/*.disabled",
    "temp_backup",
    "temp_backup/**",
    "temp_broken_components",
    "temp_broken_components/**",
    "src.corrupted/**"
  ]
}
