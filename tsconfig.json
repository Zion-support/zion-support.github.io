{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": false,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/pages/*": [
        "./src/pages/*",
        "./pages/*"
      ],
      "@/components/*": [
        "./src/components/*",
        "./components/*"
      ],
      "@/lib/*": [
        "./src/lib/*",
        "./lib/*"
      ],
      "@/utils/*": [
        "./src/utils/*",
        "./utils/*"
      ],
      "@/styles/*": [
        "./src/styles/*",
        "./styles/*"
      ],
      "@/types/*": [
        "./src/types/*",
        "./types/*"
      ],
      "@/hooks/*": [
        "./src/hooks/*",
        "./hooks/*"
      ],
      "@/contexts/*": [
        "./src/contexts/*",
        "./contexts/*"
      ],
      "@/store/*": [
        "./src/store/*",
        "./store/*"
      ],
      "@/config/*": [
        "./src/config/*",
        "./config/*"
      ],
      "@/public/*": [
        "./public/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}