{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "types": [
      "react",
      "react-dom",
      "node"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "target": "es5",
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*",
    "pages/**/*",
    "components/**/*",
    "lib/**/*",
    "__tests__/**/*"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "backup",
    "backups",
    "backup-merge-conflicts",
    "backup-problematic-files",
    "components.disabled",
    "components-disabled",
    "pages-disabled",
    "pages.disabled",
    "pages.disabled_full",
    "src.disabled",
    "src_backup",
    "src_backup_temp",
    "temp_exclude",
    "corrupted_backup",
    "recovered-branches",
    "tests"
  ]
}
