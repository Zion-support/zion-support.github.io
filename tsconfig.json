{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "types": [
      "react",
      "react-dom",
      "node"
    ],
    "typeRoots": [
      "node_modules/@types"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "target": "es5",
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "__tests__/**/*",
    "components/**/*",
    "lib/**/*",
    "next-env.d.ts",
    "pages/**/*",
    "src/**/*",
    "types/**/*",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    // Temporarily exclude corrupted components until repaired
    "components/vendors",
    "components/wallet",
    "components/zion",
    "components/token",
    "components/tokens",
    // Common backup/conflict/temp dirs (merged from origin/main)
    "data_backup",
    "backup",
    "backups",
    "pages_backup_conflict",
    "apps.backup",
    "corrupted-files-backup",
    "lib_backup",
    "**/*backup*",
    "**/*conflict*",
    "**/*temp*",
    // Disabled dirs in this repo
    "components.disabled",
    "components-disabled",
    "pages-disabled",
    "pages.disabled",
    "pages.disabled_full",
    "src.disabled",
    "src_backup",
    "src_backup_temp",
    "temp_exclude",
    "corrupted_backup",
    "recovered-branches",
    "tests"
  ]
}
