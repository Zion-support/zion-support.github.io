{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "es6",
      "es2017",
      "es2018",
      "es2019",
      "es2020",
      "es2021",
      "es2022"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/pages/*": ["./src/pages/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/types/*": ["./src/types/*"],
      "@/styles/*": ["./src/styles/*"],
      "@/assets/*": ["./src/assets/*"],
      "@/app/*": ["./app/*"],
      "@/styles/*": ["./styles/*"],
      "@/public/*": ["./public/*"]
    },
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "build",
    "backup*",
    "temp*",
    "corrupted*",
    "apps.backup*",
    "apps*",
    "recovered-branches*",
    "src*",
    "data*",
    "**/*.backup.*",
    "**/*.temp.*",
    "**/*.conflict.*",
    "src/App.tsx",
    "src/components/DynamicListingPage.tsx",
    "src/components/ErrorBoundary.tsx",
    "src/components/FeaturesGuideSection.tsx",
    "src/components/Footer.tsx",
    "src/components/Header.tsx",
    "src/components/PerformanceMonitor.tsx",
    "src/components/developers/WebhooksManager.tsx",
    "src/components/icons/index.tsx",
    "src/pages/About.tsx",
    "src/pages/Contact.tsx",
    "src/pages/Pricing.tsx",
    "src/pages/Services.tsx"
  ]
}
