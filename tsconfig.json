{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "types": ["@testing-library/jest-dom"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "target": "ES2017",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./app/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    "jest.setup.ts"
  ],
  "exclude": [
    "node_modules",
    "app-backup/**/*",
    "ai-pages-backup/**/*",
    "all-pages-backup/**/*",
    "backup-problematic/**/*",
    "corrupted-src-backup/**/*",
    "problematic-files-backup/**/*",
    "problematic-pages/**/*",
    "temp-pages/**/*",
    "temp-all-problematic/**/*",
    "temp-backup/**/*",
    "temp-problematic/**/*"
  ]
}
