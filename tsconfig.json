{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmitOnError": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "next-env.d.ts",
    "types/**/*.ts",
    "dist/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "corrupted-src-backup",
    "problematic-files-backup",
    "problematic-pages",
    "**/ai-pages-backup/**",
    "**/ai-pages-disabled/**",
    "**/api-backup/**",
    "**/app-disabled-all/**",
    "**/app-disabled/**",
    "**/api-disabled/**",
    "**/ai-customer-support-disabled/**",
    "**/ai-workflow-automation-disabled/**",
    "**/pages.disabled/**",
    "**/lib.disabled/**",
    "**/all-pages-backup/**",
    "**/backup*/**",
    "**/*.backup.*",
    "**/*.bak",
    "**/backup/**",
    "**/AdvancedPerformanceOptimizer.tsx",
    "**/AdvancedSEOOptimizer.tsx",
    "**/Analytics.tsx",
    "**/AnalyticsProvider.tsx",
    "**/AnimatedCounter.tsx",
    "**/ContentCarousel.tsx",
    "**/ContentNewsletterSignup.tsx",
    "**/ContentPromotionBanner.tsx",
    "**/ContentStatistics.tsx",
    "**/DynamicContentShowcase.tsx",
    "**/EnhancedAccessibilityEnhancer.tsx",
    "**/EnhancedHero.tsx",
    "**/EnhancedLoadingSkeleton.tsx",
    "**/EnhancedLoadingStates.tsx",
    "**/EnhancedPerformanceMonitor.tsx",
    "**/FuturisticServiceCard.tsx",
    "**/InteractiveAIROICalculator.tsx",
    "**/PageLoader.tsx",
    "**/PWAInstaller.tsx",
    "**/SecurityEnhancer.tsx",
    "**/SEOOptimizer.tsx",
    "**/ServiceWorker.tsx",
    "**/Sidebar.tsx"
  ]
}
