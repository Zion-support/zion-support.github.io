{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "build",
    "automation",
    "scripts",
    "fix_*.js",
    "fix_*.cjs",
    "*.fix.js",
    "*.fix.cjs",
    "vite.config.ts",
    "tailwind.config.ts",
    "**/*.backup.*",
    "**/*.disabled/**",
    "pages_disabled/**",
    "pages.disabled/**",
    "src_disabled/**",
    "temp_components.disabled/**",
    "tests.disabled/**"
  ]
}
