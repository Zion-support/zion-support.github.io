{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@/components/*": [
        "src/components/*"
      ],
      "@/pages/*": [
        "src/pages/*"
      ],
      "@/utils/*": [
        "src/utils/*"
      ],
      "@/types/*": [
        "src/types/*"
      ],
      "@/hooks/*": [
        "src/hooks/*"
      ],
      "@/config/*": [
        "src/config/*"
      ],
      "@/data/*": [
        "src/data/*"
      ],
      "@/content/*": [
        "src/content/*"
      ]
    },
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "_app_disabled",
    "_conflicted_disabled",
    "_pages_api_disabled",
    "_pages_disabled",
    "app_disabled",
    "components.disabled",
    "backup",
    "backup-banner-components",
    "backup-pages",
    "backup-problematic-files",
    "broken_files_backup",
    "apps",
    "apps.backup",
    "api-backup",
    "api-disabled",
    "api.disabled",
    "api.disabled.temp",
    "admin-api-disabled",
    "automation",
    "automation_backup",
    "blog",
    "corrupted-files-backup",
    "corrupted_backup",
    "corrupted_files_backup_2",
    "blockchain-solutions.tsx",
    "app/components/NewestContent2025Banner.tsx",
    "app/components/UltimateBusinessIntelligence2025Banner.tsx",
    "app/components/UltimateBusinessIntelligenceShowcase2025.tsx",
    "app_disabled_temp",
    "src.disabled",
    "utils.disabled",
    "components.disabled",
    "clean-build",
    "temp-files",
    "backup-files",
    "disabled-files",
    "components-disabled",
    "pages-disabled",
    "api-disabled",
    "utils-disabled",
    "components.disabled_full",
    "pages.disabled",
    "api.disabled",
    "utils.disabled",
    "content",
    "contracts",
    "contracts.disabled",
    "corrupted-services-backup",
    "cypress",
    "cypress.disabled",
    "data.disabled",
    "data",
    "corrupted-src-backup",
    "corrupted-backup",
    "corrupted_files_backup",
    "corrupted_files_backup_2",
    "data_backup",
    "disabled-api",
    "hooks.disabled",
    "lib.broken",
    "lib.disabled",
    "lib_backup",
    "lint-target",
    "netlify",
    "pages_disabled"
  ]
}
