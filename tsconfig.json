{
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*", "pages/*", "components/*"]
		},
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": false,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"incremental": true,
		"module": "esnext",
		"esModuleInterop": true,
		"moduleResolution": "node",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "preserve",
		"plugins": [{ "name": "next" }],
		"strictNullChecks": true,
		"target": "ES2017"
	},
	"include": [
		"next-env.d.ts",
		".next/types/**/*.ts",
		"app/**/*.ts",
		"app/**/*.tsx",
		"types/**/*.d.ts"
	],
	"exclude": [
		"node_modules",
		"**/node_modules/**",
		".next",
		".next/**",
		"dist",
		"out",
		"coverage",
		"build",
		"public/build",
		"apps/**",
		"apps.backup/**",
		"backup/**",
		"backups/**",
		"**/*backup*",
		"**/*conflict*",
		"**/*temp*",
		".temp_backup_components/**",
		"automation/**",
		"recovered-branches/**",
		"src_backup/**",
		"src_backup_temp/**",
		"src.broken/**",
		"src-corrupted/**",
		"src.corrupted/**",
		"src.disabled/**",
		"pages-disabled/**",
		"pages.bak/**",
		"pages_backup_before_cleanup/**",
		"pages.broken/**",
		"pages.corrupted*",
		"tests/**",
		"__tests__/**",
		"test/**",
		"test-results/**",
		"test-reports/**",
		"zion-os/**",
		"zion-ai-assistant/**",
		"utils.disabled/**",
		"ts_files_backup/**",
		"server/**",
		"app/page.full.tsx"
	]
}
