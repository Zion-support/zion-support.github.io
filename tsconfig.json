    "components_backup/**/*",
    "data_backup/**/*",
    "lib_backup/**/*",
    "automation/**",
    "app/blog/**",
    "_app_disabled/blog/**",
    "app_disabled/blog/**",
    "app_disabled/case-studies/**",
    "app_disabled/components/**",
