{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": false,
    "baseUrl": ".",
    "allowJs": true,
    "esModuleInterop": true
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.ts",
    "automation/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "data_backup/**",
    "src.corrupted/**",
    "pages/**",
    "components/**",
    "src/**",
    "utils/next-link-shim.tsx",
    "playwright.config.ts",
    "api-backup",
    "api-disabled",
    "api.disabled.temp",
    "pages.disabled",
    "backup-pages",
    "automation/**",
    "scripts/**",
    "src.corrupted/**",
    "deployments/**",
    "deployment/**",
    "backup/**",
    "automation/backups",
    "automation_backup",
    "broken_files_backup",
    "contracts",
    "data",
    "data/**",
    "cypress",
    "temp_working",
    "supabase/functions",
    "**/*.backup",
    "**/*.disabled",
    "src/store/authSlice.tsx",
    "src/store/cartSlice.ts",
    "src/store/hooks.ts",
    "src/store/index.ts",
    "src/store/wishlistSlice.ts",
    "src/store/wishlistSlice.tsx",
    "src/utils/safeStorage.tsx",
    "src/utils/linkChecker.ts",
    "src/utils/performance.ts",
    "src/utils/performanceOptimizer.ts",
    "src/utils/resourceMonitor.ts",
    "src/utils/serviceMapper.ts",
    "src/utils/sitemapGenerator.ts",
    "src/utils/tokenRewards.ts",
    "src/types/**/*.ts",
    "src/pages/**",
    "src/routes/**",
    "src/services/**",
    "src/test/**",
    "src/types/**"
  ]
}
