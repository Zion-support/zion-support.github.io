{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "types": ["jest", "node"],
    "baseUrl": "."
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "pages/**/*",
    "components/**/*",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "api-backup",
    "pages.disabled",
    "backup-pages",
    "automation/backups",
    "automation_backup",
    "broken_files_backup",
    "contracts",
    "cypress",
    "temp_working",
    "supabase/functions",
    "**/*.test.*",
    "**/__tests__/**",
    "**/*.spec.*",
    "**/*.backup",
    "**/*.disabled",
    "temp_backup",
    "temp_backup/**",
    "temp_broken_components",
    "temp_broken_components/**",
    "src.disabled",
    "solutions.disabled",
    "tailwind.config.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
