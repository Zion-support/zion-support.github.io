{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "types": ["vite/client", "react", "react-router-dom", "node"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,

    /* Path mapping */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/main.tsx",
    "src/App.tsx",
    "src/App.css",
    "src/index.css"
  ],
  "exclude": [
    "node_modules",
    "src/pages/**/*",
    "src/routes/**/*",
    "src/components/**/*",
    "src/context/**/*",
    "src/hooks/**/*",
    "src/services/**/*",
    "src/data/**/*",
    "src/types/**/*",
    "src/utils/**/*",
    "src/layout/**/*",
    "src/lib/**/*"
  ]
}