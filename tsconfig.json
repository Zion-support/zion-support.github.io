{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/components/*": [
        "./components/*"
      ],
      "@/pages/*": [
        "./pages/*"
      ],
      "@/utils/*": [
        "./utils/*"
      ],
      "@/hooks/*": [
        "./hooks/*"
      ],
      "@/types/*": [
        "./types/*"
      ],
      "@/styles/*": [
        "./styles/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ]
    },
    "allowSyntheticDefaultImports": true,
    "strictNullChecks": true,
    "maxNodeModuleJsDepth": 0,
    "disableSourceOfProjectReferenceRedirect": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "api-backup",
    "pages.disabled",
    "backup-pages",
    "automation/backups",
    "automation_backup",
    "broken_files_backup",
    "contracts",
    "cypress",
    "temp_working",
    "supabase/functions",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.backup",
    "**/*.disabled",
    "src",
    "src.pages.disabled",
    "src.pages.disabled.auto",
    "components.disabled",
    "src.disabled",
    "src.pages.disabled",
    "src_backup/**",
    "recovered-branches/**",
    "temp_backup/**",
    "api.disabled/**",
    "lib/analytics.ts"
  ],
  "ts-node": {
    "transpileOnly": true,
    "files": true
  }
}