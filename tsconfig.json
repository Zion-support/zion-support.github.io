{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmitOnError": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "jsxImportSource": "react",
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    ".next/types/**/*.ts",
    "app/_not-found.tsx",
    "app/layout.tsx",
    "app/page.tsx",
    "app/team/page.tsx",
    "next-env.d.ts",
    "dist/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "corrupted-src-backup",
    "problematic-files-backup",
    "problematic-pages",
    "**/ai-pages-backup/**",
    "**/ai-pages-disabled/**",
    "**/api-backup/**",
    "**/app-disabled-all/**",
    "**/app-disabled/**",
    "**/api-disabled/**",
    "**/ai-customer-support-disabled/**",
    "**/ai-workflow-automation-disabled/**",
    "**/pages.disabled/**",
    "**/lib.disabled/**",
    "**/all-pages-backup/**",
    "**/backup*/**",
    "**/*.backup.*",
    "**/*.bak",
    "**/backup/**",
    "**/AdvancedPerformanceOptimizer.tsx",
    "**/AdvancedSEOOptimizer.tsx",
    "**/Analytics.tsx",
    "**/AnalyticsProvider.tsx",
    "**/AnimatedCounter.tsx",
    "**/ContentCarousel.tsx",
    "**/ContentNewsletterSignup.tsx",
    "**/ContentPromotionBanner.tsx",
    "**/ContentStatistics.tsx",
    "**/DynamicContentShowcase.tsx",
    "**/EnhancedAccessibilityEnhancer.tsx",
    "**/EnhancedHero.tsx",
    "**/EnhancedLoadingSkeleton.tsx",
    "**/EnhancedLoadingStates.tsx",
    "**/EnhancedPerformanceMonitor.tsx",
    "**/FuturisticServiceCard.tsx",
    "**/InteractiveAIROICalculator.tsx",
    "**/PageLoader.tsx",
    "**/PWAInstaller.tsx",
    "**/SecurityEnhancer.tsx",
    "**/SEOOptimizer.tsx",
    "**/ServiceWorker.tsx",
    "**/Sidebar.tsx"
  ]
}
