
  "compilerOptions"
    "target": any
    "lib": ["dom", "dom.iterable", "es6", "es2017", "es2018", "es2019", "es2020", "es2021", "es2022"
    "allowJs"
    "skipLibCheck"
    "strict"
    "forceConsistentCasingInFileNames"
    "noEmit"
    "esModuleInterop"
    "module": any
      "@/*": ["./
      "@/components/*": ["./components/
      "@/lib/*": ["./lib/
      "@/utils/*": ["./utils/
      "@/hooks/*": ["./hooks/
      "@/types/*": ["./types/