{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2024", "DOM", "DOM.Iterable", "WebWorker", "WebWorker.Iterable"],
    "module": "ESNext",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/pages/*": ["./src/pages/*", "./pages/*"],
      "@/components/*": ["./src/components/*"],
      "@/api/*": ["./src/api/*"],
      "@/types/*": ["./src/types/*", "./types/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/context/*": ["./src/context/*"],
      "@/services/*": ["./src/services/*"],
      "react-router-dom": ["./src/stubs/react-router-dom.tsx"],
      "next-cloudinary": ["./types/next-cloudinary.d.ts"],
      "types/*": ["./types/*"]
    },
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    /* Linting */
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "allowJs": false,
    "incremental": true,
    "typeRoots": ["./node_modules/@types", "./types"],
    "types": ["node", "jest", "vitest"],
    "jsx": "preserve",
    "declaration": true,
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "noEmit": false
  },
  "include": [
    "next-env.d.ts", 
    "app/**/*.ts", 
    "app/**/*.tsx", 
    ".next/types/**/*.ts",
    "src/**/*",
    "pages/**/*",
    "*.ts",
    "*.tsx"
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ],
  "exclude": [
    "node_modules",
    "zion.app/recovered-content/**",
    "contracts/**",
    "zion-os/**",
    "zion_academy/**",
    "wiki/**",
    "temp_components/**",
    "cypress/**",
    "data/2025-cutting-edge-enterprise-solutions.ts",
    "data/2025-cutting-edge-it-infrastructure-innovations.ts",
    "data/2025-emerging-tech-services.ts",
    "data/2025-enterprise-it-solutions.ts",
    "data/2025-innovative-agriculture-services.ts",
    "data/2025-innovative-ai-automation-services.ts",
    "data/2025-innovative-ai-autonomous-ecosystem.ts",
    "data/2025-innovative-ai-services-enhanced.ts",
    "data/2025-innovative-ai-services-expansion-v2.ts",
    "data/2025-innovative-ai-services-expansion.ts",
    "data/2025-innovative-ar-vr-services.ts",
    "data/2025-innovative-business-solutions-expansion.ts",
    "data/2025-innovative-edge-computing-services.ts",
    "data/2025-innovative-energy-services.ts",
    "data/2025-innovative-entertainment-services.ts",
    "data/2025-innovative-environmental-services.ts",
    "data/2025-innovative-fintech-services.ts",
    "data/2025-innovative-gaming-services.ts",
    "data/2025-innovative-government-services.ts",
    "data/2025-innovative-healthtech-services.ts",
    "data/2025-innovative-hospitality-services.ts"
  ]
}
