{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "types": [
      "react",
      "react-dom",
      "node"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "target": "es5",
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "app/**",
    "**/tests/**",
    "**/__tests__/**",
    "**/apps/**",
    "**/app_backup/**",
    "**/app-disabled/**",
    "**/components/**",
    "**/components-disabled/**",
    "**/components.disabled/**",
    "**/components.disabled_full/**",
    "**/pages.disabled/**",
    "**/pages_backup/**",
    "**/pages.bak/**",
    "**/pages._archive_corrupted/**",
    "**/src.disabled/**",
    "**/src-disabled/**",
    "**/src_backup/**",
    "**/src_backup_temp/**",
    "**/src.broken/**",
    "**/src.corrupted/**",
    "**/backup-problematic-files/**",
    "**/ts_files_backup/**",
    "**/temp_*/**",
    "**/dist/**",
    "**/build/**",
    "**/out/**"
  ]
}
