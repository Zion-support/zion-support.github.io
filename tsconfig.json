{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": false,
    "baseUrl": "."
  },
  "include": [
    "src/**/*",
    "pages/**/*",
    "components/**/*.ts",
    "components/**/*.tsx",
    "data/services.ts",
    "styles/**/*",
    "types/**/*",
    "utils/**/*",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "api-backup",
    "api-disabled",
    "api.disabled.temp",
    "pages.disabled",
    "backup-pages",
    "automation/**",
    "scripts/**",
    "src.corrupted/**",
    "deployments/**",
    "deployment/**",
    "backup/**",
    "automation/backups",
    "automation_backup",
    "broken_files_backup",
    "contracts",
    "data",
    "data/**",
    "cypress",
    "**/*.backup",
    "**/*.disabled",
    "temp_working",
    "supabase/functions",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    ".next",
    "out",
    "dist"
  ]
}