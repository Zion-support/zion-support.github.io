{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "utils/**/*.ts",
    "utils/**/*.tsx",
    "services/**/*.ts",
    "services/**/*.tsx",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    "out/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "contracts/**/*",
    "dao/**/*",
    "automation/**/*",
    "scripts/**/*",
    "cypress/**/*",
    "cypress.config.ts",
    "deployment/**/*",
    "deployments/**/*",
    "data/**/*",
    "monitoring.bak/**/*",
    "netlify.bak/**/*",
    "i18n.bak/**/*",
    "pages-quarantine/**/*",
    "pages._quarantine/**/*",
    "services.bak/**/*",
    "**/*.bak/**/*",
    "**/*.tsx.bak",
    "**/*.ts.bak"
  ]
}
