{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "data_backup",
    "backup",
    "backups",
    "pages_backup_conflict",
    "apps.backup",
    "corrupted-files-backup",
    "lib_backup",
    "**/*backup*",
    "**/*conflict*",
    "**/*temp*",
    "zion-os",
    "zion-os/**",
    "server",
    "server/**",
    ".temp_backup_components",
    ".temp_backup_components/**",
    "automation",
    "automation/**",
    "src",
    "src/**",
    "utils",
    "utils/**",
    "zion-ai-assistant",
    "zion-ai-assistant/**",
    "zion-os.disabled",
    "zion-os.disabled/**"
  ]
}
