{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/main.tsx",
    "src/App.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "out",
    "build",
    "automation",
    "scripts",
    "tests",
    "**/*.test.*",
    "**/__tests__/**",
    "src/pages/**",
    "src/store/**",
    "src/utils/**",
    "src/types/**"
  ]
}
