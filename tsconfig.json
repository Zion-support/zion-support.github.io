{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "data_backup",
    "backup",
    "backups",
    "pages_backup_conflict",
    "apps.backup",
    "corrupted-files-backup",
    "lib_backup",
    "**/*backup*",
    "**/*conflict*",
    "**/*temp*",
    "temp*",
    "temp_*",
    "temp-*",
    "temp/**",
    "temp_backup/**",
    "temp-backup/**",
    "temp_backup_build_fix/**",
    "temp_backup_runtime_fix/**",
    "temp_components/**",
    "temp_components.disabled/**",
    "temp_disabled/**",
    "temp-disabled-pages/**",
    "temp_exclude/**",
    "temp-problematic-pages/**",
    "temp_working/**",
    "zion-os",
    "zion-website",
    "ts_files_backup",
    "types",
    "tests",
    "__tests__",
    "test",
    "tests.disabled",
    "app/**",
    "components/**",
    "pages/**",
    "utils.disabled",
    "utils",
    "src.disabled",
    "src.broken",
    "src-corrupted",
    "src.corrupted"
  ]
}
