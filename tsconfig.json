{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    "out/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "contracts/**/*",
    "dao/**/*",
    "automation/**/*",
    "scripts/**/*",
    "cypress/**/*",
    "cypress.config.ts",
    "jest.config.ts",
    "jest.setup.ts",
    "deployment/**/*",
    "deployments/**/*",
    "data/**/*",
    "monitoring/**/*",
    "netlify/**/*",
    "pages-quarantine/**/*",
    "pages._quarantine/**/*",
    "pages.bak/**/*",
    "pages.old/**/*",
    "pages_backup/**/*",
    "pages_minimal/**/*",
    "playwright.config.ts",
    "prisma/**/*",
    "seed.ts",
    "server/**/*",
    "services-broken.tsx",
    "services/**/*",
    "src-clean/**/*"
  ]
}
