{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "es6"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": false,
    "baseUrl": "."
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "lib/**/*",
    "hooks/**/*",
    "styles/**/*",
    "automation/**/*.ts",
    "automation/**/*.tsx",
    "scripts/**/*.ts",
    "scripts/**/*.tsx",
    "*.ts",
    "*.tsx",
    "**/*.d.ts",
    "types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "api-backup",
    "pages.disabled",
    "backup-pages",
    "pages/**/*",
    "components/**/*",
    "automation/backups",
    "automation_backup",
    "broken_files_backup",
    "contracts",
    "cypress",
    "playwright.config.ts",
    "temp_working",
    "supabase/functions",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.backup",
    "**/*.disabled",
    "temp_backup",
    "temp_backup/**",
    "temp_broken_components",
    "temp_broken_components/**",
    "src/utils/**",
    "utils/**",
    "types/**",
    "tailwind.config.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}