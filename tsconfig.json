{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@/app/*": [
        "app/*"
      ],
      "@/components/*": [
        "app/components/*"
      ],
      "@/lib/*": [
        "app/lib/*"
      ]
    },
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noImplicitOverride": true,
    "types": [
      "node",
      "react",
      "react-dom"
    ],
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true
  },
    "include": [
      "src/types/offline-shims.d.ts",
      ".next/types/**/*.ts",
      "app/**/*.ts",
      "app/**/*.tsx"
    ],
    "exclude": [
    	"App.tsx",
    "node_modules",
    "dist",
    "build",
    "coverage",
    "src/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "ts_files_backup",
    "zion-os.disabled",
    "zion-os",
    "zion-website",
    "zion-ai-assistant",
    "types.disabled",
    "**/*.config.ts",
    "vite.config.ts",
    "vitest.config.ts",
    // Temporarily exclude corrupted or legacy areas until cleaned
    "src/routes",
    "src/utils/errorBoundary.tsx",
    "src/utils/imageOptimizer.tsx",
    "src/utils/cartUtils.ts",
    "src/pages/solutions",
    "src/pages/services",
    "src/pages",
    "src/pages-disabled",
    "src/components",
    "src/context",
    "src/legal",
    "src/i18n.js",
    "src/utils/sitemapGenerator.ts",
    
    "src/utils/cartUtils.js"
  ]
}
