{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@components/*": [
        "components/*"
      ],
      "@app/*": [
        "app/*"
      ],
      "@utils/*": [
        "utils/*"
      ],
      "@hooks/*": [
        "hooks/*"
      ],
      "@types/*": [
        "types/*"
      ],
      "@assets/*": [
        "assets/*"
      ],
      "@styles/*": [
        "styles/*"
      ],
      "@data/*": [
        "data/*"
      ],
      "@services/*": [
        "services/*"
      ],
      "@context/*": [
        "context/*"
      ],
      "@constants/*": [
        "constants/*"
      ]
    },
    "types": [
      "vite/client",
      "node"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "types/**/*.ts",
    "utils/**/*.ts",
    "hooks/**/*.ts",
    "services/**/*.ts",
    "context/**/*.ts",
    "constants/**/*.ts",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "tailwind.config.js",
    "postcss.config.js",
    "*.ts",
    "*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "automation",
    "server",
    "zion-website",
    "zion-os",
    "zion-ai-assistant",
    "apps.backup",
    "src-clean",
    "dao",
    "netlify/functions",
    "recovered-branches",
    "token",
    "zion.app",
    "src/**",
    "pages_backup_conflict/**",
    "data_backup/**",
    "src.corrupted/**",
    "utils/next-link-shim.tsx",
    "playwright.config.ts",
    "api-backup",
    "pages.disabled",
    "backup-pages",
    "automation/**",
    "scripts/**",
    "deployments/**",
    "deployment/**",
    "backup/**",
    "automation/backups",
    "automation_backup",
    "broken_files_backup",
    "contracts",
    "cypress",
    "temp_working",
    "supabase/functions",
    "**/*.backup",
    "**/*.disabled",
    "temp_backup",
    "temp_backup/**",
    "temp_broken_components",
    "temp_broken_components/**",
    "coverage"
  ]
}
