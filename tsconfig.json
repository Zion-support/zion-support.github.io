{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "next-env.d.ts",
    "types/**/*.ts",
    "dist/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "corrupted-src-backup",
    "problematic-files-backup",
    "problematic-pages",
    "**/ai-pages-backup/**",
    "**/all-pages-backup/**",
    "**/backup*/**",
    "**/*.backup.*",
    "**/*.bak",
    "**/backup/**",
    "**/ai-pages-disabled/**",
    "**/app-disabled/**",
    "**/app-disabled-all/**",
    "**/api-disabled/**",
    "**/ai-customer-support-disabled/**",
    "**/ai-workflow-automation-disabled/**",
    "**/clean-build/**",
    "**/components/api/**",
    "**/apps/**",
    "**/blog/**",
    "**/contracts/**",
    "**/cypress/**",
    "**/data/**",
    "**/lib.disabled/**",
    "**/lib/**",
    "**/netlify/**",
    "**/page_template.tsx",
    "**/pages.disabled/**",
    "**/pages_backup/**",
    "**/pages_minimal/**",
    "**/recovered-branches/**",
    "**/scripts/**",
    "**/security.config.ts",
    "**/services/**",
    "**/src-corrupted/**",
    "**/src.broken/**",
    "**/tailwind.config.ts",
    "**/temp_conflicts/**",
    "**/utils/**",
    "**/vite.config.ts",
    "**/zion-ai-assistant/**",
    "**/zion-os/**",
    "**/__tests__/**"
  ]
}
