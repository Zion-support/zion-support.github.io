    "*.tmp",
    "*.temp",
    "**/tests/**",
    "__tests__/**",
    "temp_*/**",
    "temp-*/**",
    "temp*/**",
    "temp_conflicts/**",
    "temp_exclude/**",
    "zion-*/**",
    "zion_os/**",
    "zion/**",
    "apps/**",
    "utils/**",
    "types/**"
  ]
}
