{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "app-backup/**/*",
    "app-broken/**/*",
    "app-disabled/**/*",
    "__tests__/**/*",
    "api/**/*",
    "**/*-backup.tsx",
    "**/*-fixed.tsx",
    "**/Advanced*.tsx",
    "**/Analytics*.tsx",
    "**/Content*.tsx",
    "**/Dynamic*.tsx",
    "**/Enhanced*.tsx",
    "**/ErrorBoundary.tsx",
    "**/components/**/*.tsx",
    "**/components/**/*.ts",
    "**/components/**/*",
    "**/components/**",
    "**/components",
    "**/components/**",
    "**/components/**/*",
    "**/components/**/*.tsx",
    "**/components/**/*.ts",
    "**/components/**/*.tsx",
    "**/components/**/*.ts",
    "**/components/**/*.tsx",
    "**/components/**/*.ts",
    "**/components/**/*.tsx",
    "**/components/**/*.ts",
    "**/components/**/*.tsx",
    "**/components/**/*.ts",
    "**/components/**/*.tsx",
    "**/components/**/*.ts",
    "**/components/**/*.tsx",
    "**/components/**/*.ts",
    "**/components/**/*.tsx",
    "**/components/**/*.ts",
    "**/components/**/*.tsx",
    "**/components/**/*.ts",
    "**/components/**/*.tsx",
    "**/components/**/*.ts",
    "**/components/**/*.tsx"
  ]
}
