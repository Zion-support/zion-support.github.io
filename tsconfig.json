{
  "compilerOptions": {
    "target": "ES2017",
    "useDefineForClassFields": true,
    "lib": [
      "ES2024",
      "DOM",
      "DOM.Iterable",
      "WebWorker",
      "WebWorker.Iterable"
    ],
    "module": "esnext",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/pages/*": [
        "./src/pages/*",
        "./pages/*"
      ],
      "@/components/*": [
        "./src/components/*"
      ],
      "@/api/*": [
        "./src/api/*"
      ],
      "@/types/*": [
        "./src/types/*",
        "./types/*"
      ],
      "@/utils/*": [
        "./src/utils/*"
      ],
      "@/hooks/*": [
        "./src/hooks/*"
      ],
      "@/context/*": [
        "./src/context/*"
      ],
      "@/services/*": [
        "./src/services/*"
      ],
      "react-router-dom": [
        "./src/stubs/react-router-dom.tsx"
      ],
      "next-cloudinary": [
        "./types/next-cloudinary.d.ts"
      ],
      "types/*": [
        "./types/*"
      ]
    },
    "typeRoots": ["./src/types"],

    /* Bundler mode */
    "moduleResolution": "node",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "noImplicitThis": false,
    "strictNullChecks": false,
    "exactOptionalPropertyTypes": false,
    "noImplicitOverride": false,
    "noPropertyAccessFromIndexSignature": false,
    "noUncheckedIndexedAccess": false,
    "allowJs": true,
    "incremental": true,
    "typeRoots": [
      "./node_modules/@types",
      "./types"
    ],
    "types": [
      "node"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "alwaysStrict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "tsBuildInfoFile": ".next/tsbuildinfo"
  },
  "include": [
    "next-env.d.ts",
    "pages/**/*",
    "src/**/*",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "api-backup",
    "pages.disabled",
    "backup-pages",
    "temp_working",
    "supabase/functions",
    "src/routes",
    "automation/backups",
    "automation_backup",
    "broken_files_backup",
    "contracts",
    "cypress",
    "temp_working",
    "supabase/functions",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.backup",
    "**/*.disabled",
    "src/utils/generateRandomListing.ts",
    "src/utils/linkChecker.ts",
    "src/utils/mimeTypeFallback.ts",
    "src/utils/passwordStrength.tsx",
    "src/utils/resourceMonitor.ts",
    "src/utils/seoOptimizer.tsx",
    "src/utils/serviceWorkerRegistration.ts",
    "src/utils/unitConversion.ts",
    "src/utils/withErrorLogging.ts",
    "src/utils/generateRandomBlogPost.ts",
    "src/pages/solutions/EnterpriseSolutions.tsx",
    "src/utils/sitemapGenerator.tsx",
    "src/pages/zion-hire-ai.tsx",
    "src/pages/webinars.tsx",
    "src/routes/*Routes.tsx",
    "src/pages/services/**"
  ]
}
