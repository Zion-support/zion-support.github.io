{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "zion-website/src/*"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/**",
    ".next/cache",
    "dist",
    "out",
    "coverage",
    "build",
    "public/build",
    "apps.backup",
    "backup",
    "backups",
    "backup-merge-conflicts",
    "backup-problematic-files",
    "recovered-branches",
    "server",
    "automation",
    "src",
    "src.*",
    "src_*",
    "src-*/**",
    "src_backup",
    "src_backup_temp",
    "src.broken",
    "src.corrupted",
    "src.disabled",
    "src.pages.disabled",
    "zion-os",
    "zion-os.disabled",
    "zion-ai-assistant",
    "temp_*",
    "temp-*/**",
    "temp_backup/**",
    "__tests__/**",
    "tests/**",
    "test/**"
  ]
}
