{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "es6"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "incremental": true,
    
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "__tests__",
    "tests",
    "*.disabled",
    "**/*.disabled/**",
    "**/*.bak/**",
    "**/*.backup/**",
    "**/*_backup/**",
    "**/*-backup/**",
    "src.broken",
    "src.corrupted",
    "src.corrupted.*",
    "src_disabled",
    "src.disabled",
    "pages.disabled*",
    "pages.*backup*",
    "temp_*",
    "temp-*/**",
    "out",
    ".next",
    "public-backup",
    "pages-backup",
    "src_backup*",
    "zion-os",
    "zion-os/**",
    "zion-website",
    "zion-website/**"
  ]
}
