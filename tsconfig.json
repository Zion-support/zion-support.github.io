{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "es6"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": "."
  },
  "include": [
    "next-env.d.ts",
    "pages/**/*",
    "components/**/*.ts",
    "components/**/*.tsx",
    "data/services.ts",
    "styles/**/*",
    "types/**/*",
    "utils/**/*",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "api-backup",
    "api-disabled",
    "api.disabled.temp",
    "pages.disabled",
    "backup-pages",
    "src/pages/services",
    "src/pages/solutions",
    "src/pages/talent",
    "src/routes",
    "src/services",
    "src/store",
    "src/test",
    "src/types",
    "src/utils",
    "automation/backups",
    "automation_backup",
    "broken_files_backup",
    "contracts",
    "cypress",
    "temp_working",
    "supabase/functions",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.backup",
    "**/*.disabled",
    "temp_backup",
    "temp_backup/**",
    "temp_broken_components",
    "temp_broken_components/**",
    "src/utils/**",
    "utils/**",
    "types/**",
    "tailwind.config.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
