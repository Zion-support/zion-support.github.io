{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": { "@/*": ["zion-website/src/*"] },
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "strictNullChecks": true,
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/**",
    ".next/cache",
    "dist",
    "out",
    "coverage",
    "build",
    "public/build",
    "server/**",
    "zion-os/**",
    "zion-ai-assistant/**",
    "zion-website/**",
    "apps.backup/**",
    "src/pages_backup/**",
    "src/components/navigation/ModernNavigation-broken.tsx",
    "src/components/**/*.broken.*",
    "**/*-broken.*",
    "data_backup",
    "backup",
    "backups",
    "pages_backup_conflict",
    "corrupted-files-backup",
    "lib_backup",
    "**/*backup*",
    "**/*conflict*",
    "**/*temp*",
    "app/components/**",
    "app/**/*.disabled/**"
  ]
}
