{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,

    "paths": {
      "@/*": ["src/*"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": false,
    "baseUrl": ".",
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.ts",
    "automation/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",

    "data_backup/**",
    "src.corrupted/**",
    "pages/**",
    "components/**",
    "src/**",
    "utils/next-link-shim.tsx",
    "playwright.config.ts",
    "api-backup",
    "api-disabled",
    "api.disabled.temp",
    "pages.disabled",
    "backup-pages",
    "automation/**",
    "scripts/**",
    "src.corrupted/**",
    "deployments/**",
    "deployment/**",
    "backup/**",
    "automation/backups",
    "automation_backup",
    "broken_files_backup",
    "contracts",
    "data",
    "data/**",
    "cypress",
    "temp_working",
    "supabase/functions",
    "**/*.backup",
    "**/*.disabled"
  ]
}
