{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "zion-website/src/*"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/**",
    ".next",
    ".next/**",
    "app/components",
    "app/components/**",
    "dist",
    "out",
    "coverage",
    "build",
    "public/build",
    "automation",
    "automation/**",
    "backups",
    "backups/**",
    "backup",
    "backup/**",
    "apps.backup",
    "apps.backup/**",
    "recovered-branches",
    "recovered-branches/**",
    "server",
    "server/**",
    "zion-os",
    "zion-os/**",
    "zion-os.disabled",
    "zion-os.disabled/**",
    "zion-ai-assistant",
    "zion-ai-assistant/**",
    "zion-website/.next",
    "zion-website/.next/**",
    "src",
    "src/**",
    "components",
    "components/**",
    "lib",
    "lib/**",
    "hooks",
    "hooks/**",
    "types",
    "types/**",
    "**/*backup*",
    "**/*conflict*",
    "**/*temp*"
  ]
}
