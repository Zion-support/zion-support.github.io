{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "target": "es2022",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/components/*": ["./components/*"],
      "@/lib/*": ["./lib/*"],
      "@/utils/*": ["./utils/*"],
      "@/types/*": ["./types/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "pages/**/*",
    "app/**/*.ts",
    "app/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "data/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "utils/**",
    "**/backup/**",
    "**/backups/**",
    "**/backup-merge-conflicts/**",
    "**/app_disabled/**",
    "**/app.disabled/**",
    "**/*disabled*/**",
    "**/*.backup/**",
    "**/*.backup.*",
    "**/recovered-branches/**",
    "**/automation/**",
    "**/generated-services/**",
    "**/zion-*/**",
    "**/server/**",
    "**/backend/**",
    "**/apps/**",
    "**/api-disabled/**",
    "**/api.disabled/**",
    "**/api-backup/**",
    "**/node_modules_bak_*/*",
    "components/book/**",
    "utils/export/**",
    "data/new-2025-services.ts",
    "data/talent.ts",
    "types/reviews.ts",
    "utils/adminAuth.ts",
    "utils/api/auth.ts",
    "utils/auth.ts",
    "utils/data/enterpriseStore.ts",
    "utils/design-map.ts",
    "utils/devAccess.ts",
    "utils/fsdb.ts",
    "utils/i18n.ts",
    "utils/kyc.ts",
    "utils/moderationDb.ts"
  ]
}
