{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "zion-website/src/*"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "app-minimal/**/*.ts",
    "app-minimal/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/**",
    ".next/cache",
    "dist",
    "out",
    "coverage",
    "build",
    "public/build",
    "app",
    "pages",
    "components",
    "lib",
    "types",
    "utils",
    "zion-os",
    "**/*backup*",
    "**/*conflict*",
    "**/*temp*"
  ]
}
