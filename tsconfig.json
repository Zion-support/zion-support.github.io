{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "allowJs": true,
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": false,
    "noUncheckedIndexedAccess": false,
    "noImplicitReturns": false,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "noImplicitOverride": false,
    "types": [
      "node",
      "react",
      "react-dom"
    ],
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": false
  },
  "include": [
    "next-env.d.ts",
    "types.d.ts",
    "App.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "app/**/*",
    // Exclude problematic or unused routes/pages that contain corrupted JSX placeholders
    "src/pages/**",
    "src/pages.disabled/**",
    "src.corrupted/**",
    "src/routes/**",
    "src/utils/cartUtils.js",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "ts_files_backup",
    "zion-os.disabled",
    "zion-os",
    "zion-website",
    "zion-ai-assistant",
    "types.disabled",
    // Temporarily exclude broader areas known to be corrupted/not used by build
    "src/pages/**",
    "src/pages.disabled/**",
    "src/routes/**",
    "src/components/**",
    "src/context/**",
    "src/services/**",
    "**/*.config.ts",
    "vite.config.ts",
    "vitest.config.ts",
    // Exclude config and test files but keep application sources
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
