{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "es6"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "apps.backup/**",
    "automation_backup/**",
    "backup/**",
    "backup-merge-conflicts/**",
    "broken_files_backup/**",
    "corrupted_backup/**",
    "corrupted-files-backup/**",
    "pages.disabled/**",
    "pages.disabled_full/**",
    "pages.disabled_auto/**",
    "pages.broken/**",
    "pages.corrupted.*/**",
    "pages.old/**",
    "pages._archive_corrupted/**",
    "pages._quarantine/**",
    "pages.bak/**",
    "pages-backup/**",
    "pages-quarantine/**",
    "components-disabled/**",
    "components.disabled/**",
    "components.disabled_full/**",
    "lib.broken/**",
    "lib.disabled/**",
    "lib_backup/**",
    "backup-problematic-files/**",
    "data_backup/**",
    "automation-reports/**",
    "improvement-reports/**",
    "performance-reports/**",
    "monitoring-reports/**",
    "log-analysis-reports/**",
    "maintenance-reports/**",
    "link-reports/**"
  ]
}
