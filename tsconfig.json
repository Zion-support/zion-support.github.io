{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "zion-website/src/*"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/**",
    ".next/cache",
    "dist",
    "out",
    "coverage",
    "build",
    "public/build",
    "data_backup",
    "backup",
    "backups",
    "pages_backup_conflict",
    "apps.backup",
    "corrupted-files-backup",
    "lib_backup",
    "zion-os",
    "zion-os/**",
    "zion-os.disabled",
    "zion-os.disabled/**",
    "server",
    "server/**",
    ".temp_backup_components",
    ".temp_backup_components/**",
    "automation",
    "automation/**",
    "**/*backup*",
    "**/*conflict*",
    "**/*temp*",
    "src.broken/**",
    "src-corrupted/**",
    "src.corrupted/**",
    "src.disabled/**",
    "src.pages.disabled/**",
    "src_backup/**",
    "src_backup_temp/**",
    "ts_files_backup/**",
    "tests/**",
    "__tests__/**",
    "test/**",
    "test-results/**",
    "test-reports/**",
    "zion-ai-assistant",
    "zion-ai-assistant/**",
    "app/**/*.full.tsx",
    "app/**/*.full.ts"
  ]
}
