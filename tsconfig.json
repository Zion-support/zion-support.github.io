{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": false,
    "noEmit": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "jsxImportSource": "react",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/components/*": [
        "./src/components/*"
      ],
      "@/pages/*": [
        "./src/pages/*"
      ],
      "@/utils/*": [
        "./src/utils/*"
      ],
      "@/hooks/*": [
        "./src/hooks/*"
      ],
      "@/types/*": [
        "./src/types/*"
      ],
      "@/styles/*": [
        "./src/styles/*"
      ],
      "@/assets/*": [
        "./src/assets/*"
      ]
    },
    "allowSyntheticDefaultImports": true,
    "strictNullChecks": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "tsBuildInfoFile": ".next/cache/tsbuildinfo.json",
    "allowImportingTsExtensions": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "data/**/*.ts",
    "data/**/*.tsx",
    "types/**/*.ts",
    "types/**/*.tsx",
    "zion/**/*.ts",
    "zion/**/*.tsx",
    "protocol/**/*.ts",
    "protocol/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "lib_backup*",
    "src_backup*",
    "pages_backup*",
    "corrupted-files-backup*",
    "performance-reports*",
    "log-analysis-reports*",
    "link-reports*",
    "lint-target*",
    "monitoring*",
    "pm2-automation*",
    "automation/logs*",
    "automation/backup*",
    "src.pages.disabled.auto",
    "components.disabled",
    "src.disabled",
    "src.pages.disabled",
    "recovered-branches/**",
    "temp_backup/**",
    "api.disabled/**"
  ]
}