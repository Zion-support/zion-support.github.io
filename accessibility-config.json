{
  "axe": {
    "rules": {
      "color-contrast": {
        "enabled": true
      },
      "keyboard-navigation": {
        "enabled": true
      },
      "focus-management": {
        "enabled": true
      },
      "semantic-html": {
        "enabled": true
      },
      "alt-text": {
        "enabled": true
      },
      "aria-labels": {
        "enabled": true
      },
      "heading-structure": {
        "enabled": true
      },
      "form-labels": {
        "enabled": true
      }
    }
  },
  "testing": {
    "include": ["**/*.tsx", "**/*.jsx", "**/*.ts", "**/*.js"],
    "exclude": ["node_modules/**", ".next/**", "dist/**"]
  },
  "standards": {
    "wcag": "2.1",
    "level": "AA",
    "guidelines": ["Perceivable", "Operable", "Understandable", "Robust"]
  }
}
