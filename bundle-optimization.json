{
  "optimization": {
    "splitChunks": {
      "chunks": "all",
      "cacheGroups": {
        "vendor": {
          "test": "/[\\/]node_modules[\\/]/",
          "name": "vendors",
          "chunks": "all"
        }
      }
    },
    "minification": {
      "enabled": true,
      "removeConsole": true,
      "removeDebugger": true
    }
  }
}