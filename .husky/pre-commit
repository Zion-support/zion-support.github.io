# Run type checking (non-blocking)
echo "🔍 Running TypeScript type check..."
npm run type-check || {
    echo "⚠️  TypeScript type check failed, but continuing..."
}

# Run build check (non-blocking)
echo "🏗️ Running build check..."
npm run build || {
    echo "⚠️  Build failed, but continuing..."
}

# Check for uncommitted changes in package files
if git diff --cached --name-only | grep -E "package\.json|package-lock\.json" > /dev/null; then
    echo "📦 Package files changed, running npm install..."
    npm install
fi

echo "✅ Pre-commit checks completed"
=======
. "$(dirname -- "$0")/_/husky.sh"

