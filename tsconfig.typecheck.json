{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "pages/**/*.ts",
    "pages/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "out",
    "coverage",
    "build",
    "public/build",
    "components/**",
    "lib/**",
    "types/**",
    "**/*.test.*",
    "__tests__/**"
  ]
}

