{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "src/types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "src/App.tsx",
    "src/components/EnhancedContentShowcase2026.tsx",
    "src/components/NewContent2026Banners.tsx",
    "src/pages/**",
    "src/content/**",
    "src/hooks/**",
    "src/utils/**",
    "src/components/LatestContentBanner2025.tsx",
    "src/components/Revolutionary2026ContentMegaBanner.tsx"
  ]
}