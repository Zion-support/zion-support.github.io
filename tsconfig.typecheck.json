{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "app/**/*.ts", "app/**/*.tsx"],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "**/*disabled*/**",
    "**/*backup*/**",
    "**/*corrupted*/**",
    "**/*temp*/**",
    "**/*.broken/**",
    "cypress/**",
    "cypress.disabled/**",
    "data.disabled/**",
    "hooks.disabled/**",
    "lib.disabled/**",
    "lint-target/**",
    "netlify/**",
    "contracts.disabled/**",
    "app/components/NewestContent2025Banner.tsx",
    "app/components/NewContentPromotionalBanner2026.tsx"
  ]
}
