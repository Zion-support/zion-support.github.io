{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "app/**/*.ts", "app/**/*.tsx", "vite-env.d.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "**/*disabled*/**",
    "**/*backup*/**",
    "**/*corrupted*/**",
    "**/*temp*/**",
    "**/*.broken/**",
    "cypress/**",
    "cypress.disabled/**",
    "data.disabled/**",
    "hooks.disabled/**",
    "lib.disabled/**",
    "lint-target/**",
    "netlify/**",
    "contracts.disabled/**",
    "app/components/NewestContent2025Banner.tsx",
    "app/blog/**",
    "app/page-optimized.tsx",
    "app/App.tsx",
    "app/components/AdvancedSEOOptimizer.tsx",
    "app/components/ImprovedErrorBoundary.tsx",
    "app/components/PerformanceMonitor.tsx",
    "app/components/PerformanceOptimizer.tsx",
    "app/hooks/usePerformanceOptimization.ts",
    "app/utils/*.ts",
    "app/utils/*.tsx",
    "src/hooks/usePerformance.ts",
    "src/monitoring.ts",
    "src/utils/codeSplitting.ts",
    "src/utils/testHelpers.ts"
  ]
}
