{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.stories.ts",
    "**/*.stories.tsx",
    "dist",
    "out",
    "public",
    "apps/**",
    "apps.backup/**",
    "backup/**",
    "backup-merge-conflicts/**",
    "backup-problematic-files/**",
    "broken_files_backup/**",
    "corrupted_backup/**",
    "_conflicted_disabled/**",
    "components-disabled/**",
    "components.disabled/**",
    "components.disabled_full/**",
    "src/components-disabled/**",
    "api-backup/**",
    "api-disabled/**",
    "api.disabled/**",
    "api.disabled.temp/**",
    "src_backup/**",
    "temp_components/**",
    "data/**",
    "src/data/**",
    "pages/**",
    "src/pages/**",
    "src/pages/services/**",
    "src/legal/**",
    "src/mobile/**",
    "src/layout/**",
    "src/lib/**",
    "app/**",
    "src/app/**",
    "supabase/**",
    "src.broken/**",
    "src.corrupted/**"
  ]
}

