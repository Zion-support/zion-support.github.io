{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "src/App.tsx",
    "src/components/EnhancedContentShowcase2026.tsx",
    "src/components/NewContent2026Banners.tsx",
    "src/pages/**",
    "src/utils/componentLazyLoader.ts",
    "src/utils/lazyBannerLoader.ts",
    "src/utils/performanceMonitor.ts",
    "src/utils/analyticsIntegration.ts",
    "src/components/LatestContentBanner2025.tsx",
    "src/components/Revolutionary2026ContentMegaBanner.tsx",
    "src/hooks/useBannerRotation.tsx",
    "src/utils/advancedCacheManager.ts",
    "src/utils/cacheManager.ts",
    "src/utils/codeSpittingHelper.ts",
    "src/utils/contentRecommendationEngine.ts",
    "src/utils/enhancedAnalytics.ts",
