{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "**/*disabled*/**",
    "**/*backup*/**",
    "**/*corrupted*/**",
    "**/*temp*/**",
    "**/*.broken/**",
    "cypress/**",
    "cypress.disabled/**",
    "data.disabled/**",
    "hooks.disabled/**",
    "lib.disabled/**",
    "lint-target/**",
    "netlify/**",
    "contracts.disabled/**",
    "**/NewestContent2025Banner.tsx",
    "**/contact/page.tsx",
    "**/ErrorBoundary.tsx",
    "app/blog/**",
    "app/guides/**",
    "app/enterprise/**",
    "app/offline/**",
    "app/not-found.tsx",
    "app/layout.tsx",
    "app/components/NewestContent2025Banner.tsx",
    "app/components/UltimateBusinessIntelligence2025Banner.tsx",
    "app/components/UltimateBusinessIntelligenceShowcase2025.tsx",
    "app/components/UnifiedContentPromotion.tsx",
    "app/privacy/**",
    "app/sitemap.ts",
    "app/team/**",
    "app/terms/**"
  ]
}