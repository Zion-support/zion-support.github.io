# Explicitly disable Next.js plugin for Vite project
[[plugins]]
  package = "@netlify/plugin-nextjs"
  [plugins.inputs]
    skip = true

# Cloudinary plugin for image optimization
[[plugins]]
  package = "netlify-plugin-cloudinary"
  [plugins.inputs]
    cloud_name = "${CLOUDINARY_CLOUD_NAME}"

