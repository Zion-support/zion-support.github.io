{
  "git.enabled": true,
  "git.autorefresh": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.showPushSuccessNotification": true,
  "git.showProgress": true,
  "git.autoStash": true,
  "git.autoRepositoryDetection": true,
  "git.ignoreLimitWarning": true,
  "git.ignoreSubmodules": false,
  "git.ignoreMissingGitWarning": false,
  "git.allowNoVerifyCommit": false,
  "git.allowCommitSignOff": false,
  "cursor.backgroundAgents.enabled": true,
  "cursor.backgroundAgents.autoStart": true,
  "cursor.backgroundAgents.showStatus": true,
  "cursor.composer.enabled": true,
  "cursor.composer.backgroundMode": true,
  "cursor.agent.enabled": true,
  "cursor.agent.backgroundMode": true,
  "cursor.agent.showStatus": true,
  "cursor.agent.autoStart": true,
  "cursor.agent.backgroundAgents.enabled": true,
  "cursor.agent.backgroundAgents.autoStart": true,
  "cursor.agent.backgroundAgents.showStatus": true,
  "workbench.enableExperiments": true,
  "workbench.experimental.settingsProfiles.enabled": true,
  "cursor.experimental.backgroundAgents": true,
