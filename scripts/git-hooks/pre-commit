#!/usr/bin/env bash
# Blocks report-only commits unless openclaw-report-commit-budget allows (see automation/openclaw-report-commit-budget.cjs).
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"
if [ -n "${CI:-}" ] || [ "${SKIP_OPENCLAW_GIT_HOOKS:-}" = "1" ]; then
  exit 0
fi
if ! command -v node >/dev/null 2>&1; then
  echo "openclaw pre-commit: node not on PATH; skipping report budget check." >&2
  exit 0
fi
exec node automation/openclaw-report-commit-budget.cjs
