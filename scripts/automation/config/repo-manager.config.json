{
  "autoMergeEnabled": true,
  "conflictResolutionEnabled": true,
  "branchCleanupEnabled": true,
  "maxOpenPRs": 50,
  "mergeStrategy": "squash",
  "conflictThreshold": 3,
  "autoRebaseEnabled": true,
  "healthCheckInterval": 300000,
  "mergeBatchSize": 5,
  "branchPatterns": {
    "feature": "cursor/enhance-*",
    "hotfix": "hotfix/*",
    "release": "release/*"
  },
  "mergeRules": {
    "requireTests": true,
    "requireCodeReview": false,
    "maxFileChanges": 100,
    "maxCommitCount": 50
  },
  "conflictResolution": {
    "autoResolve": true,
    "maxRetries": 3,
    "timeout": 300000
  },
  "notifications": {
    "enabled": true,
    "channels": ["slack", "email"],
    "mergeNotifications": true,
    "conflictNotifications": true
  }
}