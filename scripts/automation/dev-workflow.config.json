{
  "autoFeatureDevelopment": true,
  "autoTesting": true,
  "autoDeployment": true,
  "qualityGates": {
    "minTestCoverage": 85,
    "maxComplexity": 8,
    "requireCodeReview": true,
    "requireSecurityScan": true,
    "requirePerformanceTest": true
  },
  "developmentCycles": {
    "featureDevelopment": 7,
    "testingPhase": 2,
    "reviewPhase": 1,
    "deploymentPhase": 1
  },
  "performanceThresholds": {
    "buildTime": 300,
    "bundleSize": 1048576,
    "loadTime": 3000,
    "memoryUsage": 104857600
  },
  "environments": {
    "development": {
      "autoDeploy": true,
      "qualityThreshold": 70
    },
    "staging": {
      "autoDeploy": true,
      "qualityThreshold": 80
    },
    "production": {
      "autoDeploy": false,
      "qualityThreshold": 90,
      "requireApproval": true
    }
  },
  "testing": {
    "unit": { "required": true, "parallel": true },
    "integration": { "required": true, "parallel": false },
    "e2e": { "required": false, "parallel": true },
    "performance": { "required": true, "parallel": false },
    "security": { "required": true, "parallel": false }
  },
  "monitoring": {
    "enabled": true,
    "interval": 900000,
    "metrics": ["progress", "quality", "performance", "security"]
  },
  "notifications": {
    "enabled": true,
    "channels": ["slack", "email", "webhook"],
    "events": ["feature_started", "quality_degraded", "deployment_completed"]
  }
}