                *.css)
                    # For CSS files, take theirs
                    git checkout --theirs "$file" 2>/dev/null || true
                    ;;
                *.md)
                    # For markdown files, take theirs
                    git checkout --theirs "$file" 2>/dev/null || true
                    ;;
