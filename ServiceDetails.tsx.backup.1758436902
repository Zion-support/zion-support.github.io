import { Server,,, Clock,,, MapPin,,  } from 'lucide-react'
import React from "react";

interface ServiceDetailsProps {
  country: string;
}

// Simple Card components for this file
const Card = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <div className={`rounded-lg border p-6 ${className || ''}`}>{children}</div>
);

const CardHeader = ({ children }: { children: React.ReactNode }) => (
  <div className="mb-4">{children}</div>
);

const CardTitle = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <h3 className={`text-lg font-semibold ${className || ''}`}>{children}</h3>
);

const CardContent = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <div className={className}>{children}</div>
);

const CardDescription = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <p className={`text-sm text-muted-foreground ${className || ''}`}>{children}</p>
);

// Component to show service details for the selected country
export function ServiceDetails({ country }: ServiceDetailsProps) {
  return (
    <Card className='bg-zion-blue-dark border-zion-blue-light'>
      <CardHeader>
        <CardTitle className='text-white flex items-center'>
          <Server className='mr-2 h-5 w-5 text-zion-cyan' />
          IT Onsite Service in {country}
        </CardTitle>
        <CardDescription className='text-zion-slate-light'>
          Details about our service locations and capabilities in {country}
        </CardDescription>
      </CardHeader>
      <CardContent className='space-y-4'>
        <div className='grid grid-cols-1 md:grid-cols-2 gap-4'>
          <div className='flex items-center space-x-3'>
            <div className='bg-zion-purple/20 p-2 rounded-full'>
              <MapPin className='h-5 w-5 text-zion-cyan' />
            </div>
            <div>
              <h4 className='text-white font-medium'>Coverage</h4>
              <p className='text-zion-slate-light text-sm'>Available in major cities</p>
            </div>
          </div>
          <div className='flex items-center space-x-3'>
            <div className='bg-zion-purple/20 p-2 rounded-full'>
              <Clock className='h-5 w-5 text-zion-cyan' />
            </div>
            <div>
              <h4 className='text-white font-medium'>Response Time</h4>
              <p className='text-zion-slate-light text-sm'>4-hour guaranteed</p>
            </div>
          </div>
        </div>
        <div className='bg-zion-blue p-4 rounded-lg border border-zion-blue-light'>
          <h4 className='text-white font-medium mb-2'>Service Areas</h4>
          <p className='text-zion-slate-light text-sm'>
            We provide comprehensive IT onsite support across {country} with certified technicians and modern equipment.
          </p>
        </div>
      </CardContent>
    </Card>
  )
}
