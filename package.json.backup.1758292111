  "scripts": {
    "dev": "NODE_OPTIONS=\"--max-old-space-size=4096 --openssl-legacy-provider\" vite",
    "build": "NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "build:netlify": "NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build --mode production",
    "build:analyze": "NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build --mode production && npx vite-bundle-analyzer dist",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "test": "echo \"No tests specified\" && exit 0",
    "clean": "rm -rf dist node_modules/.vite",
    "prebuild": "echo 'Skipping lint for build fix'",
    "validate": "npm run type-check && npm run lint && npm run build",
    "validate:fix": "npm run lint:fix && npm run type-check && npm run build",
    "dev:clean": "npm run clean && npm run dev",
    "build:production": "npm run clean && npm run build",
    "check:all": "npm run type-check && npm run lint && npm audit && npm outdated",
    "serve": "npm run build && npm run preview"
  },
