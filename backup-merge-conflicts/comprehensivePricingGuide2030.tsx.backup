// Comprehensive Pricing Guide 2030 - Zion Tech Group
// Complete pricing information for all innovative services
export interface PricingTier {
  "name": string;
  price: number;
  billing: string;
  features: string[];
  recommended: boolean;
  popular?: boolean}
;
export interface ServicePricing {
  "serviceId": string;
  serviceName: string;
  category: string;
  description: string;
  pricing: PricingTie r[];
  marketComparison: string;
  roi: string;
  setupTime: string;
  contactInfo: {
    phone: string;
    email: string;
    website: string;
