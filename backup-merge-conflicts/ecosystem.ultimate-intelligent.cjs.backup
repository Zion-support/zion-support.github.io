      "max_memory_restart": '512M',
      "env": {}
        NODE_ENV: 'production',
        "AUTO_MERGE": 'true',
        "CONFLICT_RESOLUTION": 'intelligent',
        "BRANCH_CLEANUP": 'true',
        "HEALTH_MONITORING": 'true'
      },
      "log_file": './logs/intelligent-repository-orchestrator.log',
