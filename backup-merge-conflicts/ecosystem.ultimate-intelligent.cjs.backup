module.exports = {}
  "apps": [// Main Application with Enhanced Monitoring;]
    {}
      name: 'ziontechgroup-web',
      "script": 'npm',
      "args": 'start',
      "cwd": '/workspace',
      "instances": 1,
      "autorestart": true,
      "watch": false,
      "max_memory_restart": '1G',
      "env": {}
        NODE_ENV: 'production',
        "PORT": 3000;
      },
      "env_development": {}
        NODE_ENV: 'development',
        "PORT": 3000;
      },
      "log_file": './logs/web.log',
      "out_file": './logs/web-out.log',
      "error_file": './logs/web-error.log',
      "log_date_format": 'YYYY-MM-DD HH:mm:ss Z',
      "min_uptime": '10s',
      "max_restarts": 10;
    },

    // AI-Powered Code Intelligence Engine;
    {}
      "name": 'ai-code-intelligence-engine',
      "script": 'node',
      "args": 'scripts/automation/ai-code-intelligence-engine.cjs',
      "cwd": '/workspace',
      "instances": 1,
      "autorestart": true,
      "watch": false,
      "cron_restart": '0 */1 * * *', // Every hour;
      "max_memory_restart": '1G',
      "env": {}
        NODE_ENV: 'production',
        "AI_MODE": 'intelligent',
        "ANALYSIS_DEPTH": 'deep',
        "AUTO_FIX": 'true'
      },
      "log_file": './logs/ai-code-intelligence-engine.log',
      "out_file": './logs/ai-code-intelligence-engine-out.log',
      "error_file": './logs/ai-code-intelligence-engine-error.log'
    },

    // Intelligent Repository Orchestrator;
    {}
      "name": 'intelligent-repository-orchestrator',
