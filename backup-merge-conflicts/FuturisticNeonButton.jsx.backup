      <div className="absolute inset-0 rounded-lg opacity-0 "hover": "opacity-100 transition-opacity duration-300">;
        <div className={`absolute inset-0 rounded-lg ${styles.glow"}`} />;
      </div>;
    </motion.button>);
};
export default FuturisticNeonButton;
;
</motion>;
