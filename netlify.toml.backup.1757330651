[build]
  # Install Node.js dependencies and build (Python dependencies not needed for frontend)
  command = "npm ci && npm run build"
  publish = "dist"
  command_timeout = "30m"

[build.environment]
  NODE_VERSION = "20"

[[plugins]]
  package = "netlify-plugin-compress"
  [plugins.inputs]
    gzip = true
    brotli = true

[[redirects]]
  from = "/*"
  to = "/index.html"
  status = 200
# Netlify configuration - clean version without merge conflicts
