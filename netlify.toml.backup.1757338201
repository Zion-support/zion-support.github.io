  publish = "dist"
  command_timeout = "30m"

[build.environment]
  NODE_VERSION = "20"
  PYTHON_VERSION = "3.11"
  # Ensure Netlify installs dependencies for the build
  NETLIFY_SKIP_INSTALL = "false"
  # Avoid optional binary downloads (electron, playwright, cypress)
  PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD = "1"
  PUPPETEER_SKIP_DOWNLOAD = "1"
  CYPRESS_INSTALL_BINARY = "0"
  ELECTRON_SKIP_DOWNLOAD = "1"
  # Defensive: avoid Python build steps
  MISE_PYTHON_COMPILE = "false"
  MISE_DISABLE = "1"
  MISE_SHIMS = "0"
  MISE_TOOL_VERSIONS__python = "system"
  # Skip Electron binary downloads during install to prevent build failures
  ELECTRON_SKIP_DOWNLOAD = "1"

# Keep the config minimal to avoid plugin-related build failures

[[redirects]]
  from = "/*"
  to = "/index.html"
  status = 200

# Set basic cache headers for static assets for better performance
[[headers]]
  for = "/assets/*"
  [headers.values]
    Cache-Control = "public, max-age=31536000, immutable"

[[headers]]
  for = "/_next/*"
  [headers.values]
    Cache-Control = "public, max-age=31536000, immutable"

[[headers]]
  for = "/*"
  [headers.values]
    Cache-Control = "public, max-age=300"
