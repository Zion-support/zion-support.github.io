          </div>
          <div className="flex items-center gap-2">
            <div className="w-2 h-2 bg-zion-blue rounded-full animate-pulse" />
            <span className="text-sm font-medium">24/7 Support</span>
          </div>
        </motion.div>
      </motion.div>

      {/* Bottom wave effect */}
      <div className="absolute bottom-0 left-0 right-0">
        <svg
