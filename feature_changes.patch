+
+  let fixedCount = 0;
+  files.forEach(file => {
+    const fullPath = path.join('/workspace', file);
+    if (rewritePageFile(fullPath)) {
+      fixedCount++;
+    }
+  });
+
+  console.log(`Rewrote ${fixedCount} out of ${files.length} files`);
+}
+
+main().catch(console.error);
