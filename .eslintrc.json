{
  "root": true,
  "env": { "browser": true, "es2020": true },
  "extends": [
    "eslint:recommended",
    "@typescript-eslint/recommended"
  ],
  "ignorePatterns": [
    "dist/**/*",
    ".eslintrc.cjs",
    "media/**/*",
    "scripts/**/*",
    "node_modules/**/*",
    "src.disabled/**/*",
    "src_disabled_*/**/*",
    "**/*.disabled/**/*",
    "**/*.backup/**/*",
    "**/*.temp/**/*",
    "**/*.old/**/*",
    "**/*.test.*",
    "**/*.spec.*",
    "tests/**/*",
    "__tests__/**/*",
    "cypress/**/*",
    "e2e/**/*"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": ["react-refresh"],
  "rules": {
    "react-refresh/only-export-components": [
      "warn",
      { "allowConstantExport": true }
    ]
  }
}