{
  "extends": ["next/core-web-vitals"],
  "rules": {
    "no-console": "off",
    "react/no-unescaped-entities": "off",
    "@next/next/no-html-link-for-pages": "warn",
    "@next/next/no-title-in-document-head": "warn",
    "react-hooks/exhaustive-deps": "warn"
  },
  "ignorePatterns": [
    "node_modules/",
    ".next/",
    "out/",
    "public/",
    "*.config.js",
    "*.config.ts",
    "scripts/",
    "automation/"
  ]
}