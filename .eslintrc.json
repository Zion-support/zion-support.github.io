{
  "extends": [
    "next/core-web-vitals"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "react/prop-types": "off"
  },
  "ignorePatterns": [
    "node_modules/",
    ".next/",
    "out/",
    "build/",
    "dist/",
    "src.disabled/",
    "pages.disabled/",
    "pages_backup/",
    "pages-backup/",
    "pages.__backup/",
    "api-backup/",
    "backup-pages/",
    "**/*.backup/",
    "automation/",
    "scripts/",
    "reports/",
    "error-reports/",
    "security-reports/",
    "refactoring-reports/",
    "automation-reports/"
  ]
}