{
  "root": true,
  "env": { "browser": true, "es2020": true },
  "extends": [
    "eslint:recommended",
    "@typescript-eslint/recommended"
  ],
  "ignorePatterns": [
    "dist/**/*",
    "node_modules/**/*",
    "**/*.cjs",
    "**/*.js",
    "!vite.config.js",
    "!next.config.js",
    "!tailwind.config.js",
    "!postcss.config.js",
    "**/*.backup/**/*",
    "**/*.disabled/**/*",
    "**/*.temp/**/*",
    "**/*.old/**/*",
    "**/*.test.*",
    "**/*.spec.*",
    "tests/**/*",
    "__tests__/**/*",
    "cypress/**/*",
    "e2e/**/*",
    "corrupted_backup/**/*",
    "data_backup/**/*",
    "backup/**/*",
    "broken_files_backup/**/*",
    "corrupted_files_backup/**/*",
    "corrupted_files_backup_2/**/*",
    "corrupted-files-backup/**/*",
    "pages._archive_corrupted/**/*",
    "pages.bak/**/*",
    "public-backup/**/*",
    "recovered-branches/**/*",
    "test_build/**/*",
    "lib.broken/**/*",
    "lib.disabled/**/*",
    "src.broken/**/*",
    "src.disabled/**/*",
    "api.disabled/**/*",
    "api.disabled.temp/**/*",
    "api-backup/**/*",
    "apps.backup/**/*",
    "components_backup/**/*",
    "components-disabled/**/*",
    "components.disabled/**/*",
    "components.disabled_full/**/*",
    "contracts.disabled/**/*",
    "data.disabled/**/*",
    "cypress_backup/**/*",
    "cypress.disabled/**/*",
    "deployments/**/*",
    "pm2-automation/**/*",
    "netlify/functions-backup/**/*",
    "automation/**/*",
    "advanced-*.js",
    "advanced-*.cjs",
    "aggressive-*.js",
    "aggressive-*.cjs",
    "app-*.js",
    "app-*.cjs",
    "analyze-*.js",
    "auto-*.js",
    "batch-*.js",
    "batch-*.cjs",
    "build-*.js",
    "build-*.cjs",
    "check-*.js",
    "clean-*.js",
    "comprehensive-*.js",
    "comprehensive-*.cjs",
    "continuous-*.js",
    "continuous-*.cjs",
    "create-*.js",
    "debug-*.js",
    "enhance-*.js",
    "fix-*.js",
    "generate-*.js",
    "improve-*.js",
    "optimize-*.js",
    "performance-*.js",
    "test-*.js",
    "test-*.cjs",
    "update-*.js",
    "workflow-*.js",
    "api/**/*.js"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": ["react-refresh"],
  "rules": {
    "react-refresh/only-export-components": [
      "warn",
      { "allowConstantExport": true }
    ]
  }
}