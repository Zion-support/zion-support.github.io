{
  "watchPatterns": [
    "src/**/*.{js,jsx,ts,tsx}",
    "server/**/*.{js,ts}",
    "components/**/*.{js,jsx,ts,tsx}",
    "pages/**/*.{js,jsx,ts,tsx}",
    "styles/**/*.{css,scss}",
    "public/**/*.{html,css,js}"
  ],
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/*.log",
    "**/coverage/**",
    "**/.git/**",
    "**/automation/backups/**"
  ],
  "autoTasks": {
    "lint": true,
    "typeCheck": true,
    "test": false,
    "build": false,
    "format": true,
    "security": true
  },
  "gitHooks": {
    "preCommit": true,
    "prePush": true,
    "postMerge": true,
    "postCheckout": false
  },
  "performance": {
    "monitoring": {
      "enabled": true,
      "interval": 30000,
      "thresholds": {
        "memory": {
          "warning": 70,
          "critical": 85
        },
        "cpu": {
          "warning": 60,
          "critical": 80
        }
      }
    },
    "optimization": {
      "autoScale": true,
      "memoryOptimization": true,
      "processRestart": true
    }
  },
  "notifications": {
    "enabled": true,
    "channels": ["console", "file"],
    "levels": ["error", "warning", "info"]
  },
  "logging": {
    "level": "info",
    "maxFiles": 10,
    "maxSize": "10MB",
    "retention": "7d"
  }
}