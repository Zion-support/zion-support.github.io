  async checkRedundancyHealth() {
    try {
      // Check redundancy systems
      const pm2Status = await this.runCommand('pm2 status');
      const hasProcesses = pm2Status.output.includes('online');
      return hasProcesses ? 100 : 50;
    } catch (error) {
      return 0;
    }
  }

