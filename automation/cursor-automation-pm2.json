{
  "name": "cursor-chat-automation",
  "script": "cursor-interface-automation.js",
  "cwd": "./automation",
  "instances": 1,
  "autorestart": true,
  "watch": false,
  "max_memory_restart": "1G",
  "env": {
    "NODE_ENV": "production",
    "LOG_LEVEL": "info"
  },
  "log_file": "./logs/cursor-automation.log",
  "out_file": "./logs/cursor-automation-out.log",
  "error_file": "./logs/cursor-automation-error.log",
  "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
  "merge_logs": true,
  "max_restarts": 10,
  "min_uptime": "10s",
  "restart_delay": 5000,
  "kill_timeout": 10000,
  "wait_ready": true,
  "listen_timeout": 8000,
  "cron_restart": "0 2 * * *"
}
