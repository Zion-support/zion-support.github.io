  patternToRegex(pattern) {
    // Convert glob pattern to regex
    const regexStr = pattern
      .replace(/\./g, '\\.')
      .replace(/\*/g, '.*')
      .replace(/\?/g, '.')
      .replace(/\{([^}]+)\}/g, '($1)')
      .replace(/,/g, '|');
    return new RegExp(`^${regexStr}$`);
  }
