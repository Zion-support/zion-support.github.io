{
  "name": "zion-app-automation",
  "version": "1.0.0",
  "description": "PM2 automation scripts for Zion App build health and maintenance",
  "main": "index.js",
  "scripts": {
    "start": "node build-health-monitor.js",
    "start:all": "pm2 start ecosystem.config.cjs",
    "stop:all": "pm2 stop ecosystem.config.cjs",
    "restart:all": "pm2 restart ecosystem.config.cjs",
    "logs": "pm2 logs",
    "status": "pm2 status",
    "monitor": "pm2 monit"
  },
  "dependencies": {
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "pm2": "^5.3.0"
  },
  "keywords": [
    "pm2",
    "automation",
    "monitoring",
    "build-health",
    "code-quality",
    "dependencies",
    "file-integrity"
  ],
