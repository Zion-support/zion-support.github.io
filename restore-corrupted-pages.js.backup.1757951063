                        !currentContent.includes('return');
    
    if (!isCorrupted) {
      return { restored: false, reason: 'Page is not corrupted' };
    }
    
    // Find backup
    const backupPath = findBestBackup(pagePath);
    if (!backupPath) {
      return { restored: false, reason: 'No valid backup found' };
    }
