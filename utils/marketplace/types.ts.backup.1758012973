export type Milestone = {
  id: string;
  title: string;
  dueDateIso?: string;
  amountUsd?: number;
  status?: "planned" | "in-progress" | "done";
};

export type PaymentTerms =
  | { type: "hourly"; hourlyRateUsd: number }
  | { type: "fixed"; fixedAmountUsd: number }
  | { type: "milestone"; milestones: Milestone[] };

export type OfferStatus =
  | "SENT"
  | "CONFIRMED"
  | "CHANGES_REQUESTED"
  | "DECLINED";

