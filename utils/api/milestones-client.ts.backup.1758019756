export async function fetchMilestones(projectId: string) {
  const res = await fetch(`/api/projects/${projectId}/milestones`, {
    headers: { 'Content-Type': 'application/json' },
    credentials: 'include',
  });
  if (!res.ok) throw new Error('Failed to load milestones');
  return res.json();
}

