export function readJson<T>(relativePath: string, fallback: T): T {
  const full = path.join(dataRoot, relativePath);
  try {
    const raw = fs.readFileSync(full, 'utf-8');
    return JSON.parse(raw) as T;
  } catch (_) {
    return fallback;
  }
}

