[build]
  # Skip building on Netlify and deploy prebuilt dist/ directory
  command = "echo Skipping build; deploying prebuilt dist"
  publish = "dist"
  command_timeout = "30m"

[build.environment]
  NODE_VERSION = "20"
  # Skip dependency install since we are not building on Netlify
  NETLIFY_SKIP_INSTALL = "true"

