[build]
  # Install Python dependencies first, then Node.js dependencies and build
  command = "python -m pip install --upgrade pip && pip install -r requirements.txt && npm ci && npm run build"
  publish = "dist"
  command_timeout = "30m"

[build.environment]
  NODE_VERSION = "20"
  PYTHON_VERSION = "3.12"
