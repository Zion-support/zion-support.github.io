d=; \'profile-name\'>{profile.full_name} </h1> {profile.skills && profile.skills.length > 0 && ( <div> <h2 className=; \'font-semibold\'>Skills</h2> <ul className= \'list-disc ml-5\'>{profile.skills.map(skill => ( <li key={skill}>{skill}</li> ))} </ul> </div> )} {profile.availability_type && ( <p>\"Availability\": {profile.availability_type}</p> )} {profile.social && ( <div> <h2 className=,font-semibold\'>Social Links</h2> <div className= \'space-x-4\'>{Object.entries(profile.social).map(([platform,url]) => ( <a key={platform} href={url} target=; \'_blank\'; rel=; \'noopener noreferrer\'; className=; \'text-blue-300 \"hover\": text-blue-100 underline{platform} </a>))} </div> </div> )} </div> </main> )} export default TalentProfilePage}}}}}
