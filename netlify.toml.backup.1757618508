[build]
  # Use `npm ci` for deterministic installs
  command = "npm ci && npm run build && (n=0; until [ $n -ge 3 ]; do curl -sf --connect-timeout 10 $DEPLOY_PRIME_URL/api/health | grep '\"status\":\"ok\"' && break; n=$((n+1)); echo "Health check attempt $n failed, retrying in 15s..."; sleep 15; done; if [ $n -ge 3 ]; then echo "Health check failed after 3 attempts." && exit 1; fi)"
  publish = ".next"

[build] # touch v4.57 to trigger Netlify rebuild
  # Build the site with Vite and publish the dist folder
  # Netlify runs dependency installation before build.command. Avoid redundant npm ci.
  command = "npm run build:ci"
  publish = "dist"
  functions = "netlify/functions"
  command_timeout = "30m"
  # Skip TypeScript checking during build

# API functions (if needed)
# [functions]
# directory = "netlify/functions"

[context.production.environment]
  NODE_ENV = "production"
  # Ensure dev deps are available in prod builds on Netlify
  NPM_CONFIG_PRODUCTION = "false"

[context.deploy-preview]
  command = "npm run build:ci"

[context.branch-deploy]
  command = "npm run build:ci"

