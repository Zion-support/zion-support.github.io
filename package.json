{
  "name": "bolt.new.zion.app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=\"--max-old-space-size=4096 --openssl-legacy-provider\" vite",
    "dev:backend": "cd server && npm run dev",
    "dev:hybrid": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "build": "NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "build:backend": "cd server && npm run build",
    "build:hybrid": "npm run build && npm run build:backend",
    "prebuild": "echo 'skip prebuild health-check'",
    "export": "rm -rf dist && NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "start": "vite preview",
    "start:backend": "cd server && npm start",
    "start:hybrid": "cd server && npm start",
    "postbuild": "echo 'Build completed successfully'",
    "lint": "eslint .",
    "lint:backend": "cd server && npm run lint",
    "lint:all": "npm run lint && npm run lint:backend",
    "type-check": "tsc --noEmit",
    "type-check:backend": "cd server && npm run type-check",
    "type-check:all": "npm run type-check && npm run type-check:backend",
    "prepare": "git config core.hooksPath .husky || true",
    "fix:all": "npm run lint --fix || true",
    "install:all": "npm install && cd server && npm install",
    
    "automation:start": "pm2 start ecosystem.config.cjs",
    "automation:stop": "pm2 stop ecosystem.config.cjs",
    "automation:restart": "pm2 restart ecosystem.config.cjs",
    "automation:status": "pm2 status",
    "automation:logs": "pm2 logs",
    "automation:monit": "pm2 monit",
    "automation:health": "node scripts/automation/health-checker.cjs",
    "automation:reports": "node scripts/automation/report-generator.cjs",
    
    "pm2:start": "pm2 start ecosystem.config.cjs --only",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit",
    
    "ai:code-review": "node scripts/automation/ai-code-reviewer.cjs",
    "ai:performance": "node scripts/automation/intelligent-performance-optimizer.cjs",
    "ai:dependencies": "node scripts/automation/smart-dependency-manager.cjs",
    "ai:security": "node scripts/automation/advanced-security-intelligence.cjs",
    "ai:quality": "node scripts/automation/code-quality-intelligence.cjs",
    "ai:testing": "node scripts/automation/automated-testing-intelligence.cjs",
    "ai:seo": "node scripts/automation/seo-analytics-intelligence.cjs",
    "ai:dev-assistant": "node scripts/automation/dev-assistant.cjs",
    "ai:build": "node scripts/automation/intelligent-build-orchestrator.cjs",
    "ai:health": "node scripts/automation/code-health-monitor.cjs",
    
    "automation:ai:start": "pm2 start ecosystem.config.cjs --only ai-code-reviewer,intelligent-performance-optimizer,smart-dependency-manager,advanced-security-intelligence,code-quality-intelligence,automated-testing-intelligence,seo-analytics-intelligence,dev-assistant,intelligent-build-orchestrator,code-health-monitor",
    "automation:ai:stop": "pm2 stop ai-code-reviewer intelligent-performance-optimizer smart-dependency-manager advanced-security-intelligence code-quality-intelligence automated-testing-intelligence seo-analytics-intelligence dev-assistant intelligent-build-orchestrator code-health-monitor",
    "automation:ai:restart": "pm2 restart ai-code-reviewer intelligent-performance-optimizer smart-dependency-manager advanced-security-intelligence code-quality-intelligence automated-testing-intelligence seo-analytics-intelligence dev-assistant intelligent-build-orchestrator code-health-monitor",
    "automation:ai:status": "pm2 status ai-code-reviewer intelligent-performance-optimizer smart-dependency-manager advanced-security-intelligence code-quality-intelligence automated-testing-intelligence seo-analytics-intelligence dev-assistant intelligent-build-orchestrator code-health-monitor",
    
    "automation:enhanced:start": "pm2 start ecosystem.config.cjs --only console-error-fixer,link-checker,continuous-improvement,daily-build-test,security-audit,dependency-updates,performance-monitor,quality-checks,link-integrity,front-maximizer,sitemap-runner,ai-code-reviewer,intelligent-performance-optimizer,smart-dependency-manager,advanced-security-intelligence,code-quality-intelligence,automated-testing-intelligence,seo-analytics-intelligence,dev-assistant,intelligent-build-orchestrator,code-health-monitor",
    "automation:enhanced:stop": "pm2 stop ecosystem.config.cjs",
    "automation:enhanced:restart": "pm2 restart ecosystem.config.cjs",
    "automation:enhanced:status": "pm2 status",
    "automation:enhanced:logs": "pm2 logs",
    "automation:enhanced:monit": "pm2 monit",
    
    "automation:dashboard": "node automation/automation-dashboard.cjs",
    "automation:factory": "node automation/automation-factory.cjs",
    "automation:orchestrator": "node automation/intelligent-orchestrator.cjs",
    
    "dev:assistant": "npm run ai:dev-assistant",
    "dev:review": "npm run ai:code-review",
    "dev:optimize": "npm run ai:performance",
    "dev:dependencies": "npm run ai:dependencies",
    "dev:security": "npm run ai:security",
    "dev:quality": "npm run ai:quality",
    "dev:testing": "npm run ai:testing",
    "dev:seo": "npm run ai:seo",
    "dev:build": "npm run ai:build",
    "dev:health": "npm run ai:health"
  },
