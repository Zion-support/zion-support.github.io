{
  "name": "bolt.new.zion.app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ci:preflight": "node -e \"try{require('fs').accessSync('dist');console.log('dist exists')}catch(e){process.exit(0)}\" && echo prebuilt || echo building",
    "ci:build-test": "npm run build && npm run test:smoke",
    "dev": "next dev",
    "build": "next build",
    "build:netlify": "node scripts/build-with-error-handling.js",
    "prebuild": "echo \"Starting build...\"",
    "export": "next build && next export",
    "start": "next start -p 3000",
    "postbuild": "echo \"Build completed\"",
    "lint": "eslint . --max-warnings 1000",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next out dist",
    "check": "npm run lint && npm run type-check && npm run test:smoke",
    "precommit": "npm run check",
    "prepare": "echo 'Husky prepare script disabled'",
    "test": "jest --config jest.config.cjs",
    "test:smoke": "jest --config jest.config.smoke.cjs",
    "test:watch": "jest --watch --config jest.config.ts",
    "test:coverage": "jest --coverage --config jest.config.ts",
    "test:unit": "npm test -- --testPathPattern=unit",
    "test:integration": "npm test -- --testPathPattern=integration",
    "test:e2e": "npm test -- --testPathPattern=e2e",
    "test:accessibility": "npx jest --testPathPattern=accessibility",
    "test:performance": "npx jest --testPathPattern=performance",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "analyze": "ANALYZE=true npm run build",
    "build:analyze": "ANALYZE=true npm run build",
    "build:clean": "npm run clean && npm run build",
    "build:production": "NODE_ENV=production npm run build",
    "lint:check": "eslint . --max-warnings 0",
    "ci:full": "bash scripts/comprehensive-build-test.sh",
    "ci:auto": "npm ci && npm run lint:check && npm run type-check && npm run build && npm run test:smoke",
    "ci:smoke": "npm run build && npm run test:smoke",
    "ci:consolidated": "bash scripts/ci-consolidated.sh",
    "dev:fast": "npm run dev -- --turbo",
    "dev:setup": "bash scripts/dev-setup.sh",
    "quick:test": "bash scripts/quick-test.sh",
    "deploy:app": "bash scripts/deploy.sh",
    "health:check": "bash scripts/health-check.sh",
    "sitemap": "node scripts/generate-sitemap.js",
    "sitemap:generate": "node scripts/generate-sitemap.js",
    "search:index": "node scripts/generate-search-index.js",
    "readme:generate": "node scripts/generate-readme.js",
    "perf:monitor": "node scripts/performance-monitor.js",
    "perf:audit": "npm run build:analyze",
    "perf:lighthouse": "lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html",
    "optimize:performance": "node scripts/performance-optimizer.cjs",
    "optimize:images": "node scripts/optimize-images.js",
    "optimize:ux": "node scripts/ux-optimizer.cjs",
    "audit:security": "node scripts/security-audit-enhanced.cjs",
    "security:fix": "npm audit fix --force",
    "security:scan": "node scripts/automation/ai-security-intelligence.cjs",
    "security:audit": "node scripts/security-audit.js",
    "improve:all": "node automation/comprehensive-app-improvement.cjs",
    "improve:performance": "node scripts/performance-improver.cjs",
    "improve:security": "node scripts/security-improver.cjs",
    "improve:seo": "node scripts/seo-improver.cjs",
    "improve:accessibility": "node scripts/accessibility-improver.cjs",
    "improve:monitoring": "node scripts/monitoring-improver.cjs",
    "content:fix": "node automation/content-quality-fixer.cjs && node automation/content-quality-analyzer.cjs",
    "analyze:bundle": "npm run build && npx @next/bundle-analyzer",
    "report:aggregate": "node scripts/aggregate-health-security.mjs",
    "sanitize:data": "node tools/sanitize-data-files.cjs",
    "automation:safe": "node tools/run-safe-automations.cjs",
    "error:fix": "node scripts/comprehensive-error-fix.cjs",
    "error:prevention:start": "pm2 start ecosystem.error-prevention.cjs",
    "error:prevention:stop": "pm2 stop ecosystem.error-prevention.cjs",
    "error:prevention:restart": "pm2 restart ecosystem.error-prevention.cjs",
    "error:prevention:status": "pm2 status",
    "error:prevention:logs": "pm2 logs --lines 100",
    "error:detect": "node automation/intelligent-error-detector.cjs",
    "pm2:start": "node -e \"const fs=require('fs');fs.mkdirSync('automation/logs',{recursive:true})\" && pm2 start ecosystem.config.cjs --update-env",
    "pm2:stop": "pm2 stop ecosystem.config.cjs || true",
    "pm2:restart": "node -e \"const fs=require('fs');fs.mkdirSync('automation/logs',{recursive:true})\" && (pm2 restart ecosystem.config.cjs || pm2 start ecosystem.config.cjs --update-env)",
    "pm2:reload": "pm2 reload all",
    "pm2:delete": "pm2 delete all",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs --lines 200",
    "pm2:monit": "pm2 monit",
    "pm2:save": "pm2 save",
    "pm2:resurrect": "pm2 resurrect",
    "pm2:startup": "pm2 startup",
    "pm2:unstartup": "pm2 unstartup",
    "pm2:bootstrap:logrotate": "pm2 install pm2-logrotate || true && pm2 set pm2-logrotate:max_size 10M && pm2 set pm2-logrotate:retain 30 && pm2 set pm2-logrotate:compress true && pm2 set pm2-logrotate:workerInterval 60 && pm2 set pm2-logrotate:rotateInterval '0 0 * * *'"
  },
  "pm2": {
    "ecosystem": "ecosystem.maintenance.cjs"
  },
  "dependencies": {
    "@google-analytics/data": "^5.2.0",
    "@google/generative-ai": "^0.24.1",
    "@magneticwatermelon/mcp-toolkit": "^2.0.1",
    "@modelcontextprotocol/sdk": "^1.17.1",
    "@modelcontextprotocol/server-filesystem": "^2025.8.21",
    "@modelcontextprotocol/server-memory": "^2025.8.4",
    "@modelcontextprotocol/server-sequential-thinking": "^2025.7.1",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.39.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/react-datepicker": "^6.2.0",
    "axios": "^1.11.0",
    "chalk": "^5.5.0",
    "cheerio": "^1.1.2",
    "child_process": "^1.0.2",
    "chokidar": "^4.0.3",
    "cron-parser": "^5.3.0",
    "events": "^3.3.0",
    "framer-motion": "^12.23.12",
    "fs": "^0.0.1-security",
    "fs-extra": "^11.3.1",
    "glob": "^11.0.3",
    "https": "^1.0.0",
    "import-fresh": "^3.3.1",
    "js-yaml": "^4.1.0",
    "jsdom": "^26.1.0",
    "lightningcss": "1.27.0",
    "lucide-react": "^0.541.0",
    "next": "^15.5.0",
    "node-cron": "^4.2.1",
    "openai": "^5.15.0",
    "path": "^0.12.7",
    "postcss": "^8.4.32",
    "react": "18.2.0",
    "react-datepicker": "^8.5.0",
    "react-dom": "18.2.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.32.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "18.3.23",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.32.0",
    "eslint-config-next": "^15.4.7",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "postcss": "^8.4.32",
    "sharp": "^0.34.3",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5"
  }
}
