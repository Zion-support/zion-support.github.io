{
  "name": "zion-tech-group",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "type": "module",
  "scripts": {
    "pm2:start": "node -e \"const fs=require('fs');fs.mkdirSync('automation/logs',{recursive:true})\" && pm2 start ecosystem.config.cjs --update-env",
    "pm2:stop": "pm2 stop ecosystem.config.cjs || true",
    "pm2:restart": "node -e \"const fs=require('fs');fs.mkdirSync('automation/logs',{recursive:true})\" && (pm2 restart ecosystem.config.cjs || pm2 start ecosystem.config.cjs --update-env)",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs --lines 200",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "pm2:fastads:start": "node -e \"const fs=require('fs');fs.mkdirSync('automation/logs',{recursive:true})\" && pm2 start ecosystem.fast-ads.local.cjs --update-env",
    "pm2:fastads:restart": "node -e \"const fs=require('fs');fs.mkdirSync('automation/logs',{recursive:true})\" && (pm2 restart ecosystem.fast-ads.local.cjs || pm2 start ecosystem.fast-ads.local.cjs --update-env)",
    "pm2:fastads:stop": "pm2 stop ecosystem.fast-ads.local.cjs || true",
    "pm2:cron:start": "node -e \"const fs=require('fs');fs.mkdirSync('automation/logs',{recursive:true})\" && pm2 start ecosystem.cron.local.cjs --update-env",
    "pm2:cron:restart": "node -e \"const fs=require('fs');fs.mkdirSync('automation/logs',{recursive:true})\" && (pm2 restart ecosystem.cron.local.cjs || pm2 start ecosystem.cron.local.cjs --update-env)",
    "pm2:cron:stop": "pm2 stop ecosystem.cron.local.cjs || true",
    "pm2:bootstrap:logrotate": "pm2 install pm2-logrotate || true && pm2 set pm2-logrotate:max_size 10M && pm2 set pm2-logrotate:retain 30 && pm2 set pm2-logrotate:compress true && pm2 set pm2-logrotate:workerInterval 60 && pm2 set pm2-logrotate:rotateInterval '0 0 * * *'",
    "functions:run": "node scripts/run-netlify-functions-locally.cjs",
    "functions:run:execute": "node scripts/run-netlify-functions-locally.cjs --execute",
    "front:advertise": "node automation/front-index-advertiser.cjs",
    "deps:maintain": "node automation/dependency-update-orchestrator.cjs",
    "deps:cron:start": "bash automation/dependency-maintenance-cron.sh",
    "netlify:manifest": "node scripts/generate-netlify-functions-manifest.cjs",
    "netlify:trigger": "node scripts/trigger-netlify-automations.cjs",
    "readme:generate": "node scripts/generate-readme.js",
    "search:index": "node scripts/generate-search-index.js",
    "content:fix": "node automation/content-quality-fixer.cjs && node automation/content-quality-analyzer.cjs",
    "perf:monitor": "node scripts/performance-monitor.js",
    "perf:audit": "npm run perf:monitor",
    "dev": "next dev",
    "dev:vite": "vite",
    "build": "NEXT_TELEMETRY_DISABLED=1 NEXT_DISABLE_ESLINT=1 next build",
    "build:vite": "vite build",
    "start": "next start",
    "start:vite": "vite preview",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "prebuild": "echo 'skip prebuild health-check'",
    "postbuild": "echo 'Build completed successfully'",
    "lint:fix": "eslint . --fix",
    "type-check:backend": "cd server && npm run type-check",
    "type-check:all": "npm run type-check && npm run lint:backend",
    "prepare": "git config core.hooksPath .husky || true",
    "fix:all": "npm run lint:fix || true",
    "install:all": "npm install && cd server && npm install",
    "preview": "next start",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "clean": "rm -rf dist node_modules/.vite",
    "analyze": "npm run build && npx vite-bundle-analyzer dist",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "pm2:monit": "pm2 monit",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup",
    "pm2:resurrect": "pm2 resurrect",
    "quality:check": "node scripts/pm2/code-quality-monitor.js",
    "quality:fix": "node scripts/pm2/lint-fixer.js && node scripts/pm2/auto-commit-fixes.js",
    "deps:check": "node scripts/pm2/dependency-monitor.js",
    "perf:check": "node scripts/pm2/performance-monitor.js",
    "test:automation": "node scripts/pm2/test-automation.js",
    "security:scan": "node scripts/pm2/security-scanner.js",
    "build:optimize": "node scripts/pm2/build-optimizer.js",
    "git:workflow": "node scripts/pm2/git-workflow.js",
    "health:monitor": "node scripts/pm2/health-monitor.js",
    "docs:generate": "node scripts/pm2/docs-generator.js",
    "seo:check": "node scripts/pm2/seo-accessibility.js",
    "automation:setup": "npm run pm2:start && echo 'PM2 automation processes started successfully!'",
    "automation:stop": "npm run pm2:stop && echo 'PM2 automation processes stopped successfully!'",
    "automation:restart": "npm run pm2:restart && echo 'PM2 automation processes restarted successfully!'",
    "automation:status": "npm run pm2:status && echo 'PM2 automation status displayed above'",
    "automation:logs": "npm run pm2:logs && echo 'PM2 automation logs displayed above'",
    "quality:full": "npm run lint:fix && npm run quality:check && npm run deps:check && npm run perf:check && npm run security:scan",
    "quality:quick": "npm run lint:fix && npm run quality:check",
    "quality:security": "npm run security:scan && npm run deps:check",
    "quality:performance": "npm run perf:check && npm run build:optimize",
    "dev:quality": "concurrently \"npm run dev\" \"npm run quality:check\"",
    "dev:secure": "concurrently \"npm run dev\" \"npm run security:scan\"",
    "dev:test": "concurrently \"npm run dev\" \"npm run test:automation\"",
    "build:analyze": "npm run build && npm run build:optimize",
    "build:secure": "npm run security:scan && npm run build",
    "build:quality": "npm run quality:check && npm run build",
    "build:full": "npm run quality:full && npm run build:analyze",
    "build:performance": "npm run build && npx lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html",
    "analyze:bundle": "npm run build && npx @next/bundle-analyzer",
    "clean:all": "rm -rf dist build coverage logs node_modules/.cache && npm run install:all",
    "clean:logs": "rm -rf logs/* && echo 'Logs cleaned successfully'",
    "clean:cache": "rm -rf node_modules/.cache dist/.cache && echo 'Cache cleaned successfully'",
    "health:check": "npm run health:monitor && npm run quality:check",
    "health:full": "npm run health:check && npm run security:scan && npm run perf:check",
    "dashboard": "node scripts/pm2/automation-dashboard.js",
    "docs:update": "npm run docs:generate && npm run quality:check",
    "docs:full": "npm run docs:generate && npm run seo:check",
    "automation:start": "./scripts/start-error-automation.sh",
    "automation:error-fix": "node scripts/automation/error-fixer-automation.cjs",
    "automation:comprehensive": "node scripts/automation/comprehensive-error-automation.cjs",
    "pm2:simple:start": "./scripts/pm2-automation.sh start",
    "pm2:simple:stop": "./scripts/pm2-automation.sh stop",
    "pm2:simple:restart": "./scripts/pm2-automation.sh restart",
    "pm2:simple:monitor": "./scripts/pm2-automation.sh monitor",
    "pm2:simple:ci": "./scripts/pm2-automation.sh ci",
    "pm2:simple:cd": "./scripts/pm2-automation.sh cd",
    "pm2:simple:deploy": "./scripts/pm2-automation.sh deploy",
    "pm2:simple:build": "./scripts/pm2-automation.sh build",
    "pm2:simple:test": "./scripts/pm2-automation.sh test",
    "pm2:simple:lint": "./scripts/pm2-automation.sh lint"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@reduxjs/toolkit": "^2.8.2",
    "@stripe/stripe-js": "^2.3.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query": "^5.85.5",
    "axios": "^1.11.0",
    "cheerio": "^1.1.2",
    "child_process": "^1.0.2",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.3.0",
    "esbuild": "^0.25.9",
    "events": "^3.3.0",
    "framer-motion": "5.6.0",
    "fs": "^0.0.1-security",
    "fs-extra": "^11.3.1",
    "glob": "^11.0.3",
    "https": "^1.0.0",
    "import-fresh": "^3.3.1",
    "lucide-react": "^0.536.0",
    "next": "^12.3.4",
    "node-cron": "^4.2.1",
    "openai": "^5.11.0",
    "path": "^0.12.7",
    "postcss": "^8.4.32",
    "queue-microtask": "^1.2.3",
    "react": "^17.0.2",
    "react-datepicker": "^8.4.0",
    "react-dom": "^17.0.2",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.30.1",
    "tailwind-merge": "^3.3.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.32.0",
    "eslint-config-next": "^14.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "husky": "^9.1.7",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18.18.0 <=22.x",
    "npm": ">=10.0.0"
  }
}