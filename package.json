    "react-markdown": "^4.3.1",
    "react-player": "^2.12.0",
    "react-resizable-panels": "^3.0.2",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0",
    "rollup-plugin-visualizer": "^2.7.2",
    "socket.io": "^0.9.19",
    "socket.io-client": "^0.9.17",
    "sonner": "^2.0.5",
    "swr": "^2.2.0",
