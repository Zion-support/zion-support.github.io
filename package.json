{
  "name": "bolt.new.zion.app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=\"--max-old-space-size=4096 --openssl-legacy-provider\" vite",
    "dev:backend": "cd server && npm run dev",
    "dev:hybrid": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "dev:automated": "node scripts/dev-automation.js",
    "build": "NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "build:backend": "cd server && npm run build",
    "build:hybrid": "npm run build && npm run build:backend",
    "prebuild": "echo 'skip prebuild health-check'",
    "export": "rm -rf dist && NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "start": "vite preview",
    "start:backend": "cd server && npm start",
    "start:hybrid": "cd server && npm start",
    "postbuild": "echo 'Build completed successfully'",
    "lint": "eslint .",
    "lint:backend": "cd server && npm run lint",
    "lint:all": "npm run lint && npm run lint:backend",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "type-check:backend": "cd server && npm run type-check",
    "type-check:all": "npm run type-check && npm run type-check:backend",
    "prepare": "git config core.hooksPath .husky || true",
    "fix:all": "npm run lint --fix || true",
    "install:all": "npm install && cd server && npm install",
    "test": "vitest",
    "test:unit": "vitest --run --coverage",
    "test:integration": "vitest --run --coverage --config vitest.integration.config.ts",
    "test:e2e": "vitest --run --coverage --config vitest.e2e.config.ts",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --run --coverage --reporter=html",
    "qa": "node scripts/qa-automation.js",
    "qa:watch": "node scripts/qa-automation.js all changed development --watch",
    "qa:critical": "node scripts/qa-automation.js all critical development",
    "qa:performance": "node scripts/qa-automation.js performance all development",
    "deploy": "node scripts/deploy-automation.js",
    "deploy:staging": "node scripts/deploy-automation.js staging",
    "deploy:production": "node scripts/deploy-automation.js production",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:start:dev": "pm2 start ecosystem.config.js --env development",
    "pm2:start:staging": "pm2 start ecosystem.config.js --env staging",
    "pm2:start:production": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop all",
    "pm2:restart": "pm2 restart all",
    "pm2:reload": "pm2 reload ecosystem.config.js",
    "pm2:reload:dev": "pm2 reload ecosystem.config.js --env development",
    "pm2:reload:staging": "pm2 reload ecosystem.config.js --env staging",
    "pm2:reload:production": "pm2 reload ecosystem.config.js --env production",
    "pm2:delete": "pm2 delete all",
    "pm2:logs": "pm2 logs",
    "pm2:monitor": "pm2 monit",
    "pm2:status": "pm2 status",
    "pm2:save": "pm2 save",
    "pm2:resurrect": "pm2 resurrect",
    "monitor:start": "node scripts/monitor.js",
    "gateway:start": "node scripts/gateway.js",
    "clean": "rm -rf dist build node_modules/.cache",
    "clean:all": "rm -rf dist build node_modules/.cache && cd server && rm -rf dist node_modules/.cache",
    "health:check": "curl -f http://localhost:3000/health || exit 1",
    "health:check:backend": "curl -f http://localhost:5000/health || exit 1",
    "health:check:all": "npm run health:check && npm run health:check:backend"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-aspect-ratio": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@reduxjs/toolkit": "^2.8.2",
    "@tanstack/react-query": "^5.85.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "d3-color": "^3.1.0",
    "d3-format": "^3.1.0",
    "d3-path": "^3.1.0",
    "d3-time-format": "^4.1.0",
    "date-fns": "^2.30.0",
    "framer-motion": "^10.16.4",
    "i18next": "^25.4.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-day-picker": "^8.9.1",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.0.0",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.47.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^15.7.2",
    "react-redux": "^9.2.0",
    "react-remove-scroll-bar": "^2.3.8",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.8.0",
    "tailwind-merge": "^2.0.0",
    "use-callback-ref": "^1.3.3",
    "use-sidecar": "^1.1.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.8.10",
    "@types/react": "^18.2.33",
    "@types/react-dom": "^18.2.14",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.1.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "cssnano": "^7.1.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "terser": "^5.43.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.19",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "jsdom": "^23.0.0",
    "chokidar": "^3.5.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "cors": "^2.8.5",
    "http-proxy-middleware": "^2.0.6",
    "socket.io": "^4.7.2",
    "dotenv": "^16.3.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "pm2": {
    "ecosystem": "ecosystem.config.js"
  }
}
