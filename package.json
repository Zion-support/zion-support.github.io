{
  "name": "operator-reminder-workflow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "zion": "scripts/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Zion-Holdings/zion.app.git"
  },
  "bugs": {
    "url": "https://github.com/Zion-Holdings/zion.app/issues"
  },
  "homepage": "https://github.com/Zion-Holdings/zion.app#readme",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.18.1",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "NODE_ENV=production vite build --mode production",
    "build:analyze": "NODE_ENV=production vite build --mode analyze",
    "build:preview": "npm run build && npm run preview",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "preview": "NODE_ENV=production vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:accessibility": "vitest run tests/Accessibility.test.tsx",
    "test:performance": "vitest run tests/Performance.test.tsx",
    "test:security": "vitest run tests/Security.test.tsx",
    "test:seo": "vitest run tests/SEO.test.tsx",
    "test:pwa": "vitest run tests/PWA.test.tsx",
    "test:integration": "vitest run tests/integration/",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:accessibility && npm run test:performance && npm run test:security",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run --browser chrome",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@google-analytics/data": "^4.12.1",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@tanstack/react-query": "^5.17.19",
    "@tanstack/react-query-devtools": "^5.87.3",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.3",
    "lucide-react": "^0.323.0",
    "postcss": "^8.5.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.4",
    "react-router-dom": "^6.22.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^4.1.13",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^6.3.6",
    "vite-plugin-pwa": "^0.20.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^6.1.0",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.32.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.1",
    "@types/node-cron": "^3.0.11",
    "vitest": "^2.1.8"
  }
}
