{
  "name": "zion-tech-group-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=\"--max-old-space-size=4096 --openssl-legacy-provider\" vite",
    "build": "NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "preview": "vite preview",
    "prebuild": "echo 'skip prebuild health-check'",
    "export": "rm -rf dist && NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "start": "vite preview",
    "postbuild": "echo 'Build completed successfully'",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "prepare": "git config core.hooksPath .husky || true",
    "fix:all": "npm run lint -- --fix || true",
    "test": "npm run test:unit",
    "test:unit": "jest",
    "test:integration": "echo 'Integration tests not configured'",
    "test:e2e": "echo 'E2E tests not configured'",
    "test:playwright": "echo 'Playwright tests not configured'",
    "test:cypress": "echo 'Cypress tests not configured'",
    "test:ci": "jest --coverage --ci --watchAll=false",
    "test:coverage": "jest --coverage",
    "test:lighthouse": "echo 'Lighthouse tests not configured'",
    "test:webpagetest": "echo 'WebPageTest not configured'",
    "test:load": "echo 'Load tests not configured'",
    "test:accessibility": "echo 'Accessibility tests not configured'",
    "test:lighthouse:accessibility": "echo 'Lighthouse accessibility tests not configured'",
    "security:scan": "npm audit --audit-level=moderate || true"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "framer-motion": "^10.16.4",
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "tailwind-merge": "^2.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20.8.10",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.1.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "terser": "^5.43.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2",
    "vite": "^4.5.0"
  }
}
