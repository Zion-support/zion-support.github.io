{
  "name": "zion-tech-group",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "zion": "scripts/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zion-Holdings/zion.app.git"
  },
  "keywords": [
    "zion",
    "tech",
    "services",
    "marketplace",
    "ai",
    "blockchain",
    "web3",
    "react",
    "nextjs",
    "typescript"
  ],
  "author": "Zion Holdings <contact@ziontechgroup.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Zion-Holdings/zion.app/issues"
  },
  "homepage": "https://ziontechgroup.com",
  "packageManager": "npm@10.8.3",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode production",
    "start": "vite preview",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "playwright test",
    "test:build": "npm run build && npm run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf .next node_modules/.cache dist coverage",
    "prebuild": "echo 'Starting build process...'",
    "postbuild": "echo 'Build completed successfully' && ls -la dist/",
    "deploy": "npm run build && netlify deploy --prod",
    "deploy:preview": "npm run build && netlify deploy",
    "health": "curl -f https://ziontechgroup.com/api/health || exit 1",
    "health:local": "curl -f http://localhost:3000/api/health || exit 1",
    "validate": "npm run build",
    "security:audit": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix",
    "performance:test": "lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html",
    "analyze": "npm run build && npx vite-bundle-analyzer dist",
    "prepare": "echo 'Skipping husky install in CI environment'"
  },
