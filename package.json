{
  "name": "ziontechgroup-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "build:netlify": "node scripts/build-with-error-handling.js",
    "prebuild": "echo \"Starting build...\"",
    "export": "vite build",
    "postbuild": "echo \"Build completed\"",
    "lint": "node --max-old-space-size=4096 ./node_modules/.bin/eslint . --max-warnings 1000",
    "lint:fix": "node --max-old-space-size=4096 ./node_modules/.bin/eslint . --fix --max-warnings 1000",
    "lint:check": "eslint . --max-warnings 0",
    "type-check": "node --max-old-space-size=8192 ./node_modules/.bin/tsc --noEmit --skipLibCheck",
    "test": "jest --config jest.config.cjs",
    "test:smoke": "jest --config jest.config.smoke.cjs --passWithNoTests",
    "test:watch": "jest --watch --config jest.config.ts",
    "test:coverage": "jest --coverage --config jest.config.ts",
    "verify": "npm run type-check && npm run build && npm run test:smoke",
    "check": "npm run lint && npm run type-check && npm run test:smoke",
    "clean": "rm -rf .next out dist",
    "analyze": "npm run build && npx @next/bundle-analyzer",
    "deploy": "npm run build && npm run export",
    "deploy:netlify": "npm run build:netlify",
    "seo:generate": "node scripts/generate-dynamic-sitemap.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query": "^5.85.5",
    "@types/react-datepicker": "^6.2.0",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "framer-motion": "^10.18.0",
    "fs": "^0.0.1-security",
    "fs-extra": "^11.3.1",
    "glob": "^11.0.3",
    "https": "^1.0.0",
    "import-fresh": "^3.3.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.536.0",
    "mongodb": "^6.19.0",
    "next": "^15.5.2",
    "node-cron": "^4.2.1",
    "openai": "^5.11.0",
    "path": "^0.12.7",
    "postcss": "^8.4.31",
    "postcss-preset-env": "^10.3.1",
    "prettier": "^3.0.3",
    "react": "^18.3.1",
    "react-datepicker": "^8.4.0",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.0.0",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.62.0",
    "react-hot-toast": "^2.6.0",
    "react-intersection-observer": "^9.13.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.28.0",
    "react-syntax-highlighter": "^15.6.1",
    "react-use": "^17.5.1",
    "recharts": "^2.12.7",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.15",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.5.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.5.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}