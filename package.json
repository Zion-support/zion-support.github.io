{
  "name": "zion-tech-group-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode production && cp -f _redirects dist/_redirects || true && cp -f public/_headers dist/_headers || true",
    "start": "vite preview",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/AppMinimal.tsx\" \"src/main.tsx\"",
    "lint:fix": "eslint \"src/AppMinimal.tsx\" \"src/main.tsx\" --fix",
    "type-check": "tsc --project tsconfig.typecheck.json --noEmit",
    "test": "jest --passWithNoTests --config jest.config.cjs",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "playwright test",
    "test:build": "npm run build && npm run test",
    "format": "prettier --write .",
    "automation:accessibility": "node automation/accessibility-checker.cjs",
    "automation:security-audit": "node automation/security-audit.cjs",
    "format:check": "prettier --check .",
    "test:smoke": "jest --config jest.config.smoke.cjs",
    "ci:full": "bash scripts/comprehensive-build-test.sh",
    "ci:auto": "npm ci && npm run lint:check && npm run type-check && npm run build && npm run test:smoke",
    "analyze": "ANALYZE=true npm run build",
    "dev:fast": "npm run dev -- --turbo",
    "build:analyze": "ANALYZE=true npm run build",
    "build:clean": "npm run clean && npm run build",
    "lint:check": "eslint --no-error-on-unmatched-pattern \"src/AppMinimal.tsx\" \"src/main.tsx\" --max-warnings 0",
    "automation:master": "node automation/master-orchestrator.cjs",
    "automation:performance": "node automation/performance-optimizer.cjs",
    "automation:seo": "node automation/seo-optimizer.cjs",
    "automation:health": "node automation/health-check.cjs",
    "automation:security": "node automation/security-scanner.cjs",
    "pr:merge-open": "node scripts/merge-open-prs.cjs",
    "pr:auto-resolve-and-merge": "node scripts/auto-resolve-merge-prs.cjs",
    "pr:force-merge-heads": "node scripts/force-merge-open-pr-heads-into-main.cjs",
    "optimize:performance": "node scripts/performance-optimizer.cjs",
    "audit:security": "node scripts/security-audit-enhanced.cjs",
    "optimize:ux": "node scripts/ux-optimizer.cjs",
    "improve:all": "bash scripts/comprehensive-app-improvements.sh",
    "sanitize:data": "node tools/sanitize-data-files.cjs",
    "automation:safe": "bash scripts/run-safe-automations.sh",
    "ci:smoke": "npm run build && npm run test:smoke",
    "ci:consolidated": "bash scripts/ci-consolidated.sh",
    "report:aggregate": "node scripts/aggregate-health-security.mjs",
    "dev:setup": "bash scripts/dev-setup.sh",
    "quick:test": "bash scripts/quick-test.sh",
    "deploy:app": "bash scripts/deploy.sh",
    "health:check": "bash scripts/health-check.sh",
    "error:fix": "node scripts/comprehensive-error-fix.cjs",
    "error:prevention:start": "pm2 start ecosystem.error-prevention.cjs",
    "error:prevention:stop": "pm2 stop ecosystem.error-prevention.cjs",
    "error:prevention:restart": "pm2 restart ecosystem.error-prevention.cjs",
    "error:prevention:status": "pm2 status",
    "error:prevention:logs": "pm2 logs --lines 100",
    "build:production": "NODE_ENV=production npm run build",
    "error:detect": "node automation/intelligent-error-detector.cjs",
    "automation:enhanced": "node automation/enhanced-master-automation-orchestrator.cjs",
    "optimize:images": "node scripts/optimize-images.js",
    "test:accessibility": "npx jest --testPathPattern=accessibility",
    "test:performance": "npx jest --testPathPattern=performance",
    "improve:performance": "node scripts/performance-improver.cjs",
    "improve:security": "node scripts/security-improver.cjs",
    "improve:seo": "node scripts/seo-improver.cjs",
    "improve:accessibility": "node scripts/accessibility-improver.cjs",
    "improve:monitoring": "node scripts/monitoring-improver.cjs"
  },
  "pm2": {
    "ecosystem": "ecosystem.maintenance.cjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-aspect-ratio": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@reduxjs/toolkit": "^2.8.2",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query": "^5.85.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^0.2.1",
    "d3-color": "^3.1.0",
    "d3-format": "^3.1.0",
    "d3-path": "^3.1.0",
    "d3-time-format": "^4.1.0",
    "date-fns": "^3.3.1",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^9.23.0",
    "framer-motion": "^12.23.12",
    "fuse.js": "^7.0.0",
    "i18next": "^25.4.1",
    "i18next-browser-languagedetector": "^7.2.0",
    "input-otp": "^1.1.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.1",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^0.323.0",
    "notistack": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.0.0",
    "react-helmet-async": "^2.0.5",
    "react-hot-toast": "^2.6.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.20.0",
    "tailwind-merge": "^2.0.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.1.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.20",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2",
    "vite": "^4.5.0"
  }
}
