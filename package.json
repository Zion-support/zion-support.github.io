{
  "name": "bolt.new.zion.app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "node --max-old-space-size=8192 ./node_modules/.bin/next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:smoke": "jest --config jest.config.smoke.cjs",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "analyze": "ANALYZE=true npm run build",
    "clean": "rm -rf .next out dist",
    "clean:all": "rm -rf .next out dist node_modules package-lock.json",
    "reinstall": "npm run clean:all && npm install",
    "precommit": "npm run lint && npm run type-check",
    "prepush": "npm run test && npm run build",
    "automation:run": "node comprehensive-automation-orchestrator.cjs",
    "automation:test": "node comprehensive-test-runner.cjs",
    "automation:deploy": "node deployment-automation.cjs",
    "automation:monitor": "node system-monitor.cjs",
    "automation:all": "npm run automation:run && npm run automation:test && npm run automation:deploy",
    "automation:continuous": "node automation/continuous-improvement-orchestrator.cjs"
  },
  "pm2": {
    "ecosystem": "ecosystem.maintenance.cjs"
  },
  "dependencies": {
    "@heroicons/react": "^2.0.18",
    "@next/bundle-analyzer": "^14.0.4",
