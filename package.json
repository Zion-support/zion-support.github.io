  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.18.1",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "generate": "prisma generate",
    "build": "NODE_ENV=production npx next build",
    "deploy:ipfs": "node scripts/deploy-zion-ipfs.js",
    "lint": "eslint . --fix --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "preview": "NODE_ENV=production vite preview",
    "test": "node ./node_modules/jest/bin/jest.js",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "performance": "node scripts/performance-monitor.cjs",
    "performance:monitor": "node -e \"console.log('Performance monitoring enabled. Check browser console for metrics.');\"",
    "analyze": "npm run build && npm run performance",
    "analyze:performance": "node scripts/performance-optimizer.js",
    "test:comprehensive": "node scripts/comprehensive-test.cjs",
    "test:all": "npm run test:comprehensive",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run --browser chrome",
    "test:accessibility": "vitest run tests/Accessibility.test.tsx",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist node_modules/.vite",
    "prebuild": "echo 'Skipping prebuild checks'",
    "postbuild": "node scripts/copy-netlify-files.js && echo 'Build completed successfully' && node -e \"if(!(process.env.CI==='true'||process.env.NETLIFY==='true')){process.exit(1)}\" || npm run optimize",
    "optimize": "node scripts/optimize-build.js",
    "optimize:advanced": "node scripts/advanced-optimize.js",
    "build:advanced": "npm run build && npm run optimize:advanced",
    "postinstall": "npm rebuild rollup @rollup/rollup-linux-x64-gnu || true",
    "deploy": "npm run build && netlify deploy --prod",
    "deploy:preview": "npm run build && netlify deploy",
    "health": "curl -f https://ziontechgroup.com/api/health || exit 1",
    "health:local": "curl -f http://localhost:3000/api/health || exit 1",
    "validate": "npm run build:ci"
  },
