{
  "name": "bolt.new.zion.app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS='--max-old-space-size=4096 --openssl-legacy-provider' next build --no-lint",
    "start": "next start",
    "lint": "next lint",
    "build:analyze": "ANALYZE=true npm run build",
    "build:clean": "rm -rf .next && npm run build",
    "dev:clean": "rm -rf .next && npm run dev",
    "lint:fix": "next lint --fix",
    "type-check": "NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "preview": "npm run build && npm run start",
    "prepare": "husky install",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf .next node_modules/.cache",
    "export": "npm run build && next export",
    "deploy": "npm run build && npm run export",
    "postinstall": "echo 'Type-check skipped (non-blocking)'"
  },
  "dependencies": {
    "@netlify/plugin-nextjs": "^5.13.3",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.21",
    "axios": "^1.11.0",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.536.0",
    "next": "^15.5.3",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "openai": "^5.11.0",
    "path": "^0.12.7",
    "react": "^19.1.1",
    "react-datepicker": "^8.4.0",
    "react-dom": "17.0.2",
    "sonner": "^2.0.7",
    "swr": "^2.3.6",
    "tailwind-merge": "^3.3.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^16.18.126",
    "critters": "^0.0.23",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "eslint-plugin-jest-dom": "^4.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-testing-library": "^6.0.0",
    "husky": "^9.1.7",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.0",
    "typescript": "^4.9.5"
  },
  "overrides": {
    "rollup": {
      "@rollup/rollup-linux-x64-gnu": "^4.18.0"
    }
  },
  "resolutions": {
    "@rollup/rollup-darwin-x64": "@rollup/rollup-linux-x64-gnu"
  },
  "packageManager": "yarn@4.9.4+sha512.7b1cb0b62abba6a537b3a2ce00811a843bea02bcf53138581a6ae5b1bf563f734872bd47de49ce32a9ca9dcaff995aa789577ffb16811da7c603dcf69e73750b"
}
