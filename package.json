{
  "name": "zion-tech-group",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=\"--max-old-space-size=4096 --openssl-legacy-provider\" vite",
    "build": "NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "prebuild": "echo 'skip prebuild health-check'",
    "export": "rm -rf dist && NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "start": "vite preview",
    "postbuild": "echo 'Build completed successfully'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "prepare": "git config core.hooksPath .husky || true",
    "fix:all": "npm run lint -- --fix || true",
    "test": "echo 'No tests configured yet'",
    "test:ci": "echo 'No tests configured yet'",
    "security:scan": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist node_modules/.cache",
    "preview": "vite preview",
    "analyze": "vite-bundle-analyzer"
  },
