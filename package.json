    "framer-motion": "^10.16.4",
    "lucide-react": "^0.292.0",
    "next": "^15.5.2",
    "postcss-preset-env": "^10.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.0.0",
    "react-helmet-async": "^2.0.5",
    "tailwind-merge": "^3.3.1",
    "vite": "^7.1.3",
    "web-vitals": "^3.5.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
