    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "lint:check": "eslint --no-error-on-unmatched-pattern src/AppMinimal.tsx --max-warnings 0",
    "lint:fix": "eslint \"src/AppMinimal.tsx\" \"src/main.tsx\" --fix",
    "type-check": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest",
    "test:watch": "jest --watch",
    "test:coverage": "vitest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "cypress run",
    "test:smoke": "vitest run",
    "test:build": "npm run build && npm run test",
    "format": "prettier --write .",
    "automation:accessibility": "node automation/accessibility-checker.cjs",
    "automation:security-audit": "node automation/security-audit.cjs",
