{
  "name": "ziontechgroup.com",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prebuild": "echo \"Starting build...\"",
    "export": "next export",
    "start": "next start",
    "postbuild": "echo \"Build completed\"",
    "lint": "eslint components pages --no-ignore",
    "lint:fix": "eslint components pages --fix --no-ignore",
    "type-check": "tsc --noEmit",
    "type-check:backend": "cd server && npm run type-check",
    "type-check:all": "npm run type-check && npm run type-check:backend",
    "prepare": "git config core.hooksPath .husky || true",
    "fix:all": "npm run lint --fix || true",
    "install:all": "npm install && cd server && npm install",
    "automation:start": "pm2 start ecosystem.config.cjs",
    "automation:stop": "pm2 stop ecosystem.config.cjs",
    "automation:restart": "pm2 restart ecosystem.config.cjs",
    "automation:status": "pm2 status",
    "automation:logs": "pm2 logs --lines 20",
    "automation:monit": "pm2 monit",
    "automation:health": "node scripts/automation-manager.js health",
    "automation:reports": "node scripts/automation-manager.js performance",
    "automation:dashboard": "node scripts/enhanced-automation-dashboard.js",
    "pm2:start": "pm2 start ecosystem.config.cjs --only automation",
    "pm2:stop": "pm2 stop ecosystem.config.cjs --only automation",
    "pm2:restart": "pm2 restart ecosystem.config.cjs --only automation",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit",
    "pm2:dev": "pm2 start ecosystem.config.cjs --env development",
    "pm2:prod": "pm2 start ecosystem.config.cjs --env production",
    "pm2:staging": "pm2 start ecosystem.config.cjs --env staging",
    "pm2:reload": "pm2 reload ecosystem.config.cjs",
    "pm2:delete": "pm2 delete all",
    "pm2:save": "pm2 save",
    "pm2:resurrect": "pm2 resurrect",
    "pm2:start:monitor": "pm2 start scripts/pm2-monitor.js --name zion-monitor",
    "pm2:start:watcher": "pm2 start scripts/pm2-build-watcher.js --name zion-build-watcher",
    "pm2:start:manager": "pm2 start scripts/pm2-manager.js --name zion-pm2-manager",
    "deploy:staging": "node scripts/pm2-deployer.js deploy staging",
    "deploy:production": "node scripts/pm2-deployer.js deploy production",
    "deploy:status": "node scripts/pm2-deployer.js status",
    "deploy:history": "node scripts/pm2-deployer.js history",
    "dev:full": "concurrently \"npm run pm2:start:monitor\" \"npm run pm2:start:watcher\" \"npm run pm2:start:manager\" \"npm run pm2:dev\"",
    "dev:monitored": "concurrently \"npm run pm2:start:monitor\" \"npm run pm2:dev\"",
    "dev:watched": "concurrently \"npm run pm2:start:watcher\" \"npm run dev\"",
    "setup:pm2": "npm install -g pm2 && pm2 install pm2-logrotate && pm2 set pm2-logrotate:max_size 10M && pm2 set pm2-logrotate:retain 30",
    "setup:logs": "mkdir -p logs backups",
    "setup:all": "npm run setup:logs && npm run setup:pm2",
    "health:check": "node scripts/pm2-monitor.js --health-check",
    "health:report": "node scripts/pm2-monitor.js --generate-report",
    "performance:analyze": "node scripts/pm2-manager.js --analyze",
    "performance:optimize": "node scripts/pm2-manager.js --optimize",
    "clean:logs": "rm -rf logs/*.log logs/*.json",
    "clean:backups": "rm -rf backups/*",
    "clean:all": "npm run clean:logs && npm run clean:backups",
    "backup:create": "mkdir -p backups && cp -r dist backups/dist-$(date +%Y%m%d-%H%M%S) && cp -r server/dist backups/server-dist-$(date +%Y%m%d-%H%M%S)",
    "backup:restore": "echo 'Please specify backup directory: npm run backup:restore <backup-dir>'",
    "scale:frontend": "pm2 scale zion-frontend-prod",
    "scale:backend": "pm2 scale zion-backend-prod",
    "scale:auto": "node scripts/pm2-manager.js --auto-scale",
    "logs:frontend": "pm2 logs zion-frontend-dev --lines 100",
    "logs:backend": "pm2 logs zion-backend-dev --lines 100",
    "logs:monitor": "pm2 logs zion-monitor-dev --lines 100",
    "logs:watcher": "pm2 logs zion-build-watcher-dev --lines 100",
    "restart:frontend": "pm2 restart zion-frontend-dev",
    "restart:backend": "pm2 restart zion-backend-dev",
    "restart:monitor": "pm2 restart zion-monitor-dev",
    "restart:watcher": "pm2 restart zion-build-watcher",
    "update:ecosystem": "pm2 reload ecosystem.config.cjs",
    "update:all": "npm run update:ecosystem && pm2 save",
    "test:pm2": "pm2 start ecosystem.config.cjs --env development && sleep 10 && pm2 status && pm2 stop all && pm2 delete all",
    "test:deployment": "npm run deploy:staging && npm run deploy:production",
    "test:monitoring": "npm run pm2:start:monitor && sleep 30 && npm run health:report && pm2 stop zion-monitor && pm2 delete zion-monitor",
    "pm2:error:fixer": "node scripts/pm2-error-fixer.js",
    "pm2:quality:monitor": "node scripts/pm2-quality-monitor.js",
    "pm2:eslint:fixer": "node scripts/pm2-eslint-fixer.js",
    "pm2:start:error:prevention": "pm2 start ecosystem-error-prevention.config.cjs",
    "pm2:stop:error:prevention": "pm2 stop ecosystem-error-prevention.config.cjs",
    "pm2:restart:error:prevention": "pm2 restart ecosystem-error-prevention.config.cjs",
    "pm2:status:error:prevention": "pm2 status --only zion-error-fixer,zion-quality-monitor,zion-eslint-fixer",
    "pm2:logs:error:prevention": "pm2 logs --only zion-error-fixer,zion-quality-monitor,zion-eslint-fixer --lines 50",
    "pm2:monit:error:prevention": "pm2 monit --only zion-error-fixer,zion-quality-monitor,zion-eslint-fixer",
    "error:fix:all": "npm run pm2:error:fixer check",
    "quality:check": "npm run pm2:quality:monitor check",
    "eslint:fix:all": "npm run pm2:eslint:fixer fix",
    "fix:typescript": "npm run type-check 2>&1 | grep -v 'error TS' || true",
    "fix:eslint": "npm run lint -- --fix",
    "fix:all:automated": "npm run fix:eslint && npm run fix:typescript"
  },
  "dependencies": {
    "@google-analytics/data": "^5.2.0",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.1",
    "@magneticwatermelon/mcp-toolkit": "^1.1.4",
    "@modelcontextprotocol/sdk": "^1.17.1",
    "@modelcontextprotocol/server-filesystem": "^2025.7.29",
    "@modelcontextprotocol/server-memory": "^2025.8.4",
    "@modelcontextprotocol/server-sequential-thinking": "^2025.7.1",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-aspect-ratio": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@reduxjs/toolkit": "^2.8.2",
    "@stripe/stripe-js": "^2.3.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.39.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query": "^5.85.5",
    "chalk": "^5.6.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "d3-color": "^3.1.0",
    "d3-format": "^3.1.0",
    "d3-path": "^3.1.0",
    "d3-time-format": "^4.1.0",
    "date-fns": "^2.30.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "framer-motion": "^10.16.4",
    "i18next": "^25.4.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.294.0",
    "node-cron": "^4.2.1",
    "openai": "^5.11.0",
    "path": "^0.12.7",
    "postcss": "^8.4.32",
    "postcss-preset-env": "^10.3.1",
    "prettier": "^3.0.3",
    "react": "^18.3.1",
    "react-datepicker": "^8.4.0",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "sharp": "^0.34.3",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@next/bundle-analyzer": "^15.5.2",
    "@types/node": "^20.19.11",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "chokidar": "^4.0.3",
    "cssnano": "^7.1.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "globals": "^16.3.0",
    "pm2": "^6.0.8",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "terser": "^5.43.1",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vite": "^5.4.19"
  },
  "type": "module"
}