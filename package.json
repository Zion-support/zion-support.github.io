{
  "name": "bolt.new.zion.app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "NODE_OPTIONS=\"--max-old-space-size=4096 --openssl-legacy-provider\" vite",
    "dev:backend": "cd server && npm run dev",
    "dev:hybrid": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "build": "NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "build:backend": "cd server && npm run build",
    "build:hybrid": "npm run build && npm run build:backend",
    "prebuild": "echo 'skip prebuild health-check'",
    "export": "rm -rf dist && NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "start": "vite preview",
    "start:backend": "cd server && npm start",
    "start:hybrid": "cd server && npm start",
    "postbuild": "echo 'Build completed successfully'",
    "lint": "eslint .",
    "lint:backend": "cd server && npm run lint",
    "lint:all": "npm run lint && npm run lint:backend",
    "type-check": "tsc --noEmit",
    "type-check:backend": "cd server && npm run type-check",
    "type-check:all": "npm run type-check && npm run type-check:backend",
    "prepare": "git config core.hooksPath .husky || true",
    "fix:all": "npm run lint --fix || true",
    "install:all": "npm install && cd server && npm install",
    
    "pm2:dev": "pm2 start ecosystem.config.cjs --env development",
    "pm2:prod": "pm2 start ecosystem.config.cjs --env production",
    "pm2:staging": "pm2 start ecosystem.config.cjs --env staging",
    "pm2:stop": "pm2 stop all",
    "pm2:restart": "pm2 restart all",
    "pm2:reload": "pm2 reload ecosystem.config.cjs",
    "pm2:delete": "pm2 delete all",
    "pm2:save": "pm2 save",
    "pm2:resurrect": "pm2 resurrect",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit",
    "pm2:start:monitor": "pm2 start scripts/pm2-monitor.js --name zion-monitor",
    "pm2:start:watcher": "pm2 start scripts/pm2-build-watcher.js --name zion-build-watcher",
    "pm2:start:manager": "pm2 start scripts/pm2-manager.js --name zion-pm2-manager",
    
    "deploy:staging": "node scripts/pm2-deployer.js deploy staging",
    "deploy:production": "node scripts/pm2-deployer.js deploy production",
    "deploy:status": "node scripts/pm2-deployer.js status",
    "deploy:history": "node scripts/pm2-deployer.js history",
    
    "dev:full": "concurrently \"npm run pm2:start:monitor\" \"npm run pm2:start:watcher\" \"npm run pm2:start:manager\" \"npm run pm2:dev\"",
    "dev:monitored": "concurrently \"npm run pm2:start:monitor\" \"npm run pm2:dev\"",
    "dev:watched": "concurrently \"npm run pm2:start:watcher\" \"npm run pm2:dev\"",
    
    "setup:pm2": "npm install -g pm2 && pm2 install pm2-logrotate && pm2 set pm2-logrotate:max_size 10M && pm2 set pm2-logrotate:retain 30",
    "setup:logs": "mkdir -p logs backups",
    "setup:all": "npm run setup:logs && npm run setup:pm2",
    
    "health:check": "node scripts/pm2-monitor.js --health-check",
    "health:report": "node scripts/pm2-monitor.js --generate-report",
    "performance:analyze": "node scripts/pm2-manager.js --analyze",
    "performance:optimize": "node scripts/pm2-manager.js --optimize",
    
    "clean:logs": "rm -rf logs/*.log logs/*.json",
    "clean:backups": "rm -rf backups/*",
    "clean:all": "npm run clean:logs && npm run clean:backups",
    
    "backup:create": "mkdir -p backups && cp -r dist backups/dist-$(date +%Y%m%d-%H%M%S) && cp -r server/dist backups/server-dist-$(date +%Y%m%d-%H%M%S)",
    "backup:restore": "echo 'Please specify backup directory: npm run backup:restore <backup-dir>'",
    
    "scale:frontend": "pm2 scale zion-frontend-prod",
    "scale:backend": "pm2 scale zion-backend-prod",
    "scale:auto": "node scripts/pm2-manager.js --auto-scale",
    
    "logs:frontend": "pm2 logs zion-frontend-dev --lines 100",
    "logs:backend": "pm2 logs zion-backend-dev --lines 100",
    "logs:monitor": "pm2 logs zion-monitor-dev --lines 100",
    "logs:watcher": "pm2 logs zion-build-watcher --lines 100",
    
    "restart:frontend": "pm2 restart zion-frontend-dev",
    "restart:backend": "pm2 restart zion-backend-dev",
    "restart:monitor": "pm2 restart zion-monitor-dev",
    "restart:watcher": "pm2 restart zion-build-watcher",
    
    "update:ecosystem": "pm2 reload ecosystem.config.cjs",
    "update:all": "npm run update:ecosystem && pm2 save",
    
    "test:pm2": "pm2 start ecosystem.config.cjs --env development && sleep 10 && pm2 status && pm2 stop all && pm2 delete all",
    "test:deployment": "npm run deploy:staging && npm run deploy:production",
    "test:monitoring": "npm run pm2:start:monitor && sleep 30 && npm run health:report && pm2 stop zion-monitor && pm2 delete zion-monitor"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-aspect-ratio": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@reduxjs/toolkit": "^2.8.2",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query": "^5.85.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "d3-color": "^3.1.0",
    "d3-format": "^3.1.0",
    "d3-path": "^3.1.0",
    "d3-time-format": "^4.1.0",
    "date-fns": "^2.30.0",
    "framer-motion": "^10.16.4",
    "i18next": "^25.4.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.294.0",
    "postcss-preset-env": "^10.3.1",
    "react": "^18.2.0",
    "react-day-picker": "^8.9.1",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.0.0",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.47.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^15.7.2",
    "react-redux": "^9.2.0",
    "react-remove-scroll-bar": "^2.3.8",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.8.0",
    "tailwind-merge": "^2.0.0",
    "use-callback-ref": "^1.3.3",
    "use-sidecar": "^1.1.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.8.10",
    "@types/react": "^18.2.33",
    "@types/react-dom": "^18.2.14",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "cssnano": "^7.1.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.5",
    "pm2": "^6.0.8",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "terser": "^5.43.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.19"
  }
}
