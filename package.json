{
  "name": "ziontechgroup-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:netlify": "node scripts/build-with-error-handling.js",
    "prebuild": "echo \"Starting build...\"",
    "export": "vite build",
    "start": "vite preview --port 4173",
    "postbuild": "echo \"Build completed\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:check": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "test:smoke": "jest --config jest.config.smoke.cjs --passWithNoTests",
    "test:watch": "jest --watch --config jest.config.ts",
    "test:coverage": "jest --coverage --config jest.config.ts",
    "verify": "npm run type-check && npm run build && npm run test:smoke",
    "check": "npm run lint && npm run type-check && npm run test:smoke",
    "clean": "rm -rf .next out dist",
    "precommit": "npm run check",
    "prepare": "echo 'Husky prepare script disabled'"
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "framer-motion": "^10.18.0",
    "lucide-react": "^0.536.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.8.2"
  },
  "devDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.50.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jest": "^29.7.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
