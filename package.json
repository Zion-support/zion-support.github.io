{
  "name": "bolt.new.zion.app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=\"--max-old-space-size=4096 --openssl-legacy-provider\" vite",
    "dev:backend": "cd server && npm run dev",
    "dev:hybrid": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "build": "NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "build:backend": "cd server && npm run build",
    "build:hybrid": "npm run build && npm run build:backend",
    "prebuild": "echo 'skip prebuild health-check'",
    "export": "rm -rf dist && NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "start": "vite preview",
    "start:backend": "cd server && npm start",
    "start:hybrid": "cd server && npm start",
    "postbuild": "echo 'Build completed successfully'",
    "lint": "eslint .",
    "lint:backend": "cd server && npm run lint",
    "lint:all": "npm run lint && npm run lint:backend",
    "type-check": "tsc --noEmit",
    "type-check:backend": "cd server && npm run type-check",
    "type-check:all": "npm run type-check && npm run type-check:backend",
    "prepare": "git config core.hooksPath .husky || true",
    "fix:all": "npm run lint --fix || true",
    "install:all": "npm install && cd server && npm install",
    
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:reload": "pm2 reload ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit",
    
    "automation:start": "pm2 start ecosystem.config.cjs --only automation",
    "automation:stop": "pm2 stop ecosystem.config.cjs --only automation",
    "automation:restart": "pm2 restart ecosystem.config.cjs --only automation",
    "automation:status": "pm2 status --only automation",
    "automation:logs": "pm2 logs --only automation",
    
    "intelligent:start": "pm2 start ai-code-quality intelligent-dev-workflow advanced-performance-monitor",
    "intelligent:stop": "pm2 stop ai-code-quality intelligent-dev-workflow advanced-performance-monitor",
    "intelligent:restart": "pm2 restart ai-code-quality intelligent-dev-workflow advanced-performance-monitor",
    "intelligent:status": "pm2 status ai-code-quality intelligent-dev-workflow advanced-performance-monitor",
    "intelligent:logs": "pm2 logs ai-code-quality intelligent-dev-workflow advanced-performance-monitor",
    
    "quality:analyze": "node scripts/automation/ai-code-quality-automation.cjs",
    "quality:report": "cat ai-quality-reports/quality-summary.json",
    "quality:full-report": "cat ai-quality-reports/quality-report.txt",
    
    "workflow:analyze": "node scripts/automation/intelligent-dev-workflow.cjs",
    "workflow:report": "cat dev-workflow-reports/workflow-summary.json",
    "workflow:full-report": "cat dev-workflow-reports/workflow-report.txt",
    
    "performance:monitor": "node scripts/automation/advanced-performance-monitor.cjs",
    "performance:report": "cat performance-reports/performance-summary.json",
    "performance:full-report": "cat performance-reports/performance-report.txt",
    
    "reports:all": "npm run quality:report && echo '---' && npm run workflow:report && echo '---' && npm run performance:report",
    "reports:full": "npm run quality:full-report && echo '---' && npm run workflow:full-report && echo '---' && npm run performance:full-report",
    
    "health:check": "pm2 status && echo '---' && npm run reports:all",
    "health:full": "pm2 status && echo '---' && npm run reports:full"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-aspect-ratio": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@reduxjs/toolkit": "^2.8.2",
    "@tanstack/react-query": "^5.85.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "d3-color": "^3.1.0",
    "d3-format": "^3.1.0",
    "d3-path": "^3.1.0",
    "d3-time-format": "^4.1.0",
    "date-fns": "^2.30.0",
    "framer-motion": "^10.16.4",
    "i18next": "^25.4.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-day-picker": "^8.9.1",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.0.0",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.47.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^15.7.2",
    "react-redux": "^9.2.0",
    "react-remove-scroll-bar": "^2.3.8",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.8.0",
    "tailwind-merge": "^2.0.0",
    "use-callback-ref": "^1.3.3",
    "use-sidecar": "^1.1.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.8.10",
    "@types/react": "^18.2.33",
    "@types/react-dom": "^18.2.14",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "cssnano": "^7.1.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "terser": "^5.43.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.19"
  }
}
