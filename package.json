{
  "name": "zion-website",
  "version": "1.0.0",
  "description": "Zion Tech Group - Advanced AI and IT Solutions Website",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:no-check": "vite build",
    "build:prod": "NODE_ENV=production vite build",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 200",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "analyze": "npx vite-bundle-analyzer dist/stats.html --open=false",
    "build:analyze-bundle": "vite build --mode analyze && npx vite-bundle-analyzer dist/stats.html",
    "serve": "vite preview --port 3000",
    "clean": "rm -rf dist node_modules/.vite",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "build:production": "NODE_ENV=production pnpm run build:minimal",
    "build:fast": "vite build --mode development",
    "build:optimized": "NODE_ENV=production vite build --minify terser --sourcemap false",
    "build:minimal": "NODE_ENV=production vite build --minify terser --sourcemap false",
    "prebuild": "pnpm lint",
    "postbuild": "if [ \"$CI\" != \"true\" ]; then pnpm analyze; fi",
    "performance:audit": "lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html",
    "performance:check": "pnpm build && pnpm serve & sleep 5 && pnpm performance:audit",
    "optimize": "node scripts/optimize-build.js",
    "build:netlify": "pnpm run build:no-check",
    "build:ci": "pnpm run lint && pnpm run build:no-check && pnpm run test:ci",
    "health-check": "pnpm run type-check && pnpm run lint && pnpm run build:no-check",
    "preview:optimized": "vite preview --port 3000 --host",
    "audit:performance": "lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html",
    "optimize:images": "node scripts/optimize-images.js",
    "optimize:css": "node scripts/optimize-css.js",
    "optimize:all": "pnpm run optimize:images && pnpm run optimize:css && pnpm run build:optimized",
    "build:performance": "NODE_ENV=production vite build --mode performance",
    "analyze:bundle": "vite-bundle-analyzer dist/stats.html",
    "test:performance": "lighthouse http://localhost:3000 --output=html --output-path=./performance-report.html",
    "audit:security": "npm audit --audit-level=moderate",
    "preload:critical": "echo \"Preloading critical resources...\"",
    "optimize:advanced": "node scripts/advanced-performance-optimizer.js",
    "audit:accessibility": "echo \"Running accessibility audit...\"",
    "audit:seo": "echo \"Running SEO audit...\"",
    "audit:all": "pnpm run audit:accessibility && pnpm run audit:seo && pnpm run audit:security",
    "analyze:performance": "node scripts/performance-optimizer.js"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.13",
    "axios": "^1.12.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.22",
    "lucide-react": "^0.544.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.4",
    "react-router-dom": "^7.9.3",
    "recharts": "^3.2.1",
    "tailwind-merge": "^3.3.1",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.14",
    "@types/react-dom": "^19.1.9",
    "@types/react-helmet": "^6.1.11",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.0",
    "prettier": "^3.2.5",
    "rollup-plugin-visualizer": "^6.0.3",
    "tailwindcss": "^4.1.13",
    "terser": "^5.31.0",
    "ts-jest": "^29.4.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.1",
    "vite-bundle-analyzer": "^1.2.3"
  },
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "keywords": [
    "react",
    "typescript",
    "vite",
    "tailwindcss",
    "ai",
    "it-solutions",
    "website"
  ],
  "author": "Zion Tech Group",
  "license": "MIT"
}