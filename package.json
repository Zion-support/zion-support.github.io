{
  "name": "bolt.new.zion.app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS='--max-old-space-size=4096 --openssl-legacy-provider' next build --no-lint",
    "start": "next start",
    "lint": "eslint app components pages src hooks lib --no-error-on-unmatched-pattern",
    "build:analyze": "ANALYZE=true npm run build",
    "build:clean": "rm -rf .next && npm run build",
    "dev:clean": "rm -rf .next && npm run dev",
    "lint:fix": "eslint app components pages src hooks lib --fix --no-error-on-unmatched-pattern",
    "type-check": "NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit",
    "test": "jest -c jest.config.smoke.cjs --runInBand --passWithNoTests --no-cache",
    "test:watch": "jest -c jest.config.smoke.cjs --watch --runInBand",
    "preview": "npm run build && npm run start",
    "test:coverage": "jest -c jest.config.smoke.cjs --coverage",
    "clean": "rm -rf .next out dist build",
    "export": "npm run build && next export",
    "deploy": "npm run build && npm run export",
    "postinstall": "echo 'Type-check skipped (non-blocking)'",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@netlify/plugin-nextjs": "^5.13.3",
    
    "autoprefixer": "^10.4.21",
    "axios": "^1.11.0",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.536.0",
    "next": "^15.5.3",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "openai": "^5.11.0",
    "path": "^0.12.7",
    "react": "^19.1.1",
    "react-datepicker": "^8.4.0",
    "react-dom": "^19.1.1",
    "react-error-boundary": "^4.0.11",
    "sonner": "^2.0.7",
    "swr": "^2.3.6",
    "tailwind-merge": "^3.3.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-transform-runtime": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@eslint/js": "^9.36.0",
    "@headlessui/react": "^2.2.8",
    "@next/bundle-analyzer": "^14.2.0",
    "@next/swc-linux-x64-gnu": "^15.5.3",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "12.1.5",
    "@types/jest": "^29.0.0",
    "@types/node": "^16.18.126",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "babel-jest": "^29.7.0",
    "critters": "^0.0.23",
    "eslint": "^9.36.0",
    "eslint-config-next": "^14.0.0",
    "eslint-plugin-jest-dom": "^4.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.21",
    "eslint-plugin-testing-library": "^6.0.0",
    "globals": "^16.4.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1"
  },
  "packageManager": "npm@11.6.0"
}
