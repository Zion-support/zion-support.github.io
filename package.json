{
  "name": "bolt.new.zion.app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS='--max-old-space-size=4096 --openssl-legacy-provider' next build --no-lint",
    "start": "next start",
    "lint": "next lint",
    "build:analyze": "ANALYZE=true npm run build",
    "build:clean": "rm -rf .next && npm run build",
    "dev:clean": "rm -rf .next && npm run dev",
    "lint:fix": "next lint --fix",
    "type-check": "NODE_OPTIONS='--max-old-space-size=4096' tsc --noEmit",
    "test": "jest --runInBand --passWithNoTests --no-cache",
    "test:watch": "jest --watch --runInBand",
    "preview": "npm run build && npm run start",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf .next node_modules/.cache",
    "export": "npm run build && next export",
    "deploy": "npm run build && npm run export",
    "postinstall": "npm run type-check || echo 'Type-check skipped (non-blocking)'"
  },
  "dependencies": {
    "@netlify/plugin-nextjs": "^5.13.3",
    "@types/react": "^17.0.88",
    "@types/react-dom": "^17.0.26",
    "autoprefixer": "^10.4.21",
    "axios": "^1.11.0",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.536.0",
    "next": "^14.2.31",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "openai": "^5.11.0",
    "path": "^0.12.7",
    "react": "^18.3.0",
    "react-datepicker": "^8.4.0",
    "react-dom": "^18.3.0",
    "react-error-boundary": "^4.0.11",
    "sonner": "^2.0.7",
    "swr": "^2.3.6",
    "tailwind-merge": "^3.3.1",
    "uuid": "^11.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^16.18.126",
    "critters": "^0.0.23",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "eslint-plugin-jest-dom": "^4.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-testing-library": "^6.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.0",
    "typescript": "^4.9.5"
  },
  "packageManager": "npm@11.6.0+sha512.77f3fb0dbbd881835d7bd1217deabdf7ed77fc4ec4f363df64fc3cb986404abf6c437661041080f5c5d225103508e7c9ea30cb2742b7e942675d05a10af2d7b9"
}
