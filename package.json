{
  "name": "bolt.new.zion.app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=\"--max-old-space-size=4096 --openssl-legacy-provider\" vite",
    "dev:backend": "cd server && npm run dev",
    "dev:hybrid": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "build": "NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "build:backend": "cd server && npm run build",
    "build:hybrid": "npm run build && npm run build:backend",
    "prebuild": "echo 'skip prebuild health-check'",
    "export": "rm -rf dist && NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "start": "vite preview",
    "start:backend": "cd server && npm start",
    "start:hybrid": "cd server && npm start",
    "postbuild": "echo 'Build completed successfully'",
    "lint": "eslint .",
    "lint:backend": "cd server && npm run lint",
    "lint:all": "npm run lint && npm run lint:backend",
    "type-check": "tsc --noEmit",
    "type-check:backend": "cd server && npm run type-check",
    "type-check:all": "npm run type-check && npm run type-check:backend",
    "prepare": "git config core.hooksPath .husky || true",
    "fix:all": "npm run lint --fix || true",
    "install:all": "npm install && cd server && npm install",
    "preview": "vite preview",
    "lint:fix": "node scripts/pm2/lint-fixer.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "pm2:monit": "pm2 monit",
    "quality:check": "node scripts/pm2/code-quality-monitor.js",
    "quality:fix": "node scripts/pm2/lint-fixer.js && node scripts/pm2/auto-commit-fixes.js",
    "deps:check": "node scripts/pm2/dependency-monitor.js",
    "perf:check": "node scripts/pm2/performance-monitor.js",
    "automation:setup": "npm run pm2:start && echo 'PM2 automation processes started successfully!'",
    "automation:stop": "npm run pm2:stop && echo 'PM2 automation processes stopped successfully!'",
    "automation:orchestrate": "node scripts/automation/intelligent-automation-orchestrator.cjs",
    "automation:ai-quality": "node scripts/automation/ai-code-quality-enhancer.cjs",
    "automation:performance": "node scripts/automation/intelligent-performance-optimizer.cjs",
    "automation:security": "node scripts/automation/smart-security-compliance-monitor.cjs",
    "automation:health": "node scripts/automation/project-health-monitor.cjs",
    "automation:syntax": "node scripts/automation/typescript-syntax-fixer.cjs",
    "automation:deps": "node scripts/automation/dependency-manager.cjs",
    "automation:dashboard": "node scripts/automation/project-health-dashboard.cjs",
    "automation:start-all": "npm run automation:orchestrate && echo 'All intelligent automations started!'",
    "automation:status": "pm2 list | grep -E '(ai-code-quality|intelligent-performance|smart-security|project-health|typescript-syntax|dependency-manager|project-health-dashboard)'",
    "automation:logs": "pm2 logs --lines 100 | grep -E '(ai-code-quality|intelligent-performance|smart-security|project-health|typescript-syntax|dependency-manager|project-health-dashboard)'",
    "automation:restart-all": "pm2 restart ai-code-quality-enhancer intelligent-performance-optimizer smart-security-compliance-monitor project-health-monitor typescript-syntax-fixer dependency-manager project-health-dashboard && echo 'All automations restarted!'",
    "automation:monitor": "pm2 monit",
    "automation:generate-reports": "npm run automation:ai-quality && npm run automation:performance && npm run automation:security && npm run automation:health && echo 'All automation reports generated!'",
    "automation:view-dashboards": "echo 'Opening automation dashboards...' && open ./logs/ai-quality-dashboard/index.html ./logs/performance-dashboard/index.html ./logs/security-dashboard/index.html ./logs/health-dashboard/index.html ./logs/orchestration-dashboard/index.html"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-aspect-ratio": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@reduxjs/toolkit": "^2.8.2",
    "@tanstack/react-query": "^5.85.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "d3-color": "^3.1.0",
    "d3-format": "^3.1.0",
    "d3-path": "^3.1.0",
    "d3-time-format": "^4.1.0",
    "date-fns": "^2.30.0",
    "framer-motion": "^10.16.4",
    "i18next": "^25.4.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-day-picker": "^8.9.1",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.0.0",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.47.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^15.7.2",
    "react-redux": "^9.2.0",
    "react-remove-scroll-bar": "^2.3.8",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.8.0",
    "tailwind-merge": "^2.0.0",
    "use-callback-ref": "^1.3.3",
    "use-sidecar": "^1.1.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.8.10",
    "@types/react": "^18.2.33",
    "@types/react-dom": "^18.2.14",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "cssnano": "^7.1.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "terser": "^5.43.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.19"
  }
}
