{
  "name": "zion-app",
  "version": "1.0.0",
  "description": "ZionTechGroup - Comprehensive IT, AI, and Micro SaaS Solutions",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint . --max-warnings 1000",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "test:smoke": "jest --config jest.config.smoke.cjs",
    "clean": "rm -rf .next out dist",
    "check": "npm run lint && npm run type-check && npm run test:smoke",
    "pm2:start": "pm2 start ecosystem.config.cjs --update-env",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs --lines 200"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10.4.16",
    "bs58": "^5.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.32",
    "ethers": "^6.8.1",
    "framer-motion": "^10.16.16",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.294.0",
    "next": "^14.0.0",
    "next-themes": "^0.2.1",
    "postcss": "^8.4.32",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-hook-form": "^7.48.2",
    "react-hot-toast": "^2.4.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.0",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^13.4.0",
    "@types/bs58": "^4.0.4",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  }
}
