{
  "name": "operator-reminder-workflow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "zion": "scripts/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Zion-Holdings/zion.app.git"
  },
  "bugs": {
    "url": "https://github.com/Zion-Holdings/zion.app/issues"
  },
  "homepage": "https://github.com/Zion-Holdings/zion.app#readme",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.18.1",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "NODE_ENV=production vite build --mode analyze",
    "build:preview": "npm run build && npm run preview",
    "build:optimize": "npm run build && npm run optimize",
    "build:analyze:open": "npm run build:analyze && open dist/stats.html",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "preview": "NODE_ENV=production vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:accessibility": "vitest run tests/Accessibility.test.tsx",
    "test:performance": "vitest run tests/Performance.test.tsx",
    "test:security": "vitest run tests/Security.test.tsx",
    "test:seo": "vitest run tests/SEO.test.tsx",
    "test:pwa": "vitest run tests/PWA.test.tsx",
    "test:integration": "vitest run tests/integration/",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:accessibility && npm run test:performance && npm run test:security",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run --browser chrome",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist node_modules/.vite",
    "prebuild": "echo 'Skipping type-check and lint for build compatibility'",
    "postbuild": "echo 'Build completed successfully' && npm run optimize",
    "optimize": "node scripts/optimize-build.js",
    "audit:accessibility": "node scripts/accessibility-audit.js",
    "audit:performance": "node scripts/performance-audit.js",
    "audit:security": "node scripts/security-audit.js",
    "audit:seo": "node scripts/seo-audit.js",
    "audit:all": "npm run audit:accessibility && npm run audit:performance && npm run audit:security && npm run audit:seo",
    "generate:manifest": "node scripts/generate-manifest.js",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "generate:robots": "node scripts/generate-robots.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-toast": "^1.1.5",
    "@reduxjs/toolkit": "^2.8.2",
    "@reown/appkit": "latest",
    "@reown/appkit-adapter-ethers": "latest",
    "@supabase/supabase-js": "^2.39.3",
    "@tanstack/react-query": "^5.17.19",
    "@types/lodash.debounce": "^4.0.9",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "embla-carousel-react": "^8.0.0-rc19",
    "ethers": "^6.14.3",
    "framer-motion": "^11.0.3",
    "html2canvas": "^1.4.1",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^7.2.2",
    "input-otp": "^1.1.0",
    "jspdf": "^3.0.1",
    "lucide-react": "^0.323.0",
    "next": "^14.2.32",
    "node-fetch": "*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.4",
    "react-hook-form": "^7.50.1",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^14.1.3",
    "react-markdown": "^4.3.1",
    "react-router-dom": "^6.22.0",
    "rollup-plugin-visualizer": "^2.7.2",
    "socket.io": "^0.9.19",
    "sonner": "^2.0.5",
    "swr": "^2.2.0",
    "tailwind-merge": "^2.2.1",
    "vite": "^6.3.6",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@tanstack/react-query-devtools": "^5.87.3",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.2.1",
    "@types/react": "^17.0.34",
    "@types/react-dom": "17.0.11",
    "@typescript-eslint/eslint-plugin": "^5.8.1",
    "@typescript-eslint/parser": "^3.10.1",
    "@vitejs/plugin-react": "^5.0.2",
    "dotenv": "^17.2.1",
    "eslint": "^0.6.2",
    "eslint-config-next": "^11.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest": "^28.1.0",
    "jsdom": "^16.5.3",
    "msw": "^0.3.1",
    "prettier": "^3.3.3",
    "rollup-plugin-visualizer": "^2.7.2",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.2",
    "vite": "^6.3.6",
    "vitest": "^0.12.6"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
