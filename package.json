{
  "name": "zion-tech-group",
  "version": "1.0.0",
  "description": "Zion Tech Group - Advanced AI & Technology Solutions",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096 --openssl-legacy-provider\" vite",
    "build": "cross-env NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "build:analyze": "cross-env NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build --mode analyze",
    "build:prod": "cross-env NODE_ENV=production NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "preview": "vite preview",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "export": "rimraf dist && cross-env NODE_OPTIONS=\"--max-old-space-size=6144 --openssl-legacy-provider\" vite build",
    "analyze": "npm run build:analyze && npx vite-bundle-analyzer dist",
    "performance": "npm run build:prod && npx lighthouse dist/index.html --output=json --output-path=./lighthouse-report.json",
    "test:performance": "npm run build:prod && npx webpack-bundle-analyzer dist/stats.json",
    "clean": "rimraf dist node_modules/.cache",
    "prebuild": "npm run clean",
    "postbuild": "echo 'Build completed successfully!'"
  },
  "dependencies": {
    "@esbuild/linux-x64": "^0.25.9",
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-aspect-ratio": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@reduxjs/toolkit": "^2.8.2",
    "@rollup/rollup-linux-x64-gnu": "^4.18.0",
    "@stripe/stripe-js": "^7.9.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@tanstack/react-query": "^5.85.5",
    "axios": "^1.11.0",
    "cheerio": "^1.1.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "d3-color": "^3.1.0",
    "d3-format": "^3.1.0",
    "d3-path": "^3.1.0",
    "d3-time-format": "^4.1.0",
    "date-fns": "^2.30.0",
    "esbuild": "^0.21.5",
    "framer-motion": "^10.16.4",
    "i18next": "^25.4.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.47.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.20.0",
    "tailwind-merge": "^2.0.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.5.2",
    "@rollup/rollup-linux-x64-gnu": "^4.49.0",
    "@types/node": "^20.8.10",
    "@types/react": "^18.2.33",
    "@types/react-dom": "^18.2.14",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.1.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "cssnano": "^7.1.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "lighthouse": "^12.8.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "terser": "^5.43.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.19",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^1.3.1"
  },
  "overrides": {
    "rollup": {
      "@rollup/rollup-linux-x64-gnu": "^4.18.0"
    },
    "@esbuild/darwin-x64": "@esbuild/linux-x64",
    "@rollup/rollup-darwin-x64": "@rollup/rollup-linux-x64-gnu"
  },
  "resolutions": {
    "@rollup/rollup-darwin-x64": "@rollup/rollup-linux-x64-gnu",
    "@esbuild/darwin-x64": "@esbuild/linux-x64"
  }
}
