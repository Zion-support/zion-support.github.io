{
  "name": "ziontechgroup-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run --browser chrome",
    "sitemap": "node scripts/generate-sitemap.js",
    "links:scan": "node automation/site-link-crawler.cjs && node automation/site-link-fixer.cjs",
    "footer:inject": "node automation/footer-injector.cjs",
    "readme:generate": "node scripts/generate-readme.js",
    "analyze:site": "node website-analyzer.js --url https://ziontechgroup.com --max-depth 4 --output zion-live-crawl.json"
  },
