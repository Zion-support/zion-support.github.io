{
  "name": "operator-reminder-workflow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "zion": "scripts/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zion-Holdings/zion.app.git"
  },
  "keywords": [
    "zion",
    "tech",
    "services",
    "marketplace",
    "ai",
    "blockchain",
    "web3",
    "react",
    "vite",
    "typescript"
  ],
  "author": "Zion Holdings <contact@ziontechgroup.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Zion-Holdings/zion.app/issues"
  },
  "homepage": "https://ziontechgroup.com",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.18.1",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "ROLLUP_SKIP_NODEJS_NATIVE=true NODE_ENV=production SKIP_TYPE_CHECK=true vite build --logLevel info",
    "build:ci": "DEBUG=vite:build ROLLUP_SKIP_NODEJS_NATIVE=true NODE_ENV=production SKIP_TYPE_CHECK=true vite build --logLevel info",
    "build:analyze": "ANALYZE=true vite build",
    "build:preview": "npm run build && npm run start",
    "analyze:bundle": "node scripts/bundle-analyzer.js",
    "analyze:detailed": "npm run build && npm run analyze:bundle",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "start": "next start",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "performance": "node scripts/performance-monitor.cjs",
    "analyze": "npm run build && npm run performance",
    "analyze:performance": "node scripts/performance-optimizer.js",
    "test:comprehensive": "node scripts/comprehensive-test.cjs",
    "test:all": "npm run test:comprehensive",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run --browser chrome",
    "test:accessibility": "vitest run tests/Accessibility.test.tsx",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist node_modules/.vite",
    "prebuild": "echo 'Skipping prebuild checks'",
    "postbuild": "node scripts/copy-netlify-files.js && echo 'Build completed successfully' && node -e \"if(!(process.env.CI==='true'||process.env.NETLIFY==='true')){process.exit(1)}\" || npm run optimize",
    "optimize": "node scripts/optimize-build.js",
    "optimize:advanced": "node scripts/advanced-optimize.js",
    "build:optimize": "npm run build && npm run optimize",
    "build:advanced": "npm run build && npm run optimize:advanced",
    "postinstall": "npm rebuild rollup @rollup/rollup-linux-x64-gnu || true",
    "deploy": "npm run build && netlify deploy --prod",
    "deploy:preview": "npm run build && netlify deploy",
    "health": "curl -f https://ziontechgroup.com/api/health || exit 1",
    "validate": "npm run type-check && npm run lint && npm run build:ci"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.26.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.1",
    "@netlify/functions": "^4.2.5",
    "@prisma/client": "^6.15.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "@reduxjs/toolkit": "^2.8.2",
    "@reown/appkit": "latest",
    "@reown/appkit-adapter-ethers": "latest",
    "@sendgrid/mail": "^8.1.5",
    "@stripe/react-stripe-js": "^4.0.1",
    "@stripe/stripe-js": "^7.9.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.39.3",
    "@tanstack/react-query": "^5.17.19",
    "ajv": "^8.17.1",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.3.1",
    "embla-carousel-react": "^8.0.0-rc19",
    "ethers": "^6.14.3",
    "file-saver": "^2.0.5",
    "framer-motion": "^11.18.2",
    "html2canvas": "^1.4.1",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^7.2.2",
    "input-otp": "^1.1.0",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.323.0",
    "micro": "^10.0.1",
    "mongoose": "^8.18.1",
    "next": "^14.2.32",
    "next-auth": "^4.24.11",
    "next-cloudinary": "^6.16.0",
    "node-cache": "^5.1.2",
    "node-fetch": "*",
    "react": "^18.2.0",
    "react-day-picker": "^9.9.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.0.0",
    "react-helmet-async": "^2.0.4",
    "react-hook-form": "^7.50.1",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^14.1.3",
    "react-markdown": "^4.3.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.22.0",
    "react-window": "^2.1.0",
    "socket.io": "^0.9.19",
    "sonner": "^2.0.5",
    "string-replace-loader": "^3.2.0",
    "swr": "^2.2.0",
    "tailwind-merge": "^2.6.0",
    "uuid": "^11.1.0",
    "web-push": "^3.6.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@rollup/rollup-linux-x64-gnu": "4.50.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.2.1",
    "@types/react": "^17.0.34",
    "@types/react-dom": "17.0.11",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@typescript-eslint/eslint-plugin": "^5.8.1",
    "@typescript-eslint/parser": "^8.39.0",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "cssnano": "^7.1.1",
    "dotenv": "^17.2.1",
    "eslint": "^0.6.2",
    "eslint-config-next": "^11.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "jest": "^25.0.0",
    "jest-axe": "^3.1.1",
    "jsdom": "^16.5.3",
    "msw": "^0.3.1",
    "postcss": "^8.5.6",
    "prettier": "^3.3.3",
    "rollup-plugin-visualizer": "^2.7.2",
    "tailwindcss": "^3.4.17",
    "terser": "^5.44.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.33.0",
    "vite": "^6.3.6",
    "vitest": "^0.12.6"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
