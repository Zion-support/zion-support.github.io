  "scripts": {
    "ci:preflight": "node -e \"try{require('fs').accessSync('dist');console.log('dist exists')}catch(e){process.exit(0)}\" && echo prebuilt || echo building",
    "ci:build-test": "npm run build && npm run test:smoke",
    "dev": "next dev",
    "build": "node --max-old-space-size=8192 ./node_modules/.bin/next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "node --max-old-space-size=8192 ./node_modules/.bin/tsc --noEmit",
    "build:netlify": "node scripts/build-with-error-handling.js",
    "prebuild": "echo \"Starting build...\"",
    "postbuild": "echo \"Build completed\"",
    "test": "jest --config jest.config.cjs",
    "test:smoke": "jest --config jest.config.smoke.cjs --passWithNoTests",
    "test:watch": "jest --watch --config jest.config.ts",
    "test:coverage": "jest --coverage --config jest.config.ts",
    "verify": "npm run type-check && npm run build && npm run test:smoke",
    "check": "npm run lint && npm run type-check && npm run test:smoke",
    "clean": "rm -rf .next out dist",
    "precommit": "npm run check",
    "prepare": "echo 'Husky prepare script disabled'",
    "sitemap": "node scripts/generate-sitemap.js",
    "automation:master": "node automation/master-orchestrator.cjs",
    "automation:performance": "node automation/performance-optimizer.cjs",
    "automation:seo": "node automation/seo-optimizer.cjs",
