{
  "name": "zion-tech-group",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --fix .",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --watchAll=false",
    "analyze": "ANALYZE=true next build",
    "build:analyze": "npm run build && npx @next/bundle-analyzer",
    "perf": "node scripts/performance-check.js",
    "optimize": "npm run build && npm run perf",
    "check-deps": "npx depcheck",
    "audit": "npm audit --audit-level moderate",
    "build:prod": "NODE_ENV=production next build",
    "start:prod": "NODE_ENV=production next start",
    "build:production": "NODE_ENV=production npm run build",
    "build:clean": "rm -rf .next && npm run build",
    "build:check": "npm run type-check && npm run lint && npm run build",
    "dev:clean": "rm -rf .next && npm run dev",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "lint:check": "eslint . --max-warnings 0",
    "type-check:strict": "tsc --noEmit --strict",
    "precommit": "npm run type-check && npm run lint && npm run test:ci",
    "postinstall": "npm run type-check",
    "improve": "node comprehensive-improvements.js",
    "security-audit": "npm audit --audit-level moderate && npm run lint:check",
    "performance-audit": "npm run build && npm run perf",
    "accessibility-audit": "npm run build && npx @axe-core/cli http://localhost:3000",
    "full-audit": "npm run security-audit && npm run performance-audit && npm run accessibility-audit"
  },
  "dependencies": {
    "@storybook/react-vite": "^10.0.0",
    "@tailwindcss/postcss": "^4.1.16",
    "autoprefixer": "^10.4.21",
    "clsx": "^2.1.1",
    "eslint-config-next": "^16.0.0",
    "glob": "^11.0.3",
    "lucide-react": "^0.544.0",
    "next": "^15.5.4",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.9.4",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.16"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.37.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.0",
    "@types/react": "^18.3.26",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.37.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.23",
    "globals": "13.24.0",
    "jest": "^30.2.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "sharp": "^0.34.4",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
