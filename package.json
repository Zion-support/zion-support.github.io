{
  "name": "bolt.new.zion.app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "ci:install": "npm ci",
    "ci:lint": "npm run lint",
    "ci:type-check": "npm run type-check",
    "ci:build": "npm run build",
    "ci:test": "npm test --if-present",
    "ci:audit": "npm audit --audit-level=moderate",
    "ci:outdated": "npm outdated",
    "ci:full": "npm run ci:install && npm run ci:lint && npm run ci:type-check && npm run ci:build && npm run ci:test && npm run ci:audit",
    "quality:lint": "npm run lint",
    "quality:type-check": "npm run type-check",
    "quality:build": "npm run build",
    "quality:audit": "npm audit --audit-level=moderate",
    "quality:outdated": "npm outdated",
    "quality:full": "npm run quality:lint && npm run quality:type-check && npm run quality:build && npm run quality:audit",
    "test:unit": "npm test --if-present",
    "test:build": "npm run build",
    "test:verify": "npm run test:build && npm run test:unit",
    "dev:start": "npm run dev",
    "dev:build": "npm run build",
    "dev:preview": "npm run preview",
    "prod:build": "npm run build",
    "prod:start": "npm run preview",
    "prod:deploy": "npm run prod:build && pm2 start ecosystem.config.js --env production"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@reduxjs/toolkit": "^2.8.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^10.16.4",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.0.0",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.62.0",
    "react-i18next": "^15.7.3",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.20.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.12.1",
    "@next/bundle-analyzer": "^13.5.6",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^13.4.0",
    "@types/node": "24.3.0",
    "@types/react": "19.1.12",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "cssnano": "^7.1.1",
    "eslint": "^8.51.0",
    "eslint-config-next": "^13.5.6",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.5",
    "postcss": "^8.4.31",
    "postcss-preset-env": "^10.3.1",
    "prettier": "^3.0.3",
    "tailwindcss": "^3.3.5",
    "terser": "^5.43.1",
    "typescript": "5.9.2",
    "vite": "^7.1.3"
  }
