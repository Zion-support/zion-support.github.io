  logStep('automation:guardian', () => runNode('automation/automation-guardian-10min.cjs'));

  // Attempt to push any changes
  logStep('git:sync', () => runNode('automation/advanced-git-sync.cjs'));

  return { statusCode: 200, body: logs.join('\n') };
};