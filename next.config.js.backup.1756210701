  webpack: (config, { dev, isServer, webpack }) => {
    // Exclude contracts directory from webpack build
    config.resolve.alias = {
      ...config.resolve.alias,
      'contracts': false,
    };
    
    config.module.rules.push({
      test: /\.sol$/,
      use: 'ignore-loader'
