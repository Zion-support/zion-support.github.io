# Force npm usage and prevent Yarn detection
# This file explicitly tells npm to be the only package manager
package-manager=npm
engine-strict=false
fund=false
audit=false
update-notifier=false
prefer-offline=true
ignore-scripts=true
optional=false
legacy-peer-deps=true
strict-ssl=false
build-from-source=false
platform=linux
arch=x64
target-platform=linux
target-arch=x64
