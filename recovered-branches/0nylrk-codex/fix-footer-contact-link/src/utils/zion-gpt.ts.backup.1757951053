  purpose: string,
  active: boolean;
}
// Get the latest active model ID for a specific purpose;
export async function getActiveModelId (purpose: 'job' | 'resume' | 'support'): Promise < ModelVersion> {
  try {
    const { data, error } = await supabase;
      .from ('model_versions');
      .select ('id');
      .eq ('purpose', purpose);
      .eq ('active', true);
      .order ('version', { ascending: false });
      .limit (1);
      .single ();
;
