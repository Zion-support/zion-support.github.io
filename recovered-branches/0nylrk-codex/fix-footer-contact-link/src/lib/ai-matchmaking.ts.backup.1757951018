      matchedSkills:item.skills?.slice(0, 2) || [],;
      reason:`This ${item.category.split(' - ')[0].toLowerCase()} matches your needs based on the provided description.`;
    })),;
    ;
    // Sort by score;
    return matches.sort((a, b) => b.score - a.score).slice(0, limit),;
