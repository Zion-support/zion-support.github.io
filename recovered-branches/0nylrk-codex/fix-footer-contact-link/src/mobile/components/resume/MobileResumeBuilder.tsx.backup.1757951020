function BasicsStep() {
  return (
    <Card>;
      <CardContent className="p - 4 space - y-4">;
        <div className="space - y-2">;
          <Label html_for="title">Resume Title</Label>;
          <Input id="title" placeholder="e.g. Senior Frontend Developer" />;
