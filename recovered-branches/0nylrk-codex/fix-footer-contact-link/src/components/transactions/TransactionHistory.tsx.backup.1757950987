              size="sm";
              variant={filter === 'escrow' ? 'default' : 'outline'}
              on_click={() => set_filter ('escrow')}
              className={filter === 'escrow' ? 'bg - zion - purple text - white' : 'text - zion - slate - light'}
            >;
              Escrow;
            </Button>;
          </div>;
        </div>;
        {is_loading ? (
          Array (3).fill (0).map ((_, i) => (
