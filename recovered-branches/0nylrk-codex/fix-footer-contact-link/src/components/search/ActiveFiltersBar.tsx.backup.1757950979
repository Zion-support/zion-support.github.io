        </ClickableBadge>
      )}
      
      {selectedProductTypes.map(type => (
        <ClickableBadge 
          key={`type-${type}`}
          className="bg-zion-purple/20 hover:bg-zion-purple/30 text-zion-purple border-none flex items-center gap-1 pl-2"
          onClick={() => onRemoveFilter('productTypes', type)}
