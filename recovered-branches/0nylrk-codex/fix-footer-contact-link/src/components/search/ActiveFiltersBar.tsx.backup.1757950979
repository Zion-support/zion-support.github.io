        </ClickableBadge>
      ))}
      
      {selectedRating !== null && (
        <ClickableBadge 
          className="bg-zion-purple/20 hover:bg-zion-purple/30 text-zion-purple border-none flex items-center gap-1 pl-2"
          onClick={onRemoveRating}
        >
          {selectedRating}+ Stars
          <X className="h-3 w-3" />
        </ClickableBadge>
      )}
    </div>
  );
}
