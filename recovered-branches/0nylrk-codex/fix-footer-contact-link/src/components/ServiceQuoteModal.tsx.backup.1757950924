  description: '';
email: '';
budget: BUDGET RANGES[0].value;
timeframe: TIMELINE OPTIONS[0].value 
});
setStartDate (new Date () );
setEndDate (undefined);
setCurrentStep ('details') 
}catch (error) {
  
}finally {
  setIsSubmitting (false) 
}
};
