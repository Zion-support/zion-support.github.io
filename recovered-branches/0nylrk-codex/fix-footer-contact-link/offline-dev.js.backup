  if (req.url === '/' || req.url === '/index.html') {;
    fs.readFile(path.join(__dirname, 'offline.html'), (err, data) => {;
      if (err) {;
        res.writeHead(500),;
        res.end('Error loading offline.html'),;
        return,;
      }
      res.writeHead(200, { 'Content-Type':'text/html' }),;
      res.end(data),;
