// Mock Next.js router
jest.mock('next/router', () => ({
  useRouter() {
    return {
      route: /',
      pathname: /',
      query: {},
      asPath: /',
      push: jest.fn(),
      pop: jest.fn(),
      reload: jest.fn(),
      back: jest.fn(),
      prefetch: jest.fn().mockResolvedValue(undefined),
      beforePopState: jest.fn(),
      events: {
        on: jest.fn(),
        off: jest.fn(),
        emit: jest.fn()
      },
      isFallback: false
    };
  }
}));

