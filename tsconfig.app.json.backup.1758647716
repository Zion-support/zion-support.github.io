{
  "extends": "./tsconfig.json",
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**",
    "tests/**",
    "automation/**",
    "backups/**",
    "backup*/**",
    "zion-*/**",
    "utils/**",
    "types/**",
    "src.broken/**",
    "temp_*/**"
  ]
}
