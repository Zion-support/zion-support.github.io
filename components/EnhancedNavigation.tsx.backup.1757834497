import React, { useState, useEffect } from 'react';
import Link from 'next/link';

const EnhancedNavigation = () => {
  const [isScrolled, setIsScrolled] = useState(false);
  const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);

  useEffect(() => {
    const handleScroll = () => {
      setIsScrolled(window.scrollY > 50);
    };

    window.addEventListener('scroll', handleScroll);
    return () => window.removeEventListener('scroll', handleScroll);
  }, []);

  const navigationItems = [
    {
      title: 'AI 2025',
      href: '#',
      submenu: [
        { title: 'Ultimate Breakthrough Revolution', href: '/ai-2025-ultimate-breakthrough-revolution' },
        { title: 'Enterprise Automation', href: '/blog/ai-2025-enterprise-automation-revolution' },
        { title: 'Implementation Master Guide', href: '/resources/ai-2025-implementation-master-guide' },
        { title: 'Synthetic Intelligence Guide', href: '/resources/ai-2025-synthetic-intelligence-implementation-guide' }
      ]
    },
    {
      title: 'AI 2026',
      href: '#',
      submenu: [
        { title: 'Quantum-Neural Fusion', href: '/ai-2026-quantum-neural-fusion-revolutionary-breakthrough' },
        { title: 'Future Predictions', href: '/ai-2026-2030-future-predictions-breakthrough' },
        { title: 'Advanced Automation', href: '/ai-2026-advanced-automation-mastery' }
      ]
    },
    {
      title: 'Case Studies',
      href: '/case-studies',
      submenu: [
        { title: 'Global Manufacturing ($2.4B ROI)', href: '/case-studies/ai-2025-global-manufacturing-transformation-breakthrough' },
        { title: 'Fortune 500 Success', href: '/case-studies/ai-2025-fortune-500-transformation-breakthrough' },
        { title: 'Financial Services', href: '/case-studies/ai-2025-global-finance-transformation-breakthrough' }
      ]
    },
    {
      title: 'Resources',
      href: '/resources',
      submenu: [
        { title: 'Implementation Guides', href: '/resources' },
        { title: 'ROI Calculator', href: '/tools/ai-2025-roi-calculator' },
        { title: 'Best Practices', href: '/blog' }
      ]
    }
  ];

  const toggleDropdown = (dropdown: string) => {
    setActiveDropdown(activeDropdown === dropdown ? null : dropdown);
  };

  const closeAllDropdowns = () => {
    setActiveDropdown(null);
    setIsOpen(false);
  };

  return (
    <nav className={`fixed top-0 left-0 right-0 z-50 transition-all duration-300 ${
