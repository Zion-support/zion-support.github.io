import Link from 'next/link';

interface ContentItem {
  id: string;
  title: string;
  description: string;
  type: 'blog' | 'case-study' | 'guide';
  readTime: string;
  metrics: {
    label: string;
    value: string;
  }[];
  href: string;
  featured?: boolean;
}

const contentItems: ContentItem[] = [
  {
    id: 'ai-advanced-automation',
