import React, { useState, useEffect } from 'react';
import Link from 'next/link';

const InteractiveContentDiscoveryWidget2025 = () => {
  const [searchTerm, setSearchTerm] = useState('');
  const [selectedCategory, setSelectedCategory] = useState('all');
  const [isSearching, setIsSearching] = useState(false);
  const [searchResults, setSearchResults] = useState([]);

  const categories = [
    { id: 'all', name: 'All Content', icon: '🌟', count: 247 },
    { id: 'ai', name: 'AI & Machine Learning', icon: '🤖', count: 89 },
    { id: 'quantum', name: 'Quantum Computing', icon: '⚛️', count: 34 },
    { id: 'neural', name: 'Neural Interfaces', icon: '🧠', count: 28 },
    { id: 'business', name: 'Business Solutions', icon: '💼', count: 67 },
    { id: 'automation', name: 'Automation', icon: '⚡', count: 45 },
    { id: 'space', name: 'Space Technology', icon: '🚀', count: 12 }
  ];

  const trendingContent = [
    {
      title: "AI 2025 Ultimate Breakthrough",
      description: "Revolutionary AI innovations transforming industries",
      category: "ai",
      views: "15.2K",
      link: "/ai-2025-ultimate-breakthrough",
      trending: true
    },
    {
      title: "Quantum Neural Fusion 2026",
      description: "Next-generation computational paradigms",
      category: "quantum",
      views: "12.8K",
      link: "/quantum-neural-fusion-2026",
      trending: true
    },
    {
      title: "Autonomous Business Operations",
      description: "Self-managing enterprise systems",
      category: "business",
      views: "9.7K",
      link: "/autonomous-business-operations-2025",
      trending: false
    },
    {
      title: "Neural Interface Revolution",
      description: "Mind-machine integration breakthroughs",
      category: "neural",
      views: "8.3K",
      link: "/neural-interface-2025-breakthrough",
      trending: false
    }
  ];

  const handleSearch = async (term) => {
    if (!term.trim()) return;
    
    setIsSearching(true);
    // Simulate search delay
    setTimeout(() => {
      const filtered = trendingContent.filter(item => 
        item.title.toLowerCase().includes(term.toLowerCase()) ||
        item.description.toLowerCase().includes(term.toLowerCase())
      );
      setSearchResults(filtered);
      setIsSearching(false);
    }, 800);
  };

  useEffect(() => {
    const timeoutId = setTimeout(() => {
      if (searchTerm) {
        handleSearch(searchTerm);
      } else {
        setSearchResults([]);
      }
    }, 300);

    return () => clearTimeout(timeoutId);
  }, [searchTerm]);

const InteractiveContentDiscoveryWidget2025: React.FC = () => {
  return (
    <div className="bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900 rounded-2xl p-6 md:p-8 border border-purple-500/20 shadow-2xl">
      {/* Header */}
      <div className="text-center mb-8">
        <h2 className="text-3xl font-bold text-white mb-2">
          🔍 Interactive Content Discovery
        </h2>
        <p className="text-gray-300">
          Find the perfect content for your needs with our AI-powered search
        </p>
      </div>

      {/* Search Bar */}
      <div className="relative mb-8">
        <div className="flex items-center bg-white/10 backdrop-blur-sm rounded-xl border border-white/20 focus-within:border-purple-400/50 transition-colors">
          <div className="pl-4 pr-2">
            <span className="text-2xl">🔍</span>
          </div>
          <input
            type="text"
            placeholder="Search for AI solutions, quantum tech, neural interfaces..."
            value={searchTerm}
            onChange={(e) => setSearchTerm(e.target.value)}
            className="flex-1 bg-transparent text-white placeholder-gray-400 py-4 px-2 focus:outline-none"
          />
          {isSearching && (
            <div className="pr-4">
              <div className="animate-spin rounded-full h-6 w-6 border-2 border-purple-400 border-t-transparent"></div>
            </div>
          )}
        </div>
      </div>

      {/* Category Filter */}
      <div className="mb-8">
        <h3 className="text-lg font-semibold text-white mb-4">📂 Browse by Category</h3>
        <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
          {categories.map((category) => (
            <button
              key={category.id}
              onClick={() => setSelectedCategory(category.id)}
              className={`p-3 rounded-lg border transition-all duration-300 text-left ${
                selectedCategory === category.id
                  ? 'bg-purple-600/30 border-purple-400/50 text-white'
                  : 'bg-white/5 border-white/20 text-gray-300 hover:bg-white/10 hover:border-white/30'
              }`}
            >
              <div className="flex items-center justify-between">
                <div>
                  <div className="text-lg">{category.icon}</div>
                  <div className="text-sm font-medium">{category.name}</div>
                </div>
                <div className="text-xs bg-white/20 rounded-full px-2 py-1">
                  {category.count}
                </div>
              </div>
            </button>
          ))}
        </div>
      </div>

      {/* Search Results or Trending Content */}
      <div className="mb-8">
        <div className="flex items-center justify-between mb-4">
          <h3 className="text-lg font-semibold text-white">
            {searchResults.length > 0 ? '🔎 Search Results' : '🔥 Trending Now'}
          </h3>
          {searchResults.length > 0 && (
            <button
              onClick={() => {
                setSearchTerm('');
                setSearchResults([]);
              }}
              className="text-sm text-purple-400 hover:text-purple-300 transition-colors"
            >
              Clear search
            </button>
          )}
        </div>

        <div className="space-y-4">
          {(searchResults.length > 0 ? searchResults : trendingContent)
            .filter(item => selectedCategory === 'all' || item.category === selectedCategory)
            .map((item, index) => (
              <Link
                key={index}
                href={item.link}
                className="block group bg-white/5 hover:bg-white/10 backdrop-blur-sm rounded-xl p-4 border border-white/20 hover:border-purple-400/30 transition-all duration-300 hover:scale-[1.02]"
              >
                <div className="flex items-start justify-between">
                  <div className="flex-1">
                    <div className="flex items-center gap-2 mb-2">
                      <h4 className="text-white font-semibold group-hover:text-purple-300 transition-colors">
                        {item.title}
                      </h4>
                      {item.trending && (
                        <span className="text-xs bg-gradient-to-r from-orange-500 to-red-500 text-white px-2 py-1 rounded-full">
                          🔥 Trending
                        </span>
                      )}
                    </div>
                    <p className="text-gray-300 text-sm mb-2">
                      {item.description}
                    </p>
                    <div className="flex items-center gap-4 text-xs text-gray-400">
                      <span>👁️ {item.views} views</span>
                      <span className="capitalize">📂 {item.category}</span>
                    </div>
                  </div>
                  <div className="ml-4 text-purple-400 group-hover:translate-x-1 transition-transform">
                    →
                  </div>
                </div>
              </Link>
            ))}
        </div>
      </div>

      {/* Quick Actions */}
      <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
        <Link
          href="/content-showcase"
          className="bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-700 hover:to-blue-700 text-white font-semibold py-3 px-4 rounded-lg text-center transition-all duration-300 hover:scale-105"
        >
          🎯 View All Content
        </Link>
        <Link
          href="/newsletter"
          className="bg-white/10 hover:bg-white/20 text-white font-semibold py-3 px-4 rounded-lg text-center border border-white/30 hover:border-white/50 transition-all duration-300"
        >
          📧 Get Updates
        </Link>
        <Link
          href="/contact"
          className="bg-white/10 hover:bg-white/20 text-white font-semibold py-3 px-4 rounded-lg text-center border border-white/30 hover:border-white/50 transition-all duration-300"
        >
          💬 Contact Expert
        </Link>
      </div>

      {/* Stats */}
      <div className="mt-8 pt-6 border-t border-white/20">
        <div className="grid grid-cols-3 gap-4 text-center">
          <div>
            <div className="text-2xl font-bold text-purple-400">247+</div>
            <div className="text-xs text-gray-400">Content Pieces</div>
          </div>
          <div>
            <div className="text-2xl font-bold text-blue-400">15.2K</div>
            <div className="text-xs text-gray-400">Monthly Views</div>
          </div>
          <div>
            <div className="text-2xl font-bold text-green-400">98%</div>
            <div className="text-xs text-gray-400">User Satisfaction</div>
          </div>
        </div>
      </div>
    </div>
  );
};

export default InteractiveContentDiscoveryWidget2025;
