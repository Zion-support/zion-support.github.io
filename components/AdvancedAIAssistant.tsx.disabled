interface AIConversation {
  id: string;
  type: "chat" | "task" | "analysis" | "recommendation";
  title: string;
  description: string;
  status: "active" | "completed" | "archived";
  priority: "low" | "medium" | "high" | "critical";
  createdAt: string;
  lastUpdated: string;,
}
;
interface AIInsight {;
