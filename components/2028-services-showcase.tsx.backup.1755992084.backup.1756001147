      </Head>

      <UltraFuturisticNavigation2028 />

      {/* Hero Section */}
          <motion.div
            initial={{ opacity: 0, y: 30 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8 }}
          </motion.div>
        </div>
      </section>

        </div>
      </section>

      {/* CTA Section */}
          <motion.div
            initial={{ opacity: 0, y: 30 }}
            whileInView={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8 }}
            viewport={{ once: true }}
              </div>
            </div>
          </motion.div>
        </div>
      </section>
      <UltraFuturisticFooter2028 />
    </>
  );
}