                          <span className="text-sm text-gray-300">{type}</span>
                        </label>
                      ))}
                    </div>
                  </div>
                  <div>
                    <label className="block text-sm font-medium text-gray-300 mb-2">Duration</label>
                    <div className="space-y-2">
                      {['Any', 'Under 10 min', '10-30 min', '30+ min'].map(duration => (
