      description: 'Intelligent data analysis and business insights platform',
      category: 'analytics',
      icon: <BarChart3 className="w-6 h-6" />,
      features: ['Predictive 'analytics', 'Real-time 'insights', 'Custom 'dashboards', 'Automated reports'],
      pricing: '$25/month',
      rating: 4.7,
      users: '300K+'
    },
    {
      id: 'chat-assistant',
