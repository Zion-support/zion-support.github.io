      icon: <Code className="w-6 h-6" />,
      features: ['Multi-language 'support', 'Bug 'detection', 'Code 'optimization', 'Documentation'],
      pricing: '$15/month',
      rating: 4.8,
      users: '500K+'
    },
    {
      id: 'analytics-ai',
