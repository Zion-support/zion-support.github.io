        :root {
          --font-size: ${settings.fontSize}px;
          --line-height: ${settings.lineHeight};
          --letter-spacing: ${settings.letterSpacing}px;
          --focus-visible: ${settings.focusIndicator ? '2px solid #3b82f6' : 'none'};
