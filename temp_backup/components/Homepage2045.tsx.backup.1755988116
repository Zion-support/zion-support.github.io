    },
    { 
      id: 'ai', 
      name: 'AI & Consciousness', 
      icon: BrainIcon, 
      color: 'from-cyan-500 to-blue-500',
      description: 'Artificial intelligence and consciousness solutions'
    },
    { 
      id: 'quantum', 
      name: 'Quantum Technology', 
      icon: AtomIcon, 
      color: 'from-blue-500 to-indigo-500',
