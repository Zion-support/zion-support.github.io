    },
    {
      "src": "/images/screenshot-mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Zion Tech Group Mobile View"
    }
  ],
  "shortcuts": [
    {
      "name": "Micro SAAS Services",
      "short_name": "Services",
      "description": "Browse our micro SAAS services",
