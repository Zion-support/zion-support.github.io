  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://ziontechgroup.com"
    }
  ],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "handle_links": "preferred",
  "scope_extensions": [
    {
      "origin": "https://ziontechgroup.com"
    }
  ],
  "file_handlers": [
    {
      "action": "/file-handler",
      "accept": {
        "application/pdf": [".pdf"],
        "image/*": [".png", ".jpg", ".jpeg", ".gif", ".webp"],
        "text/*": [".txt", ".md", ".json", ".csv"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+zion",
      "url": "/protocol-handler?url=%s"
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["image/*", "text/*", "application/pdf"]
        }
      ]
    }
  },
  "background": {
    "service_worker": "/sw.js",
    "type": "module"
  },
  "permissions": [
    "notifications",
    "background-sync",
    "storage",
    "geolocation"
  ],
  "features": [
    "Cross Platform",
    "fast",
    "simple",
    "AI-Powered",
    "Micro SAAS",
    "Business Solutions",
    "Tech Marketplace"
  ],
  "developer": {
    "name": "Zion Tech Group",
    "url": "https://ziontechgroup.com"
  },
  "version": "2.0.0",
  "build_date": "2025-01-20",
  "last_updated": "2025-01-20"
}