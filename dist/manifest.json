  "categories": [
    "business",
    "productivity",
    "utilities"
  ],
  "lang": "en",
  "dir": "ltr",
  "orientation": "portrait-primary",
  "scope": "/",
  "id": "zion-tech-group",
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "capture_links": "new-client",
  "file_handlers": [
    {
      "action": "/file-handler",
      "accept": {
        "image/*": [".png", ".jpg", ".jpeg", ".gif", ".webp"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+zion",
      "url": "/protocol-handler?protocol=%s"
    }
  ],
  "permissions": [
    "notifications",
    "background-sync",
    "storage"
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "features": [
    "responsive",
    "offline-capable"
  ]
}
