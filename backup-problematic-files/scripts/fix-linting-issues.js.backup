  hasLintingIssues(content) {
    const issuePatterns = [/,\s*}/g,
      /,\s*]/g,
      /import\s+{\s*}\s+from/g,
      /;\s*$/gm,
      /["']\s*;\s*['"]/g,
    ];
    return issuePatterns.some(pattern => pattern.test(content));
