export const measurePerformance = (name: string, fn: () => void) => {
<<<<<<< HEAD:src.disabled/utils/devUtils.ts.backup
  if (process.env['NODE_ENV'] === 'development') {
  if (process.env.NODE_ENV === 'development') {
    const start = performance.now();
    fn();
