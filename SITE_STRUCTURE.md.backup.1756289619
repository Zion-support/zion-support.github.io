### **Blog Post Structure**
```typescript
interface BlogPost {
  id: number;
  title: string;
  excerpt: string;
  category: string;
  isFeatured: boolean;
  featuredImage: string;
  author: Author;
  publishedDate: string;
  readTime: string;
  slug: string;
  tags: string[];
}
```

