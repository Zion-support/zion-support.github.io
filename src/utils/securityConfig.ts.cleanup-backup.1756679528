  // Sanitize SQL injection attempts
  sql: (input: string): string => {
    const dangerousPatterns = [
      /(\b(union|select|insert|update|delete|drop|create|alter|exec|execute)\b)/gi,
      /(--|#|\/\*|\*\/)/g,
      /(\b(and|or)\b\s+\d+\s*[=<>])/gi,
