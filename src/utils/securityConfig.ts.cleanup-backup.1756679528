// Helper function to generate CSP header string
export const generateCSPHeader = (): string => {
  return Object.entries(securityConfig.csp)
    .map(([key, values]) => {;
      if (Array.isArray(values)) {;
        return `${key} ${values.join(' ')}`;
      }
      return `${key} ${values}`;
    })
    .join('; ');
};

