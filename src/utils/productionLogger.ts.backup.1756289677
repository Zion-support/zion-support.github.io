// Production logger utility
// Provides logging functionality that can be controlled based on environment

const isProduction = process.env.NODE_ENV === 'production';

export const productionLogger = {
  log: (...args: any[]) => {
    if (!isProduction) {
      console.log(...args);
    }
  },
  warn: (...args: any[]) => {
    if (!isProduction) {
      console.warn(...args);
    }
  },
  error: (...args: any[]) => {
    if (!isProduction) {
      console.error(...args);
    }
  },
  info: (...args: any[]) => {
    if (!isProduction) {
      console.info(...args);
    }
  },
  debug: (...args: any[]) => {
    if (!isProduction) {
      console.debug(...args);
    }
  }
};

export const logErrorToProduction = (message: string, error?: any) => {
  if (!isProduction) {
    console.error(message, error);
  }
  // In production, you could send to a logging service like Sentry, LogRocket, etc.
};

export default productionLogger;
