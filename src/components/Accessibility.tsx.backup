  highContrast,
        reducedMotion,
        fontSize,
        colorBlindMode,
        toggleHighContrast,
        toggleReducedMotion,
        setFontSize,
  setColorBlindMode
    

};
    return (<AccessibilityContext.Provider value={value}>
      {children}
    </AccessibilityContext.Provider>)};
// Accessibility Panel Component
