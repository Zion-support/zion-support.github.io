        case 'focusIndicator':
          setSettings(prev => ({ ...prev, focusIndicator: !prev.focusIndicator }));
          break;
        case 'reducedMotion':
          setSettings(prev => ({ ...prev, reducedMotion: !prev.reducedMotion }));
          break;
        case 'help':
