import React from 'react';
import { motion } from 'framer-motion';
import { Link } from 'react-router-dom';
import { ArrowRight } from 'lucide-react';
import { GradientHeading } from './GradientHeading';
interface Category {
  title: string;
  description: string;
  icon: string;
  color: string;
  link: string;
  features: string[];
}
interface SpecialService {
  title: string;
  link: string;
}
interface CategoriesSectionProps {
  showTitle?: boolean;
}
const categories: Category[] = [
  {
    title: "AI & Machine Learning",
    description: "Cutting-edge artificial intelligence solutions for business automation and insights",
    icon: "🤖",
    color: "from-zion-cyan to-zion-blue",
    link: "/services/ai-machine-learning",
    features: ["Predictive Analytics", "Natural Language Processing", "Computer Vision", "Automated Decision Making"]
  },
  {
    title: "Cybersecurity",
    description: "Advanced security solutions to protect your digital assets and infrastructure",
    icon: "🔒",
    color: "from-zion-purple to-zion-red",
    link: "/services/cybersecurity",
    features: ["Threat Detection", "Incident Response", "Security Audits", "Compliance Management"]
  },
  {
    title: "Cloud & DevOps",
    description: "Scalable cloud infrastructure and streamlined development operations",
    icon: "☁️",
    color: "from-zion-blue to-zion-cyan",
    link: "/services/cloud-devops",
    features: ["Cloud Migration", "Container Orchestration", "CI/CD Pipelines", "Infrastructure as Code"]
  },
  {
    title: "Blockchain & Web3",
    description: "Next-generation decentralized solutions and digital asset management",
    icon: "⛓️",
    color: "from-zion-green to-zion-cyan",
    link: "/services/blockchain-web3",
    features: ["Smart Contracts", "DeFi Platforms", "NFT Solutions", "DApp Development"]
  },
  {
    title: "IoT & Edge Computing",
    description: "Connected devices and real-time data processing at the edge",
    icon: "🌐",
    color: "from-zion-orange to-zion-yellow",
    link: "/services/iot-edge",
    features: ["Device Management", "Data Analytics", "Real-time Processing", "Security Protocols"]
  },
  {
    title: "Data Analytics",
    description: "Transform raw data into actionable business intelligence and insights",
    icon: "📊",
    color: "from-zion-pink to-zion-purple",
    link: "/services/data-analytics",
    features: ["Business Intelligence", "Data Visualization", "Predictive Modeling", "Real-time Dashboards"]
  },
  {
    title: "Digital Transformation",
    description: "End-to-end digital transformation services for modern businesses",
    icon: "🚀",
    color: "from-zion-red to-zion-orange",
    link: "/services/digital-transformation",
    features: ["Process Automation", "Legacy Modernization", "Change Management", "Technology Strategy"]
  },
  {
    title: "Quantum Computing",
    description: "Revolutionary quantum solutions for complex computational problems",
    icon: "⚛️",
    color: "from-zion-cyan to-zion-purple",
    link: "/services/quantum-computing",
    features: ["Quantum Algorithms", "Optimization Problems", "Cryptography", "Research & Development"]
  }
];
const specialServices: SpecialService[] = [
  { title: "Enterprise Solutions", link: "/services/enterprise" },
  { title: "Startup Acceleration", link: "/services/startup" },
  { title: "Government & Defense", link: "/services/government" },
  { title: "Healthcare Technology", link: "/services/healthcare" },
  { title: "Financial Services", link: "/services/financial" },
  { title: "Manufacturing 4.0", link: "/services/manufacturing" }
];
export function CategoriesSection({ showTitle = true }: CategoriesSectionProps) {
  return (
    <section className="py-20 bg-gradient-to-br from-zion-slate-dark via-zion-blue to-zion-slate-dark relative overflow-hidden">
      {/* Background pattern */}
      <div className="absolute inset-0 opacity-5">
        <div className="absolute inset-0" style={{
          backgroundImage: `radial-gradient(circle at 50% 50%, currentColor 1px, transparent 1px)`,
          backgroundSize: '40px 40px'
        }} />
      </div>
      {/* Floating elements */}
      <div className="absolute inset-0">
        <motion.div 
          className="absolute top-20 left-20 w-32 h-32 border border-zion-cyan/20 rounded-full opacity-30"
          animate={{ rotate: 360 }}
          transition={{ duration: 20, repeat: Infinity, ease: "linear" }}
        />
        <motion.div 
          className="absolute bottom-20 right-20 w-24 h-24 border border-zion-purple/20 rounded-full opacity-30"
          animate={{ rotate: -360 }}
          transition={{ duration: 25, repeat: Infinity, ease: "linear" }}
        />
      </div>
      <div className="container mx-auto px-4 relative z-10">
        {showTitle && (
          <motion.div 
            className="text-center mb-16"
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.6 }}
            className="text-4xl md:text-5xl font-bold text-white mb-6"
          >
            <GradientHeading className="mb-4">
              Explore Our Service Categories
            </GradientHeading>
            <p className="text-zion-slate-light text-lg max-w-3xl mx-auto">
              Discover comprehensive solutions across multiple technology domains designed to transform your business
            </p>
          </motion.div>
        )}
        <motion.div 
          className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-16"
          variants={{
            hidden: { opacity: 0 },
            visible: {
              opacity: 1,
              transition: {
                staggerChildren: 0.1,
                delayChildren: 0.2
              }
            }
          }}
          initial="hidden"
          whileInView="visible"
          viewport={{ once: true }}
        >
          {categories.map((category, index) => (
            <motion.div
              key={category.title}
              variants={{
                hidden: { opacity: 0, y: 20, scale: 0.95 },
                visible: { opacity: 1, y: 0, scale: 1 }
              }}
              whileHover={{ y: -8, scale: 1.02 }}
              transition={{ duration: 0.3 }}
              className="group"
            >
              <Link to={category.link} className="block h-full">
                <div className="h-full rounded-2xl overflow-hidden border border-zion-cyan/20 bg-zion-slate-dark/60 backdrop-blur-sm p-6 transition-all duration-300 hover:border-zion-cyan/40 hover:bg-zion-slate-dark/80 hover:shadow-xl hover:shadow-zion-cyan/20">
                  <div className={`w-16 h-16 bg-gradient-to-r ${category.color} rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300 shadow-lg`}>
                    <span className="text-2xl">{category.icon}</span>
                  </div>
                  <h3 className="text-white text-xl font-bold mb-3 group-hover:text-zion-cyan transition-colors">
                    {category.title}
                  </h3>
                  <p className="text-zion-slate-light text-sm mb-4 leading-relaxed">
                    {category.description}
                  </p>
                  {/* Feature list */}
                  <ul className="space-y-2 mb-4">
                    {category.features.slice(0, 3).map((feature, idx) => (
                      <li key={idx} className="flex items-center gap-2 text-zion-slate-light text-xs">
                        <div className="w-2 h-2 bg-zion-cyan rounded-full"></div>
                        <span>{feature}</span>
                      </li>
                    ))}
                  </ul>
                  <div className="flex items-center text-zion-cyan group-hover:text-zion-cyan-light transition-colors mt-auto">
                    <span className="text-sm font-medium">Learn More</span>
                    <ArrowRight className="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" />
                  </div>
                </div>
              </Link>
            </motion.div>
          ))}
        </motion.div>
        {/* Special Services */}
        <motion.div 
          className="text-center mb-16"
          initial={{ opacity: 0, y: 20 }}
          whileInView={{ opacity: 1, y: 0 }}
          viewport={{ once: true }}
          transition={{ duration: 0.6, delay: 0.3 }}
        >
          <h3 className="text-2xl font-bold text-white mb-8">Specialized Solutions</h3>
          <div className="flex flex-wrap justify-center gap-4">
            {specialServices.map((service, index) => (
              <motion.div
                key={service.title}
                initial={{ opacity: 0, scale: 0.9 }}
                whileInView={{ opacity: 1, scale: 1 }}
                viewport={{ once: true }}
                transition={{ duration: 0.5, delay: index * 0.1 }}
              >
                <Link 
                  to={service.link}
                  className="inline-flex items-center gap-2 px-6 py-3 bg-zion-cyan/20 hover:bg-zion-cyan/30 border border-zion-cyan/30 hover:border-zion-cyan/50 rounded-xl text-zion-cyan transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-zion-cyan/25 backdrop-blur-sm"
                >
                  {service.title}
                </Link>
              </motion.div>
            ))}
          </div>
        </motion.div>
        {/* Call to Action */}
        <motion.div 
          className="text-center"
          initial={{ opacity: 0, scale: 0.9 }}
          whileInView={{ opacity: 1, scale: 1 }}
          viewport={{ once: true }}
          transition={{ duration: 0.5, delay: 0.5 }}
        >
          <Link 
            to="/services"
            className="inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-zion-purple to-zion-purple-dark hover:from-zion-purple-light hover:to-zion-purple border border-zion-purple/50 hover:border-zion-purple rounded-xl text-white transition-all duration-300 shadow-lg hover:shadow-zion-purple/25 font-semibold group"
          >
            View All Services
            <ArrowRight className="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300" />
          </Link>
        </motion.div>
      </div>
    </section>
  );
};
// Icon components
const Building = ({ className }: { className?: string }) => (
  <svg className={className} fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
  </svg>
);
const ArrowRight = ({ className }: { className?: string }) => (
  <svg className={className} fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M17 8l4 4m0 0l-4 4m4-4H3" />
  </svg>
);
export default CategoriesSection;
