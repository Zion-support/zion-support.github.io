    const announcement = { message, priority, id: Date.now() } as any;
    setAnnouncements(prev => [...prev, announcement]);
    
    // Auto-remove after 5 seconds
    setTimeout(() => {
      setAnnouncements(prev => prev.filter((a: any) => a.id !== announcement.id));
    }, 5000);
