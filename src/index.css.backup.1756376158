  animation: hologram-flicker 3s ease-in-out infinite;
}

.energy-field {
  animation: energy-field 8s ease-in-out infinite;
}

.quantum-shift {
  animation: quantum-shift 4s ease-in-out infinite;
}

.neural-network {
  animation: neural-network 10s ease-in-out infinite;
}

/* Enhanced Hover Effects */
.hover-neon:hover {
  text-shadow: 0 0 5px currentColor, 0 0 10px currentColor, 0 0 15px currentColor;
  transition: text-shadow 0.3s ease;
}

.hover-cyber:hover {
  box-shadow: 0 0 20px rgba(0, 255, 136, 0.5);
  transition: box-shadow 0.3s ease;
}

.hover-quantum:hover {
  transform: translateY(-2px) scale(1.02);
  transition: transform 0.3s ease;
}

/* Futuristic Backgrounds */
.bg-futuristic {
  background: 
    radial-gradient(circle at 20% 20%, rgba(34, 211, 238, 0.05) 0%, transparent 50%),
    radial-gradient(circle at 80% 80%, rgba(139, 92, 246, 0.05) 0%, transparent 50%),
    linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
}

.bg-cyber-grid {
  background-image: 
    linear-gradient(rgba(34, 211, 238, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(34, 211, 238, 0.03) 1px, transparent 1px);
  background-size: 50px 50px;
}

.bg-quantum-field {
  background: 
    radial-gradient(circle at 50% 50%, rgba(34, 211, 238, 0.1) 0%, transparent 70%),
    radial-gradient(circle at 80% 20%, rgba(139, 92, 246, 0.1) 0%, transparent 70%);
}

/* Enhanced Card Effects */
.card-futuristic {
  background: rgba(30, 41, 59, 0.8);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(34, 211, 238, 0.2);
  box-shadow: 
    0 8px 32px rgba(0, 0, 0, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.1);
}

.card-futuristic:hover {
  border-color: rgba(34, 211, 238, 0.5);
  box-shadow: 
    0 12px 40px rgba(0, 0, 0, 0.4),
    0 0 20px rgba(34, 211, 238, 0.2),
    inset 0 1px 0 rgba(255, 255, 255, 0.2);
  transform: translateY(-2px);
  transition: all 0.3s ease;
}

/* Enhanced Button Effects */
.btn-futuristic {
  background: linear-gradient(135deg, #22d3ee 0%, #3b82f6 100%);
  border: none;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.btn-futuristic::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}

.btn-futuristic:hover::before {
  left: 100%;
}

.btn-futuristic:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(34, 211, 238, 0.3);
}

/* Enhanced Text Effects */
.text-gradient-futuristic {
  background: linear-gradient(135deg, #22d3ee 0%, #3b82f6 50%, #8b5cf6 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.text-neon {
  text-shadow: 
    0 0 5px currentColor,
    0 0 10px currentColor,
    0 0 15px currentColor;
}

/* Enhanced Border Effects */
.border-futuristic {
  border: 1px solid transparent;
  background: linear-gradient(135deg, #22d3ee, #3b82f6) border-box;
  -webkit-mask: 
    linear-gradient(#fff 0 0) padding-box, 
    linear-gradient(#fff 0 0);
  -webkit-mask-composite: destination-out;
  mask: 
    linear-gradient(#fff 0 0) padding-box, 
    linear-gradient(#fff 0 0);
  mask-composite: exclude;
}

/* Enhanced Loading Effects */
.loading-futuristic {
  position: relative;
  overflow: hidden;
}

.loading-futuristic::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(34, 211, 238, 0.3), transparent);
  animation: loading-shimmer 1.5s infinite;
}

@keyframes loading-shimmer {
  0% { left: -100%; }
  100% { left: 100%; }
}

/* Enhanced Scrollbar */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: rgba(30, 41, 59, 0.5);
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(135deg, #22d3ee, #3b82f6);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(var(--zion-cyan-light), var(--zion-purple-light));
}

/* Futuristic neon glow effects */
.neon-glow {
  box-shadow: 
    0 0 5px currentColor,
    0 0 10px currentColor,
    0 0 15px currentColor,
    0 0 20px currentColor;
}

.neon-glow-cyan {
  box-shadow: 
    0 0 5px #22ddd2,
    0 0 10px #22ddd2,
    0 0 15px #22ddd2,
    0 0 20px #22ddd2;
}

.neon-glow-purple {
  box-shadow: 
    0 0 5px #8c15e9,
    0 0 10px #8c15e9,
    0 0 15px #8c15e9,
    0 0 20px #8c15e9;
}

/* Matrix rain effect */
.matrix-rain {
  position: relative;
  overflow: hidden;
}

.matrix-rain::before {
  content: '';
  position: absolute;
  top: -100%;
  left: 0;
  width: 100%;
  height: 200%;
  background: linear-gradient(
    to bottom,
    transparent 0%,
    rgba(34, 221, 210, 0.1) 50%,
    transparent 100%
  );
  animation: matrix-rain 3s linear infinite;
}

/* Futuristic border animations */
.futuristic-border {
  position: relative;
  background: linear-gradient(45deg, #22ddd2, #8c15e9, #22ddd2);
  background-size: 200% 200%;
  animation: gradient-shift 3s ease infinite;
}

/* High contrast focus styles */
.high-contrast *:focus {
  outline: 3px solid #ffff00;
  outline-offset: 3px;
}

/* Futuristic Background Animations */
@keyframes neon-pulse {
  0%, 100% { 
    opacity: 0.3; 
    box-shadow: 0 0 20px var(--zion-cyan), 0 0 40px var(--zion-cyan), 0 0 60px var(--zion-cyan);
  }
  50% { 
    opacity: 1; 
    box-shadow: 0 0 30px var(--zion-cyan), 0 0 60px var(--zion-cyan), 0 0 90px var(--zion-cyan);
  }
}

@keyframes neon-glow {
  0%, 100% { 
    text-shadow: 0 0 5px var(--zion-cyan), 0 0 10px var(--zion-cyan), 0 0 15px var(--zion-cyan);
  }
  50% { 
    text-shadow: 0 0 10px var(--zion-cyan), 0 0 20px var(--zion-cyan), 0 0 30px var(--zion-cyan);
  }
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-20px); }
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes slide-in-left {
  from { transform: translateX(-100%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

@keyframes slide-in-right {
  from { transform: translateX(100%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

@keyframes fade-in-up {
  from { transform: translateY(30px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes scale-in {
  from { transform: scale(0.8); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

/* Futuristic Grid Background */
.futuristic-grid {
  background-image: 
    linear-gradient(rgba(6, 182, 212, 0.1) 1px, transparent 1px),
    linear-gradient(90deg, rgba(6, 182, 212, 0.1) 1px, transparent 1px);
  background-size: 50px 50px;
  animation: grid-move 20s linear infinite;
}

@keyframes grid-move {
  0% { background-position: 0 0; }
  100% { background-position: 50px 50px; }
}

/* Neon Text Effects */
.neon-text {
  color: var(--zion-cyan);
  text-shadow: 
    0 0 5px var(--zion-cyan),
    0 0 10px var(--zion-cyan),
    0 0 15px var(--zion-cyan),
    0 0 20px var(--zion-cyan);
  animation: neon-glow 2s ease-in-out infinite alternate;
}

.neon-text-purple {
  color: var(--zion-purple);
  text-shadow: 
    0 0 5px var(--zion-purple),
    0 0 10px var(--zion-purple),
    0 0 15px var(--zion-purple),
    0 0 20px var(--zion-purple);
  animation: neon-glow 2s ease-in-out infinite alternate;
}

.neon-text-green {
  color: var(--zion-green);
  text-shadow: 
    0 0 5px var(--zion-green),
    0 0 10px var(--zion-green),
    0 0 15px var(--zion-green),
    0 0 20px var(--zion-green);
  animation: neon-glow 2s ease-in-out infinite alternate;
}

/* Futuristic Buttons */
.btn-futuristic {
  background: linear-gradient(135deg, var(--zion-cyan), var(--zion-blue));
  border: 2px solid var(--zion-cyan);
  color: white;
  padding: 12px 24px;
  border-radius: 8px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  box-shadow: 0 0 20px rgba(14, 165, 233, 0.3);
}

.btn-futuristic::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s;
}

.btn-futuristic:hover::before {
  left: 100%;
}

.btn-futuristic:hover {
  transform: translateY(-2px);
  box-shadow: 0 0 30px rgba(14, 165, 233, 0.5);
  border-color: var(--zion-cyan-light);
}

/* Futuristic Cards */
.card-futuristic {
  background: rgba(15, 23, 42, 0.8);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(14, 165, 233, 0.2);
  border-radius: 16px;
  padding: 24px;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.card-futuristic::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--zion-cyan), var(--zion-purple), var(--zion-green));
  transform: scaleX(0);
  transition: transform 0.3s ease;
}

.card-futuristic:hover::before {
  transform: scaleX(1);
}

.card-futuristic:hover {
  transform: translateY(-5px);
  border-color: rgba(14, 165, 233, 0.5);
  box-shadow: 0 20px 40px rgba(14, 165, 233, 0.1);
}

/* Animated Background Elements */
.floating-orb {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(14, 165, 233, 0.3), transparent);
  animation: float 6s ease-in-out infinite;
}

.floating-orb:nth-child(1) {
  width: 100px;
  height: 100px;
  top: 20%;
  left: 10%;
  animation-delay: 0s;
}

.floating-orb:nth-child(2) {
  width: 150px;
  height: 150px;
  top: 60%;
  right: 15%;
  animation-delay: 2s;
}

.floating-orb:nth-child(3) {
  width: 80px;
  height: 80px;
  bottom: 20%;
  left: 20%;
  animation-delay: 4s;
}

/* Neon Border Effects */
.neon-border {
  position: relative;
}

.neon-border::after {
  content: '';
  position: absolute;
  top: -2px;
  left: -2px;
  right: -2px;
  bottom: -2px;
  background: linear-gradient(45deg, var(--zion-cyan), var(--zion-purple), var(--zion-green), var(--zion-cyan));
  border-radius: inherit;
  z-index: -1;
  animation: rotate 3s linear infinite;
}

/* Responsive Design Improvements */
@media (max-width: 768px) {
  .card-futuristic {
    padding: 16px;
    margin: 8px;
  }
  
  .btn-futuristic {
    padding: 10px 20px;
    font-size: 14px;
  }
  
  .neon-text {
    font-size: 18px;
  }
}

@media (max-width: 480px) {
  .card-futuristic {
    padding: 12px;
    margin: 4px;
  }
  
  .btn-futuristic {
    padding: 8px 16px;
    font-size: 12px;
  }
}

/* Enhanced Loading Animations */
.loading-futuristic {
  display: inline-block;
  width: 40px;
  height: 40px;
  border: 3px solid rgba(14, 165, 233, 0.3);
