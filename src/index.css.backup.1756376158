/* Futuristic Animations and Effects */
@keyframes neon-glow {
  0%, 100% {
    box-shadow: 
      0 0 5px currentColor,
      0 0 10px currentColor,
      0 0 15px currentColor,
      0 0 20px currentColor;
  }
  50% {
    box-shadow: 
      0 0 10px currentColor,
      0 0 20px currentColor,
      0 0 30px currentColor,
      0 0 40px currentColor;
  }
}

@keyframes cyber-pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.05);
    opacity: 0.8;
  }
}

@keyframes hologram-flicker {
  0%, 100% {
    opacity: 1;
    filter: brightness(1) contrast(1);
  }
  25% {
    opacity: 0.9;
    filter: brightness(1.1) contrast(1.1);
  }
  50% {
    opacity: 0.95;
    filter: brightness(0.9) contrast(0.9);
  }
  75% {
    opacity: 0.85;
    filter: brightness(1.05) contrast(1.05);
  }
}

@keyframes quantum-float {
  0%, 100% {
    transform: translateY(0px) rotate(0deg);
  }
  25% {
    transform: translateY(-10px) rotate(1deg);
  }
  50% {
    transform: translateY(-5px) rotate(-1deg);
  }
  75% {
    transform: translateY(-15px) rotate(0.5deg);
  }
}

@keyframes data-stream {
  0% {
    transform: translateX(-100%);
    opacity: 0;
  }
  50% {
    opacity: 1;
  }
  100% {
    transform: translateX(100%);
    opacity: 0;
  }
}

@keyframes energy-wave {
  0%, 100% {
    transform: scaleX(0);
    opacity: 0;
  }
  50% {
    transform: scaleX(1);
    opacity: 1;
  }
}

/* Utility Classes for Futuristic Effects */
.neon-glow {
  animation: neon-glow 2s ease-in-out infinite alternate;
}

.cyber-pulse {
  animation: cyber-pulse 3s ease-in-out infinite;
}

.hologram-flicker {
  animation: hologram-flicker 4s ease-in-out infinite;
}

.quantum-float {
  animation: quantum-float 6s ease-in-out infinite;
}

.data-stream {
  animation: data-stream 3s linear infinite;
}

.energy-wave {
  animation: energy-wave 2s ease-in-out infinite;
}

/* Futuristic Background Patterns */
.cyber-grid {
  background-image: 
    linear-gradient(rgba(6, 182, 212, 0.1) 1px, transparent 1px),
    linear-gradient(90deg, rgba(6, 182, 212, 0.1) 1px, transparent 1px);
  background-size: 20px 20px;
}

.neon-border {
  border: 2px solid transparent;
  background: linear-gradient(45deg, #0ea5e9, #8b5cf6, #ec4899) border-box;
  -webkit-mask: 
    linear-gradient(#fff 0 0) padding-box, 
    linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
}

.glassmorphism {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
}

.quantum-gradient {
  background: linear-gradient(45deg, 
    #0ea5e9, #8b5cf6, #ec4899, #10b981, #f59e0b, #ef4444
  );
  background-size: 400% 400%;
  animation: quantum-float 8s ease infinite;
}

/* Enhanced Hover Effects */
.hover-neon:hover {
  animation: neon-glow 1s ease-in-out infinite alternate;
}

.hover-cyber:hover {
  animation: cyber-pulse 1s ease-in-out infinite;
}

.hover-quantum:hover {
  animation: quantum-float 2s ease-in-out infinite;
}

