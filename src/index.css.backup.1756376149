}

/* Enhanced Disabled States */
.disabled-futuristic:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  background: rgba(30, 41, 59, 0.5);
  border-color: rgba(14, 165, 233, 0.2);
}

/* Enhanced Loading States */
.loading-futuristic-spinner {
