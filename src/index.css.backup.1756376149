  /* Performance and Accessibility Variables */
  --base-font-size: 16px;
  --heading-scale: 1.2;
  --animation-duration: 0.3s;
  --transition-duration: 0.3s;
  --focus-outline: 3px solid #22d3ee;
  --focus-outline-offset: 2px;
  --touch-target-size: 32px;
  --font-size-scale: 1;
  --mobile-optimized: false;
  --tablet-optimized: false;
  --desktop-optimized: false;
}

/* Enhanced Accessibility Styles */
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.skip-link:focus {
  position: absolute !important;
  width: auto !important;
  height: auto !important;
  padding: 8px 16px !important;
  margin: 0 !important;
  overflow: visible !important;
  clip: auto !important;
  white-space: normal !important;
  z-index: 9999 !important;
}

/* High Contrast Mode */
.high-contrast {
  color-scheme: dark;
}

.high-contrast * {
  border-color: #ffff00 !important;
}

.high-contrast button,
.high-contrast a {
  background-color: #ffff00 !important;
  color: #000000 !important;
}

/* Focus Management */
*:focus {
  outline: var(--focus-outline) !important;
  outline-offset: var(--focus-outline-offset) !important;
}

/* Skip focus outline for mouse users */
*:focus:not(:focus-visible) {
  outline: none !important;
}

/* Enhanced focus for keyboard users */
*:focus-visible {
  outline: var(--focus-outline) !important;
  outline-offset: var(--focus-outline-offset) !important;
}

/* Reduced Motion Support */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}

/* Mobile Optimizations */
@media (max-width: 768px) {
  :root {
    --mobile-optimized: true;
    --touch-target-size: 44px;
    --font-size-scale: 0.9;
  }
  
  /* Mobile-specific touch targets */
  button, a, input, select, textarea {
    min-height: var(--touch-target-size);
    min-width: var(--touch-target-size);
  }
  
  /* Mobile scrollbar */
  ::-webkit-scrollbar {
    width: 6px;
  }
  
  ::-webkit-scrollbar-track {
    background: transparent;
  }
  
  ::-webkit-scrollbar-thumb {
    background: rgba(6, 182, 212, 0.3);
    border-radius: 3px;
  }
}

/* Tablet Optimizations */
@media (min-width: 769px) and (max-width: 1024px) {
  :root {
    --tablet-optimized: true;
    --touch-target-size: 40px;
    --font-size-scale: 0.95;
  }
}

/* Desktop Optimizations */
@media (min-width: 1025px) {
  :root {
    --desktop-optimized: true;
    --touch-target-size: 32px;
    --font-size-scale: 1;
  }
}

/* Color Blind Support */
.color-blind-support {
  filter: contrast(1.2) saturate(1.5);
}

.color-blind-support * {
  border-width: 2px !important;
}

/* Dyslexia Support */
.dyslexia-support {
  font-family: 'OpenDyslexic', 'Arial', sans-serif !important;
  line-height: 1.8 !important;
  letter-spacing: 0.1em !important;
}

.dyslexia-support h1,
.dyslexia-support h2,
.dyslexia-support h3,
.dyslexia-support h4,
.dyslexia-support h5,
.dyslexia-support h6 {
  font-weight: 600 !important;
  line-height: 1.6 !important;
}

/* Performance Optimizations */
.glass {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

/* Optimized animations */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(20px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes scaleIn {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

/* Smooth scrolling */
html {
  scroll-behavior: smooth;
}

/* Optimized font loading */
@font-face {
  font-family: 'Orbitron';
  font-display: swap;
  src: url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&display=swap');
}

@font-face {
  font-family: 'Rajdhani';
  font-display: swap;
  src: url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&display=swap');
}

/* Enhanced button states */
.btn-primary {
  @apply bg-gradient-to-r from-cyan-500 to-blue-500 text-white font-semibold px-6 py-3 rounded-xl transition-all duration-300;
}

.btn-primary:hover {
  @apply from-cyan-400 to-blue-400 transform scale-105 shadow-lg shadow-cyan-500/25;
}

.btn-primary:focus {
  @apply outline-none ring-4 ring-cyan-400/50;
}

.btn-secondary {
  @apply border-2 border-cyan-400/50 text-cyan-400 font-semibold px-6 py-3 rounded-xl transition-all duration-300;
}

.btn-secondary:hover {
  @apply bg-cyan-400/10 border-cyan-400;
}

.btn-secondary:focus {
  @apply outline-none ring-4 ring-cyan-400/50;
}

/* Enhanced form elements */
.form-input {
  @apply w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-cyan-400 focus:border-transparent transition-all duration-300;
}

.form-input:focus {
  @apply outline-none;
}

/* Enhanced loading states */
.loading-skeleton {
  @apply animate-pulse bg-gray-200 rounded;
}

/* Optimized image loading */
.lazy-image {
  opacity: 0;
  transition: opacity 0.3s ease-in-out;
}

.lazy-image.loaded {
  opacity: 1;
}

/* Enhanced accessibility for screen readers */
.sr-only-focusable:focus {
  @apply sr-only;
}

/* Skip to content link */
.skip-link {
  @apply sr-only;
}

.skip-link:focus {
  @apply not-sr-only absolute top-4 left-4 bg-cyan-500 text-white px-4 py-2 rounded z-50;
}

/* Enhanced mobile navigation */
.mobile-nav {
  @apply fixed inset-0 z-50 bg-black/80 backdrop-blur-sm;
}

 .mobile-nav.hidden {
   display: none;
 }

/* Touch gesture optimizations */
@media (hover: none) and (pointer: coarse) {
  .hover\:scale-105:hover {
    transform: none;
  }
  
  .hover\:shadow-lg:hover {
    box-shadow: none;
  }
}

/* Performance monitoring styles */
.performance-metrics {
  @apply fixed bottom-4 right-4 bg-black/80 backdrop-blur-sm text-white p-4 rounded-lg text-xs z-50;
}

/* Enhanced accessibility for interactive elements */
[role="button"],
[role="tab"],
[role="menuitem"] {
  cursor: pointer;
}

[role="button"]:focus,
[role="tab"]:focus,
[role="menuitem"]:focus {
  outline: var(--focus-outline) !important;
  outline-offset: var(--focus-outline-offset) !important;
}

/* Enhanced keyboard navigation */
.keyboard-nav *:focus {
  outline: var(--focus-outline) !important;
  outline-offset: var(--focus-outline-offset) !important;
}

/* Optimized animations for performance */
.will-change-transform {
  will-change: transform;
}

.will-change-opacity {
  will-change: opacity;
}

/* Enhanced mobile experience */
@media (max-width: 768px) {
  .mobile-optimized {
    font-size: calc(16px * var(--font-size-scale));
  }
  
  .mobile-optimized button,
  .mobile-optimized a {
    min-height: var(--touch-target-size);
    min-width: var(--touch-target-size);
  }
}

/* Enhanced tablet experience */
@media (min-width: 769px) and (max-width: 1024px) {
  .tablet-optimized {
    font-size: calc(16px * var(--font-size-scale));
  }
}

/* Enhanced desktop experience */
@media (min-width: 1025px) {
  .desktop-optimized {
    font-size: calc(16px * var(--font-size-scale));
  }
}

/* Custom scrollbar for webkit browsers */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: rgba(0, 0, 0, 0.1);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb {
  background: rgba(6, 182, 212, 0.5);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(var(--zion-cyan-light), var(--zion-purple-light));
}

/* Futuristic Animations and Effects */
@keyframes neon-glow {
  0%, 100% { 
    box-shadow: 0 0 5px currentColor, 0 0 10px currentColor, 0 0 15px currentColor;
  }
  50% { 
    box-shadow: 0 0 10px currentColor, 0 0 20px currentColor, 0 0 30px currentColor;
  }
}

@keyframes cyber-pulse {
  0% { 
    box-shadow: 0 0 0 0 rgba(0, 255, 136, 0.7);
  }
  70% { 
    box-shadow: 0 0 0 10px rgba(0, 255, 136, 0);
  }
  100% { 
    box-shadow: 0 0 0 0 rgba(0, 255, 136, 0);
  }
}

@keyframes matrix-rain {
  0% { transform: translateY(-100vh); opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { transform: translateY(100vh); opacity: 0; }
}

@keyframes hologram-flicker {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.8; }
  75% { opacity: 0.9; }
}

@keyframes energy-field {
  0% { 
    background: radial-gradient(circle, rgba(34, 211, 238, 0.1) 0%, transparent 70%);
  }
  50% { 
    background: radial-gradient(circle, rgba(139, 92, 246, 0.1) 0%, transparent 70%);
  }
  100% { 
    background: radial-gradient(circle, rgba(34, 211, 238, 0.1) 0%, transparent 70%);
  }
}

@keyframes quantum-shift {
  0% { transform: translateX(0) scale(1); }
  25% { transform: translateX(5px) scale(1.02); }
  50% { transform: translateX(0) scale(1); }
  75% { transform: translateX(-5px) scale(0.98); }
  100% { transform: translateX(0) scale(1); }
}

@keyframes neural-network {
  0% { 
    background-image: 
      radial-gradient(circle at 20% 20%, rgba(34, 211, 238, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(139, 92, 246, 0.1) 0%, transparent 50%);
  }
  50% { 
    background-image: 
      radial-gradient(circle at 80% 20%, rgba(34, 211, 238, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 20% 80%, rgba(139, 92, 246, 0.1) 0%, transparent 50%);
  }
  100% { 
    background-image: 
      radial-gradient(circle at 20% 20%, rgba(34, 211, 238, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(139, 92, 246, 0.1) 0%, transparent 50%);
  }
}

/* Futuristic Utility Classes */
.neon-glow {
  animation: neon-glow 2s ease-in-out infinite;
}

.cyber-pulse {
  animation: cyber-pulse 2s infinite;
}

.matrix-rain {
  animation: matrix-rain 20s linear infinite;
}

.hologram-flicker {
  animation: hologram-flicker 3s ease-in-out infinite;
}

.energy-field {
  animation: energy-field 8s ease-in-out infinite;
}

.quantum-shift {
  animation: quantum-shift 4s ease-in-out infinite;
}

.neural-network {
  animation: neural-network 10s ease-in-out infinite;
}

/* Enhanced Hover Effects */
.hover-neon:hover {
  text-shadow: 0 0 5px currentColor, 0 0 10px currentColor, 0 0 15px currentColor;
  transition: text-shadow 0.3s ease;
}

.hover-cyber:hover {
  box-shadow: 0 0 20px rgba(0, 255, 136, 0.5);
  transition: box-shadow 0.3s ease;
}

.hover-quantum:hover {
  transform: translateY(-2px) scale(1.02);
  transition: transform 0.3s ease;
}

/* Futuristic Backgrounds */
.bg-futuristic {
  background: 
    radial-gradient(circle at 20% 20%, rgba(34, 211, 238, 0.05) 0%, transparent 50%),
    radial-gradient(circle at 80% 80%, rgba(139, 92, 246, 0.05) 0%, transparent 50%),
    linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
}

.bg-cyber-grid {
  background-image: 
    linear-gradient(rgba(34, 211, 238, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(34, 211, 238, 0.03) 1px, transparent 1px);
  background-size: 50px 50px;
}

.bg-quantum-field {
  background: 
    radial-gradient(circle at 50% 50%, rgba(34, 211, 238, 0.1) 0%, transparent 70%),
    radial-gradient(circle at 80% 20%, rgba(139, 92, 246, 0.1) 0%, transparent 70%);
}

/* Enhanced Card Effects */
.card-futuristic {
  background: rgba(30, 41, 59, 0.8);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(34, 211, 238, 0.2);
  box-shadow: 
    0 8px 32px rgba(0, 0, 0, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.1);
}

.card-futuristic:hover {
  border-color: rgba(34, 211, 238, 0.5);
  box-shadow: 
    0 12px 40px rgba(0, 0, 0, 0.4),
    0 0 20px rgba(34, 211, 238, 0.2),
    inset 0 1px 0 rgba(255, 255, 255, 0.2);
  transform: translateY(-2px);
  transition: all 0.3s ease;
}

/* Enhanced Button Effects */
.btn-futuristic {
  background: linear-gradient(135deg, #22d3ee 0%, #3b82f6 100%);
  border: none;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.btn-futuristic::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}

.btn-futuristic:hover::before {
  left: 100%;
}

.btn-futuristic:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(34, 211, 238, 0.3);
}

/* Enhanced Text Effects */
.text-gradient-futuristic {
  background: linear-gradient(135deg, #22d3ee 0%, #3b82f6 50%, #8b5cf6 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.text-neon {
  text-shadow: 
    0 0 5px currentColor,
    0 0 10px currentColor,
    0 0 15px currentColor;
}

/* Enhanced Border Effects */
.border-futuristic {
  border: 1px solid transparent;
  background: linear-gradient(135deg, #22d3ee, #3b82f6) border-box;
  -webkit-mask: 
    linear-gradient(#fff 0 0) padding-box, 
    linear-gradient(#fff 0 0);
  -webkit-mask-composite: destination-out;
  mask: 
    linear-gradient(#fff 0 0) padding-box, 
    linear-gradient(#fff 0 0);
  mask-composite: exclude;
}

/* Enhanced Loading Effects */
.loading-futuristic {
  position: relative;
  overflow: hidden;
}

.loading-futuristic::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(34, 211, 238, 0.3), transparent);
  animation: loading-shimmer 1.5s infinite;
}

@keyframes loading-shimmer {
  0% { left: -100%; }
  100% { left: 100%; }
}

/* Enhanced Scrollbar */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: rgba(30, 41, 59, 0.5);
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(135deg, #22d3ee, #3b82f6);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(var(--zion-cyan-light), var(--zion-purple-light));
}

