  .futuristic-bg::before,
  .matrix-rain,
  .particle-bg::before,
  .scan-line::after,
  .data-stream::before {
    display: none;
  }
  
  .futuristic-card {
    background: white;
    color: black;
    border: 1px solid #ccc;
    box-shadow: none;
  }
