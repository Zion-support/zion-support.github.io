@keyframes zoom-in {
  from { opacity: 0; transform: scale(0.8); }
  to { opacity: 1; transform: scale(1); }
}

@layer utilities {
  .animate-neon-glow {
    animation: neonGlow 2s ease-in-out infinite;
  }
  
  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
  
  .animate-float-delayed {
    animation: float-delayed 3s ease-in-out infinite;
    animation-delay: 1s;
  }
  
  .animate-pulse-glow {
    animation: pulse-glow 2s ease-in-out infinite;
  }
  
  .animate-rotate-slow {
    animation: rotate-slow 20s linear infinite;
  }
  
  .animate-slide-in-left {
    animation: slide-in-left 0.6s ease-out;
  }
  
  .animate-slide-in-right {
    animation: slide-in-right 0.6s ease-out;
  }
  
  .animate-zoom-in {
    animation: zoom-in 0.6s ease-out;
  }
  
  .text-neon {
    text-shadow: 0 0 5px currentColor, 0 0 10px currentColor, 0 0 15px currentColor;
  }
  
  .border-neon {
    box-shadow: 0 0 5px currentColor, 0 0 10px currentColor, 0 0 15px currentColor;
  }
  
  .bg-glass {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .bg-glass-dark {
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
}

@layer base {
  :root {
    --font-sans: 'Orbitron', system-ui, sans-serif;
    --font-rajdhani: 'Rajdhani', system-ui, sans-serif;

    --background: 0 0% 7%;
    --foreground: 142 71% 45%;

    --card: 0 0% 7%;
    --card-foreground: 142 71% 45%;

    --popover: 0 0% 7%;
    --popover-foreground: 142 71% 45%;

    --primary: 216 84% 50%;
    --primary-foreground: 142 71% 45%;

    --secondary: 0 0% 68%;
    --secondary-foreground: 0 0% 7%;

    --muted: 0 0% 68%;
    --muted-foreground: 215 20% 65%;

    --accent: 228 12% 92%;
    --accent-foreground: 0 0% 7%;

    --destructive: 0 84.2% 60.2%;
    --destructive-foreground: 142 71% 45%;

    --border: 0 0% 68%;
    --input: 0 0% 68%;
    --ring: 216 84% 53%;

    --radius: 0.5rem;

    --sidebar-background: 228 12% 92%;
    --sidebar-foreground: 0 0% 7%;
    --sidebar-primary: 216 84% 53%;
    --sidebar-primary-foreground: 142 71% 45%;
    --sidebar-accent: 0 0% 68%;
    --sidebar-accent-foreground: 0 0% 7%;
    --sidebar-border: 0 0% 68%;
    --sidebar-ring: 216 84% 53%;
  }

  .dark {
    --background: 0 0% 7%;
    --foreground: 142 71% 45%;

    --card: 0 0% 7%;
    --card-foreground: 142 71% 45%;

    --popover: 0 0% 7%;
    --popover-foreground: 142 71% 45%;

    --primary: 216 84% 50%;
    --primary-foreground: 142 71% 45%;

    --secondary: 0 0% 68%;
    --secondary-foreground: 0 0% 7%;

    --muted: 0 0% 68%;
    --muted-foreground: 215 20% 65%;

    --accent: 228 12% 92%;
    --accent-foreground: 0 0% 7%;

    --destructive: 0 84.2% 60.2%;
    --destructive-foreground: 142 71% 45%;

    --border: 0 0% 68%;
    --input: 0 0% 68%;
    --ring: 216 84% 53%;

    --sidebar-background: 228 12% 92%;
    --sidebar-foreground: 0 0% 7%;
    --sidebar-primary: 216 84% 53%;
    --sidebar-primary-foreground: 142 71% 45%;
    --sidebar-accent: 0 0% 68%;
    --sidebar-accent-foreground: 0 0% 7%;
    --sidebar-border: 0 0% 68%;
    --sidebar-ring: 216 84% 53%;
  }
}

@layer components {
  .btn-primary {
    @apply bg-gradient-to-r from-zion-cyan to-zion-purple text-white font-semibold py-3 px-6 rounded-lg 
           hover:from-zion-purple hover:to-zion-cyan transition-all duration-300 transform hover:scale-105 
           focus:outline-none focus:ring-2 focus:ring-zion-cyan focus:ring-opacity-50;
  }

  .btn-secondary {
    @apply bg-transparent border-2 border-zion-cyan text-zion-cyan font-semibold py-3 px-6 rounded-lg 
           hover:bg-zion-cyan hover:text-white transition-all duration-300 transform hover:scale-105 
           focus:outline-none focus:ring-2 focus:ring-zion-cyan focus:ring-opacity-50;
  }

  .card {
    @apply bg-zion-slate-dark/50 backdrop-blur-sm border border-zion-blue/20 rounded-xl p-6 
           hover:border-zion-blue/40 transition-all duration-300;
  }

  .input {
    @apply bg-zion-slate-dark/50 border border-zion-blue/20 rounded-lg px-4 py-3 text-white 
           placeholder-zion-blue/50 focus:border-zion-cyan focus:outline-none focus:ring-2 
           focus:ring-zion-cyan/20 transition-all duration-300;
  }

  .heading {
    @apply font-orbitron text-white font-bold;
  }

  .text-gradient {
    @apply bg-gradient-to-r from-zion-cyan to-zion-purple bg-clip-text text-transparent;
  }

  .neon-glow {
    @apply shadow-[0_0_20px_rgba(56,189,248,0.5)] shadow-zion-cyan/50;
  }

  .neon-glow-purple {
    @apply shadow-[0_0_20px_rgba(168,85,247,0.5)] shadow-zion-purple/50;
  }
}

/* Responsive utilities */
@media (max-width: 768px) {
  .container {
    padding-left: 1rem;
    padding-right: 1rem;
  }

  .loading-dots::after {
    content: '';
    animation: loading-dots 1.5s infinite;
  }

  @keyframes loading-dots {
    0%, 20% { content: ''; }
    40% { content: '.'; }
    60% { content: '..'; }
    80%, 100% { content: '...'; }
  }
}

@layer utilities {
  /* Animation Keyframes */
  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
  }

  @keyframes pulse-glow {
    0%, 100% { 
      box-shadow: 0 0 20px rgba(34, 221, 210, 0.5);
      transform: scale(1);
    }
    50% { 
      box-shadow: 0 0 40px rgba(34, 221, 210, 0.8);
      transform: scale(1.05);
    }
  }

  @keyframes neon-flicker {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.8; }
  }

  @keyframes slide-in-left {
    from { transform: translateX(-100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }

  @keyframes slide-in-right {
    from { transform: translateX(100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }

  @keyframes fade-in-up {
    from { transform: translateY(30px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  /* Utility Classes */
  .animate-fade-in-up {
    animation: fade-in-up 0.6s ease-out;
  }

  .animate-slide-in-left {
    animation: slide-in-left 0.6s ease-out;
  }

  .animate-slide-in-right {
    animation: slide-in-right 0.6s ease-out;
  }

  .animate-neon-flicker {
    animation: neon-flicker 2s ease-in-out infinite;
  }

  /* Responsive Utilities */
  .container-responsive {
    @apply max-w-7xl mx-auto px-4 sm:px-6 lg:px-8;
  }

  .section-padding {
    @apply py-16 sm:py-20 lg:py-24;
  }

  .text-responsive {
    @apply text-sm sm:text-base lg:text-lg;
  }

  .heading-responsive {
    @apply text-2xl sm:text-3xl lg:text-4xl xl:text-5xl;
  }
}

/* Accessibility Styles */
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.high-contrast {
  --text-primary: #ffffff;
  --text-secondary: #e5e7eb;
  --bg-primary: #000000;
  --bg-secondary: #111827;
  --accent: #fbbf24;
}

.large-text {
  font-size: 1.2em;
  line-height: 1.6;
}

.reduced-motion * {
  animation-duration: 0.01ms !important;
  animation-iteration-count: 1 !important;
  transition-duration: 0.01ms !important;
}

.focus-visible *:focus {
  outline: 3px solid #fbbf24 !important;
  outline-offset: 2px !important;
}

.keyboard-navigation *:focus {
  outline: 3px solid #fbbf24 !important;
  outline-offset: 2px !important;
}

.light-theme {
  --bg-primary: #ffffff;
  --bg-secondary: #f8fafc;
  --text-primary: #0f172a;
  --text-secondary: #475569;
}

.dark-theme {
  --bg-primary: #0f172a;
  --bg-secondary: #1e293b;
  --text-primary: #f8fafc;
  --text-secondary: #cbd5e1;
}

/* Focus styles for better accessibility */
*:focus {
  outline: 2px solid #22ddd2;
  outline-offset: 2px;
}

/* Skip to content link */
.skip-link {
  position: absolute;
  top: -40px;
  left: 6px;
  background: #22ddd2;
  color: #0f172a;
  padding: 8px;
  text-decoration: none;
  border-radius: 4px;
  z-index: 1000;
}

.skip-link:focus {
  top: 6px;
}

/* High contrast focus styles */
.high-contrast *:focus {
  outline: 3px solid #ffff00;
  outline-offset: 3px;
}

/* Enhanced Futuristic Styles */
.futuristic-gradient {
  background: linear-gradient(135deg, 
    rgba(6, 182, 212, 0.1) 0%, 
    rgba(139, 92, 246, 0.1) 25%, 
    rgba(236, 72, 153, 0.1) 50%, 
    rgba(16, 185, 129, 0.1) 75%, 
    rgba(6, 182, 212, 0.1) 100%
  );
}

.neon-glow {
  box-shadow: 
    0 0 20px rgba(6, 182, 212, 0.5),
    0 0 40px rgba(6, 182, 212, 0.3),
    0 0 60px rgba(6, 182, 212, 0.1);
}

.neon-text {
  text-shadow: 
    0 0 10px currentColor,
    0 0 20px currentColor,
    0 0 30px currentColor;
}

.animated-border {
  background: linear-gradient(90deg, 
    transparent 0%, 
    rgba(6, 182, 212, 0.5) 50%, 
    transparent 100%
  );
  background-size: 200% 100%;
  animation: border-flow 3s ease-in-out infinite;
}

@keyframes border-flow {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.floating-particles {
  position: relative;
  overflow: hidden;
}

.floating-particles::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(circle at 20% 80%, rgba(6, 182, 212, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(139, 92, 246, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 40% 40%, rgba(236, 72, 153, 0.1) 0%, transparent 50%);
  animation: particle-float 20s ease-in-out infinite;
}

@keyframes particle-float {
  0%, 100% { transform: translateY(0px) rotate(0deg); }
  33% { transform: translateY(-20px) rotate(120deg); }
  66% { transform: translateY(20px) rotate(240deg); }
}

.glass-effect {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.holographic {
  background: linear-gradient(45deg, 
    rgba(6, 182, 212, 0.1), 
    rgba(139, 92, 246, 0.1), 
    rgba(236, 72, 153, 0.1), 
    rgba(16, 185, 129, 0.1)
  );
  background-size: 400% 400%;
  animation: holographic-shift 8s ease-in-out infinite;
}

@keyframes holographic-shift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

.cyber-grid {
  background-image: 
    linear-gradient(rgba(6, 182, 212, 0.1) 1px, transparent 1px),
    linear-gradient(90deg, rgba(6, 182, 212, 0.1) 1px, transparent 1px);
  background-size: 50px 50px;
  animation: grid-move 20s linear infinite;
}

@keyframes grid-move {
  0% { transform: translate(0, 0); }
  100% { transform: translate(50px, 50px); }
}

.quantum-pulse {
  animation: quantum-pulse 4s ease-in-out infinite;
}

@keyframes quantum-pulse {
  0%, 100% { 
    transform: scale(1);
    opacity: 1;
  }
  50% { 
    transform: scale(1.05);
    opacity: 0.8;
  }
}

.neon-button {
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.neon-button::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}

.neon-button:hover::before {
  left: 100%;
}

.neon-button:hover {
  transform: translateY(-2px);
  box-shadow: 
    0 10px 20px rgba(6, 182, 212, 0.3),
    0 0 30px rgba(6, 182, 212, 0.5);
}

/* Enhanced Slider Styles */
.slider {
  -webkit-appearance: none;
  appearance: none;
  height: 8px;
  border-radius: 4px;
  background: linear-gradient(90deg, var(--zion-cyan), var(--zion-purple));
  outline: none;
  opacity: 0.7;
  transition: opacity 0.2s;
}

.slider:hover {
  opacity: 1;
}

.slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: var(--zion-cyan);
  cursor: pointer;
  box-shadow: 0 0 10px rgba(6, 182, 212, 0.5);
}

.slider::-moz-range-thumb {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: var(--zion-cyan);
  border: none;
  cursor: pointer;
  box-shadow: 0 0 10px rgba(6, 182, 212, 0.5);
}

/* Line Clamp Utility */
.line-clamp-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Enhanced Scrollbar */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: var(--zion-slate-800);
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(var(--zion-cyan), var(--zion-purple));
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(var(--zion-cyan-light), var(--zion-purple-light));
}

/* Futuristic Background Animations */
@keyframes matrix-rain {
  0% { transform: translateY(-100vh); opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { transform: translateY(100vh); opacity: 0; }
}

@keyframes holographic-shift {
  0%, 100% { 
    background: linear-gradient(45deg, var(--holographic-1), var(--holographic-2), var(--holographic-3));
    background-size: 200% 200%;
  }
  25% { 
    background: linear-gradient(45deg, var(--holographic-2), var(--holographic-3), var(--holographic-4));
    background-size: 200% 200%;
  }
  50% { 
    background: linear-gradient(45deg, var(--holographic-3), var(--holographic-4), var(--holographic-5));
    background-size: 200% 200%;
  }
  75% { 
    background: linear-gradient(45deg, var(--holographic-4), var(--holographic-5), var(--holographic-1));
    background-size: 200% 200%;
  }
}

@keyframes neon-pulse {
  0%, 100% { 
    text-shadow: 
      0 0 5px currentColor,
      0 0 10px currentColor,
      0 0 15px currentColor,
      0 0 20px currentColor;
  }
  50% { 
    text-shadow: 
      0 0 10px currentColor,
      0 0 20px currentColor,
      0 0 30px currentColor,
      0 0 40px currentColor;
  }
}

@keyframes cyber-glitch {
  0%, 100% { transform: translate(0); }
  20% { transform: translate(-2px, 2px); }
  40% { transform: translate(-2px, -2px); }
  60% { transform: translate(2px, 2px); }
  80% { transform: translate(2px, -2px); }
}

@keyframes float-3d {
  0%, 100% { transform: translateZ(0) rotateX(0) rotateY(0); }
  25% { transform: translateZ(20px) rotateX(5deg) rotateY(5deg); }
  50% { transform: translateZ(40px) rotateX(0deg) rotateY(0deg); }
  75% { transform: translateZ(20px) rotateX(-5deg) rotateY(-5deg); }
}

@keyframes energy-wave {
  0% { transform: scaleX(0); opacity: 1; }
  50% { transform: scaleX(1); opacity: 0.5; }
  100% { transform: scaleX(0); opacity: 0; }
}

@keyframes particle-float {
  0% { transform: translateY(0px) rotate(0deg); opacity: 1; }
  100% { transform: translateY(-100px) rotate(360deg); opacity: 0; }
}

@keyframes scan-line {
  0% { transform: translateY(-100%); }
  100% { transform: translateY(100vh); }
}

@keyframes data-stream {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100vw); }
}

/* Futuristic Utility Classes */
.futuristic-bg {
  background: linear-gradient(135deg, #0f0f23 0%, #1a1a2e 25%, #16213e 50%, #0f3460 75%, #533483 100%);
  position: relative;
  overflow: hidden;
}

.futuristic-bg::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(circle at 20% 80%, rgba(120, 119, 198, 0.3) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(255, 119, 198, 0.3) 0%, transparent 50%),
    radial-gradient(circle at 40% 40%, rgba(120, 219, 255, 0.2) 0%, transparent 50%);
  animation: holographic-shift 8s ease-in-out infinite;
}

.neon-text {
  color: var(--neon-cyan);
  text-shadow: 
    0 0 5px var(--neon-cyan),
    0 0 10px var(--neon-cyan),
    0 0 15px var(--neon-cyan),
    0 0 20px var(--neon-cyan);
  animation: neon-pulse 2s ease-in-out infinite;
}

.neon-border {
  border: 2px solid var(--neon-cyan);
  box-shadow: 
    0 0 5px var(--neon-cyan),
    0 0 10px var(--neon-cyan),
    0 0 15px var(--neon-cyan),
    inset 0 0 5px var(--neon-cyan);
}

.cyber-glitch {
  animation: cyber-glitch 0.3s ease-in-out infinite;
}

.float-3d {
  animation: float-3d 6s ease-in-out infinite;
}

.energy-wave {
  position: relative;
  overflow: hidden;
}

.energy-wave::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--neon-cyan), transparent);
  animation: energy-wave 2s ease-in-out infinite;
}

.particle-bg {
  position: relative;
  overflow: hidden;
}

.particle-bg::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(2px 2px at 20px 30px, var(--neon-cyan), transparent),
    radial-gradient(2px 2px at 40px 70px, var(--neon-purple), transparent),
    radial-gradient(1px 1px at 90px 40px, var(--neon-green), transparent),
    radial-gradient(1px 1px at 130px 80px, var(--neon-pink), transparent),
    radial-gradient(2px 2px at 160px 30px, var(--neon-blue), transparent);
  background-repeat: repeat;
  background-size: 200px 100px;
  animation: particle-float 20s linear infinite;
}

.scan-line {
  position: relative;
  overflow: hidden;
}

.scan-line::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--neon-green), transparent);
  animation: scan-line 3s linear infinite;
}

.data-stream {
  position: relative;
  overflow: hidden;
}

.data-stream::before {
  content: '01';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  color: var(--neon-green);
  font-family: 'Courier New', monospace;
  font-size: 12px;
  line-height: 12px;
  white-space: nowrap;
  animation: data-stream 10s linear infinite;
}

/* Matrix Rain Effect */
.matrix-rain {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: -1;
}

.matrix-rain::before {
  content: '01';
  position: absolute;
  top: -100vh;
  left: 0;
  width: 100%;
  height: 100vh;
  color: var(--matrix-green);
  font-family: 'Courier New', monospace;
  font-size: 14px;
  line-height: 14px;
  white-space: nowrap;
  animation: matrix-rain 20s linear infinite;
}

/* Futuristic Card Styles */
.futuristic-card {
  background: rgba(15, 15, 35, 0.8);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(0, 255, 255, 0.3);
  border-radius: 16px;
  box-shadow: 
    0 8px 32px rgba(0, 255, 255, 0.1),
    inset 0 1px 0 rgba(255, 255, 255, 0.1);
  transition: all 0.3s ease;
}

.futuristic-card:hover {
  transform: translateY(-8px) scale(1.02);
  border-color: rgba(0, 255, 255, 0.6);
  box-shadow: 
    0 16px 64px rgba(0, 255, 255, 0.2),
    inset 0 1px 0 rgba(255, 255, 255, 0.2);
}

/* Futuristic Button Styles */
.futuristic-btn {
  background: linear-gradient(135deg, var(--neon-cyan), var(--neon-blue));
  border: none;
  border-radius: 8px;
  padding: 12px 24px;
  color: white;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  cursor: pointer;
}

.futuristic-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.5s ease;
}

.futuristic-btn:hover::before {
  left: 100%;
}

.futuristic-btn:hover {
  transform: translateY(-2px);
  box-shadow: 
    0 8px 25px rgba(0, 255, 255, 0.4),
    0 0 0 2px rgba(0, 255, 255, 0.2);
}

/* Futuristic Navigation */
.futuristic-nav {
  background: rgba(15, 15, 35, 0.95);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(0, 255, 255, 0.3);
}

.futuristic-nav-item {
  position: relative;
  padding: 12px 20px;
  color: white;
  text-decoration: none;
  transition: all 0.3s ease;
}

.futuristic-nav-item::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 0;
  height: 2px;
  background: var(--neon-cyan);
  transition: all 0.3s ease;
  transform: translateX(-50%);
}

.futuristic-nav-item:hover::before {
  width: 100%;
}

.futuristic-nav-item:hover {
  color: var(--neon-cyan);
  text-shadow: 0 0 10px var(--neon-cyan);
}

/* Responsive Design Enhancements */
@media (max-width: 768px) {
  .futuristic-card {
    margin: 16px;
    border-radius: 12px;
  }
  
  .futuristic-btn {
    padding: 10px 20px;
    font-size: 14px;
  }
  
  .neon-text {
    font-size: 24px;
  }
}

@media (max-width: 480px) {
  .futuristic-card {
    margin: 12px;
    border-radius: 8px;
  }
  
  .futuristic-btn {
    padding: 8px 16px;
    font-size: 12px;
  }
  
  .neon-text {
    font-size: 20px;
  }
}

/* Enhanced Loading Animations */
.futuristic-loader {
  display: inline-block;
  width: 40px;
  height: 40px;
  border: 3px solid rgba(0, 255, 255, 0.3);
  border-radius: 50%;
  border-top-color: var(--neon-cyan);
  animation: spin 1s ease-in-out infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Futuristic Grid Layout */
.futuristic-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 24px;
  padding: 24px;
}

/* Enhanced Typography */
.futuristic-heading {
  font-family: 'Orbitron', monospace;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  background: linear-gradient(135deg, var(--neon-cyan), var(--neon-blue), var(--neon-purple));
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  text-shadow: 0 0 30px rgba(0, 255, 255, 0.5);
}

.futuristic-subheading {
  font-family: 'Exo 2', sans-serif;
  font-weight: 300;
  color: rgba(255, 255, 255, 0.8);
  letter-spacing: 1px;
}

/* Enhanced Scrollbar */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: rgba(15, 15, 35, 0.8);
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(135deg, var(--neon-cyan), var(--neon-blue));
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(135deg, var(--neon-blue), var(--neon-purple));
}

/* Enhanced Focus States */
.futuristic-focus:focus {
  outline: none;
  box-shadow: 
    0 0 0 3px rgba(0, 255, 255, 0.3),
    0 0 20px rgba(0, 255, 255, 0.2);
}

/* Enhanced Transitions */
.futuristic-transition {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Enhanced Shadows */
.futuristic-shadow {
  box-shadow: 
    0 4px 6px -1px rgba(0, 0, 0, 0.1),
    0 2px 4px -1px rgba(0, 0, 0, 0.06),
    0 0 0 1px rgba(0, 255, 255, 0.1);
}

.futuristic-shadow-lg {
  box-shadow: 
    0 10px 15px -3px rgba(0, 0, 0, 0.1),
    0 4px 6px -2px rgba(0, 0, 0, 0.05),
    0 0 0 1px rgba(0, 255, 255, 0.2);
}

/* Enhanced Gradients */
.futuristic-gradient {
  background: linear-gradient(135deg, 
    rgba(0, 255, 255, 0.1) 0%, 
    rgba(0, 128, 255, 0.1) 25%, 
    rgba(128, 0, 255, 0.1) 50%, 
    rgba(255, 0, 128, 0.1) 75%, 
    rgba(255, 128, 0, 0.1) 100%);
}

/* Enhanced Borders */
.futuristic-border {
  border: 1px solid rgba(0, 255, 255, 0.3);
  border-radius: 8px;
}

.futuristic-border-lg {
  border: 2px solid rgba(0, 255, 255, 0.4);
  border-radius: 16px;
}

/* Enhanced Opacity */
.futuristic-opacity-10 { opacity: 0.1; }
.futuristic-opacity-20 { opacity: 0.2; }
.futuristic-opacity-30 { opacity: 0.3; }
.futuristic-opacity-40 { opacity: 0.4; }
.futuristic-opacity-50 { opacity: 0.5; }
.futuristic-opacity-60 { opacity: 0.6; }
.futuristic-opacity-70 { opacity: 0.7; }
.futuristic-opacity-80 { opacity: 0.8; }
.futuristic-opacity-90 { opacity: 0.9; }

/* Enhanced Contrast */
.futuristic-contrast-high {
  filter: contrast(1.2) brightness(1.1);
}

.futuristic-contrast-medium {
  filter: contrast(1.1) brightness(1.05);
}

.futuristic-contrast-low {
  filter: contrast(0.9) brightness(0.95);
}

/* Enhanced Visibility */
.futuristic-visible {
  visibility: visible;
  opacity: 1;
  transition: all 0.3s ease;
}

.futuristic-hidden {
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

/* Enhanced Spacing */
.futuristic-space-xs { margin: 4px; padding: 4px; }
.futuristic-space-sm { margin: 8px; padding: 8px; }
.futuristic-space-md { margin: 16px; padding: 16px; }
.futuristic-space-lg { margin: 24px; padding: 24px; }
.futuristic-space-xl { margin: 32px; padding: 32px; }
.futuristic-space-2xl { margin: 48px; padding: 48px; }

/* Enhanced Pagination */
.futuristic-pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
  margin: 32px 0;
}

.futuristic-pagination-item {
  padding: 8px 16px;
  border: 1px solid rgba(0, 255, 255, 0.3);
  border-radius: 4px;
  color: white;
  text-decoration: none;
  transition: all 0.3s ease;
}

.futuristic-pagination-item:hover,
.futuristic-pagination-item.active {
  background: rgba(0, 255, 255, 0.2);
  border-color: var(--neon-cyan);
  color: var(--neon-cyan);
}

/* Enhanced Sidebar */
.futuristic-sidebar {
  background: rgba(15, 15, 35, 0.95);
  backdrop-filter: blur(20px);
  border-right: 1px solid rgba(0, 255, 255, 0.3);
  min-height: 100vh;
  width: 280px;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 1000;
  transition: transform 0.3s ease;
}

.futuristic-sidebar-item {
  padding: 16px 24px;
  color: white;
  text-decoration: none;
  border-bottom: 1px solid rgba(0, 255, 255, 0.1);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  gap: 12px;
}

.futuristic-sidebar-item:hover {
  background: rgba(0, 255, 255, 0.1);
  color: var(--neon-cyan);
  padding-left: 32px;
}

.futuristic-sidebar-item.active {
  background: rgba(0, 255, 255, 0.2);
  color: var(--neon-cyan);
  border-left: 4px solid var(--neon-cyan);
}

/* Enhanced Footer */
.futuristic-footer {
  background: rgba(15, 15, 35, 0.95);
  backdrop-filter: blur(20px);
  border-top: 1px solid rgba(0, 255, 255, 0.3);
  padding: 48px 0 24px;
  margin-top: auto;
}

.futuristic-footer-content {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 32px;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

.futuristic-footer-section h3 {
  color: var(--neon-cyan);
  font-family: 'Orbitron', monospace;
  font-weight: 600;
  margin-bottom: 16px;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.futuristic-footer-section p,
.futuristic-footer-section a {
  color: rgba(255, 255, 255, 0.8);
  text-decoration: none;
  transition: color 0.3s ease;
}

.futuristic-footer-section a:hover {
  color: var(--neon-cyan);
}

/* Enhanced Mobile Experience */
@media (max-width: 768px) {
  .futuristic-sidebar {
    transform: translateX(-100%);
    width: 100%;
  }
  
  .futuristic-sidebar.open {
    transform: translateX(0);
  }
  
  .futuristic-grid {
    grid-template-columns: 1fr;
    gap: 16px;
    padding: 16px;
  }
  
  .futuristic-footer-content {
    grid-template-columns: 1fr;
    gap: 24px;
    padding: 0 16px;
  }
}

/* Enhanced Accessibility */
@media (prefers-reduced-motion: reduce) {
  .futuristic-card,
  .futuristic-btn,
  .futuristic-nav-item,
  .futuristic-sidebar-item {
    transition: none;
  }
  
  .matrix-rain::before,
  .particle-bg::before,
  .scan-line::after,
  .data-stream::before {
    animation: none;
  }
}

