@layer components {
  /* Futuristic Neon Effects */
  .neon-glow {
    box-shadow: 
      0 0 5px currentColor,
      0 0 10px currentColor,
      0 0 15px currentColor,
      0 0 20px currentColor;
  }

  .neon-cyan {
    color: #22ddd2;
    text-shadow: 
      0 0 5px #22ddd2,
      0 0 10px #22ddd2,
      0 0 15px #22ddd2,
      0 0 20px #22ddd2;
  }

  .neon-purple {
    color: #8c15e9;
    text-shadow: 
      0 0 5px #8c15e9,
      0 0 10px #8c15e9,
      0 0 15px #8c15e9,
      0 0 20px #8c15e9;
  }

  .neon-blue {
    color: #2e73ea;
    text-shadow: 
      0 0 5px #2e73ea,
      0 0 10px #2e73ea,
      0 0 15px #2e73ea,
      0 0 20px #2e73ea;
  }

  /* Animated Backgrounds */
  .bg-futuristic {
    background: 
      radial-gradient(circle at 20% 80%, rgba(34, 221, 210, 0.15) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(140, 21, 233, 0.15) 0%, transparent 50%),
      radial-gradient(circle at 40% 40%, rgba(46, 115, 234, 0.15) 0%, transparent 50%),
      radial-gradient(circle at 60% 60%, rgba(34, 197, 94, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 10% 30%, rgba(236, 72, 153, 0.1) 0%, transparent 50%),
      linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);
    background-size: 100% 100%;
    animation: gradient-shift 20s ease infinite;
    position: relative;
    overflow: hidden;
  }

  .bg-futuristic::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
      radial-gradient(circle at 50% 50%, rgba(34, 221, 210, 0.05) 0%, transparent 70%);
    animation: pulse-glow 8s ease-in-out infinite;
    pointer-events: none;
  }

  .bg-futuristic::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
      linear-gradient(45deg, transparent 30%, rgba(140, 21, 233, 0.03) 50%, transparent 70%);
    animation: scan-line 12s linear infinite;
    pointer-events: none;
  }

  .bg-mesh-gradient {
    background: linear-gradient(45deg, #8c15e9, #22ddd2, #2e73ea, #8c15e9);
    background-size: 400% 400%;
    animation: gradient-shift 3s ease infinite;
  }

  /* Glass Morphism */
  .glass {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  .glass-dark {
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  /* Floating Elements */
  .float {
    animation: float 6s ease-in-out infinite;
  }

  .float-delayed {
    animation: float 6s ease-in-out infinite;
    animation-delay: 2s;
  }

  .float-slow {
    animation: float 8s ease-in-out infinite;
  }

  /* Holographic Effects */
  .holographic {
    background: linear-gradient(45deg, #00d4ff, #8b5cf6, #ec4899, #10b981);
    background-size: 400% 400%;
    animation: holographic-shift 3s ease infinite;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .holographic-border {
    position: relative;
    border: 2px solid transparent;
    background: linear-gradient(45deg, #00d4ff, #8b5cf6, #ec4899, #10b981);
    background-clip: padding-box;
    border-radius: 8px;
  }

  .holographic-border::before {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: linear-gradient(45deg, #00d4ff, #8b5cf6, #ec4899, #10b981);
    background-size: 400% 400%;
    animation: holographic-shift 3s ease infinite;
    border-radius: 8px;
    z-index: -1;
  }

  /* Matrix Rain Effect */
  .matrix-rain {
    position: relative;
    overflow: hidden;
  }

  .matrix-rain::before {
    content: '';
    position: absolute;
    top: -100%;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, transparent, rgba(0, 255, 0, 0.1), transparent);
    animation: matrix-rain 3s linear infinite;
    pointer-events: none;
  }

  /* Cyber Grid */
  .cyber-grid {
    background-image: 
      linear-gradient(rgba(34, 221, 210, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(34, 221, 210, 0.1) 1px, transparent 1px);
    background-size: 20px 20px;
    animation: grid-move 20s linear infinite;
  }

  /* Neon Text Effects */
  .neon-text-cyan {
    color: #22ddd2;
    text-shadow: 
      0 0 5px #22ddd2,
      0 0 10px #22ddd2,
      0 0 15px #22ddd2,
      0 0 20px #22ddd2,
      0 0 35px #22ddd2;
    animation: neon-flicker 2s ease-in-out infinite alternate;
  }

  .neon-text-purple {
    color: #8c15e9;
    text-shadow: 
      0 0 5px #8c15e9,
      0 0 10px #8c15e9,
      0 0 15px #8c15e9,
      0 0 20px #8c15e9,
      0 0 35px #8c15e9;
    animation: neon-flicker 2s ease-in-out infinite alternate;
  }

  .neon-text-blue {
    color: #2e73ea;
    text-shadow: 
      0 0 5px #2e73ea,
      0 0 10px #2e73ea,
      0 0 15px #2e73ea,
      0 0 20px #2e73ea,
      0 0 35px #2e73ea;
    animation: neon-flicker 2s ease-in-out infinite alternate;
  }

  /* Hover Effects */
  .hover-lift {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hover-lift:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .hover-glow:hover {
    box-shadow: 0 0 30px rgba(34, 221, 210, 0.6);
  }

  /* Text Gradients */
  .text-gradient {
    background: linear-gradient(45deg, #22ddd2, #8c15e9, #2e73ea);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% 200%;
    animation: gradient-shift 3s ease infinite;
  }

  .text-gradient-cyan {
    background: linear-gradient(45deg, #22ddd2, #7aeae4);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .text-gradient-purple {
    background: linear-gradient(45deg, #8c15e9, #b971f2);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Button Styles */
  .btn-futuristic {
    @apply relative overflow-hidden px-6 py-3 rounded-lg font-medium transition-all duration-300;
    background: linear-gradient(45deg, #22ddd2, #8c15e9);
    background-size: 200% 200%;
    animation: gradient-shift 3s ease infinite;
  }

  .btn-futuristic:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(34, 221, 210, 0.4);
  }

  .btn-neon {
    @apply relative px-6 py-3 rounded-lg font-medium transition-all duration-300;
    background: transparent;
    border: 2px solid #22ddd2;
    color: #22ddd2;
  }

  .btn-neon:hover {
    background: #22ddd2;
    color: #000;
    box-shadow: 0 0 20px rgba(34, 221, 210, 0.6);
  }

  /* Card Styles */
  .card-futuristic {
    @apply relative overflow-hidden rounded-xl p-6 transition-all duration-300;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .card-futuristic:hover {
    transform: translateY(-5px);
    border-color: rgba(34, 221, 210, 0.5);
    box-shadow: 0 20px 40px rgba(34, 221, 210, 0.2);
  }

  /* Navigation Styles */
  .nav-link {
    @apply relative px-4 py-2 text-sm font-medium transition-all duration-300;
    color: rgba(255, 255, 255, 0.8);
  }

  .nav-link:hover {
    color: #22ddd2;
  }

  .nav-link::after {
    content: '';
    @apply absolute bottom-0 left-0 w-0 h-0.5 bg-gradient-to-r from-zion-cyan to-zion-purple transition-all duration-300;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  /* Responsive Grid */
  .grid-futuristic {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  /* Loading Animations */
  .loading-dots {
    display: inline-block;
  }

  .loading-dots::after {
    content: '';
    animation: loading-dots 1.5s infinite;
  }

  @keyframes loading-dots {
    0%, 20% { content: ''; }
    40% { content: '.'; }
    60% { content: '..'; }
    80%, 100% { content: '...'; }
  }
