  /* Enhanced Animation Utilities */
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  .animate-pulse-slow {
    animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  .animate-glow {
    animation: glow 2s ease-in-out infinite alternate;
  }

  .animate-shimmer {
    animation: shimmer 2.5s linear infinite;
  }

  .animate-gradient {
    animation: gradient 8s ease infinite;
  }

  .animate-neon-pulse {
    animation: neon-pulse 1.5s ease-in-out infinite alternate;
  }

  .animate-holographic-shift {
    animation: holographic-shift 3s ease infinite;
  }

  .animate-cyber-float {
    animation: cyber-float 6s ease-in-out infinite;
  }

  .animate-particle-drift {
    animation: particle-drift 8s linear infinite;
  }

  .animate-matrix-rain {
    animation: matrix-rain 3s linear infinite;
  }

  .animate-neon-text-glow {
    animation: neon-text-glow 2s ease-in-out infinite;
  }

  .animate-scan-line {
    animation: scan-line 3s linear infinite;
  }

  .animate-glitch {
    animation: glitch 0.3s ease-in-out infinite;
  }

  .animate-typewriter {
    animation: typewriter 3s steps(40) infinite;
  }

  .animate-breathe {
    animation: breathe 4s ease-in-out infinite;
  }

  .animate-orbit {
    animation: orbit 20s linear infinite;
  }

  .animate-pulse-neon {
    animation: pulse-neon 1.5s ease-in-out infinite;
  }

  .animate-wave {
    animation: wave 2s ease-in-out infinite;
  }

  /* Animation Delays */
  .animation-delay-1000 {
    animation-delay: 1s;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-3000 {
    animation-delay: 3s;
  }

  /* Enhanced Background Utilities */
  .bg-futuristic {
    background: linear-gradient(135deg, #0f0f23 0%, #1a1a2e 50%, #16213e 100%);
  }

  .bg-cyber-grid {
    background-image: 
      linear-gradient(rgba(6,182,212,0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(6,182,212,0.1) 1px, transparent 1px);
    background-size: 50px 50px;
  }

  .bg-neon-glow {
    box-shadow: 
      0 0 20px rgba(34, 211, 238, 0.3),
      0 0 40px rgba(34, 211, 238, 0.2),
      0 0 60px rgba(34, 211, 238, 0.1);
  }

  /* Enhanced Border Utilities */
  .border-neon {
    border: 1px solid rgba(34, 211, 238, 0.5);
    box-shadow: 0 0 10px rgba(34, 211, 238, 0.3);
  }

  .border-glow {
    border: 1px solid rgba(34, 211, 238, 0.3);
    box-shadow: 
      inset 0 0 10px rgba(34, 211, 238, 0.1),
      0 0 20px rgba(34, 211, 238, 0.2);
  }

  /* Enhanced Shadow Utilities */
  .shadow-neon {
    box-shadow: 
      0 0 20px rgba(34, 211, 238, 0.3),
      0 0 40px rgba(34, 211, 238, 0.2),
      0 0 60px rgba(34, 211, 238, 0.1);
  }

  .shadow-cyber {
    box-shadow: 
      0 4px 20px rgba(0, 0, 0, 0.3),
      0 0 40px rgba(34, 211, 238, 0.1);
  }

  /* Enhanced Text Utilities */
  .text-neon {
    text-shadow: 
      0 0 5px rgba(34, 211, 238, 0.8),
      0 0 10px rgba(34, 211, 238, 0.6),
      0 0 15px rgba(34, 211, 238, 0.4);
  }

  .text-cyber {
    text-shadow: 
      0 0 10px rgba(34, 211, 238, 0.5),
      0 0 20px rgba(34, 211, 238, 0.3),
      0 0 30px rgba(34, 211, 238, 0.1);
  }

  /* Enhanced Hover Utilities */
  .hover-lift {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .hover-lift:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .hover-glow {
    transition: all 0.3s ease;
  }

  .hover-glow:hover {
    box-shadow: 0 0 30px rgba(34, 211, 238, 0.4);
  }

  /* Enhanced Responsive Utilities */
  .container-responsive {
    @apply container mx-auto px-4 sm:px-6 lg:px-8;
  }

  .grid-responsive {
    @apply grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 lg:gap-8;
  }

  .text-responsive {
    @apply text-base sm:text-lg lg:text-xl xl:text-2xl;
  }

  .heading-responsive {
    @apply text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl;
  }

  /* Enhanced Scrollbar */
  .scrollbar-futuristic {
    scrollbar-width: thin;
    scrollbar-color: rgba(34, 211, 238, 0.5) rgba(15, 23, 42, 0.3);
  }

  .scrollbar-futuristic::-webkit-scrollbar {
    width: 8px;
  }

  .scrollbar-futuristic::-webkit-scrollbar-track {
    background: rgba(15, 23, 42, 0.3);
    border-radius: 4px;
  }

  .scrollbar-futuristic::-webkit-scrollbar-thumb {
    background: rgba(34, 211, 238, 0.5);
    border-radius: 4px;
  }

  .scrollbar-futuristic::-webkit-scrollbar-thumb:hover {
    background: rgba(34, 211, 238, 0.7);
  }

  /* Enhanced Focus Utilities */
  .focus-neon:focus {
    outline: none;
    box-shadow: 
      0 0 0 3px rgba(34, 211, 238, 0.1),
      0 0 0 6px rgba(34, 211, 238, 0.05);
  }

  .focus-cyber:focus {
    outline: none;
    border-color: rgba(34, 211, 238, 0.5);
    box-shadow: 0 0 20px rgba(34, 211, 238, 0.2);
  }
}

