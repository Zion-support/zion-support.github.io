@layer base {
  * {
    @apply border-slate-300 dark:border-slate-700;
  }

  body {
    @apply bg-white text-gray-900 dark:bg-slate-950 dark:text-slate-100;
    font-feature-settings: "rlig" 1, "calt" 1;
  }

  /* Enhanced Typography */
  h1, h2, h3, h4, h5, h6 {
    @apply font-sans;
  }

  p, span, div {
    @apply font-sans;
  }
}

@layer components {
  .btn-primary {
    @apply futuristic-button;
  }

  .btn-secondary {
    @apply bg-slate-800/70 border border-slate-600 text-slate-300 px-6 py-3 rounded-lg font-semibold hover:bg-slate-700/70 hover:border-slate-500 transition-all duration-300;
  }

  .card {
    @apply futuristic-card;
  }

  .input {
    @apply futuristic-input;
  }

  .nav-item {
    @apply futuristic-nav-item;
  }

  .heading {
    @apply futuristic-heading;
  }

  .subheading {
    @apply futuristic-subheading;
  }

  .loading {
    @apply animate-pulse;
  }

  .animate {
    @apply transition-all duration-300 ease-out;
  }

  .focus {
    @apply focus:outline-none focus:ring-2 focus:ring-blue-500/40;
  }
}

@layer utilities {
  .text-balance {
    text-wrap: balance;
  }

  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  .bg-gradient-zion {
    background: linear-gradient(135deg, #22ddd2, #38bdf8, #a855f7);
  }

  .text-gradient-zion {
    background: linear-gradient(135deg, #22ddd2, #38bdf8, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .border-gradient-zion {
    border: 2px solid;
    border-image: linear-gradient(135deg, #22ddd2, #38bdf8, #a855f7) 1;
  }

  .shadow-zion {
    box-shadow: 
      0 8px 32px rgba(34, 221, 210, 0.2),
      0 0 0 1px rgba(34, 221, 210, 0.1);
  }

  .animate-slide-in-left {
    animation: slide-in-left 0.6s ease-out;
  }

  .animate-slide-in-right {
    animation: slide-in-right 0.6s ease-out;
  }

  .animate-neon-flicker {
    animation: neon-flicker 2s ease-in-out infinite;
  }

  /* Responsive Utilities */
  .container-responsive {
    @apply max-w-7xl mx-auto px-4 sm:px-6 lg:px-8;
  }

  .section-padding {
    @apply py-16 sm:py-20 lg:py-24;
  }

  .text-responsive {
    @apply text-sm sm:text-base lg:text-lg;
  }

  .heading-responsive {
    @apply text-2xl sm:text-3xl lg:text-4xl xl:text-5xl;
  }

  /* Accessibility Styles */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .high-contrast {
    --text-primary: #ffffff;
    --text-secondary: #e5e7eb;
    --bg-primary: #000000;
    --bg-secondary: #111827;
    --accent: #fbbf24;
  }

  .large-text {
    font-size: 1.2em;
    line-height: 1.6;
  }

  .reduced-motion * {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }

  .focus-visible *:focus {
    outline: 3px solid #fbbf24 !important;
    outline-offset: 2px !important;
  }

  .keyboard-navigation *:focus {
    outline: 3px solid #fbbf24 !important;
    outline-offset: 2px !important;
  }

  .light-theme {
    --bg-primary: #ffffff;
    --bg-secondary: #f8fafc;
    --text-primary: #0f172a;
    --text-secondary: #475569;
  }

  .dark-theme {
    --bg-primary: #0f172a;
    --bg-secondary: #1e293b;
    --text-primary: #f8fafc;
    --text-secondary: #cbd5e1;
  }

  /* Focus styles for better accessibility */
  *:focus {
    outline: 2px solid #22ddd2;
    outline-offset: 2px;
  }

  /* Skip to content link */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 6px;
    background: #22ddd2;
    color: #000;
    padding: 8px;
    text-decoration: none;
    border-radius: 4px;
    z-index: 1000;
  }

  .skip-link:focus {
    top: 6px;
  }
}

/* Animations */
@keyframes slide-in-left {
  from {
    transform: translateX(-100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

@keyframes slide-in-right {
  from {
    transform: translateX(100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

@keyframes neon-flicker {
  0%, 100% {
    box-shadow: 
      0 0 5px #22ddd2,
      0 0 10px #22ddd2,
      0 0 15px #22ddd2,
      0 0 20px #22ddd2;
  }
  50% {
    box-shadow: 
      0 0 2px #22ddd2,
      0 0 5px #22ddd2,
      0 0 8px #22ddd2,
      0 0 12px #22ddd2;
  }
}