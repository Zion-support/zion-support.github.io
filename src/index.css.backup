@tailwind base;
@tailwind components;
@tailwind utilities;

/* Zion Tech Group Custom Styles */
:root {
  /* Zion Tech Group Brand Colors */
  --zion-blue: #0ea5e9;
  --zion-cyan: #06b6d4;
  --zion-purple: #8b5cf6;
  --zion-pink: #a855f7;
  --zion-orange: #f59e0b;
  --zion-green: #10b981;
  --zion-red: #ef4444;
  --zion-yellow: #eab308;
  
  /* Zion Tech Group Slate Colors */
  --zion-slate-dark: #0f172a;
  --zion-slate: #334155;
  --zion-slate-light: #64748b;
  --zion-slate-lighter: #64748b;
  
  /* Zion Tech Group Purple Variants */
  --zion-purple-dark: #581c87;
  --zion-purple-light: #a855f7;
  
  /* Legacy CSS Variables for Compatibility */
  --background: 0 0% 7%;
  --foreground: 142 71% 45%;
  --card: 0 0% 7%;
  --card-foreground: 142 71% 45%;
  --popover: 0 0% 7%;
  --popover-foreground: 142 71% 45%;
  --primary: 216 84% 50%;
  --primary-foreground: 142 71% 45%;
  --secondary: 0 0% 68%;
  --secondary-foreground: 0 0% 7%;
  --muted: 0 0% 68%;
  --muted-foreground: 215 20% 65%;
  --accent: 228 12% 92%;
  --accent-foreground: 0 0% 7%;
  --destructive: 0 84.2% 60.2%;
  --destructive-foreground: 142 71% 45%;
  --border: 0 0% 68%;
  --input: 0 0% 68%;
  --ring: 216 84% 53%;
  --radius: 0.5rem;
  --sidebar-background: 228 12% 92%;
  --sidebar-foreground: 0 0% 7%;
  --sidebar-primary: 216 84% 53%;
  --sidebar-primary-foreground: 142 71% 45%;
  --sidebar-accent: 0 0% 68%;
  --sidebar-accent-foreground: 0 0% 7%;
  --sidebar-border: 0 0% 68%;
  --sidebar-ring: 216 84% 53%;
}

.dark {
  --background: 0 0% 7%;
  --foreground: 142 71% 45%;
  --card: 0 0% 7%;
  --card-foreground: 142 71% 45%;
  --popover: 0 0% 7%;
  --popover-foreground: 142 71% 45%;
  --primary: 216 84% 50%;
  --primary-foreground: 142 71% 45%;
  --secondary: 0 0% 68%;
  --secondary-foreground: 0 0% 7%;
  --muted: 0 0% 68%;
  --muted-foreground: 215 20% 65%;
  --accent: 228 12% 92%;
  --accent-foreground: 0 0% 7%;
  --destructive: 0 62.8% 30.6%;
  --destructive-foreground: 142 71% 45%;
  --border: 0 0% 68%;
  --input: 0 0% 68%;
  --ring: 216 84% 53%;
  --sidebar-background: 228 12% 92%;
  --sidebar-foreground: 0 0% 7%;
  --sidebar-primary: 216 84% 53%;
  --sidebar-primary-foreground: 142 71% 45%;
  --sidebar-accent: 0 0% 68%;
  --sidebar-accent-foreground: 0 0% 7%;
  --sidebar-border: 0 0% 68%;
  --sidebar-ring: 216 84% 53%;
}

.light {
  --background: 0 0% 100%;
  --foreground: 224 71% 4%;
  --card: 0 0% 100%;
  --card-foreground: 224 71% 4%;
  --popover: 0 0% 100%;
  --popover-foreground: 224 71% 4%;
  --primary: 216 84% 50%;
  --primary-foreground: 142 71% 45%;
  --secondary: 0 0% 68%;
  --secondary-foreground: 0 0% 7%;
  --muted: 0 0% 68%;
  --muted-foreground: 215 20% 65%;
  --accent: 228 12% 92%;
  --accent-foreground: 0 0% 7%;
  --destructive: 0 62.8% 30.6%;
  --destructive-foreground: 142 71% 45%;
  --border: 0 0% 68%;
  --input: 0 0% 68%;
  --ring: 216 84% 53%;
  --sidebar-background: 228 12% 92%;
  --sidebar-foreground: 0 0% 7%;
  --sidebar-primary: 216 84% 53%;
  --sidebar-primary-foreground: 142 71% 45%;
  --sidebar-accent: 0 0% 68%;
  --sidebar-accent-foreground: 0 0% 7%;
  --sidebar-border: 0 0% 68%;
  --sidebar-ring: 216 84% 53%;
}

@layer base {
  * {
    @apply border-border;
  }
  
  body {
    @apply bg-background text-foreground overflow-x-hidden;
    font-feature-settings: "rlig" 1, "calt" 1;
  }
  
  /* Enhanced Scrollbar Styling */
  ::-webkit-scrollbar {
    width: 12px;
    height: 12px;
  }
  
  ::-webkit-scrollbar-track {
    background: linear-gradient(135deg, var(--zion-slate-dark), var(--zion-slate));
    border-radius: 6px;
  }
  
  ::-webkit-scrollbar-thumb {
    background: linear-gradient(135deg, var(--zion-cyan), var(--zion-purple));
    border-radius: 6px;
    border: 2px solid transparent;
    background-clip: content-box;
  }
  
  ::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(135deg, var(--zion-purple), var(--zion-pink));
  }
  
  /* Custom Selection Styling */
  ::selection {
    background: linear-gradient(135deg, var(--zion-cyan), var(--zion-purple));
    color: white;
  }
  
  ::-moz-selection {
    background: linear-gradient(135deg, var(--zion-cyan), var(--zion-purple));
    color: white;
  }
}

@layer components {
  /* Futuristic Card Component */
  .futuristic-card {
    @apply bg-gradient-to-br from-zion-slate-dark/80 via-zion-slate/60 to-zion-slate-light/40;
    @apply backdrop-blur-xl border border-zion-cyan/20;
    @apply shadow-2xl;
    @apply rounded-2xl overflow-hidden;
    @apply transition-all duration-500 ease-out;
  }
  
  .futuristic-card:hover {
    box-shadow: 0 25px 50px -12px rgba(6, 182, 212, 0.2);
    border-color: rgba(6, 182, 212, 0.4);
    transform: scale(1.02) translateY(-4px);
  }
  
  /* Futuristic Button Component */
  .futuristic-button {
    @apply bg-gradient-to-r from-zion-cyan to-zion-purple;
    @apply text-white font-semibold px-6 py-3;
    @apply rounded-xl shadow-lg;
    @apply transition-all duration-300 ease-out;
    @apply hover:scale-105;
    @apply active:scale-95 focus:outline-none;
  }
  
  .futuristic-button:hover {
    background: linear-gradient(to right, var(--zion-purple), var(--zion-purple-light));
    box-shadow: 0 10px 25px -3px rgba(139, 92, 246, 0.4);
  }
  
  .futuristic-button:focus {
    outline: none;
    box-shadow: 0 0 0 2px var(--zion-cyan), 0 0 0 4px rgba(6, 182, 212, 0.5);
  }
  
  /* Futuristic Input Component */
  .futuristic-input {
    @apply bg-zion-slate-dark/60 backdrop-blur-sm;
    @apply border border-zion-cyan/30 rounded-xl;
    @apply text-white placeholder-zion-slate-light;
    @apply px-4 py-3 transition-all duration-300;
    @apply focus:border-zion-cyan focus:ring-2;
    @apply focus:ring-zion-cyan/20 focus:outline-none;
    @apply hover:border-zion-cyan/50;
  }
  
  /* Futuristic Heading Components */
  .futuristic-heading {
    @apply text-4xl md:text-5xl lg:text-6xl font-bold;
    @apply bg-gradient-to-r from-zion-cyan via-zion-purple to-zion-purple-light;
    @apply bg-clip-text text-transparent;
    @apply leading-tight tracking-tight;
  }
  
  .futuristic-subheading {
    @apply text-2xl md:text-3xl lg:text-4xl font-semibold;
    @apply bg-gradient-to-r from-zion-cyan to-zion-purple;
    @apply bg-clip-text text-transparent;
    @apply leading-relaxed;
  }
  
  .futuristic-text {
    @apply text-lg text-zion-slate-light leading-relaxed;
    @apply max-w-4xl mx-auto;
  }
  
  /* Navigation Link Component */
  .nav-link {
    @apply text-zion-slate-light hover:text-zion-cyan;
    @apply transition-colors duration-300 ease-out;
    @apply relative overflow-hidden;
  }
  
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--zion-cyan);
    transition: width 0.3s ease-out;
  }
  
  .nav-link:hover::after {
    width: 100%;
  }
  
  /* Service Card Component */
  .service-card {
    @apply futuristic-card p-6;
    @apply group cursor-pointer;
  }
  
  .service-card:hover {
    background: linear-gradient(to bottom right, rgba(15, 23, 42, 0.9), rgba(51, 65, 85, 0.7), rgba(100, 116, 139, 0.5));
  }
  
  /* Hero Section Component */
  .hero-section {
    @apply relative min-h-screen flex items-center justify-center;
    @apply overflow-hidden;
    @apply bg-gradient-to-br from-zion-slate-dark via-zion-slate to-zion-slate-light;
  }
  
  /* Stats Card Component */
  .stats-card {
    @apply futuristic-card p-8 text-center;
  }
  
  .stats-card:hover {
    background: linear-gradient(to bottom right, rgba(15, 23, 42, 0.9), rgba(51, 65, 85, 0.7), rgba(100, 116, 139, 0.5));
  }
  
  .stats-number {
    @apply text-4xl md:text-5xl font-bold;
    @apply bg-gradient-to-r from-zion-cyan to-zion-purple;
    @apply bg-clip-text text-transparent;
    @apply mb-2;
  }
  
  /* Feature Item Component */
  .feature-item {
    @apply flex items-start space-x-4 p-6;
    @apply futuristic-card;
  }
  
  .feature-item:hover {
    background: linear-gradient(to bottom right, rgba(15, 23, 42, 0.9), rgba(51, 65, 85, 0.7), rgba(100, 116, 139, 0.5));
  }
  
  .feature-icon {
    @apply w-12 h-12 rounded-xl;
    @apply bg-gradient-to-br from-zion-cyan to-zion-purple;
    @apply flex items-center justify-center;
    @apply text-white text-xl font-bold;
    @apply flex-shrink-0;
  }
  
  /* CTA Section Component */
  .cta-section {
    @apply relative py-20 overflow-hidden;
    @apply bg-gradient-to-br from-zion-slate-dark via-zion-slate to-zion-slate-light;
  }
  
  .cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(6, 182, 212, 0.1), rgba(139, 92, 246, 0.1), rgba(168, 85, 247, 0.1));
  }
}

@layer utilities {
  /* Text Glow Effects */
  .text-glow {
    text-shadow: 0 0 20px currentColor, 0 0 40px currentColor;
  }
  
  .text-glow-cyan {
    text-shadow: 0 0 20px var(--zion-cyan), 0 0 40px var(--zion-cyan);
  }
  
  .text-glow-purple {
    text-shadow: 0 0 20px var(--zion-purple), 0 0 40px var(--zion-purple);
  }
  
  .text-glow-pink {
    text-shadow: 0 0 20px var(--zion-pink), 0 0 40px var(--zion-pink);
  }
  
  /* Background Glass Effects */
  .bg-glass {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }
  
  .bg-glass-dark {
    background: rgba(15, 23, 42, 0.8);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(6, 182, 212, 0.2);
  }
  
  /* Border Glow Effects */
  .border-glow {
    box-shadow: 0 0 20px currentColor, inset 0 0 20px currentColor;
  }
  
  .border-glow-cyan {
    box-shadow: 0 0 20px var(--zion-cyan), inset 0 0 20px var(--zion-cyan);
  }
  
  .border-glow-purple {
    box-shadow: 0 0 20px var(--zion-purple), inset 0 0 20px var(--zion-purple);
  }
  
  /* Responsive Spacing Utilities */
  .section-padding {
    @apply py-16 md:py-20 lg:py-24;
  }
  
  .container-padding {
    @apply px-4 sm:px-6 lg:px-8;
  }
  
  /* Animation Utilities */
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  .animate-cyber-float {
    animation: cyber-float 8s ease-in-out infinite;
  }
  
  .animate-matrix {
    animation: matrix 10s linear infinite;
  }
  
  .animate-neon-pulse {
    animation: neon-pulse 2s ease-in-out infinite alternate;
  }
  
  .animate-hero-glow {
    animation: hero-glow 4s ease-in-out infinite alternate;
  }
  
  .animate-cta-glow {
    animation: cta-glow 3s ease-in-out infinite alternate;
  }
  
  .animate-shimmer {
    animation: shimmer 2s linear infinite;
  }
  
  /* Animation Delays */
  .animation-delay-100 { animation-delay: 100ms; }
  .animation-delay-200 { animation-delay: 200ms; }
  .animation-delay-300 { animation-delay: 300ms; }
  .animation-delay-400 { animation-delay: 400ms; }
  .animation-delay-500 { animation-delay: 500ms; }
  .animation-delay-600 { animation-delay: 600ms; }
  .animation-delay-700 { animation-delay: 700ms; }
  .animation-delay-800 { animation-delay: 800ms; }
  .animation-delay-900 { animation-delay: 900ms; }
  .animation-delay-1000 { animation-delay: 1000ms; }
}

/* Custom Keyframe Animations */
@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-20px); }
}

@keyframes cyber-float {
  0%, 100% { 
    transform: translateY(0px) rotate(0deg); 
    filter: hue-rotate(0deg);
  }
  25% { 
    transform: translateY(-15px) rotate(2deg); 
    filter: hue-rotate(90deg);
  }
  50% { 
    transform: translateY(-25px) rotate(0deg); 
    filter: hue-rotate(180deg);
  }
  75% { 
    transform: translateY(-15px) rotate(-2deg); 
    filter: hue-rotate(270deg);
  }
}

@keyframes matrix {
  0% { 
    background-position: 0% 0%;
    filter: hue-rotate(0deg);
  }
  100% { 
    background-position: 100% 100%;
    filter: hue-rotate(360deg);
  }
}

@keyframes neon-pulse {
  0% { 
    box-shadow: 0 0 5px currentColor, 0 0 10px currentColor, 0 0 15px currentColor;
    filter: brightness(1);
  }
  100% { 
    box-shadow: 0 0 10px currentColor, 0 0 20px currentColor, 0 0 30px currentColor;
    filter: brightness(1.2);
  }
}

@keyframes hero-glow {
  0% { 
    background: radial-gradient(circle at 30% 30%, var(--zion-cyan) 0%, transparent 50%);
    opacity: 0.3;
  }
  100% { 
    background: radial-gradient(circle at 70% 70%, var(--zion-purple) 0%, transparent 50%);
    opacity: 0.6;
  }
}

@keyframes cta-glow {
  0% { 
    background: linear-gradient(45deg, var(--zion-cyan), var(--zion-purple));
    transform: scale(1);
  }
  100% { 
    background: linear-gradient(45deg, var(--zion-purple), var(--zion-pink));
    transform: scale(1.05);
  }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* Media Queries for Responsive Design */
@media (max-width: 640px) {
  .futuristic-heading {
    @apply text-3xl leading-tight;
  }
  
  .futuristic-subheading {
    @apply text-xl leading-relaxed;
  }
  
  .section-padding {
    @apply py-12;
  }
}

@media (max-width: 768px) {
  .futuristic-card {
    @apply rounded-xl;
  }
  
  .futuristic-button {
    @apply px-4 py-2 text-sm;
  }
}

@media (max-width: 1024px) {
  .container-padding {
    @apply px-6;
  }
}

/* Print Styles */
@media print {
  .futuristic-card,
  .futuristic-button,
  .futuristic-input {
    @apply shadow-none border border-gray-300;
  }
  
  .futuristic-heading,
  .futuristic-subheading {
    @apply text-black;
  }
  
  .bg-gradient-to-br,
  .bg-gradient-to-r {
    @apply bg-white;
  }
}

/* Reduced Motion Preferences */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
  
  .animate-float,
  .animate-cyber-float,
  .animate-matrix,
  .animate-neon-pulse,
  .animate-hero-glow,
  .animate-cta-glow,
  .animate-shimmer {
    animation: none !important;
  }
}

/* High Contrast Mode Support */
@media (prefers-contrast: high) {
  .futuristic-card {
    @apply border-2 border-zion-cyan;
  }
  
  .futuristic-button {
    @apply border-2 border-white;
  }
  
  .futuristic-input {
    @apply border-2 border-zion-cyan;
  }
}

/* Focus Visible for Accessibility */
.futuristic-button:focus-visible,
.futuristic-input:focus-visible,
.nav-link:focus-visible {
  outline: none;
  box-shadow: 0 0 0 2px var(--zion-cyan), 0 0 0 4px rgba(15, 23, 42, 1);
}

/* Dark Mode Enhancements */
@media (prefers-color-scheme: dark) {
  .futuristic-card {
    @apply bg-zion-slate-dark/90;
  }
  
  .futuristic-input {
    @apply bg-zion-slate-dark/80;
  }
}

/* Light Mode Enhancements */
@media (prefers-color-scheme: light) {
  .futuristic-card {
    @apply bg-white/90 shadow-lg;
  }
  
  .futuristic-input {
    @apply bg-white/80 border-zion-slate;
  }
}
