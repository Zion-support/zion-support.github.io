<<<<<<< HEAD
  .fade-in-up {
    animation: fade-in-up 0.8s ease-out;
  }

  /* Hover Effects */
  .hover-lift {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .hover-lift:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(34, 221, 210, 0.3);
  }

  .hover-glow:hover {
    box-shadow: 0 0 20px #22ddd2, 0 0 40px #22ddd2;
  }

  /* Glassmorphism */
  .glass {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }
  /* Large Text Mode */
  .large-text {
    font-size: 1.2em;
    line-height: 1.6;
  }
  
  .large-text h1 { font-size: 2.5em; }
  .large-text h2 { font-size: 2em; }
  .large-text h3 { font-size: 1.75em; }
  .large-text p { font-size: 1.2em; }
}

/* Zion Tech Group specific styles */
.zion-gradient {
  background: linear-gradient(135deg, #60a5fa 0%, #22d3ee 50%, #a78bfa 100%);
}

.zion-text-gradient {
  background: linear-gradient(135deg, #60a5fa 0%, #22d3ee 50%, #a78bfa 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.zion-border-gradient {
  border: 2px solid;
  border-image: linear-gradient(135deg, #60a5fa 0%, #22d3ee 50%, #a78bfa 100%) 1;
}

/* Animation classes */
@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-20px); }
}

.animate-float {
  animation: float 6s ease-in-out infinite;
}

.floating-delay-1 {
  animation: float 6s ease-in-out infinite;
  animation-delay: 0s;
}

.floating-delay-2 {
  animation: float 6s ease-in-out infinite;
  animation-delay: 2s;
}

.floating-delay-3 {
  animation: float 6s ease-in-out infinite;
  animation-delay: 4s;
}

/* Custom scrollbar */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: #f1f1f1;
}

::-webkit-scrollbar-thumb {
  background: #888;
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: #555;
}

/* Dark mode scrollbar */
.dark ::-webkit-scrollbar-track {
  background: #1f2937;
}

.dark ::-webkit-scrollbar-thumb {
  background: #4b5563;
}

.dark ::-webkit-scrollbar-thumb:hover {
  background: #6b7280;
}

.glass-dark {
  background: rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(34, 221, 210, 0.2);
}

/* LiveKit UI overrides */
[data-lk-theme='default'] {
  --lk-color-accent: #06B6D4;
  --lk-button-background: #06B6D4;
  --lk-button-background-hover: #0891B2;
  --lk-bg1: #0B1120;
  --lk-bg2: #0F172A;
}
