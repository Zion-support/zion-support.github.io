  /* Neon Border Effects */
  .neon-border {
    border: 1px solid transparent;
    background: linear-gradient(45deg, #06b6d4, #581c87) border-box;
  }
  
  .neon-border-cyan {
    border: 1px solid transparent;
    background: linear-gradient(45deg, #06b6d4, #14b8a6) border-box;
    box-shadow: 0 0 20px rgba(6, 182, 212, 0.3);
  }
  
  .neon-border-purple {
    border: 1px solid transparent;
    background: linear-gradient(45deg, #8c15e9, #a855f7) border-box;
    box-shadow: 0 0 20px rgba(140, 21, 233, 0.3);
  }
  
  /* Enhanced Button Styles */
  .btn-primary {
    @apply bg-gradient-to-r from-zion-cyan to-zion-purple text-white px-6 py-3 rounded-lg font-medium transition-all duration-300;
    box-shadow: 0 4px 15px rgba(6, 182, 212, 0.3);
  }
  
  .btn-primary:hover {
    @apply from-zion-cyan-dark to-zion-purple-dark;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(6, 182, 212, 0.4);
  }
  
  .btn-secondary {
    @apply border border-zion-cyan text-zion-cyan px-6 py-3 rounded-lg font-medium transition-all duration-300;
  }
  
  .btn-secondary:hover {
    @apply bg-zion-cyan text-white;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(6, 182, 212, 0.3);
  }
  
  /* Card Enhancements */
  .card-hover {
    @apply transition-all duration-300 hover:transform hover:scale-105 hover:shadow-2xl;
  }
  
  .card-glow {
    @apply transition-all duration-300;
    box-shadow: 0 4px 20px rgba(6, 182, 212, 0.1);
  }
  
  .card-glow:hover {
    box-shadow: 0 8px 30px rgba(6, 182, 212, 0.2);
  }
  
  /* Text Gradients */
  .text-gradient {
    background: linear-gradient(135deg, #06b6d4, #8c15e9);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .text-gradient-cyan {
    background: linear-gradient(135deg, #06b6d4, #14b8a6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  /* Enhanced Animations */
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  
  .animate-glow {
    animation: glow 2s ease-in-out infinite alternate;
  }
  
  .animate-slide-up {
    animation: slide-up 0.6s ease-out;
  }
  
  .animate-fade-in {
    animation: fade-in 0.8s ease-out;
  }
  
  .animate-bounce-slow {
    animation: bounce 3s infinite;
  }
  
  /* Responsive Utilities */
  .container-responsive {
    @apply max-w-7xl mx-auto px-4 sm:px-6 lg:px-8;
  }
  
  /* Section Spacing */
  .section-padding {
    @apply py-16 sm:py-20 lg:py-24;
  }
  
  /* Grid Responsive */
  .grid-responsive {
    @apply grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8;
  }
}

@layer utilities {
  /* Custom Scrollbar */
  .scrollbar-thin {
    scrollbar-width: thin;
    scrollbar-color: #06b6d4 #1e293b;
  }
  
  .scrollbar-thin::-webkit-scrollbar {
    width: 6px;
  }
  
  .scrollbar-thin::-webkit-scrollbar-track {
    background: #1e293b;
  }
  
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: #06b6d4;
    border-radius: 3px;
  }
  
  /* Focus States */
  .focus-ring {
    @apply focus:outline-none focus:ring-2 focus:ring-zion-cyan focus:ring-offset-2 focus:ring-offset-zion-blue-dark;
  }
  
  /* Selection */
  ::selection {
    background: rgba(6, 182, 212, 0.3);
    color: white;
  }
  
  /* Smooth Transitions */
  .transition-smooth {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  /* Hover Effects */
  .hover-lift {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .hover-lift:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }
