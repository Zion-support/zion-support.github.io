      case 'Testing': return 'bg-yellow-500';
      case 'Research': return 'bg-purple-500';
      case 'Vision': return 'bg-pink-500';
      case 'Development': return 'bg-cyan-500';
      case 'Concept': return 'bg-orange-500';
      case 'Alpha': return 'bg-indigo-500';
