        <div className="bg-gradient-to-r from-indigo-600/30 to-purple-600/30 backdrop-blur-sm rounded-2xl p-8 mb-16">
          <h2 className="text-4xl font-bold text-center mb-8">Performance Metrics</h2>
          <div className="grid md:grid-cols-4 gap-6">
            <div className="text-center">
              <div className="text-4xl font-bold text-indigo-300 mb-2">∞</div>
              <div className="text-lg text-gray-300">Parallel Universes</div>
            </div>
            <div className="text-center">
              <div className="text-4xl font-bold text-purple-300 mb-2">1000+</div>
              <div className="text-lg text-gray-300">Qubits</div>
            </div>
            <div className="text-center">
              <div className="text-4xl font-bold text-cyan-300 mb-2">99.9%</div>
              <div className="text-lg text-gray-300">Accuracy</div>
            </div>
            <div className="text-center">
              <div className="text-4xl font-bold text-pink-300 mb-2">0ms</div>
              <div className="text-lg text-gray-300">Latency</div>
            </div>
          </div>
        </div>

        {/* Call to Action */}
        <div className="text-center bg-gradient-to-r from-indigo-600/30 to-purple-600/30 backdrop-blur-sm rounded-2xl p-12">
          <h2 className="text-4xl font-bold mb-4">Enter the Quantum Reality</h2>
          <p className="text-xl opacity-90 mb-8 max-w-3xl mx-auto">
            Experience reality like never before. Step into a world where quantum mechanics 
            creates infinite possibilities and parallel universes await your exploration.
          </p>
          <div className="flex justify-center space-x-4">
            <button className="bg-gradient-to-r from-indigo-600 to-purple-600 text-white px-10 py-4 rounded-lg hover:shadow-lg transition-all duration-300 font-semibold text-lg">
              Launch Quantum Engine
            </button>
            <button className="border-2 border-white text-white px-10 py-4 rounded-lg hover:bg-white hover:text-indigo-900 transition-all duration-300 font-semibold text-lg">
              Explore Features
            </button>
          </div>
        </div>
      </div>
    </div>
  );
};

export default QuantumRealityEngine2025;