                  <p className="text-zion-slate-light text-sm">
                    <strong>Data Collected:</strong> {service.data}
                  </p>
                </div>
              ))}
            </div>
          </div>
        </motion.div>

        {/* Cookie Management */}
        <motion.div 
          className="max-w-4xl mx-auto mb-16"
