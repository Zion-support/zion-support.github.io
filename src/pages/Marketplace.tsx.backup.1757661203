      features: ["Data Visualization", "ETL Processing", "Real-time Streaming", "Advanced Reporting"],
      tags: ["Data", "Analytics", "Visualization", "Big Data"]
    },
    {
      id: 6,
      name: "AI Chatbot Platform",
