interface Partner {
  id: string;
  name: string;
  logo: string;
  description: string;
  category: string;
  tier: 'Platinum' | 'Gold' | 'Silver' | 'Bronze';
  website: string;
  location: string;
  specialties: string[];
}

interface PartnershipTier {
  name: string;
  icon: any;
  description: string;
  benefits: string[];
  requirements: string[];
  color: string;
}

