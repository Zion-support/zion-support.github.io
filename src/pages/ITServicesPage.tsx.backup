              <MessageSquare className="h-5 w-5 mr-2"/>
              Schedule Consultation
            </Button>
            <Button size="lg" variant="outline" className="border-zion-cyan text-zion-cyan hover:bg-zion-cyan/10">
              <Code className="h-5 w-5 mr-2"/>
              View Case Studies
            </Button>
          </div>
        </div>
      </div>
    </div>);
}
