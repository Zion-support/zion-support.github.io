                  >
                    Schedule Assessment
                  </Link>
                </div>
                <div className="text-center">
                  <Building2 className="w-16 h-16 text-zion-cyan mx-auto mb-4" />
                  <h3 className="text-2xl font-bold text-white mb-3">Enterprise Solutions</h3>
                  <p className="text-zion-slate-light mb-4">
