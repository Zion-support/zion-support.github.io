      fileSize: '2.2 MB',
      language: 'English'
    }
  ];

  const featuredInsights = [
    {
      title: 'AI Adoption Trends 2025',
      description: 'Key insights from our latest research on enterprise AI adoption',
      icon: <TrendingUp className="w-6 h-6" />,
