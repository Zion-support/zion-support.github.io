import React from 'react';
import { Link } from 'react-router-dom';
import { 
  Brain, 
  Cpu, 
  Rocket, 
  Shield, 
  Cloud, 
  Server, 
  Zap, 
  Leaf, 
  Smartphone, 
  DollarSign, 
  Building,
  CheckCircle,
  ArrowRight,
  Star,
  Users,
  Globe,
  Lock,
  Database,
  Network,
  Code
} from 'lucide-react';

const Services: React.FC = () => {
  const serviceCategories = [
    {
