  const getAnnualDiscount = (monthlyPrice: string) => {
    const price = parseInt(monthlyPrice.replace(/[^0-9]/g, ''));
    const annualPrice = price * 12 * 0.8; // 20% discount
    return `$${Math.round(annualPrice / 1000)}K`;
  };

