                    {event.type.charAt(0)}
                  </div>
                </div>

                <div className="p-6">
                  {/* Event Type & Price */}
                  <div className="flex items-center justify-between mb-4">
                    <span className="inline-flex items-center px-3 py-1 bg-zion-cyan/10 border border-zion-cyan/20 rounded-full text-zion-cyan text-sm font-medium">
                      {event.type}
                    </span>
                    <div className="text-right">
                      <div className="text-lg font-bold text-zion-cyan">{event.price}</div>
                    </div>
                  </div>

                  {/* Title */}
                  <h3 className="text-xl font-bold text-white mb-3 group-hover:text-zion-cyan transition-colors duration-300">
                    {event.title}
                  </h3>

                  {/* Description */}
                  <p className="text-zion-slate-light text-sm mb-4 line-clamp-2">
                    {event.description}
                  </p>

                  {/* Event Details */}
                  <div className="space-y-2 mb-4">
                    <div className="flex items-center space-x-2 text-zion-slate-light text-sm">
                      <Calendar className="w-4 h-4 text-zion-cyan" />
                      <span>{formatDate(event.date)}</span>
                    </div>
                    <div className="flex items-center space-x-2 text-zion-slate-light text-sm">
                      <Clock className="w-4 h-4 text-zion-cyan" />
                      <span>{event.time}</span>
                    </div>
                    <div className="flex items-center space-x-2 text-zion-slate-light text-sm">
                      <MapPin className="w-4 h-4 text-zion-cyan" />
                      <span>{event.location}</span>
                    </div>
                  </div>

                  {/* Registration Status */}
                  <div className="flex items-center justify-between mb-4">
                    <div className="flex items-center space-x-2 text-sm text-zion-slate-light">
                      <Users className="w-4 h-4" />
                      <span>{event.registered}/{event.capacity} registered</span>
                    </div>
                    <div className="w-20 bg-zion-slate-light/20 rounded-full h-2">
                      <div 
                        className="bg-gradient-to-r from-zion-cyan to-zion-blue h-2 rounded-full"
                        style={{ width: `${(event.registered / event.capacity) * 100}%` }}
                      ></div>
                    </div>
                  </div>

                  {/* Tags */}
                  <div className="flex flex-wrap gap-2 mb-4">
                    {event.tags.slice(0, 3).map((tag, idx) => (
                      <span
                        key={idx}
                        className="px-2 py-1 bg-zion-slate-light/10 border border-zion-slate-light/20 rounded-full text-zion-slate-light text-xs"
                      >
                        {tag}
                      </span>
                    ))}
                  </div>

                  {/* CTA */}
                  <Link
                    to={`/events/${event.id}`}
                    className="w-full inline-flex items-center justify-center space-x-2 px-4 py-3 border border-zion-cyan text-zion-cyan font-semibold rounded-lg hover:bg-zion-cyan hover:text-white transition-all duration-300"
                  >
                    <span>Learn More</span>
                    <ArrowRight className="w-4 h-4" />
                  </Link>
                </div>
              </motion.div>
            ))}
          </div>

          {upcomingEvents.length === 0 && (
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              className="text-center py-20"
            >
              <div className="text-6xl mb-4">📅</div>
              <h3 className="text-2xl font-bold text-white mb-2">No upcoming events found</h3>
              <p className="text-zion-slate-light">Try adjusting your filters or check back later for new events.</p>
            </motion.div>
          )}
        </div>
      </section>

      {/* Past Events */}
      {pastEvents.length > 0 && (
        <section className="py-20 bg-zion-slate-dark/30">
          <div className="container-responsive">
            <motion.div
              initial={{ opacity: 0, y: 30 }}
              whileInView={{ opacity: 1, y: 0 }}
              transition={{ duration: 0.8 }}
              viewport={{ once: true }}
              className="text-center mb-16"
            >
              <h2 className="text-4xl font-bold text-white mb-4">
                Past Events
              </h2>
              <p className="text-xl text-zion-slate-light max-w-3xl mx-auto">
                Missed an event? Explore recordings, presentations, and resources from our previous conferences and workshops.
              </p>
            </motion.div>

            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {pastEvents.slice(0, 6).map((event, index) => (
                <motion.div
                  key={event.id}
                  initial={{ opacity: 0, y: 30 }}
                  whileInView={{ opacity: 1, y: 0 }}
                  transition={{ duration: 0.6, delay: index * 0.1 }}
                  viewport={{ once: true }}
                  className="bg-zion-slate-dark/50 border border-zion-slate-light/20 rounded-xl p-6 hover:border-zion-slate-light/40 transition-all duration-300"
                >
                  <div className="flex items-center justify-between mb-4">
                    <span className="px-3 py-1 bg-zion-slate-light/10 border border-zion-slate-light/20 rounded-full text-zion-slate-light text-sm">
                      {event.type}
                    </span>
                    <span className="text-zion-slate-light text-sm">{formatDate(event.date)}</span>
                  </div>

                  <h3 className="text-lg font-bold text-white mb-3">{event.title}</h3>
                  <p className="text-zion-slate-light text-sm mb-4 line-clamp-2">{event.description}</p>

                  <div className="flex items-center justify-between">
                    <div className="flex items-center space-x-2 text-zion-slate-light text-sm">
                      <Users className="w-4 h-4" />
                      <span>{event.registered} attendees</span>
                    </div>
                    <Link
                      to={`/events/${event.id}`}
                      className="text-zion-cyan hover:text-zion-cyan-light text-sm font-medium"
                    >
                      View Resources
                    </Link>
                  </div>
                </motion.div>
              ))}
            </div>
          </div>
        </section>
      )}

      {/* CTA Section */}
      <section className="py-20 bg-gradient-to-r from-zion-slate-dark to-zion-slate">
        <div className="container-responsive text-center">
          <motion.div
            initial={{ opacity: 0, y: 30 }}
            whileInView={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8 }}
            viewport={{ once: true }}
            className="max-w-3xl mx-auto"
          >
            <h2 className="text-4xl font-bold text-white mb-6">
              Stay Connected
            </h2>
            <p className="text-xl text-zion-slate-light mb-8">
              Never miss an important event! Subscribe to our newsletter for updates on upcoming events, 
              exclusive content, and early registration opportunities.
            </p>
            <div className="flex flex-col sm:flex-row gap-4 justify-center">
              <Link
                to="/contact"
                className="inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-zion-cyan to-zion-blue text-white font-semibold rounded-lg hover:from-zion-cyan-light hover:to-zion-blue-light transition-all duration-300 transform hover:scale-105"
              >
                Subscribe to Updates
                <ArrowRight className="w-5 h-5 ml-2" />
              </Link>
              <Link
                to="/contact"
                className="inline-flex items-center justify-center px-8 py-4 border border-zion-cyan text-zion-cyan font-semibold rounded-lg hover:bg-zion-cyan hover:text-white transition-all duration-300"
              >
                Host an Event
              </Link>
            </div>
          </motion.div>
        </div>
      </section>
    </div>
  );
