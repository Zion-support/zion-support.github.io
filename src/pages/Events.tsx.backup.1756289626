                    </div>
                    
                    {/* Speakers */}
                    <div className="mb-6">
                      <div className="text-sm font-medium text-zion-slate-light mb-2">Featured Speakers</div>
                      <div className="flex flex-wrap gap-2">
                        {event.speakers.map((speaker, speakerIndex) => (
