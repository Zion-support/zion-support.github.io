  /* Accessibility Enhancements */
  .high-contrast {
    --background: 0 0% 0%;
    --foreground: 0 0% 100%;
    --primary: 0 0% 100%;
    --secondary: 0 0% 20%;
    --muted: 0 0% 20%;
    --accent: 0 0% 100%;
    --border: 0 0% 100%;
    --input: 0 0% 100%;
    --ring: 0 0% 100%;
  }

  .high-contrast * {
    border-color: hsl(var(--border)) !important;
  }

  .show-focus-indicator *:focus {
    outline: 3px solid var(--zion-cyan) !important;
    outline-offset: 2px !important;
  }

  /* Screen Reader Only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Reduced Motion Support */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }

  /* Custom Scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  ::-webkit-scrollbar-track {
    background: hsl(var(--background));
  }

  ::-webkit-scrollbar-thumb {
    background: var(--zion-cyan);
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: var(--zion-blue);
  }

  /* Focus Management */
  .focus-visible:focus-visible {
    outline: 2px solid var(--zion-cyan);
    outline-offset: 2px;
  }

  /* Skip Links */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 6px;
    background: var(--zion-cyan);
    color: var(--zion-slate-dark);
    padding: 8px;
    text-decoration: none;
    border-radius: 4px;
    z-index: 10000;
    transition: top 0.3s;
  }

  .skip-link:focus {
    top: 6px;
  }

