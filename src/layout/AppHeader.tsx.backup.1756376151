              {/* User Menu */}
              <button className="p-2 text-gray-300 hover:text-white hover:bg-white/10 rounded-xl transition-all duration-300">
                <User className="w-5 h-5" />
              </button>

              {/* Mobile Menu Button */}
              <button
                onClick={() => setMobileMenuOpen(!mobileMenuOpen)}
