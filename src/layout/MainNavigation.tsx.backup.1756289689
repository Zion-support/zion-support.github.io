                      <button className="w-full text-left flex items-center space-x-3 p-3 rounded-lg hover:bg-white/10 transition-all duration-300 text-white">
                        <Settings className="w-5 h-5 text-zion-cyan" />
                        <span>Settings</span>
                      </button>
                    </div>
                  ) : (
