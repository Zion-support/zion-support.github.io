export interface Service {
  id: string;
  title: string;
  description: string;
  category: string;
  subcategory: string;
  price: {
    basic: number;
    professional: number;
    enterprise: number;
  };
  features: string[];
  tags: string[];
  featured: boolean;
  popular: boolean;
  estimatedTime: string;
  included: string[];
  notIncluded: string[];
  requirements: string[];
  deliverables: string[];
  technologies: string[];
  certifications: string[];
  support: string[];
  warranty: string;
  location: string[];
  languages: string[];
  availability: string;
  rating: number;
  reviews: number;
  provider: {
    name: string;
    verified: boolean;
    rating: number;
    completedProjects: number;
    responseTime: string;
    location: string;
    languages: string[];
    certifications: string[];
    specialties: string[];
  };
}

