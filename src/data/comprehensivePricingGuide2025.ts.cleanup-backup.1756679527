export type PricingTier = {
  name: string;
  price: string;
  billing: 'month' | 'year' | 'project' | 'hour';
  description: string;
  features: string[];
  benefits: string[];
  bestFor: string[];
  popular?: boolean;
};

export type ServicePricing = {
  id: string;
  title: string;
  description: string;
  category: string;
  pricingTiers: PricingTier[];
  marketComparison: {
    averageMarketPrice: string;
    ourPrice: string;
    savings: string;
    valueProposition: string;
  };
  features: string[];
  benefits: string[];
  useCases: string[];
  contactInfo: {
    mobile: string;
    email: string;
    address: string;
    website: string;
    address: string;
  };
};

