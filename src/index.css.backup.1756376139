/* Futuristic Cards */
.card-futuristic {
  background: linear-gradient(135deg, rgba(26, 26, 26, 0.9), rgba(42, 42, 42, 0.9));
  border: 1px solid var(--neon-cyan);
  border-radius: 0;
  padding: 2rem;
  margin: 1rem 0;
  position: relative;
  overflow: hidden;
  backdrop-filter: blur(10px);
  box-shadow: 0 0 20px rgba(0, 255, 255, 0.3);
  transition: all 0.3s ease;
}

.card-futuristic::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--neon-cyan), var(--neon-blue), var(--neon-purple));
  animation: data-stream 3s linear infinite;
}

.card-futuristic:hover {
  transform: translateY(-5px);
  box-shadow: 0 0 40px rgba(0, 255, 255, 0.5), 0 10px 30px rgba(0, 0, 0, 0.3);
  border-color: var(--neon-blue);
}

.card-futuristic.card-primary {
  border-color: var(--neon-blue);
  box-shadow: 0 0 20px rgba(0, 128, 255, 0.3);
}

.card-futuristic.card-primary:hover {
  box-shadow: 0 0 40px rgba(0, 128, 255, 0.5);
}

.card-futuristic.card-secondary {
  border-color: var(--neon-purple);
  box-shadow: 0 0 20px rgba(128, 0, 255, 0.3);
}

.card-futuristic.card-secondary:hover {
  box-shadow: 0 0 40px rgba(128, 0, 255, 0.5);
}

/* Futuristic Navigation */
.nav-futuristic {
  background: rgba(0, 0, 0, 0.9);
  backdrop-filter: blur(20px);
  border-bottom: 2px solid var(--neon-cyan);
  box-shadow: 0 0 30px rgba(0, 255, 255, 0.3);
}

.nav-futuristic .nav-link {
  color: var(--zion-slate-300);
  text-decoration: none;
  padding: 0.5rem 1rem;
  margin: 0 0.25rem;
  position: relative;
  transition: all 0.3s ease;
  font-family: 'Orbitron', monospace;
  font-weight: 500;
}

.nav-futuristic .nav-link::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 0;
  height: 2px;
  background: var(--neon-cyan);
  transition: all 0.3s ease;
  transform: translateX(-50%);
}

.nav-futuristic .nav-link:hover {
  color: var(--neon-cyan);
  text-shadow: 0 0 10px var(--neon-cyan);
}

.nav-futuristic .nav-link:hover::before {
  width: 100%;
}

.nav-futuristic .nav-link.active {
  color: var(--neon-cyan);
  text-shadow: 0 0 10px var(--neon-cyan);
}

.nav-futuristic .nav-link.active::before {
  width: 100%;
}

/* Futuristic Forms */
.form-futuristic {
  background: rgba(26, 26, 26, 0.8);
  border: 1px solid var(--neon-cyan);
  border-radius: 0;
  padding: 2rem;
  backdrop-filter: blur(10px);
}

.form-futuristic .form-group {
  margin-bottom: 1.5rem;
}

.form-futuristic label {
  display: block;
  margin-bottom: 0.5rem;
  color: var(--neon-cyan);
  font-family: 'Orbitron', monospace;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.form-futuristic input,
.form-futuristic textarea,
.form-futuristic select {
  width: 100%;
  padding: 0.75rem;
  background: rgba(0, 0, 0, 0.7);
  border: 1px solid var(--neon-cyan);
  border-radius: 0;
  color: var(--zion-white);
  font-family: 'Rajdhani', sans-serif;
  transition: all 0.3s ease;
}

.form-futuristic input:focus,
.form-futuristic textarea:focus,
.form-futuristic select:focus {
  outline: none;
  border-color: var(--neon-blue);
  box-shadow: 0 0 20px rgba(0, 128, 255, 0.5);
  background: rgba(0, 0, 0, 0.9);
}

.form-futuristic input::placeholder,
.form-futuristic textarea::placeholder {
  color: var(--zion-slate-500);
}

/* Futuristic Tables */
.table-futuristic {
  width: 100%;
  border-collapse: collapse;
  background: rgba(26, 26, 26, 0.8);
  backdrop-filter: blur(10px);
}

.table-futuristic th,
.table-futuristic td {
  padding: 1rem;
  text-align: left;
  border-bottom: 1px solid var(--neon-cyan);
}

.table-futuristic th {
  background: rgba(0, 255, 255, 0.1);
  color: var(--neon-cyan);
  font-family: 'Orbitron', monospace;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.table-futuristic tr:hover {
  background: rgba(0, 255, 255, 0.05);
}

/* Futuristic Alerts */
.alert-futuristic {
  padding: 1rem 1.5rem;
  margin: 1rem 0;
  border: 1px solid;
  border-radius: 0;
  position: relative;
  overflow: hidden;
  backdrop-filter: blur(10px);
}

.alert-futuristic::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: currentColor;
  animation: data-stream 2s linear infinite;
}

.alert-futuristic.alert-info {
  background: rgba(0, 255, 255, 0.1);
  border-color: var(--neon-cyan);
  color: var(--neon-cyan);
}

.alert-futuristic.alert-success {
  background: rgba(0, 255, 0, 0.1);
  border-color: var(--neon-green);
  color: var(--neon-green);
}

.alert-futuristic.alert-warning {
  background: rgba(255, 255, 0, 0.1);
  border-color: var(--neon-yellow);
  color: var(--neon-yellow);
}

.alert-futuristic.alert-error {
  background: rgba(255, 0, 0, 0.1);
  border-color: var(--neon-red);
  color: var(--neon-red);
}

/* Futuristic Modals */
.modal-futuristic {
  background: rgba(0, 0, 0, 0.95);
  backdrop-filter: blur(20px);
  border: 2px solid var(--neon-cyan);
  border-radius: 0;
  box-shadow: 0 0 50px rgba(0, 255, 255, 0.5);
}

.modal-futuristic .modal-header {
  border-bottom: 1px solid var(--neon-cyan);
  padding: 1.5rem;
}

.modal-futuristic .modal-title {
  color: var(--neon-cyan);
  font-family: 'Orbitron', monospace;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.modal-futuristic .modal-body {
  padding: 1.5rem;
  color: var(--zion-slate-300);
}

.modal-futuristic .modal-footer {
  border-top: 1px solid var(--neon-cyan);
  padding: 1.5rem;
}

/* Futuristic Loading Spinners */
.spinner-futuristic {
  width: 50px;
  height: 50px;
  border: 3px solid transparent;
  border-top: 3px solid var(--neon-cyan);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.spinner-futuristic.spinner-large {
  width: 80px;
  height: 80px;
  border-width: 4px;
}

.spinner-futuristic.spinner-small {
  width: 30px;
  height: 30px;
  border-width: 2px;
}

/* Futuristic Progress Bars */
.progress-futuristic {
  background: rgba(0, 0, 0, 0.7);
  border: 1px solid var(--neon-cyan);
  border-radius: 0;
  height: 20px;
  overflow: hidden;
  position: relative;
}

.progress-futuristic .progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--neon-cyan), var(--neon-blue));
  transition: width 0.3s ease;
  position: relative;
}

.progress-futuristic .progress-bar::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: data-stream 2s linear infinite;
}

/* Futuristic Tooltips */
.tooltip-futuristic {
  position: relative;
  display: inline-block;
}

.tooltip-futuristic .tooltip-text {
  visibility: hidden;
  width: 200px;
  background: rgba(0, 0, 0, 0.9);
  color: var(--neon-cyan);
  text-align: center;
  border: 1px solid var(--neon-cyan);
  border-radius: 0;
  padding: 0.5rem;
  position: absolute;
  z-index: 1;
  bottom: 125%;
  left: 50%;
  margin-left: -100px;
  opacity: 0;
  transition: opacity 0.3s;
  backdrop-filter: blur(10px);
  font-family: 'Rajdhani', sans-serif;
  font-size: 0.9rem;
}

.tooltip-futuristic .tooltip-text::after {
  content: "";
  position: absolute;
  top: 100%;
  left: 50%;
  margin-left: -5px;
  border-width: 5px;
  border-style: solid;
  border-color: var(--neon-cyan) transparent transparent transparent;
}

.tooltip-futuristic:hover .tooltip-text {
  visibility: visible;
  opacity: 1;
}

/* Futuristic Animations */
@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-50px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(50px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.8);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* Animation Classes */
.animate-fade-in {
  animation: fadeIn 0.6s ease-out;
}

.animate-slide-in-left {
  animation: slideInLeft 0.6s ease-out;
}

.animate-slide-in-right {
  animation: slideInRight 0.6s ease-out;
}

.animate-scale-in {
  animation: scaleIn 0.6s ease-out;
}

/* Responsive Design */
@media (max-width: 768px) {
  .card-futuristic {
    padding: 1.5rem;
    margin: 0.5rem 0;
  }
  
  .btn-futuristic {
    padding: 0.5rem 1.5rem;
    font-size: 0.9rem;
  }
  
  h1 {
    font-size: clamp(2rem, 6vw, 3rem);
  }
  
  h2 {
    font-size: clamp(1.5rem, 5vw, 2.5rem);
  }
  
  h3 {
    font-size: clamp(1.25rem, 4vw, 2rem);
  }
}

@media (max-width: 480px) {
  .card-futuristic {
    padding: 1rem;
  }
  
  .btn-futuristic {
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
  }
  
  .form-futuristic {
    padding: 1.5rem;
  }
}

/* Dark Mode Enhancements */
@media (prefers-color-scheme: dark) {
  body {
    background: linear-gradient(135deg, var(--cyber-black) 0%, var(--cyber-dark) 25%, var(--cyber-gray) 50%, var(--cyber-dark) 75%, var(--cyber-black) 100%);
  }
  
  .card-futuristic {
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.9), rgba(26, 26, 26, 0.9));
  }
}

/* High Contrast Mode */
@media (prefers-contrast: high) {
  .btn-futuristic {
    border-width: 3px;
  }
  
  .card-futuristic {
    border-width: 2px;
  }
  
  .nav-futuristic {
    border-bottom-width: 3px;
  }
}

/* Reduced Motion */
@media (prefers-reduced-motion: reduce) {
  * {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
  
  .matrix-rain,
  .quantum-particles,
  .data-stream,
  .energy-wave {
    animation: none;
  }
