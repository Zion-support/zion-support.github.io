/* High Contrast Mode */
.high-contrast {
  --high-contrast-text: #000000 !important;
  --high-contrast-bg: #ffffff !important;
  --high-contrast-border: #000000 !important;
}

.high-contrast * {
  color: var(--high-contrast-text) !important;
  background-color: var(--high-contrast-bg) !important;
  border-color: var(--high-contrast-border) !important;
}

