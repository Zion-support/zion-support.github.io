  --primary: 216 84% 53%;
  --primary-foreground: 0 0% 100%;

  --secondary: 0 0% 96%;
  --secondary-foreground: 0 0% 7%;

  --muted: 0 0% 96%;
  --muted-foreground: 215 20% 65%;

  --accent: 228 12% 92%;
  --accent-foreground: 0 0% 7%;

  --destructive: 0 84.2% 60.2%;
  --destructive-foreground: 0 0% 100%;

  --border: 0 0% 90%;
  --input: 0 0% 90%;
  --ring: 216 84% 53%;
  --sidebar-background: 228 12% 92%;
  --sidebar-foreground: 0 0% 7%;
  --sidebar-primary: 216 84% 53%;
  --sidebar-primary-foreground: 0 0% 100%;
  --sidebar-accent: 0 0% 96%;
  --sidebar-accent-foreground: 0 0% 7%;
  --sidebar-border: 0 0% 90%;
  --sidebar-ring: 216 84% 53%;
}

/* Base styles */
* {
  border-color: hsl(var(--border));
}

body {
  color: hsl(var(--foreground));
  background: hsl(var(--background));
}

/* Futuristic Background Effects */
.futuristic-bg {
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 25%, #334155 50%, #1e293b 75%, #0f172a 100%);
  position: relative;
  overflow: hidden;
}

.futuristic-bg::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(circle at 20% 80%, rgba(34, 221, 210, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(140, 21, 233, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 40% 40%, rgba(16, 185, 129, 0.05) 0%, transparent 50%);
  animation: backgroundShift 20s ease-in-out infinite;
}

@keyframes backgroundShift {
  0%, 100% { transform: scale(1) rotate(0deg); }
  50% { transform: scale(1.1) rotate(1deg); }
}

/* Neon Effects */
.neon-glow {
  box-shadow: 
    0 0 5px currentColor,
    0 0 10px currentColor,
    0 0 15px currentColor,
    0 0 20px currentColor;
}

.neon-glow-cyan {
  box-shadow: 
    0 0 5px #22ddd2,
    0 0 10px #22ddd2,
    0 0 15px #22ddd2,
    0 0 20px #22ddd2;
}

.neon-glow-purple {
  box-shadow: 
    0 0 5px #8c15e9,
    0 0 10px #8c15e9,
    0 0 15px #8c15e9,
    0 0 20px #8c15e9;
}

.neon-glow-green {
  box-shadow: 
    0 0 5px #10b981,
    0 0 10px #10b981,
    0 0 15px #10b981,
    0 0 20px #10b981;
}

/* Animated Borders */
.animated-border {
  position: relative;
  background: linear-gradient(135deg, #22ddd2, #8c15e9, #10b981, #22ddd2);
  background-size: 400% 400%;
  animation: borderGradient 3s ease infinite;
}

.animated-border::before {
  content: '';
  position: absolute;
  inset: 2px;
  background: #1e293b;
  border-radius: inherit;
  z-index: -1;
}

@keyframes borderGradient {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* Floating Elements */
.floating {
  animation: floating 6s ease-in-out infinite;
}

.floating-delay-1 {
  animation-delay: 1s;
}

.floating-delay-2 {
  animation-delay: 2s;
}

.floating-delay-3 {
  animation-delay: 3s;
}

@keyframes floating {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-20px); }
}

/* Pulse Effects */
.pulse-glow {
  animation: pulseGlow 2s ease-in-out infinite alternate;
}

@keyframes pulseGlow {
  from { box-shadow: 0 0 20px rgba(34, 221, 210, 0.4); }
  to { box-shadow: 0 0 40px rgba(34, 221, 210, 0.8); }
}

/* Gradient Text */
.gradient-text-cyan-purple {
  background: linear-gradient(135deg, #22ddd2 0%, #8c15e9 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.gradient-text-cyan-green {
  background: linear-gradient(135deg, #22ddd2 0%, #10b981 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.gradient-text-purple-orange {
  background: linear-gradient(135deg, #8c15e9 0%, #f59e0b 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Glassmorphism */
.glass {
  background: rgba(30, 41, 59, 0.8);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(34, 221, 210, 0.2);
}

.glass-strong {
  background: rgba(30, 41, 59, 0.95);
  backdrop-filter: blur(30px);
  border: 1px solid rgba(34, 221, 210, 0.3);
}

/* Hover Effects */
.hover-lift {
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.hover-lift:hover {
  transform: translateY(-5px);
  box-shadow: 0 20px 40px rgba(34, 221, 210, 0.2);
}

.hover-glow:hover {
  box-shadow: 0 0 30px rgba(34, 221, 210, 0.5);
}

/* Custom Scrollbar */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: #1e293b;
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(135deg, #22ddd2, #8c15e9);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(135deg, #1bb8a6, #7a13d1);
}

/* Selection */
::selection {
  background: rgba(34, 221, 210, 0.3);
  color: #ffffff;
}

/* Focus States */
.focus-glow:focus {
  outline: none;
  box-shadow: 0 0 0 3px rgba(34, 221, 210, 0.3);
}

/* Loading Animations */
.loading-dots {
  display: inline-block;
}

.loading-dots::after {
  content: '';
  animation: loadingDots 1.5s infinite;
}

@keyframes loadingDots {
  0%, 20% { content: ''; }
  40% { content: '.'; }
  60% { content: '..'; }
  80%, 100% { content: '...'; }
}

/* Responsive Typography */
.text-responsive-xl {
  font-size: clamp(2rem, 5vw, 4rem);
}

.text-responsive-lg {
  font-size: clamp(1.5rem, 4vw, 2.5rem);
}

.text-responsive-md {
  font-size: clamp(1rem, 3vw, 1.5rem);
}

/* Grid Patterns */
.grid-pattern {
  background-image: 
    linear-gradient(rgba(34, 221, 210, 0.1) 1px, transparent 1px),
    linear-gradient(90deg, rgba(34, 221, 210, 0.1) 1px, transparent 1px);
  background-size: 20px 20px;
}

/* Particle Effects */
.particles {
  position: relative;
}

.particles::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(circle at 25% 25%, rgba(34, 221, 210, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 75% 75%, rgba(140, 21, 233, 0.1) 0%, transparent 50%);
  animation: particleFloat 15s ease-in-out infinite;
}

@keyframes particleFloat {
  0%, 100% { transform: translateY(0px) rotate(0deg); }
  50% { transform: translateY(-30px) rotate(180deg); }
}

/* Enhanced Button Styles */
.btn-futuristic {
  position: relative;
  background: linear-gradient(135deg, #22ddd2, #8c15e9);
  border: none;
  color: white;
  padding: 12px 24px;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  overflow: hidden;
  transition: all 0.3s ease;
}

.btn-futuristic::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}

.btn-futuristic:hover::before {
  left: 100%;
}

.btn-futuristic:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 30px rgba(34, 221, 210, 0.4);
}

/* Card Hover Effects */
.card-hover {
  transition: all 0.3s ease;
  position: relative;
}

.card-hover::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(34, 221, 210, 0.1), rgba(140, 21, 233, 0.1));
  opacity: 0;
  transition: opacity 0.3s ease;
  border-radius: inherit;
}

.card-hover:hover::before {
  opacity: 1;
}

.card-hover:hover {
  transform: translateY(-5px) scale(1.02);
  box-shadow: 0 20px 40px rgba(34, 221, 210, 0.2);
}

/* Responsive Utilities */
@media (max-width: 640px) {
  .container {
    padding-left: 1rem;
    padding-right: 1rem;
  }
}

@media (min-width: 641px) and (max-width: 1024px) {
  .container {
    padding-left: 2rem;
    padding-right: 2rem;
  }
}

@media (min-width: 1025px) {
  .container {
    padding-left: 4rem;
    padding-right: 4rem;
