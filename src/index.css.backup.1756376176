  /* Performance and Accessibility Variables */
  --base-font-size: 16px;
  --heading-scale: 1.2;
  --animation-duration: 0.3s;
  --transition-duration: 0.3s;
  --focus-outline: 3px solid #22d3ee;
  --focus-outline-offset: 2px;
  --touch-target-size: 32px;
  --font-size-scale: 1;
  --mobile-optimized: false;
  --tablet-optimized: false;
  --desktop-optimized: false;
}

/* Enhanced Futuristic Animations */
@keyframes neon-pulse {
  0%, 100% {
    box-shadow: 0 0 5px currentColor, 0 0 10px currentColor, 0 0 15px currentColor;
  }
  50% {
    box-shadow: 0 0 10px currentColor, 0 0 20px currentColor, 0 0 30px currentColor;
  }
}

@keyframes neon-glow {
  0%, 100% {
    text-shadow: 0 0 5px currentColor, 0 0 10px currentColor, 0 0 15px currentColor;
  }
  50% {
    text-shadow: 0 0 10px currentColor, 0 0 20px currentColor, 0 0 30px currentColor;
  }
}

@keyframes matrix-rain {
  0% {
    transform: translateY(-100vh);
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    transform: translateY(100vh);
    opacity: 0;
  }
}

@keyframes hologram-flicker {
  0%, 100% {
    opacity: 1;
    filter: hue-rotate(0deg);
  }
  25% {
    opacity: 0.8;
    filter: hue-rotate(90deg);
  }
  50% {
    opacity: 0.9;
    filter: hue-rotate(180deg);
  }
  75% {
    opacity: 0.7;
    filter: hue-rotate(270deg);
  }
}

@keyframes quantum-float {
  0%, 100% {
    transform: translateY(0px) rotate(0deg);
  }
  25% {
    transform: translateY(-10px) rotate(90deg);
  }
  50% {
    transform: translateY(-20px) rotate(180deg);
  }
  75% {
    transform: translateY(-10px) rotate(270deg);
  }
}

.animate-pulse-glow {
  animation: pulse-glow 2s ease-in-out infinite;
}

/* Futuristic neon effects */
@keyframes neon-glow {
  0%, 100% {
    text-shadow: 
      0 0 5px currentColor,
      0 0 10px currentColor,
      0 0 15px currentColor,
      0 0 20px currentColor;
  }
  50% {
    text-shadow: 
      0 0 10px currentColor,
      0 0 20px currentColor,
      0 0 30px currentColor,
      0 0 40px currentColor;
  }
}

.neon-glow {
  animation: neon-glow 2s ease-in-out infinite;
}

/* Enhanced grid background */
.cyber-grid-enhanced {
  background-image: 
    linear-gradient(rgba(6, 182, 212, 0.15) 1px, transparent 1px),
    linear-gradient(90deg, rgba(6, 182, 212, 0.15) 1px, transparent 1px);
  background-size: 40px 40px;
  animation: grid-move 20s linear infinite;
}

@keyframes grid-move {
  0% {
    transform: translate(0, 0);
=======
  --zion-cyan: 56 189 248;
  --zion-purple: 168 85 247;
  --zion-neon: 0 255 255;
  --zion-glow: 0 255 255;
}

.bg-futuristic {
  background: 
    radial-gradient(1200px 600px at 10% -10%, rgba(56,189,248,0.15), transparent 60%),
    radial-gradient(900px 500px at 110% 10%, rgba(168,85,247,0.10), transparent 60%),
    linear-gradient(180deg, rgba(2,6,23,1) 0%, rgba(2,6,23,0.95) 100%);
  position: relative;
  overflow: hidden;
}

.bg-futuristic::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(circle at 20% 80%, rgba(56,189,248,0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(168,85,247,0.1) 0%, transparent 50%),
    radial-gradient(circle at 40% 40%, rgba(0,255,255,0.05) 0%, transparent 50%);
  animation: backgroundShift 20s ease-in-out infinite;
  pointer-events: none;
}

@keyframes backgroundShift {
  0%, 100% { transform: translate(0, 0) scale(1); }
  25% { transform: translate(-2%, -1%) scale(1.02); }
  50% { transform: translate(1%, -2%) scale(0.98); }
  75% { transform: translate(-1%, 1%) scale(1.01); }
}

.container-responsive {
  @apply mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl;
}

.animate-fade-in {
  animation: fadeIn 220ms ease-out both;
}

.animate-slide-up {
  animation: slideUp 220ms ease-out both;
}

.animate-float {
  animation: float 6s ease-in-out infinite;
}

.animate-float-delayed {
  animation: float 6s ease-in-out infinite 2s;
}

.animate-glow {
  animation: glow 2s ease-in-out infinite alternate;
}

.animate-neon-pulse {
  animation: neonPulse 1.5s ease-in-out infinite;
}

.animate-cyber-grid {
  animation: cyberGrid 10s linear infinite;
}

.animate-hologram {
  animation: hologram 8s ease-in-out infinite;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(4px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes float {
  0%, 100% { transform: translateY(0px) rotate(0deg); }
  33% { transform: translateY(-10px) rotate(1deg); }
  66% { transform: translateY(5px) rotate(-1deg); }
}

@keyframes glow {
  from { box-shadow: 0 0 20px rgba(56,189,248,0.5); }
  to { box-shadow: 0 0 30px rgba(56,189,248,0.8), 0 0 40px rgba(56,189,248,0.3); }
}

@keyframes neonPulse {
  0%, 100% { 
    text-shadow: 0 0 5px rgba(0,255,255,0.8), 0 0 10px rgba(0,255,255,0.6), 0 0 15px rgba(0,255,255,0.4);
  }
  50% { 
    text-shadow: 0 0 10px rgba(0,255,255,1), 0 0 20px rgba(0,255,255,0.8), 0 0 30px rgba(0,255,255,0.6);
  }
}

@keyframes cyberGrid {
  0% { background-position: 0% 0%; }
  100% { background-position: 100% 100%; }
}

@keyframes hologram {
  0%, 100% { 
    opacity: 0.8;
    filter: hue-rotate(0deg) brightness(1);
  }
  50% { 
    opacity: 1;
    filter: hue-rotate(180deg) brightness(1.2);
  }
}

/* Futuristic Button Styles */
.btn-futuristic {
  @apply relative overflow-hidden bg-gradient-to-r from-cyan-400 to-blue-500 text-white font-semibold py-3 px-6 rounded-lg transition-all duration-300 transform hover:scale-105;
  box-shadow: 0 0 20px rgba(56,189,248,0.3);
}

.btn-futuristic::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  transition: left 0.5s;
}

.btn-futuristic:hover::before {
  left: 100%;
}

.btn-futuristic:hover {
  box-shadow: 0 0 30px rgba(56,189,248,0.6), 0 0 40px rgba(56,189,248,0.3);
}

/* Neon Text Effects */
.text-neon {
  text-shadow: 
    0 0 5px currentColor,
    0 0 10px currentColor,
    0 0 15px currentColor,
    0 0 20px currentColor;
}

.text-neon-cyan {
  color: #00ffff;
  text-shadow: 
    0 0 5px #00ffff,
    0 0 10px #00ffff,
    0 0 15px #00ffff,
    0 0 20px #00ffff;
}

.text-neon-purple {
  color: #b971f2;
  text-shadow: 
    0 0 5px #b971f2,
    0 0 10px #b971f2,
    0 0 15px #b971f2,
    0 0 20px #b971f2;
}

/* Futuristic Card Styles */
.card-futuristic {
  @apply bg-slate-900/60 backdrop-blur border border-cyan-400/15 rounded-2xl p-6 transition-all duration-300;
  box-shadow: 0 0 20px rgba(56,189,248,0.1);
}

.card-futuristic:hover {
  @apply border-cyan-400/40;
  box-shadow: 0 0 30px rgba(56,189,248,0.2), 0 0 40px rgba(56,189,248,0.1);
  transform: translateY(-2px);
}

/* Animated Background Patterns */
.bg-cyber-grid {
  background-image: 
    linear-gradient(rgba(56,189,248,0.1) 1px, transparent 1px),
    linear-gradient(90deg, rgba(56,189,248,0.1) 1px, transparent 1px);
  background-size: 50px 50px;
  animation: cyberGrid 20s linear infinite;
}

.bg-hologram {
  background: linear-gradient(45deg, 
    rgba(56,189,248,0.1) 0%, 
    rgba(168,85,247,0.1) 25%, 
    rgba(0,255,255,0.1) 50%, 
    rgba(168,85,247,0.1) 75%, 
    rgba(56,189,248,0.1) 100%);
  background-size: 400% 400%;
  animation: hologram 8s ease-in-out infinite;
}

/* Floating Elements */
.floating-element {
  position: absolute;
  pointer-events: none;
  opacity: 0.6;
  animation: float 8s ease-in-out infinite;
}

.floating-element:nth-child(2) { animation-delay: -2s; }
.floating-element:nth-child(3) { animation-delay: -4s; }
.floating-element:nth-child(4) { animation-delay: -6s; }

/* Responsive Design Improvements */
@media (max-width: 640px) {
  .container-responsive {
    @apply px-4;
  }
  
  .card-futuristic {
    @apply p-4;
  }
  
  .btn-futuristic {
    @apply py-2 px-4 text-sm;
  }
}

@media (max-width: 768px) {
  .bg-cyber-grid {
    background-size: 30px 30px;
  }
}

/* Enhanced Scrollbar */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: rgba(56,189,248,0.1);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, #38bdf8, #8c15e9);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(180deg, #0ea5e9, #7c3aed);
}

/* Selection Styles */
::selection {
  background: rgba(56,189,248,0.3);
  color: #ffffff;
}

::-moz-selection {
  background: rgba(56,189,248,0.3);
  color: #ffffff;
}

@layer base {
  :root {
    --font-sans: 'Orbitron', system-ui, sans-serif;
    --font-rajdhani: 'Rajdhani', system-ui, sans-serif;

    --background: 0 0% 7%;
    --foreground: 142 71% 45%;

    --card: 0 0% 7%;
    --card-foreground: 142 71% 45%;

    --popover: 0 0% 7%;
    --popover-foreground: 142 71% 45%;

    --primary: 216 84% 50%;
    --primary-foreground: 142 71% 45%;

    --secondary: 0 0% 68%;
    --secondary-foreground: 0 0% 7%;

    --muted: 0 0% 68%;
    --muted-foreground: 215 20% 65%;

    --accent: 228 12% 92%;
    --accent-foreground: 0 0% 7%;

    --destructive: 0 84.2% 60.2%;
    --destructive-foreground: 142 71% 45%;

    --border: 0 0% 68%;
    --input: 0 0% 68%;
    --ring: 216 84% 53%;

    --radius: 0.5rem;

    --sidebar-background: 228 12% 92%;
    --sidebar-foreground: 0 0% 7%;
    --sidebar-primary: 216 84% 53%;
    --sidebar-primary-foreground: 142 71% 45%;
    --sidebar-accent: 0 0% 68%;
    --sidebar-accent-foreground: 0 0% 7%;
    --sidebar-border: 0 0% 68%;
    --sidebar-ring: 216 84% 53%;
  }

  .dark {
    --background: 0 0% 7%;
    --foreground: 142 71% 45%;

    --card: 0 0% 7%;
    --card-foreground: 142 71% 45%;

    --popover: 0 0% 7%;
    --popover-foreground: 142 71% 45%;

    --primary: 216 84% 50%;
    --primary-foreground: 142 71% 45%;

    --secondary: 0 0% 68%;
    --secondary-foreground: 0 0% 7%;

    --muted: 0 0% 68%;
    --muted-foreground: 215 20% 65%;

    --accent: 228 12% 92%;
    --accent-foreground: 0 0% 7%;

    --destructive: 0 84.2% 60.2%;
    --destructive-foreground: 142 71% 45%;

    --border: 0 0% 68%;
    --input: 0 0% 68%;
    --ring: 216 84% 53%;

    --radius: 0.5rem;

    --sidebar-background: 228 12% 92%;
    --sidebar-foreground: 0 0% 7%;
    --sidebar-primary: 216 84% 53%;
    --sidebar-primary-foreground: 142 71% 45%;
    --sidebar-accent: 0 0% 68%;
    --sidebar-accent-foreground: 0 0% 7%;
    --sidebar-border: 0 0% 68%;
    --sidebar-ring: 216 84% 53%;
  }

  * {
    @apply border-border;
  }

  body {
    @apply bg-background text-foreground;
    font-feature-settings: "rlig" 1, "calt" 1;
  }

  /* Enhanced Typography */
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-sans);
    font-weight: 700;
    letter-spacing: -0.025em;
  }

  /* Enhanced Focus States */
  .focus-visible:focus-visible {
    outline: 2px solid hsl(var(--ring));
    outline-offset: 2px;
    box-shadow: 0 0 0 4px rgba(56,189,248,0.1);
  }

  /* Enhanced Button States */
  .btn:active {
    transform: scale(0.98);
  }

  /* Enhanced Link Hover Effects */
  a:hover {
    text-decoration: none;
  }

  /* Enhanced Form Elements */
  input, textarea, select {
    transition: all 0.2s ease-in-out;
  }

  input:focus, textarea:focus, select:focus {
