            <motion.div
              initial="initial"
              animate="in"
              exit="out"
              variants={pageVariants}
              transition={pageTransition}
              className="relative"
            >
              <BannerManager 
                banners={bannerData}
                rotationInterval={8000}
                maxVisibleBanners={3}
              />
            </motion.div>

            {/* Main Content */}
            <motion.main
