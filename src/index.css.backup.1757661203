  .scrollbar-thin {
    scrollbar-width: thin;
    scrollbar-color: rgba(139, 92, 246, 0.3) transparent;
  }

  .scrollbar-thin::-webkit-scrollbar {
    width: 6px;
  }

  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }

  .scrollbar-thin::-webkit-scrollbar-thumb {
    background-color: rgba(139, 92, 246, 0.3);
    border-radius: 3px;
  }

  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background-color: rgba(139, 92, 246, 0.5);
  }
}

/* Text Utilities */
@layer utilities {
  .text-gradient {
    @apply bg-gradient-to-r from-zion-purple to-zion-cyan bg-clip-text text-transparent;
  }

  .text-gradient-reverse {
    @apply bg-gradient-to-r from-zion-cyan to-zion-purple bg-clip-text text-transparent;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
}

/* Glassmorphism Effects */
@layer utilities {
  .glass {
    @apply bg-white/10 backdrop-blur-md border border-white/20;
  }

  .glass-dark {
    @apply bg-zion-blue-dark/50 backdrop-blur-md border border-zion-purple/20;
  }

  .glass-purple {
    @apply bg-zion-purple/10 backdrop-blur-md border border-zion-purple/30;
  }
}

/* Hover Effects */
@layer utilities {
  .hover-lift {
    @apply transition-transform duration-300 hover:-translate-y-1;
  }

  .hover-glow {
    @apply transition-shadow duration-300 hover:shadow-lg hover:shadow-zion-purple/25;
  }

  .neon-glow {
    @apply shadow-lg shadow-zion-purple/25;
  }

  .neon-glow:hover {
    @apply shadow-xl shadow-zion-purple/40;
  }
}

/* Responsive Utilities */
@layer utilities {
  .container {
    @apply max-w-7xl mx-auto px-4 sm:px-6 lg:px-8;
  }

  .section-padding {
    @apply py-16 md:py-24;
  }

  .section-padding-sm {
    @apply py-12 md:py-16;
  }
}

/* Focus States */
@layer utilities {
  .focus-ring {
    @apply focus:outline-none focus:ring-2 focus:ring-zion-purple focus:ring-offset-2 focus:ring-offset-zion-blue-dark;
  }

  .focus-ring-cyan {
    @apply focus:outline-none focus:ring-2 focus:ring-zion-cyan focus:ring-offset-2 focus:ring-offset-zion-blue-dark;
  }
}

/* Loading States */
@layer utilities {
  .loading {
    @apply animate-pulse bg-zion-blue-light/20;
  }

  .loading-text {
    @apply animate-pulse bg-zion-blue-light/20 rounded;
  }
}

/* Custom Button Styles */
@layer components {
  .btn-primary {
    @apply bg-gradient-to-r from-zion-purple to-zion-purple-dark hover:from-zion-purple-light hover:to-zion-purple text-white font-semibold py-3 px-6 rounded-xl transition-all duration-300 transform hover:scale-105 focus-ring;
  }

  .btn-secondary {
    @apply bg-transparent border-2 border-zion-cyan text-zion-cyan hover:bg-zion-cyan hover:text-zion-blue-dark font-semibold py-3 px-6 rounded-xl transition-all duration-300 focus-ring-cyan;
  }

  .btn-ghost {
    @apply bg-transparent text-zion-slate-light hover:text-white hover:bg-zion-purple/10 font-medium py-2 px-4 rounded-lg transition-all duration-300;
  }
}

/* Card Styles */
@layer components {
  .card {
    @apply bg-zion-blue-dark/50 border border-zion-purple/20 rounded-2xl p-6 shadow-xl hover:shadow-2xl transition-all duration-300;
  }

  .card-hover {
    @apply hover:-translate-y-2 hover:shadow-2xl hover:shadow-zion-purple/25;
  }
}

/* Form Styles */
@layer components {
  .input-field {
    @apply bg-zion-blue-light/20 border border-zion-purple/30 focus:border-zion-purple focus:ring-zion-purple/20 text-white placeholder-zion-slate-light rounded-xl px-4 py-3 transition-all duration-300 focus-ring;
  }

  .input-field:focus {
    @apply bg-zion-blue-light/30;
  }
}

/* Animation Delays */
@layer utilities {
  .animation-delay-100 {
    animation-delay: 100ms;
  }

  .animation-delay-200 {
    animation-delay: 200ms;
  }

  .animation-delay-300 {
    animation-delay: 300ms;
  }

  .animation-delay-400 {
    animation-delay: 400ms;
  }

  .animation-delay-500 {
    animation-delay: 500ms;
  }
}

/* Performance Optimizations */
@layer utilities {
  .will-change-transform {
    will-change: transform;
  }

  .will-change-opacity {
    will-change: opacity;
  }

  .will-change-scroll {
    will-change: scroll-position;
  }
}

/* Print Styles */
@media print {
  .no-print {
    display: none !important;
  }
  
  .print-break {
    page-break-before: always;
  }
}
