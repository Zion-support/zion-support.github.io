}

/* Color Blindness Support */
.protanopia {
  filter: url('#protanopia');
}

.deuteranopia {
  filter: url('#deuteranopia');
}

.tritanopia {
  filter: url('#tritanopia');
}

/* Enhanced Focus Indicators */
.show-focus-indicator *:focus-visible {
  outline: var(--focus-ring-width) solid var(--focus-ring-color) !important;
  outline-offset: var(--focus-ring-offset) !important;
  border-radius: 4px;
}

/* Skip to Content Link */
.skip-to-content {
  position: absolute;
  top: -40px;
  left: 6px;
  background: #000;
  color: #fff;
  padding: 8px;
  text-decoration: none;
  border-radius: 4px;
}

/* Futuristic Design Elements */
.futuristic-bg {
  background: linear-gradient(135deg, #0f0f23 0%, #1a1a2e 25%, #16213e 50%, #0f3460 75%, #533483 100%);
  position: relative;
  overflow: hidden;
}

.futuristic-bg::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    radial-gradient(circle at 20% 80%, rgba(120, 119, 198, 0.3) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(255, 119, 198, 0.3) 0%, transparent 50%),
    radial-gradient(circle at 40% 40%, rgba(120, 219, 255, 0.2) 0%, transparent 50%);
  animation: var(--float-animation);
}

.futuristic-bg::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.02'%3E%3Ccircle cx='30' cy='30' r='2'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  animation: var(--matrix-animation);
}

/* Neon Effects */
.neon-text {
  text-shadow: 
    0 0 5px currentColor,
    0 0 10px currentColor,
    0 0 15px currentColor,
    0 0 20px currentColor;
}

.neon-border {
  box-shadow: 
    0 0 5px currentColor,
    0 0 10px currentColor,
    0 0 15px currentColor,
    inset 0 0 5px currentColor;
}

.neon-cyan { color: var(--neon-cyan); }
.neon-purple { color: var(--neon-purple); }
.neon-pink { color: var(--neon-pink); }
.neon-green { color: var(--neon-green); }
.neon-blue { color: var(--neon-blue); }
.neon-orange { color: var(--neon-orange); }
.neon-yellow { color: var(--neon-yellow); }
.neon-red { color: var(--neon-red); }

/* Glass Morphism */
.glass-card {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}

.glass-card:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.2);
  transform: translateY(-2px);
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
}

/* Futuristic Buttons */
.futuristic-btn {
  background: linear-gradient(135deg, var(--neon-cyan) 0%, var(--neon-blue) 100%);
  border: none;
  border-radius: 8px;
  color: #000;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(0, 255, 255, 0.3);
}

.futuristic-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
  transition: left 0.5s;
}

.futuristic-btn:hover::before {
  left: 100%;
}

.futuristic-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(0, 255, 255, 0.5);
}

.futuristic-btn:active {
  transform: translateY(0);
}

/* Animated Backgrounds */
.animated-bg {
  background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab);
  background-size: 400% 400%;
  animation: gradientShift 15s ease infinite;
}

.cyber-grid {
  background-image: 
    linear-gradient(rgba(0, 255, 255, 0.1) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 255, 255, 0.1) 1px, transparent 1px);
  background-size: 50px 50px;
  animation: gridMove 20s linear infinite;
}

.quantum-particles {
  background: radial-gradient(circle at center, transparent 0%, rgba(0, 255, 255, 0.1) 100%);
  animation: quantumFloat 8s ease-in-out infinite;
}

/* Futuristic Animations */
@keyframes float {
  0%, 100% { transform: translateY(0px) rotate(0deg); }
  33% { transform: translateY(-20px) rotate(1deg); }
  66% { transform: translateY(-10px) rotate(-1deg); }
}

@keyframes glow {
  from { box-shadow: 0 0 5px currentColor, 0 0 10px currentColor, 0 0 15px currentColor; }
  to { box-shadow: 0 0 10px currentColor, 0 0 20px currentColor, 0 0 30px currentColor; }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes matrix {
  0% { transform: translateY(0); }
  100% { transform: translateY(50px); }
}

@keyframes gradientShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

@keyframes gridMove {
  0% { transform: translate(0, 0); }
  100% { transform: translate(50px, 50px); }
}

@keyframes quantumFloat {
  0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.1; }
  50% { transform: scale(1.2) rotate(180deg); opacity: 0.3; }
}

/* Responsive Design Improvements */
@media (max-width: 768px) {
  .glass-card {
    backdrop-filter: blur(10px);
    border-radius: 12px;
  }
  
  .futuristic-btn {
    font-size: 14px;
    padding: 12px 20px;
  }
  
  .neon-text {
    text-shadow: 
      0 0 3px currentColor,
      0 0 6px currentColor,
      0 0 9px currentColor;
  }
}

@media (max-width: 480px) {
  .glass-card {
    backdrop-filter: blur(5px);
    border-radius: 8px;
  }
  
  .futuristic-btn {
    font-size: 12px;
    padding: 10px 16px;
  }
  
  .neon-text {
    text-shadow: 
      0 0 2px currentColor,
      0 0 4px currentColor;
  }
}

/* Enhanced Typography */
.futuristic-heading {
  background: linear-gradient(135deg, var(--neon-cyan), var(--neon-purple), var(--neon-pink));
  background-size: 200% 200%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: gradientShift 3s ease infinite;
  font-weight: 800;
  letter-spacing: -0.02em;
}

.futuristic-subheading {
  color: var(--neon-cyan);
  font-weight: 600;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

/* Enhanced Cards */
.service-card {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 20px;
  padding: 2rem;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.service-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--neon-cyan), var(--neon-purple), var(--neon-pink));
  transform: scaleX(0);
  transition: transform 0.4s ease;
}

.service-card:hover::before {
  transform: scaleX(1);
}

.service-card:hover {
  transform: translateY(-8px) scale(1.02);
  border-color: rgba(255, 255, 255, 0.3);
  box-shadow: 
    0 20px 40px rgba(0, 0, 0, 0.4),
    0 0 20px rgba(0, 255, 255, 0.2);
}

/* Enhanced Navigation */
.futuristic-nav {
  background: rgba(0, 0, 0, 0.8);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.futuristic-nav-item {
  position: relative;
  color: rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
}

.futuristic-nav-item::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 50%;
  width: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--neon-cyan), var(--neon-purple));
  transition: all 0.3s ease;
  transform: translateX(-50%);
}

.futuristic-nav-item:hover::after {
  width: 100%;
}

.futuristic-nav-item:hover {
  color: var(--neon-cyan);
}

/* Enhanced Footer */
.futuristic-footer {
  background: linear-gradient(135deg, #0f0f23 0%, #1a1a2e 100%);
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  position: relative;
  overflow: hidden;
}

.futuristic-footer::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--neon-cyan), transparent);
}

/* Enhanced Sidebar */
.futuristic-sidebar {
  background: rgba(0, 0, 0, 0.95);
  backdrop-filter: blur(30px);
  border-right: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: 5px 0 30px rgba(0, 0, 0, 0.5);
}

.futuristic-sidebar-item {
  color: rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
  border-radius: 8px;
  margin: 4px 8px;
  padding: 12px 16px;
}

.futuristic-sidebar-item:hover {
  background: rgba(0, 255, 255, 0.1);
  color: var(--neon-cyan);
  transform: translateX(8px);
}

/* Enhanced Forms */
.futuristic-input {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 8px;
  color: white;
  padding: 12px 16px;
  transition: all 0.3s ease;
}

.futuristic-input:focus {
  border-color: var(--neon-cyan);
  box-shadow: 0 0 20px rgba(0, 255, 255, 0.3);
  outline: none;
}

.futuristic-input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

/* Enhanced Tables */
.futuristic-table {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  border-radius: 16px;
  overflow: hidden;
}

.futuristic-table th {
  background: rgba(0, 255, 255, 0.1);
  color: var(--neon-cyan);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.futuristic-table tr:hover {
  background: rgba(255, 255, 255, 0.05);
}

/* Enhanced Modals */
.futuristic-modal {
  background: rgba(0, 0, 0, 0.95);
  backdrop-filter: blur(30px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 20px;
  box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
}

.futuristic-modal-header {
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  padding: 1.5rem;
}

.futuristic-modal-title {
  color: var(--neon-cyan);
  font-weight: 700;
  font-size: 1.5rem;
}

/* Enhanced Loading States */
.futuristic-loader {
  width: 60px;
  height: 60px;
  border: 3px solid rgba(255, 255, 255, 0.1);
  border-top: 3px solid var(--neon-cyan);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* Enhanced Scrollbar */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.05);
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(135deg, var(--neon-cyan), var(--neon-purple));
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(135deg, var(--neon-purple), var(--neon-pink));
}

/* Enhanced Selection */
::selection {
  background: rgba(0, 255, 255, 0.3);
  color: white;
}

::-moz-selection {
  background: rgba(0, 255, 255, 0.3);
  color: white;
}

/* Enhanced Focus States */
.futuristic-focus:focus {
  outline: none;
  box-shadow: 
    0 0 0 3px rgba(0, 255, 255, 0.3),
    0 0 20px rgba(0, 255, 255, 0.2);
}

/* Enhanced Hover Effects */
.futuristic-hover {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.futuristic-hover:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
}

/* Enhanced Transitions */
.futuristic-transition {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Enhanced Gradients */
.gradient-text {
  background: linear-gradient(135deg, var(--neon-cyan), var(--neon-purple), var(--neon-pink));
  background-size: 200% 200%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: gradientShift 3s ease infinite;
}

.gradient-border {
  border: 2px solid;
  border-image: linear-gradient(135deg, var(--neon-cyan), var(--neon-purple), var(--neon-pink)) 1;
}

.gradient-bg {
  background: linear-gradient(135deg, var(--neon-cyan), var(--neon-purple), var(--neon-pink));
  background-size: 200% 200%;
  animation: gradientShift 3s ease infinite;
}

/* Enhanced Shadows */
.neon-shadow {
  box-shadow: 
    0 0 5px currentColor,
    0 0 10px currentColor,
    0 0 15px currentColor,
    0 0 20px currentColor;
}

.neon-shadow-hover:hover {
  box-shadow: 
    0 0 10px currentColor,
    0 0 20px currentColor,
    0 0 30px currentColor,
    0 0 40px currentColor;
}

/* Enhanced Animations for Reduced Motion */
@media (prefers-reduced-motion: reduce) {
  .futuristic-bg::before,
  .futuristic-bg::after,
  .cyber-grid,
  .quantum-particles {
    animation: none;
  }
  
  .futuristic-btn::before {
    display: none;
  }
  
  .service-card:hover {
    transform: none;
  }
  
  .futuristic-sidebar-item:hover {
    transform: none;
  }
}

/* Print Styles */
@media print {
  .futuristic-bg::before,
  .futuristic-bg::after,
  .cyber-grid,
  .quantum-particles {
    display: none;
  }
  
  .glass-card {
    background: white;
    border: 1px solid #ccc;
    box-shadow: none;
  }
  
  .neon-text {
    text-shadow: none;
    color: black;
  }
  
  .futuristic-btn {
    background: #ccc;
    color: black;
    box-shadow: none;
  }
}

