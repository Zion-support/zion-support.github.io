@layer base {
  :root {
    --background: 0 0% 100%;
    --foreground: 224 71% 4%;
    --card: 0 0% 100%;
    --card-foreground: 224 71% 4%;
    --popover: 0 0% 100%;
    --popover-foreground: 224 71% 4%;
    --primary: 220.9 39.3% 11%;
    --primary-foreground: 210 9% 98%;
    --secondary: 220 14.3% 95.9%;
    --secondary-foreground: 220.9 39.3% 11%;
    --muted: 220 14.3% 95.9%;
    --muted-foreground: 220 8.9% 46.1%;
    --accent: 220 14.3% 95.9%;
    --accent-foreground: 220.9 39.3% 11%;
    --destructive: 0 84.2% 60.2%;
    --destructive-foreground: 142 71% 45%;

    --border: 0 0% 68%;
    --input: 0 0% 68%;
    --ring: 216 84% 53%;

    --radius: 0.5rem;

    --sidebar-background: 228 12% 92%;
    --sidebar-foreground: 0 0% 7%;
    --sidebar-primary: 216 84% 53%;
    --sidebar-primary-foreground: 142 71% 45%;
    --sidebar-accent: 0 0% 68%;
    --sidebar-accent-foreground: 0 0% 7%;
    --sidebar-border: 0 0% 68%;
    --sidebar-ring: 216 84% 53%;

    /* Custom Zion variables */
    --zion-cyan: #22ddd2;
    --zion-blue: #2e73ea;
    --zion-purple: #8c15e9;
    --zion-slate: #17072b;
    --zion-slate-light: #451582;
    --zion-slate-dark: #000000;
    
    /* Accessibility variables */
    --font-size: 16px;
    --line-height: 1.5;
    --letter-spacing: 0px;
    --reduced-motion: no-preference;
  }

