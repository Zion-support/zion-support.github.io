  .btn-ghost {
    @apply inline-flex items-center px-6 py-3 text-zion-cyan font-semibold rounded-lg hover:bg-zion-cyan/10 transition-all duration-300 focus:outline-none focus:ring-4 focus:ring-zion-cyan/50;
