{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "noEmit": true,
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "exclude": [
    "src/pages/blog-disabled/**/*",
    "app/blog",
    "app/components",
    "blog",
    "components",
    "src/components/**/*",
    "src/pages/blog/**/*"
  ]
}