# Yarn configuration for Netlify builds
# Disable immutable installs to prevent file system conflicts
enable-immutable-installs false

# Set cache folder
cache-folder "/opt/buildhome/.yarn_cache"

# Ignore engines to prevent version conflicts
ignore-engines true

# Network timeout
network-timeout 1000000

# Prefer offline packages when available
prefer-offline true

# Disable optional dependencies to reduce conflicts
optional false

# Disable frozen lockfile for more flexible installs
frozen-lockfile false

# Enable network concurrency for faster installs
network-concurrency 1

# Disable progress bar for cleaner logs
progress false