# Yarn configuration for Netlify builds
# Disable immutable installs to allow dependency resolution
enable-immutable-installs false

# Network timeout for slow connections
network-timeout 1000000

# Ignore engine requirements to prevent build failures
ignore-engines true

# Disable frozen lockfile to allow dependency updates
frozen-lockfile false

# Cache configuration
cache-folder "/opt/buildhome/.yarn_cache"

# Enable parallel installs for faster builds
enable-parallel-installs true

# Disable telemetry
enable-telemetry false