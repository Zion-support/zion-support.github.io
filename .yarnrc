# Force npm usage and disable Yarn completely
# This file explicitly tells Yarn to not work
yarn-path "npm"
yarn-version "npm"
package-manager "npm"
enableGlobalCache false
enableScripts false
enableTelemetry false
enableStrictSsl false
enablePreferOffline false
enablePreferOnline false
enablePreferInteractive false
enablePreferOffline false
enablePreferOnline false
enablePreferInteractive false
