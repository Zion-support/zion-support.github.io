# Yarn configuration for Netlify builds and prevent EEXIST errors
# Enable network timeout for better reliability
network-timeout 1000000
# Use frozen lockfile for consistent builds
frozen-lockfile true
# Ignore engine requirements for compatibility
ignore-engines true
# Disable immutable installs to allow dependency resolution
install.enable-immutable-installs false
# Additional flags to prevent EEXIST errors
--install.frozen-lockfile false
--install.prefer-offline false
--install.ignore-engines false
