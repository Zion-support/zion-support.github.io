# Environment Variables Example
# Copy this file to .env.local and fill in your actual values

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Zion Tech Group"
NEXT_PUBLIC_APP_VERSION=1.0.0

# Database
DATABASE_URL=your_database_url_here
DATABASE_POOL_SIZE=10

# Authentication
JWT_SECRET=your_jwt_secret_here_min_32_chars
SESSION_SECRET=your_session_secret_here_min_32_chars

# Supabase (Public variables - safe to expose)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase (Private variables - keep secret)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_DATABASE_URL=your_supabase_database_url_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Analytics (Public variables - safe to expose)
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_ga_measurement_id_here
NEXT_PUBLIC_GTM_ID=your_gtm_id_here

# Sentry (Public variables - safe to expose)
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# Sentry (Private variables - keep secret)
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
SENTRY_DSN=your_sentry_dsn_here
SENTRY_ORG=your_sentry_org_here
SENTRY_PROJECT=your_sentry_project_here

# Email Configuration
SMTP_HOST=your_smtp_host_here
SMTP_PORT=587
SMTP_USER=your_smtp_user_here
SMTP_PASS=your_smtp_password_here

# AI Services
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudinary (Public variables - safe to expose)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here

# Cloudinary (Private variables - keep secret)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here

# LaunchDarkly
LAUNCHDARKLY_SHARED_SECRET=your_launchdarkly_shared_secret_here

# Other
NPM_CONFIG_LEGACY_PEER_DEPS=true
SKIP_REACT_VERSION_CHECK=true
NODE_VERSION=20

# Vite (if using Vite)
VITE_GA_ID=your_ga_id_here
VITE_REOWN_PROJECT_ID=your_reown_project_id_here
VITE_REOWN_PROJECT_SECRET=your_reown_project_secret_here
VITE_SUPABASE_URL=your_supabase_url_here