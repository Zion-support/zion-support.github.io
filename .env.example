# Zion Tech Group — Environment Configuration
# Copy to .env and fill in real credentials

# ── Email Responder (IMAP/SMTP) ─────────────────────────────────────────────
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=your-email@domain.com
EMAIL_PASS=your-app-password

# Optional: SMTP for sending (uses same host if not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-app-password

# ── LLM Provider (for AI features) ──────────────────────────────────────────
# Currently uses local LLM via inference provider — no API key needed.
# If switching to OpenAI/Anthropic, set:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Contact Info (for auto-generated content) ───────────────────────────────
CONTACT_PHONE=+1 302 464 0950
CONTACT_EMAIL=kleber@ziontechgroup.com
CONTACT_ADDRESS=364 E Main St STE 1008 Middletown DE 19709

# ── JWT Secret (for magic-link auth in future features) ─────────────────────
JWT_SECRET=generate-a-long-random-string-and-keep-it-secret

# ── Cron & Automation ───────────────────────────────────────────────────────
# Set timezone for scheduled jobs (default: UTC)
TZ=America/New_York

# Optional: Telegram bot token for notifications (if using Telegram channel)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
