# Zion Tech Group - Environment Configuration
# Copy this file to .env.local for local development

# =============================================================================
# APP CONFIGURATION
# =============================================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://ziontechgroup.com
NEXT_PUBLIC_APP_NAME="Zion Tech Group"
NEXT_PUBLIC_VERSION=1.0.0

# =============================================================================
# ANALYTICS
# =============================================================================
# Google Analytics Measurement ID (starts with G-)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# =============================================================================
# API CONFIGURATION
# =============================================================================
NEXT_PUBLIC_API_BASE_URL=https://api.ziontechgroup.com
NEXT_PUBLIC_API_TIMEOUT=30000

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable analytics tracking
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Enable/disable error tracking (Sentry, etc.)
NEXT_PUBLIC_ENABLE_ERROR_TRACKING=true

# Enable/disable performance monitoring
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true

# =============================================================================
# LOGGING
# =============================================================================
# Log level: DEBUG, INFO, WARN, ERROR, NONE
NEXT_PUBLIC_LOG_LEVEL=INFO

# =============================================================================
# BUILD CONFIGURATION
# =============================================================================
# Unique build identifier
BUILD_ID=

# =============================================================================
# THIRD-PARTY SERVICES (Optional)
# =============================================================================
# Add your service API keys here
# NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
# NEXT_PUBLIC_MAPBOX_TOKEN=
# SENTRY_DSN=

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================
# These should only be set in development
# NEXT_PUBLIC_DEV_MODE=true
# NEXT_PUBLIC_MOCK_API=false
