# Email Responder Configuration
# Copy to .env and fill in your credentials

# IMAP Settings
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password

# Optional
EMAIL_MAILBOX=INBOX
EMAIL_DRY_RUN=true
EMAIL_CONFIDENCE_THRESHOLD=0.75
EMAIL_POLL_INTERVAL=300000

# LLM Endpoint (uses existing Next.js LLM API)
EMAIL_LLM_ENDPOINT=http://localhost:3000/api/llm/chat

# Base URL for links in emails
BASE_URL=https://ziontechgroup.com

# Auto-send delay (ms) after draft creation for human review
EMAIL_AUTO_SEND_DELAY=0