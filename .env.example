# Google Analytics Tracking ID
REACT_APP_GA_TRACKING_ID=G-XXXXXXXXXX

# Environment
NODE_ENV=production

# Build Configuration
VITE_APP_TITLE=Zion Tech Group
VITE_APP_DESCRIPTION=Leading provider of AI-powered enterprise solutions, quantum computing, autonomous systems, and digital transformation services.

# ── Automation AI Provider ─────────────────────────────────
# Primary: Local Ollama (free, no key needed). Run: npm run llm:install
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
# OLLAMA_ENABLED=false   # Set to skip Ollama, use OpenRouter only

# Fallback: OpenRouter (when Ollama unavailable, e.g. CI/GitHub Actions)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
# Anthropic Claude (legacy fallback)
ANTHROPIC_API_KEY=
# OpenAI GPT (legacy fallback)
OPENAI_API_KEY=

# ── Notifications ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Social Media Automation ────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_URN=
IG_ACCESS_TOKEN=
IG_USER_ID=
TWITTER_ACCESS_TOKEN=

# ── Email Automation ───────────────────────────────────────
EMAIL_USER=
EMAIL_PASS=
EMAIL_SERVICE=gmail

# ── AI Chat Widget (client-side) ──────────────────────────
NEXT_PUBLIC_OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
