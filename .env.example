# Google Analytics Tracking ID
REACT_APP_GA_TRACKING_ID=G-XXXXXXXXXX

# Environment
NODE_ENV=production

# Build Configuration
VITE_APP_TITLE=Zion Tech Group
VITE_APP_DESCRIPTION=Leading provider of AI-powered enterprise solutions, quantum computing, autonomous systems, and digital transformation services.

# ── Automation AI Provider (multi-provider with free fallbacks) ──
# 1. Primary: Local Ollama (free, no key). Run: npm run llm:install
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:0.6b
# OLLAMA_ENABLED=false   # Set to skip Ollama as fallback

# 2. Cloud LLMs (in order, first-available with API keys):
#    Groq (ultra-fast) — console.groq.com
GROQ_API_KEY=
#    Google Gemini (1.5k req/day) — aistudio.google.com/apikey
GEMINI_API_KEY=
#    Cloudflare Workers AI (10k Neurons/day) — dash.cloudflare.com
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
#    HuggingFace (300 req/hr) — huggingface.co/settings/tokens
HUGGINGFACE_HUB_TOKEN=
#    Cerebras (1M tokens/day) — cloud.cerebras.ai
CEREBRAS_API_KEY=
#    DeepSeek (5M tokens free) — platform.deepseek.com
DEEPSEEK_API_KEY=
#    Mistral AI (free tier) — console.mistral.ai
MISTRAL_API_KEY=
#    Together AI (free research models) — together.ai
TOGETHER_API_KEY=
#    Fireworks AI (free trial) — fireworks.ai
FIREWORKS_API_KEY=
#    Cohere (1k req/month trial) — dashboard.cohere.com
COHERE_API_KEY=
#    OpenRouter (broad fallback) — openrouter.ai
OPENROUTER_API_KEY=
# Optional model overrides per provider:
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.5-flash-preview-05-20
# OPENROUTER_MODEL=openrouter/free

# Anthropic / OpenAI (legacy direct)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Notifications ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Social Media Automation ────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_URN=
IG_ACCESS_TOKEN=
IG_USER_ID=
TWITTER_ACCESS_TOKEN=

# ── Email Automation ───────────────────────────────────────
EMAIL_USER=
EMAIL_PASS=
EMAIL_SERVICE=gmail

# ── AI Chat Widget (client-side) ──────────────────────────
# Netlify /api/chat uses: Ollama → Groq → Gemini → HF → Cerebras → Cloudflare → DeepSeek → Mistral → Together → Cohere → OpenRouter (server-side)
# Client fallback: OpenRouter direct when /api/chat unavailable
# Rule-based fallback for common questions works without any API key
NEXT_PUBLIC_OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
