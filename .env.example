# Email Responder Configuration
# Copy to .env and fill in your email credentials

# IMAP server settings
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password  # Use app-specific password for Gmail
EMAIL_MAILBOX=INBOX

# Behavior
EMAIL_DRY_RUN=true              # Set to false to send real replies
EMAIL_CONFIDENCE_THRESHOLD=0.8  # Min confidence (0-1) to auto-respond
EMAIL_POLL_INTERVAL=300000      # Poll every 5 minutes (ms)

# LLM endpoint (defaults to local Next.js llm/chat)
EMAIL_LLM_ENDPOINT=http://localhost:3000/api/llm/chat

# Base URL used in auto-replies
BASE_URL=https://ziontechgroup.com
