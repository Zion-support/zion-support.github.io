# Environment Configuration Example
# Copy this file to .env.local for local development

# Application Environment
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://ziontechgroup.com

# Analytics & Monitoring
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_ANALYTICS_ENABLED=true

# Performance Monitoring
NEXT_PUBLIC_PERFORMANCE_MONITORING=true
NEXT_PUBLIC_WEB_VITALS_ENABLED=true

# Feature Flags
NEXT_PUBLIC_PWA_ENABLED=true
NEXT_PUBLIC_OFFLINE_MODE=true

# API Configuration
NEXT_PUBLIC_API_URL=
API_SECRET_KEY=

# Security
NEXT_PUBLIC_CSP_NONCE=

# Logging
NEXT_PUBLIC_LOG_LEVEL=info
NEXT_PUBLIC_REMOTE_LOGGING=false
NEXT_PUBLIC_REMOTE_LOG_ENDPOINT=

# Build Configuration
ANALYZE=false
NEXT_PUBLIC_BUILD_TIME=

# SEO
NEXT_PUBLIC_SITE_NAME=Zion Tech Group
NEXT_PUBLIC_SITE_DESCRIPTION=Leading provider of AI-powered enterprise solutions