# Environment Configuration
NODE_ENV=development

# Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Authentication
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# OAuth Provider Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Wallet & Web3 Configuration
NEXT_PUBLIC_REOWN_PROJECT_ID=your_reown_project_id_here
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key_here
NEXT_PUBLIC_ZION_TOKEN_CONTRACT_ADDRESS=your_token_contract_address_here
NEXT_PUBLIC_ZION_TOKEN_NETWORK_ID=1
NEXT_PUBLIC_SNAPSHOT_SPACE_ID=yourproject.eth
NEXT_PUBLIC_SNAPSHOT_HUB_URL=https://hub.snapshot.org

# Sentry Error Monitoring
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here # For Next.js frontend
SENTRY_DSN_DJANGO=your_django_sentry_dsn_here # For Django backend
SENTRY_DSN_SUPABASE=your_supabase_sentry_dsn_here # For Supabase Functions (set in Supabase Dashboard)
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development # Or production, staging. Used by all Sentry instances.
NEXT_PUBLIC_SENTRY_RELEASE=your_app_release_version_here # e.g., myapp@1.0.0. Used by all Sentry instances.

# Datadog Browser Logs (Frontend)
NEXT_PUBLIC_DATADOG_CLIENT_TOKEN=your_datadog_client_token_here
NEXT_PUBLIC_DATADOG_SITE=datadoghq.com # e.g., datadoghq.com, datadoghq.eu
NEXT_PUBLIC_DATADOG_SERVICE_NAME=zion-frontend # Your service name in Datadog

# LogRocket (Frontend)
NEXT_PUBLIC_LOGROCKET_APP_ID=your_logrocket_app_id_here

# Other Logging Settings
CLIENT_DEBUG_LOGGING=false # Set to true for /api/logs to process client-side debug messages

# Stripe Payment Processing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
NEXT_PUBLIC_STRIPE_TEST_PUBLISHABLE_KEY=your_stripe_test_publishable_key_here
NEXT_PUBLIC_STRIPE_TEST_KEY=
STRIPE_TEST_SECRET_KEY=your_stripe_test_secret_key_here

# Cloudinary Media Management
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Email Configuration
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourcompany.com
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=your_ga_id_here
NEXT_PUBLIC_INTERCOM_APP_ID=your_intercom_app_id_here

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_ENABLE_ERROR_REPORTING=true

# Supabase Environment Variables
NEXT_PUBLIC_SUPABASE_URL="your_supabase_url_here"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# Development Configuration
VITE_DEV_TOOLS=true
VITE_HOT_RELOAD=true