#!/usr/bin/env node import fs from 'fs';' import path from 'path'; // Get all files with errors from the lint output' const lintOutput = fs.readFileSync('/workspace/lint_output.txt', 'utf8'); const errorFiles = []; // Extract file paths from lint output' const lines = lintOutput.split('\n'); for (const line of lines) {' if (line.startsWith('/workspace/app/blog/') && line.includes('.tsx')) {' const filePath = line.split(' ')[0]; if (filePath && !errorFiles.includes(filePath)) { errorFiles.push(filePath); } } } console.log(`Found ${errorFiles.length} files with errors`); // Function to fix merge conflicts function fixMergeConflicts(content) { // Remove merge conflict markers and keep the HEAD version' const lines = content.split('\n'); const fixedLines = []; let inConflict = false; let keepLines = true; for (const line of lines) {' if (line.includes('')) { inConflict = true; keepLines = true; continue;' } else if (line.includes('')) { keepLines = false; continue;' } else if (line.includes('>>>>>>>')) { inConflict = false; keepLines = true; continue; } if (!inConflict || keepLines) { fixedLines.push(line); } } ' return fixedLines.join('\n'); } // Function to fix malformed JSX function fixMalformedJSX(content) { // Fix /* content */} patterns' content = content.replace(/\/\* content \*\/\}/g, ''); // Fix className="$1" patterns' content = content.replace(/className="\$1"/g, 'className=""'); // Fix duplicate return statements' content = content.replace(/return \(\s*<div>\s*\/\* content \*\/\}\s*return \(/g, 'return ('); // Fix malformed JSX closing tags' content = content.replace(/<div>\s*\/\* content \*\/\}/g, '<div>'); return content; } // Function to fix missing commas in objects function fixMissingCommas(content) { // Fix twitter object missing comma' content = content.replace(/twitter:\s*\n\s*card:/g, 'twitter: {\n card:');' content = content.replace(/description: '([^']*)',\s*\n\s*},/g, 'description: \'$1\',\n },\n};'); return content; } // Process each file let fixedCount = 0; for (const filePath of errorFiles) { try {' let content = fs.readFileSync(filePath, 'utf8'); const originalContent = content; // Apply fixes content = fixMergeConflicts(content); content = fixMalformedJSX(content); content = fixMissingCommas(content); // Only write if content changed if (content !== originalContent) {' fs.writeFileSync(filePath, content, 'utf8'); console.log(`Fixed: ${filePath}`); fixedCount++; } } catch (error) { console.error(`Error processing ${filePath}:`, error.message); } } console.log(`Fixed ${fixedCount} files`);'