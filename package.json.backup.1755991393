{
  "name": "zion-multichain-suite",
  "version": "0.1.0",
  "private": true,
  "description": "Secure, modular smart contracts and deploy scripts for ZION$ multichain (zkSync, Starknet relay, L2s)",
  "license": "MIT",
  "scripts": {
          "postautomation": "npm run automation:git-sync",
      "lint:staged": "lint-staged",
      "performance:audit": "node automation/performance-audit.cjs",
      "nextgen:factory": "node automation/nextgen-autonomous-factory.cjs scan",
      "nextgen:orchestrator": "node automation/nextgen-orchestrator.cjs start",
      "nextgen:scan": "node automation/nextgen-autonomous-factory.cjs scan",
      "nextgen:cron:start": "bash automation/nextgen-cron.sh start",
      "nextgen:cron:stop": "bash automation/nextgen-cron.sh stop",
      "nextgen:cron:status": "bash automation/nextgen-cron.sh status",
      "nextgen:scheduler": "node automation/nextgen-scheduler.cjs"
    },
  "dependencies": {
    "@google-analytics/data": "^5.2.0",
    "@google/generative-ai": "^0.24.1",
    "@magneticwatermelon/mcp-toolkit": "^1.1.4",
    "@modelcontextprotocol/sdk": "^1.17.1",
    "@modelcontextprotocol/server-filesystem": "^2025.7.29",
    "@modelcontextprotocol/server-memory": "^2025.8.4",
    "@modelcontextprotocol/server-sequential-thinking": "^2025.7.1",