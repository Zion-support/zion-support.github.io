[[plugins]]
  package = "netlify-plugin-cloudinary"

[[plugins]]
  package = "./netlify/plugins/run-functions-and-rerun"
  [plugins.inputs]
    # Optional: comma-separated includes/excludes
    include = ""
    exclude = ""
    concurrency = 6
    timeoutMs = 180000

# Scheduled Functions (new automations replacing some GitHub Actions cadence)
[[scheduled.functions]]
  name = "homepage_advertiser"
  schedule = "*/15 * * * *" # every 15 minutes

[[scheduled.functions]]
  name = "cloud_orchestrator"
  schedule = "0 */4 * * *" # every 4 hours

[[scheduled.functions]]
  name = "front-enhancer"
  schedule = "*/5 * * * *" # every 5 minutes

[[scheduled.functions]]
  name = "front-index-orchestrator"
  schedule = "*/5 * * * *" # every 5 minutes

[[scheduled.functions]]
  name = "frontpage-enhancer"
  schedule = "*/20 * * * *" # every 20 minutes

[[scheduled.functions]]
  name = "marketing-and-features-promo"
  schedule = "0 */2 * * *" # every 2 hours

[[scheduled.functions]]
  name = "link-and-health-scheduler"
  schedule = "0 */6 * * *" # every 6 hours

[[scheduled.functions]]
  name = "sitemap_runner"
  schedule = "0 */12 * * *" # twice per day

[[redirects]]
  from = "/team"
  to = "/about"
  status = 301

