{
  "name": "ziontechgroup-site",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3000",
    "export": "next build && next export",
    "clean": "rm -rf .next out dist",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0 || true",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix || true",
    "type-check": "tsc --noEmit",
    "perf:lighthouse": "npx --yes lighthouse https://ziontechgroup.com --output=html --output-path=./lighthouse-report.html",
    "format": "prettier --write ."
  },
  "dependencies": {
    "next": "^15.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lucide-react": "^0.536.0",
    "framer-motion": "^12.23.12",
    "axios": "^1.11.0",
    "@radix-ui/react-navigation-menu": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.0.6"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9.34.0",
    "eslint-config-next": "^14.2.32",
    "prettier": "^3.3.3",
    "typescript": "^5.9.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zion-Holdings/zion.app.git"
  },
  "author": "Zion Tech Group",
  "license": "MIT"
}

