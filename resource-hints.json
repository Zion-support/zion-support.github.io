{
  "preload": [
    {
      "href": "/fonts/inter-var.woff2",
      "as": "font",
      "type": "font/woff2",
      "crossorigin": "anonymous"
    },
    {
      "href": "/css/critical.css",
      "as": "style"
    }
  ],
  "prefetch": [
    {
      "href": "/images/hero-bg.webp",
