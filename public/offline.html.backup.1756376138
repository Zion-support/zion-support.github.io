        // Keyboard navigation support
        document.addEventListener('keydown', (event) => {
            if (event.key === 'Enter' || event.key === ' ') {
                event.preventDefault();
                if (document.activeElement.classList.contains('btn-primary')) {
                    window.location.reload();
                } else if (document.activeElement.classList.contains('btn-secondary')) {
                    checkConnection();
                }
            }
        });

        // Focus management for accessibility
        const buttons = document.querySelectorAll('.btn');
        buttons.forEach((button, index) => {
            button.setAttribute('tabindex', '0');
            button.setAttribute('role', 'button');
            button.setAttribute('aria-label', button.textContent.trim());
            
            // Add focus indicators
            button.addEventListener('focus', () => {
                button.style.outline = '3px solid #22ddd2';
                button.style.outlineOffset = '2px';
            });
            
            button.addEventListener('blur', () => {
                button.style.outline = 'none';
            });
        });

        // Announce status changes to screen readers
        function announceToScreenReader(message) {
            const announcement = document.createElement('div');
            announcement.setAttribute('aria-live', 'polite');
            announcement.setAttribute('aria-atomic', 'true');
            announcement.className = 'sr-only';
            announcement.textContent = message;
            
            document.body.appendChild(announcement);
            
            setTimeout(() => {
                if (document.body.contains(announcement)) {
                    document.body.removeChild(announcement);
                }
            }, 1000);
        }

        // Enhanced connection checking with user feedback
        function enhancedCheckConnection() {
            const statusText = document.getElementById('statusText');
            statusText.textContent = 'Testing connection...';
            
            // Test multiple endpoints
            const testUrls = [
                'https://www.google.com/favicon.ico',
                'https://www.cloudflare.com/favicon.ico',
                '/favicon.ico'
            ];
            
            let successCount = 0;
            let totalTests = testUrls.length;
            
            testUrls.forEach(url => {
                fetch(url, { 
                    method: 'HEAD',
                    cache: 'no-cache',
                    mode: 'no-cors'
                })
                .then(() => {
                    successCount++;
                    if (successCount === totalTests) {
                        handleConnectionRestored();
                    }
                })
                .catch(() => {
                    totalTests--;
                    if (successCount === 0 && totalTests === 0) {
                        handleConnectionFailed();
                    }
                });
            });
        }

        function handleConnectionRestored() {
            const statusDot = document.getElementById('statusDot');
            const statusText = document.getElementById('statusText');
            
            statusDot.className = 'status-dot online';
            statusText.textContent = 'Connection restored! Refreshing...';
            
            announceToScreenReader('Connection restored. Refreshing page.');
            
            setTimeout(() => {
                window.location.reload();
            }, 2000);
        }

        function handleConnectionFailed() {
            const statusDot = document.getElementById('statusDot');
            const statusText = document.getElementById('statusText');
            
            statusDot.className = 'status-dot';
            statusText.textContent = 'Connection test failed. Please check your network.';
            
            announceToScreenReader('Connection test failed. Please check your network connection.');
        }

