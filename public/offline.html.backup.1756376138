        // Monitor connection status
        function updateConnectionStatus() {
            const statusText = document.getElementById('status-text');
            const statusElement = document.querySelector('.connection-status');
            
            if (navigator.onLine) {
                statusText.textContent = 'Online';
                statusElement.style.background = 'rgba(34, 197, 94, 0.9)';
                statusElement.classList.remove('pulse');
                
                // Redirect to home page after a short delay
                setTimeout(() => {
                    window.location.href = '/';
                }, 2000);
            } else {
                statusText.textContent = 'Offline';
                statusElement.style.background = 'rgba(239, 68, 68, 0.9)';
                statusElement.classList.add('pulse');
            }
        }

        // Retry connection
        function retryConnection() {
            const btn = event.target;
            btn.textContent = 'Checking...';
            btn.disabled = true;
            
            // Simulate connection check
            setTimeout(() => {
                if (navigator.onLine) {
                    btn.textContent = 'Connected!';
                    btn.style.background = 'linear-gradient(135deg, #22c55e, #16a34a)';
                    setTimeout(() => {
                        window.location.reload();
                    }, 1000);
                } else {
                    btn.textContent = 'Try Again';
                    btn.disabled = false;
                    alert('Still offline. Please check your internet connection.');
                }
            }, 2000);
        }

        // Event listeners
        window.addEventListener('online', updateConnectionStatus);
        window.addEventListener('offline', updateConnectionStatus);
        
        // Initial status check
        updateConnectionStatus();

        // Service Worker registration
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js')
                .then(registration => {
                    console.log('Service Worker registered:', registration);
                })
                .catch(error => {
=======
        // Connection checking functionality
        function checkConnection() {
            const statusDot = document.getElementById('statusDot');
            const statusText = document.getElementById('statusText');
            
            statusText.textContent = 'Checking connection...';
            statusDot.className = 'status-dot';
            
            // Try to fetch a small resource to test connectivity
            fetch('/favicon.ico', { 
                method: 'HEAD',
                cache: 'no-cache',
                mode: 'no-cors'
            })
            .then(() => {
                // Success - we're back online
                statusDot.className = 'status-dot online';
                statusText.textContent = 'Connection restored! Refreshing...';
                
                // Wait a moment then refresh
                setTimeout(() => {
                    window.location.reload();
                }, 2000);
            })
            .catch(() => {
                // Still offline
                statusDot.className = 'status-dot';
                statusText.textContent = 'Still offline. Check your connection.';
            });
        }

        // Auto-check connection every 10 seconds
