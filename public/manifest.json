  "shortcuts": [
    {
      "name": "Services",
      "short_name": "Services",
      "description": "View our AI and technology services",
      "url": "/services",
      "icons": [
        {
          "src": "/images/services-icon.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Contact",
      "short_name": "Contact",
      "description": "Get in touch with our team",
      "url": "/contact",
      "icons": [
        {
          "src": "/images/contact-icon.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "AI Solutions",
      "short_name": "AI Solutions",
