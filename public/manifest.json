  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://ziontechgroup.com"
    }
  ],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "handle_links": "preferred",
  "capture_links": "new-client",
  "file_handlers": [
    {
      "action": "/file-handler",
      "accept": {
        "text/*": [".txt", ".md", ".json", ".xml", ".html", ".css", ".js", ".ts", ".jsx", ".tsx"],
        "application/pdf": [".pdf"],
        "image/*": [".png", ".jpg", ".jpeg", ".gif", ".svg", ".webp"],
        "application/json": [".json"],
        "text/markdown": [".md"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+zion",
      "url": "/protocol-handler?protocol=%s"
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["image/*", "text/*", "application/pdf"]
        }
      ]
    }
  },
  "background": {
    "service_worker": "/sw.js",
    "type": "module"
  },
  "permissions": [
    "notifications",
    "geolocation",
    "camera",
    "microphone",
    "storage"
  ],
  "features": [
    "Cross Platform",
    "fast",
    "simple",
    "AI-Powered",
    "Enterprise Ready"
  ],
  "developer": {
    "name": "Zion Tech Group",
    "url": "https://ziontechgroup.com"
  },
  "version": "2.0.0",
  "minimum_version": "1.0.0"
}