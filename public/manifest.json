  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://ziontechgroup.com"
    }
  ],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "handle_links": "preferred",
  "protocol_handlers": [
    {
      "protocol": "mailto",
      "url": "/contact?email=%s"
    },
    {
      "protocol": "tel",
      "url": "/contact?phone=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/file-viewer",
      "accept": {
        "application/pdf": [".pdf"],
        "text/*": [".txt", ".md", ".html"],
        "image/*": [".png", ".jpg", ".jpeg", ".gif", ".svg"]
      }
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["image/*", "application/pdf", "text/*"]
        }
      ]
    }
  },
  "permissions": [
    "notifications",
    "geolocation",
    "camera",
    "microphone"
  ],
  "features": [
    "Cross Platform",
    "fast",
    "simple",
    "ai-powered",
    "responsive"
  ],
  "developer": {
    "name": "Zion Tech Group",
    "url": "https://ziontechgroup.com"
  },
  "homepage_url": "https://ziontechgroup.com",
  "scope_extensions": [
    {
      "origin": "https://ziontechgroup.com"
    }
  ],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "id": "zion-tech-group-pwa",
  "version": "1.0.0",
  "minimum_version": "1.0.0",
  "platforms": [
    "web",
    "android",
    "ios"
  ],
  "installable": true,
  "offline_enabled": true,
  "background": {
    "service_worker": "/sw.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "/images/*",
        "/icons/*",
        "/fonts/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://ziontechgroup.com/*",
      "https://*.ziontechgroup.com/*"
    ],
    "accepts_tls_channel_id": false
  },
  "externally_connectable": {
    "matches": [
      "https://ziontechgroup.com/*",
      "https://*.ziontechgroup.com/*"
    ],
    "accepts_tls_channel_id": false,
    "ids": [
      "abcdefghijklmnopabcdefghijklmnop",
      "fedcbaonmlkjihgfedcbaonmlkjihgfe"
    ]
  },
  "externally_connectable": {
    "matches": [
      "https://ziontechgroup.com/*",
      "https://*.ziontechgroup.com/*"
    ],
    "accepts_tls_channel_id": false,
    "matches": [
      "https://*.google.com/*",
      "https://*.github.com/*"
    ]
  },
  "externally_connectable": {
    "matches": [
      "https://ziontechgroup.com/*",
      "https://*.ziontechgroup.com/*"
    ],
    "accepts_tls_channel_id": false,
    "matches": [
      "https://*.google.com/*",
