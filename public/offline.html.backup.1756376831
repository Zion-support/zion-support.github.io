    <script>
        // Check network status
        function checkConnection() {
            const statusElement = document.getElementById('networkStatus');
            
            if (navigator.onLine) {
                statusElement.innerHTML = '✅ You\'re back online! Refreshing...';
                statusElement.style.background = 'rgba(34, 221, 210, 0.1)';
                statusElement.style.border = '1px solid rgba(34, 221, 210, 0.3)';
                statusElement.style.color = '#22ddd2';
                
                setTimeout(() => {
                    window.location.reload();
                }, 2000);
            } else {
                statusElement.innerHTML = '❌ Still offline. Please check your connection.';
                statusElement.style.background = 'rgba(239, 68, 68, 0.1)';
                statusElement.style.border = '1px solid rgba(239, 68, 68, 0.3)';
                statusElement.style.color = '#fca5a5';
            }
        }

        // Listen for online/offline events
        window.addEventListener('online', () => {
