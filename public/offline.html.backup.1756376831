        // Check network status
        function updateNetworkStatus() {
            const networkStatus = document.querySelector('.network-status');
            const retryIndicator = document.querySelector('.retry-indicator');
            
            if (navigator.onLine) {
                networkStatus.innerHTML = `
                    <strong>Network Status:</strong> Online
                    <div class="retry-indicator">
                        Your connection has been restored! Redirecting...
                    </div>
                `;
                networkStatus.style.background = 'rgba(34, 221, 210, 0.1)';
                networkStatus.style.borderColor = 'rgba(34, 221, 210, 0.2)';
                networkStatus.style.color = '#22ddd2';
                
                // Redirect to homepage after a short delay
                setTimeout(() => {
                    window.location.href = '/';
                }, 2000);
            } else {
                networkStatus.innerHTML = `
                    <strong>Network Status:</strong> Offline
                    <div class="retry-indicator">
                        We'll automatically retry when your connection is restored
                    </div>
                `;
            }
        }

        // Retry connection
        function retryConnection() {
            const spinner = document.getElementById('retrySpinner');
            const button = spinner.parentElement;
            
            spinner.style.display = 'inline-block';
            button.disabled = true;
            button.textContent = 'Checking Connection...';
            
            // Simulate connection check
            setTimeout(() => {
                if (navigator.onLine) {
                    window.location.reload();
                } else {
                    spinner.style.display = 'none';
                    button.disabled = false;
                    button.innerHTML = 'Try Again';
                    
                    // Show error message
                    const networkStatus = document.querySelector('.network-status');
                    networkStatus.innerHTML = `
                        <strong>Network Status:</strong> Still Offline
                        <div class="retry-indicator">
                            Please check your internet connection and try again
                        </div>
                    `;
                }
            }, 2000);
        }

        // Connection checking functionality
        function checkConnection() {
            const statusDot = document.getElementById('statusDot');
            const statusText = document.getElementById('statusText');
            
            statusText.textContent = 'Checking connection...';
            statusDot.className = 'status-dot';
            
            // Try to fetch a small resource to test connectivity
            fetch('/favicon.ico', { 
                method: 'HEAD',
                cache: 'no-cache',
                mode: 'no-cors'
            })
            .then(() => {
                // Success - we're back online
                statusDot.className = 'status-dot online';
                statusText.textContent = 'Connection restored! Refreshing...';
                
                // Wait a moment then refresh
                setTimeout(() => {
                    window.location.reload();
                }, 2000);
            })
            .catch(() => {
                // Still offline
                statusDot.className = 'status-dot';
                statusText.textContent = 'Still offline. Check your connection.';
            });
        }

        // Auto-check connection every 10 seconds
        setInterval(checkConnection, 10000);

        // Check connection on page load
        window.addEventListener('load', checkConnection);

        // Listen for online/offline events
        window.addEventListener('online', () => {
            const statusDot = document.getElementById('statusDot');
            const statusText = document.getElementById('statusText');
            
            statusDot.className = 'status-dot online';
            statusText.textContent = 'Connection restored! Refreshing...';
=======

