st a = document.createElement(&apos;a&apos;); a.href = url;&apos;;&apos;; a.download = `security-audit-log-${new Date().toISOString().split(&apos;T&apos;)[0]}.json`; a.click(); URL.revokeObjectURL(url);&apos;;&apos;; trackEvent(&apos;security&apos;,&apos;dashboard&apos;,&apos;audit_log_exported&apos;)},[exportAuditLog,trackEvent]); const handleAddComplianceRule = useCallback(() => { const newRule = { name: &apos;Custom Compliance Rule&apos;,category: &apos;custom&apos;,description: &apos;Custom compliance requirement&apos;,status: &apos;pending_review&apos;,requirements: [&apos;Requirement 1&apos;,&apos;Requirement 2&apos;],violations: [] };;&apos;; addComplianceRule(newRule);&apos;;&apos;; trackEvent(&apos;security&apos;,&apos;dashboard&apos;,&apos;compliance_rule_added&apos;)},[addComplianceRule,trackEvent]); const getSeverityColor = (props) => { switch (severity) { case &apos;critical&apos;: return &apos;text-red-600 bg-red-100&apos;; case &apos;high&apos;: return &apos;text-orange-600 bg-orange-100&apos;; case &apos;medium&apos;: return &apos;text-yellow-600 bg-yellow-100&apos;; case &apos;low&apos;: return &apos;text-green-600 bg-green-100&apos;; default: return &apos;text-gray-600 bg-gray-100&apos;} }; const getStatusColor = (props) => { switch (status) { case &apos;compliant&apos;: return &apos;text-green-600 bg-green-100&apos;; case &apos;non_compliant&apos;: return &apos;text-red-600 bg-red-100&apos;; case &apos;pending_review&apos;: return &apos;text-yellow-600 bg-yellow-100&apos;; default: return &apos;text-gray-600 bg-gray-100&apos;} }; const getThreatLevelColor = (props) => { switch (level) { case &apos;critical&apos;: return &apos;text-red-600 bg-red-100 border-red-200&apos;; case &apos;high&apos;: return &apos;text-orange-600 bg-orange-100 border-orange-200&apos;; case &apos;medium&apos;: return &apos;text-yellow-600 bg-yellow-100 border-yellow-200&apos;; case &apos;low&apos;: return &apos;text-green-600 bg-green-100 border-green-200&apos;; default: return &apos;text-gray-600 bg-gray-100 border-gray-200&apos;} }; return (<div className={`bg-white dark:bg-gray-900 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 ${className}`}> {} <div className=&quot;flex items-center justify-between p-4 border-b border-gray-200 dark:border-gray-700&quot;>&quot;; <div className=&quot;flex items-center space-x-3&quot;>&quot;; <div className=&quot;p-2 bg-blue-100 dark:bg-blue-900 rounded-lg&quot;>&quot;; <Shield className=&quot;w-6 h-6 text-blue-600 dark:text-blue-400&quot; />; </div>&quot;; <div>&quot;; <h2 className=&quot;text-lg font-semibold text-gray-900 dark:text-white&quot;>; Security & Compliance&quot;; </h2>&quot;; <p className=&quot;text-sm text-gray-500 dark:text-gray-400&quot;>; Real-time monitoring and compliance management; </p> </div> </div>&quot; &quot; &quot; export const SecurityComplianceDashboard = (props) => { const { trackEvent } = useAnalytics({enableTracking: true,enableUserBehaviorTracking: true}) const [activeTab,setActiveTab] = useState(&quot;overview&quot;) const [showSettings,setShowSettings] = useState(false) const [copied,setCopied] = useState(false) const {securityEvents,complianceRules,securityMetrics,isMonitoring,isComplianceChecking,startMonitoring,stopMonitoring,addSecurityEvent,updateEventStatus,addComplianceRule,checkCompliance,generateSecurityReport,exportAuditLog,configureSecurity} = useSecurityCompliance() const handleStartMonitoring = useCallback(() => {startMonitoring() trackEvent(&quot;security&quot;,dashboard&quot;,monitoring_started&quot;)},[startMonitoring,trackEvent]) const handleStopMonitoring = useCallback(() => {stopMonitoring() trackEvent(&quot;security&quot;,dashboard&quot;,monitoring_stopped&quot;)},[stopMonitoring,trackEvent]) const handleCheckCompliance = useCallback(async () => {await checkCompliance() trackEvent(&quot;security&quot;,dashboard&quot;,compliance_checked&quot;)},[checkCompliance,trackEvent]) const handleGenerateReport = useCallback(() => {const report = generateSecurityReport() navigator.clipboard.writeText(report) setCopied(true) setTimeout(() => setCopied(false),2000) trackEvent(&quot;security&quot;,dashboard&quot;,report_generated&quot;)},[generateSecurityReport,trackEvent]) const handleExportAuditLog = useCallback(() => { const auditLog = exportAuditLog() const blob = new Blob([auditLog] { type &quot;application/json&quot; }) const url = URL.createObjectURL(blob) const a = document.createElement(&quot;a&quot;) a.href = url a.download = &quot;security-audit-log-${new Date().toISOString().split(&quot;T&quot;)[0]}.json&quot; a.click() URL.revokeObjectURL(url) trackEvent(&quot;security&quot;,dashboard&quot;,audit_log_exported&quot;)},[exportAuditLog,trackEvent]) const handleAddComplianceRule = useCallback(() => { const newRule = {} addComplianceRule(newRule) trackEvent(&quot;security&quot;,dashboard&quot;,compliance_rule_added&quot;)},[addComplianceRule,trackEvent]) const getSeverityColor = (props) => { switch(severity) { case &quot;critical&quot;: return &quot;text-red-600 bg-red-100&quot; case &quot;high&quot;: return &quot;text-orange-600 bg-orange-100&quot; case &quot;medium&quot;: return &quot;text-yellow-600 bg-yellow-100&quot; case &quot;low&quot;: return &quot;text-green-600 bg-green-100&quot; default: return &quot;text-gray-600 bg-gray-100&quot;} } const getStatusColor = (props) => { switch(status) { case &quot;compliant&quot;: return &quot;text-green-600 bg-green-100&quot; case &quot;non_compliant&quot;: return &quot;text-red-600 bg-red-100&quot; case &quot;pending_review&quot;: return &quot;text-yellow-600 bg-yellow-100&quot; default: return &quot;text-gray-600 bg-gray-100&quot;} } const getThreatLevelColor = (props) => { switch(level) { case &quot;critical&quot;: return &quot;text-red-600 bg-red-100 border-red-200&quot; case &quot;high&quot;: return &quot;text-orange-600 bg-orange-100 border-orange-200&quot; case &quot;medium&quot;: return &quot;text-yellow-600 bg-yellow-100 border-yellow-200&quot; case &quot;low&quot;: return &quot;text-green-600 bg-green-100 border-green-200&quot; default: return &quot;text-gray-600 bg-gray-100 border-gray-200&quot;} }&quot; return (&quot; <div className=&quot;{&quot;bg-white&quot; dark:bg-gray-900 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 ${className}&quot;}> {}&quot; <div className=&quot;flex items-center justify-between p-4 border-b border-gray-200 dark:border-gray-700&quot;>&quot; <div className=&quot;flex items-center space-x-3&quot;>&quot; <div className=&quot;p-2 bg-blue-100 dark:bg-blue-900 rounded-lg&quot;>&quot; <Shield className=&quot;w-6 h-6 text-blue-600 dark:text-blue-400&quot; /> </div> <div>&quot; <h2 className=&quot;text-lg font-semibold text-gray-900 dark:text-white&quot;> Security & Compliance </h2>&quot; <p className=&quot;text-sm text-gray-500 dark:text-gray-400&quot;> Real-time monitoring and compliance management </p> </div> </div> &quot; <div className=&quot;flex items-center space-x-2&quot;>&quot; <button onClick=&quot;{handleCheckCompliance}&quot; disabled=&quot;{isComplianceChecking}&quot; className=&quot;flex items-center space-x-2 px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-800 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 disabled:opacity-50&quot;>&quot; {isComplianceChecking ? (<Loader2 className=&quot;w-4 h-4 animate-spin&quot; />) : (<RefreshCw className=&quot;w-4 h-4&quot; />)} <span>Check Compliance</span> </button> &quot; <button onClick=&quot;{()&quot; => setShowSettings(!showSettings)} className=&quot;p-2 text-gray-500 hover: text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800&quot;>&quot; <Settings className=&quot;w-5 h-5&quot; /> </button> </div> </div> {}&quot; <div className=&quot;p-4 bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 border-b border-gray-200 dark:border-gray-700&quot;>&quot; <div className=&quot;flex items-center justify-between&quot;>&quot; <div className=&quot;flex items-center space-x-4&quot;>&quot; <div className=&quot;flex items-center space-x-2&quot;>&quot; <div className=&quot;{&quot;w-3&quot; h-3 rounded-full ${isMonitoring ? &quot;bg-green-500&quot; : &quot;bg-red-500&quot;}&quot;} />&quot; <span className=&quot;text-sm font-medium text-gray-700 dark:text-gray-300&quot;> {isMonitoring ? &quot;Monitoring Active&quot; : &quot;Monitoring Inactive&quot;} </span> </div> &quot; <div className=&quot;flex items-center space-x-2&quot;>&quot; <Clock className=&quot;w-4 h-4 text-gray-500&quot; />&quot; <span className=&quot;text-sm text-gray-600 dark:text-gray-400&quot;> Last Check: {new Date().toLocaleTimeString()} </span> </div> </div> &quot; <div className=&quot;flex space-x-2&quot;>&quot; {!isMonitoring ? (<button onClick=&quot;{handleStartMonitoring}&quot; className=&quot;flex items-center space-x-2 px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-lg hover: bg-green-700&quot;>&quot; <Play className=&quot;w-4 h-4&quot; /> <span>Start Monitoring</span>&quot; </button>) : (<button onClick=&quot;{handleStopMonitoring}&quot; className=&quot;flex items-center space-x-2 px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700&quot;>&quot; <Square className=&quot;w-4 h-4&quot; /> <span>Stop Monitoring</span> </button>)} </div> </div> </div> {}&quot; <div className=&quot;flex border-b border-gray-200 dark: border-gray-700&quot;> {[&quot; { id: &quot;overview&quot;,label: &quot;Overview&quot;,icon: BarChart3 } {id: &quot;events&quot;,label: &quot;Security Events&quot;,icon: AlertTriangle} {id: &quot;compliance&quot;,label: &quot;Compliance&quot;,icon: CheckCircle} {id: &quot;threats&quot;,label: &quot;Threats&quot;,icon: Shield} {id: &quot;reports&quot;,label: &quot;Reports&quot;,icon: FileText}&quot; ].map(({id,label,icon: Icon}) => (<button key=&quot;{id}&quot; onClick=&quot;{()&quot; => setActiveTab(id)} className=&quot;{&quot;flex&quot; items-center space-x-2 px-4 py-3 text-sm font-medium border-b-2 transition-colors ${activeTab === id&quot; ? &quot;border-blue-500 text-blue-600 dark: text-blue-400&quot; : &quot;border-transparent text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200&quot;}&quot;}>&quot; <Icon className=&quot;w-4 h-4&quot; /> <span>{label}</span> </button>) ) } </div> {}&quot; <div className=&quot;p-4&quot;>&quot; <AnimatePresence mode=&quot;wait&quot;>&quot; {activeTab === &quot;overview&quot; && (<motion.div key=&quot;overview&quot; initial = { { opacity: 0,y: 20 }} animate = { { opacity: 1,y: 0 }} exit = { { opacity: 0,y: -20 &quot; }} className=&quot;space-y-6&quot;> {}&quot; <div className=&quot;grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4&quot;>&quot; <div className=&quot;bg-gray-50 dark:bg-gray-800 p-4 rounded-lg&quot;>&quot; <div className=&quot;flex items-center justify-between&quot;> <div>&quot; <p className=&quot;text-sm font-medium text-gray-600 dark:text-gray-400&quot;>Total Events</p>&quot; <p className=&quot;text-2xl font-bold text-gray-900 dark:text-white&quot;>{securityMetrics.totalEvents}</p> </div>&quot; <AlertTriangle className=&quot;w-8 h-8 text-orange-500&quot; /> </div> </div> &quot; <div className=&quot;bg-gray-50 dark:bg-gray-800 p-4 rounded-lg&quot;>&quot; <div className=&quot;flex items-center justify-between&quot;> <div>&quot; <p className=&quot;text-sm font-medium text-gray-600 dark:text-gray-400&quot;>Critical Events</p>&quot; <p className=&quot;text-2xl font-bold text-red-600&quot;>{securityMetrics.criticalEvents}</p> </div>&quot; <XCircle className=&quot;w-8 h-8 text-red-500&quot; /> </div> </div> &quot; <div className=&quot;bg-gray-50 dark:bg-gray-800 p-4 rounded-lg&quot;>&quot; <div className=&quot;flex items-center justify-between&quot;> <div>&quot; <p className=&quot;text-sm font-medium text-gray-600 dark:text-gray-400&quot;>Compliance Score</p>&quot; <p className=&quot;text-2xl font-bold text-green-600&quot;>{securityMetrics.complianceScore}%</p> </div>&quot; <CheckCircle className=&quot;w-8 h-8 text-green-500&quot; /> </div> </div> &quot; <div className=&quot;bg-gray-50 dark:bg-gray-800 p-4 rounded-lg&quot;>&quot; <div className=&quot;flex items-center justify-between&quot;> <div>&quot; <p className=&quot;text-sm font-medium text-gray-600 dark:text-gray-400&quot;>Threat Level</p>&quot; <p className=&quot;{&quot;text-lg&quot; font-bold ${getThreatLevelColor(securityMetrics.threatLevel)}&quot;}> {securityMetrics.threatLevel.toUpperCase()} </p> </div>&quot; <Shield className=&quot;w-8 h-8 text-blue-500&quot; /> </div> </div> </div> {}&quot; <div className=&quot;bg-gray-50 dark: bg-gray-800 p-4 rounded-lg&quot;>&quot; <h3 className=&quot;text-lg font-semibold text-gray-900 dark:text-white mb-4&quot;>Recent Security Events</h3>&quot; <div className=&quot;space-y-3&quot;>&quot; {securityEvents.slice(0,5).map((event) => (<div key=&quot;{event.id}&quot; className=&quot;flex items-center justify-between p-3 bg-white dark: bg-gray-700 rounded-lg&quot;>&quot; <div className=&quot;flex items-center space-x-3&quot;>&quot; <div className=&quot;{&quot;p-2&quot; rounded-lg ${getSeverityColor(event.severity)}&quot;}>&quot; <AlertTriangle className=&quot;w-4 h-4&quot; /> </div> <div>&quot; <p className=&quot;font-medium text-gray-900 dark: text-white&quot;>{event.type.replace(&quot;_&quot;)}</p>&quot; <p className=&quot;text-sm text-gray-500 dark: text-gray-400&quot;>{event.details}</p> </div> </div>&quot; <div className=&quot;flex items-center space-x-2&quot;>&quot; <span className=&quot;{&quot;px-2&quot; py-1 text-xs font-medium rounded-full ${getSeverityColor(event.severity)}&quot;}> {event.severity} </span>&quot; <span className=&quot;text-sm text-gray-500 dark: text-gray-400&quot;> {event.timestamp.toLocaleTimeString()} </span> </div> </div>) ) } </div> </div> </motion.div>)} &quot; {activeTab === &quot;events&quot; && (<motion.div key=&quot;events&quot; initial = { { opacity: 0,y: 20 }} animate = { { opacity: 1,y: 0 }} exit = { { opacity: 0,y: -20 &quot; }} className=&quot;space-y-4&quot;>&quot; <div className=&quot;flex items-center justify-between&quot;>&quot; <h3 className=&quot;text-lg font-semibold text-gray-900 dark:text-white&quot;>Security Events</h3> <button onClick={ () => addSecurityEvent({ type &quot;authentication&quot;,severity: &quot;low&quot;,details: &quot;Test security event&quot;,status: &quot;new&quot; })} className=&quot;px-3 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover: bg-blue-700&quot;> Add Test Event </button> </div> &quot; <div className=&quot;space-y-3&quot;>&quot; {securityEvents.map((event) => (<div key=&quot;{event.id}&quot; className=&quot;bg-gray-50 dark: bg-gray-800 p-4 rounded-lg&quot;>&quot; <div className=&quot;flex items-center justify-between mb-3&quot;>&quot; <div className=&quot;flex items-center space-x-3&quot;>&quot; <div className=&quot;{&quot;p-2&quot; rounded-lg ${getSeverityColor(event.severity)}&quot;}>&quot; <AlertTriangle className=&quot;w-4 h-4&quot; /> </div> <div>&quot; <p className=&quot;font-medium text-gray-900 dark: text-white&quot;> {event.type.replace(&quot;_&quot;).toUpperCase()} </p>&quot; <p className=&quot;text-sm text-gray-500 dark: text-gray-400&quot;> {event.timestamp.toLocaleString()} </p> </div> </div>&quot; <div className=&quot;flex items-center space-x-2&quot;>&quot; <span className=&quot;{&quot;px-2&quot; py-1 text-xs font-medium rounded-full ${getSeverityColor(event.severity)}&quot;}> {event.severity} </span> <select value=&quot;{event.status}&quot; onChange={(e) => updateEventStatus(event.id,e.target.value) &quot;} className=&quot;text-sm border border-gray-300 dark: border-gray-600 rounded px-2 py-1 bg-white dark:bg-gray-700 text-gray-900 dark:text-white&quot;>&quot; <option value=&quot;new&quot;>New</option>&quot; <option value=&quot;investigating&quot;>Investigating</option>&quot; <option value=&quot;resolved&quot;>Resolved</option>&quot; <option value=&quot;false_positive&quot;>False Positive</option> </select> </div> </div>&quot; <p className=&quot;text-gray-700 dark:text-gray-300 mb-3&quot;>{event.details}</p>&quot; {event.userId && (<div className=&quot;flex items-center space-x-4 text-sm text-gray-500 dark:text-gray-400&quot;> <span>User: {event.userId}</span> {event.ipAddress && <span>IP: {event.ipAddress}</span>} {event.resource && <span>Resource: {event.resource}</span>} </div>)} </div>))} </div> </motion.div>)} &quot; {activeTab === &quot;compliance&quot; && (<motion.div key=&quot;compliance&quot; initial = { { opacity: 0,y: 20 }} animate = { { opacity: 1,y: 0 }} exit = { { opacity: 0,y: -20 &quot; }} className=&quot;space-y-4&quot;>&quot; <div className=&quot;flex items-center justify-between&quot;>&quot; <h3 className=&quot;text-lg font-semibold text-gray-900 dark:text-white&quot;>Compliance Rules</h3>&quot; <button onClick=&quot;{handleAddComplianceRule}&quot; className=&quot;px-3 py-2 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700&quot;> Add Rule </button> </div> &quot; <div className=&quot;grid grid-cols-1 md:grid-cols-2 gap-4&quot;>&quot; {complianceRules.map((rule) => (<div key=&quot;{rule.id}&quot; className=&quot;bg-gray-50 dark: bg-gray-800 p-4 rounded-lg&quot;>&quot; <div className=&quot;flex items-center justify-between mb-3&quot;>&quot; <h4 className=&quot;font-medium text-gray-900 dark:text-white&quot;>{rule.name}</h4>&quot; <span className=&quot;{&quot;px-2&quot; py-1 text-xs font-medium rounded-full ${getStatusColor(rule.status)}&quot;}> {rule.status.replace(&quot;_&quot;)} </span> </div>&quot; <p className=&quot;text-sm text-gray-600 dark: text-gray-400 mb-3&quot;>{rule.description}</p>&quot; <div className=&quot;space-y-2&quot;>&quot; <div className=&quot;flex items-center justify-between text-sm&quot;>&quot; <span className=&quot;text-gray-500 dark:text-gray-400&quot;>Category:</span>&quot; <span className=&quot;font-medium text-gray-900 dark:text-white&quot;>{rule.category.toUpperCase()}</span> </div>&quot; <div className=&quot;flex items-center justify-between text-sm&quot;>&quot; <span className=&quot;text-gray-500 dark: text-gray-400&quot;>Last Check:</span>&quot; <span className=&quot;text-gray-900 dark:text-white&quot;> {rule.lastChecked.toLocaleDateString()} </span> </div>&quot; <div className=&quot;flex items-center justify-between text-sm&quot;>&quot; <span className=&quot;text-gray-500 dark: text-gray-400&quot;>Violations:</span>&quot; <span className=&quot;font-medium text-gray-900 dark:text-white&quot;>{rule.violations.length}</span> </div> </div>&quot; {rule.requirements.length > 0 && (<div className=&quot;mt-3&quot;>&quot; <p className=&quot;text-sm font-medium text-gray-700 dark:text-gray-300 mb-2&quot;>Requirements:</p>&quot; <ul className=&quot;space-y-1&quot;>&quot; {rule.requirements.map((req,index) => (<li key=&quot;{index}&quot; className=&quot;text-sm text-gray-600 dark: text-gray-400 flex items-center space-x-2&quot;>&quot; <CheckCircle className=&quot;w-3 h-3 text-green-500&quot; /> <span>{req}</span> </li>) ) } </ul> </div>) } </div>) ) } </div> </motion.div>)} &quot; {activeTab === &quot;threats&quot; && (<motion.div key=&quot;threats&quot; initial = { { opacity: 0,y: 20 }} animate = { { opacity: 1,y: 0 }} exit = { { opacity: 0,y: -20 &quot; }} className=&quot;space-y-4&quot;>&quot; <h3 className=&quot;text-lg font-semibold text-gray-900 dark:text-white&quot;>Threat Intelligence</h3> &quot; <div className=&quot;grid grid-cols-1 md:grid-cols-2 gap-4&quot;>&quot; <div className=&quot;bg-gray-50 dark:bg-gray-800 p-4 rounded-lg&quot;>&quot; <h4 className=&quot;font-medium text-gray-900 dark:text-white mb-3&quot;>Current Threat Level</h4>&quot; <div className=&quot;{&quot;p-4&quot; rounded-lg border-2 ${getThreatLevelColor(securityMetrics.threatLevel)}&quot;}>&quot; <p className=&quot;text-2xl font-bold text-center&quot;>{securityMetrics.threatLevel.toUpperCase()}</p>&quot; <p className=&quot;text-center text-sm mt-2&quot;> {securityMetrics.threatLevel === &quot;low&quot; && &quot;Normal operations&quot;} {securityMetrics.threatLevel === &quot;medium&quot; && &quot;Increased vigilance required&quot;} {securityMetrics.threatLevel === &quot;high&quot; && &quot;Immediate attention needed&quot;} {securityMetrics.threatLevel === &quot;critical&quot; && &quot;Emergency response required&quot;} </p> </div> </div> &quot; <div className=&quot;bg-gray-50 dark: bg-gray-800 p-4 rounded-lg&quot;>&quot; <h4 className=&quot;font-medium text-gray-900 dark:text-white mb-3&quot;>Response Metrics</h4>&quot; <div className=&quot;space-y-3&quot;>&quot; <div className=&quot;flex justify-between&quot;>&quot; <span className=&quot;text-gray-600 dark:text-gray-400&quot;>Avg Response Time:</span>&quot; <span className=&quot;font-medium text-gray-900 dark:text-white&quot;> {securityMetrics.averageResponseTime}ms </span> </div>&quot; <div className=&quot;flex justify-between&quot;>&quot; <span className=&quot;text-gray-600 dark:text-gray-400&quot;>False Positive Rate:</span>&quot; <span className=&quot;font-medium text-gray-900 dark:text-white&quot;> {securityMetrics.falsePositiveRate}% </span> </div>&quot; <div className=&quot;flex justify-between&quot;>&quot; <span className=&quot;text-gray-600 dark:text-gray-400&quot;>Last Incident:</span>&quot; <span className=&quot;font-medium text-gray-900 dark:text-white&quot;> {securityMetrics.lastIncident ? securityMetrics.lastIncident.toLocaleDateString() : &quot;None&quot;} </span> </div> </div> </div> </div> </motion.div>)} &quot; {activeTab === &quot;reports&quot; && (<motion.div key=&quot;reports&quot; initial = { { opacity: 0,y: 20 }} animate = { { opacity: 1,y: 0 }} exit = { { opacity: 0,y: -20 &quot; }} className=&quot;space-y-4&quot;>&quot; <h3 className=&quot;text-lg font-semibold text-gray-900 dark:text-white&quot;>Reports & Analytics</h3> &quot; <div className=&quot;grid grid-cols-1 md:grid-cols-2 gap-4&quot;>&quot; <div className=&quot;bg-gray-50 dark:bg-gray-800 p-4 rounded-lg&quot;>&quot; <h4 className=&quot;font-medium text-gray-900 dark:text-white mb-3&quot;>Security Report</h4>&quot; <p className=&quot;text-sm text-gray-600 dark:text-gray-400 mb-4&quot;> Generate a comprehensive security report with current metrics and recommendations.</p>&quot; <button onClick=&quot;{handleGenerateReport}&quot; className=&quot;w-full px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700&quot;>&quot; {copied ? (<span className=&quot;flex items-center justify-center space-x-2&quot;>&quot; <CheckCircle className=&quot;w-4 h-4&quot; /> <span>Copied to Clipboard</span>&quot; </span>) : (<span className=&quot;flex items-center justify-center space-x-2&quot;>&quot; <FileText className=&quot;w-4 h-4&quot; /> <span>Generate Report</span> </span>)} </button> </div> &quot; <div className=&quot;bg-gray-50 dark: bg-gray-800 p-4 rounded-lg&quot;>&quot; <h4 className=&quot;font-medium text-gray-900 dark:text-white mb-3&quot;>Audit Log Export</h4>&quot; <p className=&quot;text-sm text-gray-600 dark:text-gray-400 mb-4&quot;> Export the complete security audit log for compliance and analysis purposes.</p>&quot; <button onClick=&quot;{handleExportAuditLog}&quot; className=&quot;w-full px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700&quot;>&quot; <span className=&quot;flex items-center justify-center space-x-2&quot;>&quot; <Download className=&quot;w-4 h-4&quot; /> <span>Export Audit Log</span> </span> </button> </div> </div> </motion.div>) } </AnimatePresence> </div> {} <AnimatePresence> {showSettings && (<motion.div initial = { { opacity: 0,height: 0 }} animate = { { opacity: 1,height: &quot;auto&quot; }} exit = { { opacity: 0,height: 0 &quot; }} className=&quot;border-t border-gray-200 dark:border-gray-700 p-4 bg-gray-50 dark:bg-gray-800&quot;>&quot; <h3 className=&quot;text-lg font-semibold text-gray-900 dark:text-white mb-4&quot;>Security Configuration</h3>&quot; <div className=&quot;grid grid-cols-1 md:grid-cols-2 gap-4&quot;> <div>&quot; <label className=&quot;flex items-center space-x-2&quot;>&quot; <input type=&quot;checkbox&quot; checked=&quot;{isMonitoring}&quot; onChange=&quot;{(e)&quot; = / /> configureSecurity({ enableRealTimeMonitoring: e.target.checked })} className=&quot;rounded border-gray-300 text-blue-600 focus: ring-blue-500&quot; />&quot; <span className=&quot;text-sm font-medium text-gray-700 dark:text-gray-300&quot;> Enable Real-time Monitoring </span> </label> </div> <div>&quot; <label className=&quot;flex items-center space-x-2&quot;>&quot; <input type=&quot;checkbox&quot; checked=&quot;{isComplianceChecking}&quot; onChange=&quot;{(e)&quot; = / /> configureSecurity({ enableComplianceChecking: e.target.checked })} className=&quot;rounded border-gray-300 text-blue-600 focus: ring-blue-500&quot; />&quot; <span className=&quot;text-sm font-medium text-gray-700 dark:text-gray-300&quot;> Enable Compliance Checking </span> </label> </div> </div> </motion.div>) } </AnimatePresence> </div>)}&quot; &quot; &quot; export const SecurityComplianceDashboard = (props) => { const { trackEvent } = useAnalytics({enableTracking: true,enableUserBehaviorTracking: true}) const [activeTab,setActiveTab] = useState(&quot;overview&quot;) const [showSettings,setShowSettings] = useState(false) const [copied,setCopied] = useState(false) const {securityEvents,complianceRules,securityMetrics,isMonitoring,isComplianceChecking,startMonitoring,stopMonitoring,addSecurityEvent,updateEventStatus,addComplianceRule,checkCompliance,generateSecurityReport,exportAuditLog,configureSecurity} = useSecurityCompliance() const handleStartMonitoring = useCallback(() => {startMonitoring() trackEvent(&quot;security&quot;,dashboard&quot;,monitoring_started&quot;)},[startMonitoring,trackEvent]) const handleStopMonitoring = useCallback(() => {stopMonitoring() trackEvent(&quot;security&quot;,dashboard&quot;,monitoring_stopped&quot;)},[stopMonitoring,trackEvent]) const handleCheckCompliance = useCallback(async () => {await checkCompliance() trackEvent(&quot;security&quot;,dashboard&quot;,compliance_checked&quot;)},[checkCompliance,trackEvent]) const handleGenerateReport = useCallback(() => {const report = generateSecurityReport() navigator.clipboard.writeText(report) setCopied(true) setTimeout(() => setCopied(false),2000) trackEvent(&quot;security&quot;,dashboard&quot;,report_generated&quot;)},[generateSecurityReport,trackEvent]) const handleExportAuditLog = useCallback(() => { const auditLog = exportAuditLog() const blob = new Blob([auditLog] { type &quot;application/json&quot; }) const url = URL.createObjectURL(blob) const a = document.createElement(&quot;a&quot;) a.href = url a.download = &quot;security-audit-log-${new Date().toISOString().split(&quot;T&quot;)[0]}.json&quot; a.click() URL.revokeObjectURL(url) trackEvent(&quot;security&quot;,dashboard&quot;,audit_log_exported&quot;)},[exportAuditLog,trackEvent]) const handleAddComplianceRule = useCallback(() => { const newRule = {} addComplianceRule(newRule) trackEvent(&quot;security&quot;,dashboard&quot;,compliance_rule_added&quot;)},[addComplianceRule,trackEvent]) const getSeverityColor = (props) => { switch(severity) { case &quot;critical&quot;: return &quot;text-red-600 bg-red-100&quot; case &quot;high&quot;: return &quot;text-orange-600 bg-orange-100&quot; case &quot;medium&quot;: return &quot;text-yellow-600 bg-yellow-100&quot; case &quot;low&quot;: return &quot;text-green-600 bg-green-100&quot; default: return &quot;text-gray-600 bg-gray-100&quot;} } const getStatusColor = (props) => { switch(status) { case &quot;compliant&quot;: return &quot;text-green-600 bg-green-100&quot; case &quot;non_compliant&quot;: return &quot;text-red-600 bg-red-100&quot; case &quot;pending_review&quot;: return &quot;text-yellow-600 bg-yellow-100&quot; default: return &quot;text-gray-600 bg-gray-100&quot;} } const getThreatLevelColor = (props) => { switch(level) { case &quot;critical&quot;: return &quot;text-red-600 bg-red-100 border-red-200&quot; case &quot;high&quot;: return &quot;text-orange-600 bg-orange-100 border-orange-200&quot; case &quot;medium&quot;: return &quot;text-yellow-600 bg-yellow-100 border-yellow-200&quot; case &quot;low&quot;: return &quot;text-green-600 bg-green-100 border-green-200&quot; default: return &quot;text-gray-600 bg-gray-100 border-gray-200&quot;} }&quot; return (&quot; <div className=&quot;{&quot;bg-white&quot; dark:bg-gray-900 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 ${className}&quot;}&quot; > {}&quot; <div className=&quot;flex items-center justify-between p-4 border-b border-gray-200 dark:border-gray-700&quot;>&quot; <div className=&quot;flex items-center space-x-3&quot;>&quot; <div className=&quot;p-2 bg-blue-100 dark:bg-blue-900 rounded-lg&quot;>&quot; <Shield className=&quot;w-6 h-6 text-blue-600 dark:text-blue-400&quot;/&quot; > </div> <div>&quot; <h2 className=&quot;text-lg font-semibold text-gray-900 dark:text-white&quot;> Security & Compliance </h2>&quot; <p className=&quot;text-sm text-gray-500 dark:text-gray-400&quot;> Real-time monitoring and compliance management </p> </div> </div> &quot; <div className=&quot;flex items-center space-x-2&quot;>&quot; <button onClick=&quot;{handleCheckCompliance}&quot; disabled=&quot;{isComplianceChecking}&quot; className=&quot;flex items-center space-x-2 px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-800 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 disabled:opacity-50&quot;>&quot; {isComplianceChecking ? (<Loader2 className=&quot;w-4 h-4 animate-spin&quot;/&quot; >) : (<RefreshCw className=&quot;w-4 h-4&quot;/&quot; >)} <span>Check Compliance</span> </button> &quot; <button onClick=&quot;{()&quot; =&quot; > setShowSettings(!showSettings)} className=&quot;p-2 text-gray-500 hover: text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800&quot;>&quot; <Settings className=&quot;w-5 h-5&quot;/&quot; > </button> </div> </div> {}&quot; <div className=&quot;p-4 bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 border-b border-gray-200 dark:border-gray-700&quot;>&quot; <div className=&quot;flex items-center justify-between&quot;>&quot; <div className=&quot;flex items-center space-x-4&quot;>&quot; <div className=&quot;flex items-center space-x-2&quot;>&quot; <div className=&quot;{&quot;w-3&quot; h-3 rounded-full ${isMonitoring ? &quot;bg-green-500&quot; : &quot;bg-red-500&quot;}&quot;}/&quot; >&quot; <span className=&quot;text-sm font-medium text-gray-700 dark:text-gray-300&quot;> {isMonitoring ? &quot;Monitoring Active&quot; : &quot;Monitoring Inactive&quot;} </span> </div> &quot; <div className=&quot;flex items-center space-x-2&quot;>&quot; <Clock className=&quot;w-4 h-4 text-gray-500&quot;/&quot; >&quot; <span className=&quot;text-sm text-gray-600 dark:text-gray-400&quot;> Last Check: {new Date().toLocaleTimeString()} </span> </div> </div> &quot; <div className=&quot;flex space-x-2&quot;>&quot; {!isMonitoring ? (<button onClick=&quot;{handleStartMonitoring}&quot; className=&quot;flex items-center space-x-2 px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-lg hover: bg-green-700&quot;>&quot; <Play className=&quot;w-4 h-4&quot;/&quot; > <span>Start Monitoring</span>&quot; </button>) : (<button onClick=&quot;{handleStopMonitoring}&quot; className=&quot;flex items-center space-x-2 px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700&quot;>&quot; <Square className=&quot;w-4 h-4&quot;/&quot; > <span>Stop Monitoring</span> </button>)} </div> </div> </div> {}&quot; <div className=&quot;flex border-b border-gray-200 dark: border-gray-700&quot;> {[&quot; { id: &quot;overview&quot;,label: &quot;Overview&quot;,icon: BarChart3 } {id: &quot;events&quot;,label: &quot;Security Events&quot;,icon: AlertTriangle} {id: &quot;compliance&quot;,label: &quot;Compliance&quot;,icon: CheckCircle} {id: &quot;threats&quot;,label: &quot;Threats&quot;,icon: Shield} {id: &quot;reports&quot;,label: &quot;Reports&quot;,icon: FileText}&quot; ].map(({id,label,icon: Icon}) => (<button key=&quot;{id}&quot; onClick=&quot;{()&quot; =&quot; > setActiveTab(id)} className=&quot;{&quot;flex&quot; items-center space-x-2 px-4 py-3 text-sm font-medium border-b-2 transition-colors ${activeTab === id&quot; ? &quot;border-blue-500 text-blue-600 dark: text-blue-400&quot; : &quot;border-transparent text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200&quot;}&quot;}>&quot; <Icon className=&quot;w-4 h-4&quot;/&quot; > <span>{label}</span> </button>) ) } </div> {}&quot; <div className=&quot;p-4&quot;>&quot; <AnimatePresence mode=&quot;wait&quot;>&quot; {activeTab === &quot;overview&quot; && (<motion.div key=&quot;overview&quot; initial = { { opacity: 0,y: 20 }} animate = { { opacity: 1,y: 0 }} exit = { { opacity: 0,y: -20 &quot; }} className=&quot;space-y-6&quot;> {}&quot; <div className=&quot;grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4&quot;>&quot; <div className=&quot;bg-gray-50 dark:bg-gray-800 p-4 rounded-lg&quot;>&quot; <div className=&quot;flex items-center justify-between&quot;> <div>&quot; <p className=&quot;text-sm font-medium text-gray-600 dark:text-gray-400&quot;>Total Events</p>&quot; <p className=&quot;text-2xl font-bold text-gray-900 dark:text-white&quot;>{securityMetrics.totalEvents}</p> </div>&quot; <AlertTriangle className=&quot;w-8 h-8 text-orange-500&quot;/&quot; > </div> </div> &quot; <div className=&quot;bg-gray-50 dark:bg-gray-800 p-4 rounded-lg&quot;>&quot; <div className=&quot;flex items-center justify-between&quot;> <div>&quot; <p className=&quot;text-sm font-medium text-gray-600 dark:text-gray-400&quot;>Critical Events</p>&quot; <p className=&quot;text-2xl font-bold text-red-600&quot;>{securityMetrics.criticalEvents}</p> </div>&quot; <XCircle className=&quot;w-8 h-8 text-red-500&quot;/&quot; > </div> </div> &quot; <div className=&quot;bg-gray-50 dark:bg-gray-800 p-4 rounded-lg&quot;>&quot; <div className=&quot;flex items-center justify-between&quot;> <div>&quot; <p className=&quot;text-sm font-medium text-gray-600 dark:text-gray-400&quot;>Compliance Score</p>&quot; <p className=&quot;text-2xl font-bold text-green-600&quot;>{securityMetrics.complianceScore}%</p> </div>&quot; <CheckCircle className=&quot;w-8 h-8 text-green-500&quot;/&quot; > </div> </div> &quot; <div className=&quot;bg-gray-50 dark:bg-gray-800 p-4 rounded-lg&quot;>&quot; <div className=&quot;flex items-center justify-between&quot;> <div>&quot; <p className=&quot;text-sm font-medium text-gray-600 dark:text-gray-400&quot;>Threat Level</p>&quot; <p className=&quot;{&quot;text-lg&quot; font-bold ${getThreatLevelColor(securityMetrics.threatLevel)}&quot;}&quot; > {securityMetrics.threatLevel.toUpperCase()} </p> </div>&quot; <Shield className=&quot;w-8 h-8 text-blue-500&quot;/&quot; > </div> </div> </div> {}&quot; <div className=&quot;bg-gray-50 dark: bg-gray-800 p-4 rounded-lg&quot;>&quot; <h3 className=&quot;text-lg font-semibold text-gray-900 dark:text-white mb-4&quot;>Recent Security Events</h3>&quot; <div className=&quot;space-y-3&quot;>&quot; {securityEvents.slice(0,5).map((event) => (<div key=&quot;{event.id}&quot; className=&quot;flex items-center justify-between p-3 bg-white dark: bg-gray-700 rounded-lg&quot;>&quot; <div className=&quot;flex items-center space-x-3&quot;>&quot; <div className=&quot;{&quot;p-2&quot; rounded-lg ${getSeverityColor(event.severity)}&quot;}&quot; >&quot; <AlertTriangle className=&quot;w-4 h-4&quot;/&quot; > </div> <div>&quot; <p className=&quot;font-medium text-gray-900 dark: text-white&quot;>{event.type.replace(&quot;_&quot;)}</p>&quot; <p className=&quot;text-sm text-gray-500 dark: text-gray-400&quot;>{event.details}</p> </div> </div>&quot; <div className=&quot;flex items-center space-x-2&quot;>&quot; <span className=&quot;{&quot;px-2&quot; py-1 text-xs font-medium rounded-full ${getSeverityColor(event.severity)}&quot;}&quot; > {event.severity} </span>&quot; <span className=&quot;text-sm text-gray-500 dark: text-gray-400&quot;> {event.timestamp.toLocaleTimeString()} </span> </div> </div>) ) } </div> </div> </motion.div>)} &quot; {activeTab === &quot;events&quot; && (<motion.div key=&quot;events&quot; initial = { { opacity: 0,y: 20 }} animate = { { opacity: 1,y: 0 }} exit = { { opacity: 0,y: -20 &quot; }} className=&quot;space-y-4&quot;>&quot; <div className=&quot;flex items-center justify-between&quot;>&quot; <h3 className=&quot;text-lg font-semibold text-gray-900 dark:text-white&quot;>Security Events</h3> <button onClick={ () =&quot; > addSecurityEvent({ type &quot;authentication&quot;,severity: &quot;low&quot;,details: &quot;Test security event&quot;,status: &quot;new&quot; })} className=&quot;px-3 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover: bg-blue-700&quot;> Add Test Event </button> </div> &quot; <div className=&quot;space-y-3&quot;>&quot; {securityEvents.map((event) => (<div key=&quot;{event.id}&quot; className=&quot;bg-gray-50 dark: bg-gray-800 p-4 rounded-lg&quot;>&quot; <div className=&quot;flex items-center justify-between mb-3&quot;>&quot; <div className=&quot;flex items-center space-x-3&quot;>&quot; <div className=&quot;{&quot;p-2&quot; rounded-lg ${getSeverityColor(event.severity)}&quot;}&quot; >&quot; <AlertTriangle className=&quot;w-4 h-4&quot;/&quot; > </div> <div>&quot; <p className=&quot;font-medium text-gray-900 dark: text-white&quot;> {event.type.replace(&quot;_&quot;).toUpperCase()} </p>&quot; <p className=&quot;text-sm text-gray-500 dark: text-gray-400&quot;> {event.timestamp.toLocaleString()} </p> </div> </div>&quot; <div className=&quot;flex items-center space-x-2&quot;>&quot; <span className=&quot;{&quot;px-2&quot; py-1 text-xs font-medium rounded-full ${getSeverityColor(event.severity)}&quot;}&quot; > {event.severity} </span> <select value=&quot;{event.status}&quot; onChange={(e) =&quot; > updateEventStatus(event.id,e.target.value) &quot;} className=&quot;text-sm border border-gray-300 dark: border-gray-600 rounded px-2 py-1 bg-white dark:bg-gray-700 text-gray-900 dark:text-white&quot;>&quot; <option value=&quot;new&quot;>New</option>&quot; <option value=&quot;investigating&quot;>Investigating</option>&quot; <option value=&quot;resolved&quot;>Resolved</option>&quot; <option value=&quot;false_positive&quot;>False Positive</option> </select> </div> </div>&quot; <p className=&quot;text-gray-700 dark:text-gray-300 mb-3&quot;>{event.details}</p>&quot; {event.userId && (<div className=&quot;flex items-center space-x-4 text-sm text-gray-500 dark:text-gray-400&quot;> <span>User: {event.userId}</span> {event.ipAddress && <span>IP: {event.ipAddress}</span>} {event.resource && <span>Resource: {event.resource}</span>} </div>)} </div>))} </div> </motion.div>)} &quot; {activeTab === &quot;compliance&quot; && (<motion.div key=&quot;compliance&quot; initial = { { opacity: 0,y: 20 }} animate = { { opacity: 1,y: 0 }} exit = { { opacity: 0,y: -20 &quot; }} className=&quot;space-y-4&quot;>&quot; <div className=&quot;flex items-center justify-between&quot;>&quot; <h3 className=&quot;text-lg font-semibold text-gray-900 dark:text-white&quot;>Compliance Rules</h3>&quot; <button onClick=&quot;{handleAddComplianceRule}&quot; className=&quot;px-3 py-2 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700&quot;> Add Rule </button> </div> &quot; <div className=&quot;grid grid-cols-1 md:grid-cols-2 gap-4&quot;>&quot; {complianceRules.map((rule) => (<div key=&quot;{rule.id}&quot; className=&quot;bg-gray-50 dark: bg-gray-800 p-4 rounded-lg&quot;>&quot; <div className=&quot;flex items-center justify-between mb-3&quot;>&quot; <h4 className=&quot;font-medium text-gray-900 dark:text-white&quot;>{rule.name}</h4>&quot; <span className=&quot;{&quot;px-2&quot; py-1 text-xs font-medium rounded-full ${getStatusColor(rule.status)}&quot;}&quot; > {rule.status.replace(&quot;_&quot;)} </span> </div>&quot; <p className=&quot;text-sm text-gray-600 dark: text-gray-400 mb-3&quot;>{rule.description}</p>&quot; <div className=&quot;space-y-2&quot;>&quot; <div className=&quot;flex items-center justify-between text-sm&quot;>&quot; <span className=&quot;text-gray-500 dark:text-gray-400&quot;>Category:</span>&quot; <span className=&quot;font-medium text-gray-900 dark:text-white&quot;>{rule.category.toUpperCase()}</span> </div>&quot; <div className=&quot;flex items-center justify-between text-sm&quot;>&quot; <span className=&quot;text-gray-500 dark: text-gray-400&quot;>Last Check:</span>&quot; <span className=&quot;text-gray-900 dark:text-white&quot;> {rule.lastChecked.toLocaleDateString()} </span> </div>&quot; <div className=&quot;flex items-center justify-between text-sm&quot;>&quot; <span className=&quot;text-gray-500 dark: text-gray-400&quot;>Violations:</span>&quot; <span className=&quot;font-medium text-gray-900 dark:text-white&quot;>{rule.violations.length}</span> </div> </div>&quot; {rule.requirements.length > 0 && (<div className=&quot;mt-3&quot;>&quot; <p className=&quot;text-sm font-medium text-gray-700 dark:text-gray-300 mb-2&quot;>Requirements:</p>&quot; <ul className=&quot;space-y-1&quot;>&quot; {rule.requirements.map((req,index) => (<li key=&quot;{index}&quot; className=&quot;text-sm text-gray-600 dark: text-gray-400 flex items-center space-x-2&quot;>&quot; <CheckCircle className=&quot;w-3 h-3 text-green-500&quot;/&quot; > <span>{req}</span> </li>) ) } </ul> </div>) } </div>) ) } </div> </motion.div>)} &quot; {activeTab === &quot;threats&quot; && (<motion.div key=&quot;threats&quot; initial = { { opacity: 0,y: 20 }} animate = { { opacity: 1,y: 0 }} exit = { { opacity: 0,y: -20 &quot; }} className=&quot;space-y-4&quot;>&quot; <h3 className=&quot;text-lg font-semibold text-gray-900 dark:text-white&quot;>Threat Intelligence</h3> &quot; <div className=&quot;grid grid-cols-1 md:grid-cols-2 gap-4&quot;>&quot; <div className=&quot;bg-gray-50 dark:bg-gray-800 p-4 rounded-lg&quot;>&quot; <h4 className=&quot;font-medium text-gray-900 dark:text-white mb-3&quot;>Current Threat Level</h4>&quot; <div className=&quot;{&quot;p-4&quot; rounded-lg border-2 ${getThreatLevelColor(securityMetrics.threatLevel)}&quot;}&quot; >&quot; <p className=&quot;text-2xl font-bold text-center&quot;>{securityMetrics.threatLevel.toUpperCase()}</p>&quot; <p className=&quot;text-center text-sm mt-2&quot;> {securityMetrics.threatLevel === &quot;low&quot; && &quot;Normal operations&quot;} {securityMetrics.threatLevel === &quot;medium&quot; && &quot;Increased vigilance required&quot;} {securityMetrics.threatLevel === &quot;high&quot; && &quot;Immediate attention needed&quot;} {securityMetrics.threatLevel === &quot;critical&quot; && &quot;Emergency response required&quot;} </p> </div> </div> &quot; <div className=&quot;bg-gray-50 dark: bg-gray-800 p-4 rounded-lg&quot;>&quot; <h4 className=&quot;font-medium text-gray-900 dark:text-white mb-3&quot;>Response Metrics</h4>&quot; <div className=&quot;space-y-3&quot;>&quot; <div className=&quot;flex justify-between&quot;>&quot; <span className=&quot;text-gray-600 dark:text-gray-400&quot;>Avg Response Time:</span>&quot; <span className=&quot;font-medium text-gray-900 dark:text-white&quot;> {securityMetrics.averageResponseTime}ms </span> </div>&quot; <div className=&quot;flex justify-between&quot;>&quot; <span className=&quot;text-gray-600 dark:text-gray-400&quot;>False Positive Rate:</span>&quot; <span className=&quot;font-medium text-gray-900 dark:text-white&quot;> {securityMetrics.falsePositiveRate}% </span> </div>&quot; <div className=&quot;flex justify-between&quot;>&quot; <span className=&quot;text-gray-600 dark:text-gray-400&quot;>Last Incident:</span>&quot; <span className=&quot;font-medium text-gray-900 dark:text-white&quot;> {securityMetrics.lastIncident ? securityMetrics.lastIncident.toLocaleDateString() : &quot;None&quot;} </span> </div> </div> </div> </div> </motion.div>)} &quot; {activeTab === &quot;reports&quot; && (<motion.div key=&quot;reports&quot; initial = { { opacity: 0,y: 20 }} animate = { { opacity: 1,y: 0 }} exit = { { opacity: 0,y: -20 &quot; }} className=&quot;space-y-4&quot;>&quot; <h3 className=&quot;text-lg font-semibold text-gray-900 dark:text-white&quot;>Reports & Analytics</h3> &quot; <div className=&quot;grid grid-cols-1 md:grid-cols-2 gap-4&quot;>&quot; <div className=&quot;bg-gray-50 dark:bg-gray-800 p-4 rounded-lg&quot;>&quot; <h4 className=&quot;font-medium text-gray-900 dark:text-white mb-3&quot;>Security Report</h4>&quot; <p className=&quot;text-sm text-gray-600 dark:text-gray-400 mb-4&quot;> Generate a comprehensive security report with current metrics and recommendations.</p>&quot; <button onClick=&quot;{handleGenerateReport}&quot; className=&quot;w-full px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700&quot;>&quot; {copied ? (<span className=&quot;flex items-center justify-center space-x-2&quot;>&quot; <CheckCircle className=&quot;w-4 h-4&quot;/&quot; > <span>Copied to Clipboard</span>&quot; </span>) : (<span className=&quot;flex items-center justify-center space-x-2&quot;>&quot; <FileText className=&quot;w-4 h-4&quot;/&quot; > <span>Generate Report</span> </span>)} </button> </div> &quot; <div className=&quot;bg-gray-50 dark: bg-gray-800 p-4 rounded-lg&quot;>&quot; <h4 className=&quot;font-medium text-gray-900 dark:text-white mb-3&quot;>Audit Log Export</h4>&quot; <p className=&quot;text-sm text-gray-600 dark:text-gray-400 mb-4&quot;> Export the complete security audit log for compliance and analysis purposes.</p>&quot; <button onClick=&quot;{handleExportAuditLog}&quot; className=&quot;w-full px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700&quot;>&quot; <span className=&quot;flex items-center justify-center space-x-2&quot;>&quot; <Download className=&quot;w-4 h-4&quot;/&quot; > <span>Export Audit Log</span> </span> </button> </div> </div> </motion.div>) } </AnimatePresence> </div> {} <AnimatePresence> {showSettings && (<motion.div initial = { { opacity: 0,height: 0 }} animate = { { opacity: 1,height: &quot;auto&quot; }} exit = { { opacity: 0,height: 0 &quot; }} className=&quot;border-t border-gray-200 dark:border-gray-700 p-4 bg-gray-50 dark:bg-gray-800&quot;>&quot; <h3 className=&quot;text-lg font-semibold text-gray-900 dark:text-white mb-4&quot;>Security Configuration</h3>&quot; <div className=&quot;grid grid-cols-1 md:grid-cols-2 gap-4&quot;> <div>&quot; <label className=&quot;flex items-center space-x-2&quot;>&quot; <input type=&quot;checkbox&quot; checked=&quot;{isMonitoring}&quot; onChange=&quot;{(e)&quot; = / /&quot; > configureSecurity({ enableRealTimeMonitoring: e.target.checked })} className=&quot;rounded border-gray-300 text-blue-600 focus: ring-blue-500&quot; />&quot; <span className=&quot;text-sm font-medium text-gray-700 dark:text-gray-300&quot;> Enable Real-time Monitoring </span> </label> </div> <div>&quot; <label className=&quot;flex items-center space-x-2&quot;>&quot; <input type=&quot;checkbox&quot; checked=&quot;{isComplianceChecking}&quot; onChange=&quot;{(e)&quot; = / /&quot; > configureSecurity({ enableComplianceChecking: e.target.checked })} className=&quot;rounded border-gray-300 text-blue-600 focus: ring-blue-500&quot; />&quot; <span className=&quot;text-sm font-medium text-gray-700 dark:text-gray-300&quot;> Enable Compliance Checking </span> </label> </div> </div> </motion.div>) } </AnimatePresence> </div>)};&quot; &quot;`&quot; &quot; export default Component </motion> </Download> </FileText> </CheckCircle> </motion> </CheckCircle> </motion> </AlertTriangle> </motion> </AlertTriangle> </Shield> </CheckCircle> </XCircle> </AlertTriangle> </motion> </Icon> </Square> </Play> </Clock> </Settings> </RefreshCw> </Loader2> </Shield> </div> </motion> </motion> </div> </div>;&apos;;&apos;;
const React,{useState,useCallback} from "react";" import {motion,AnimatePresence} from "framer-motion"; import {Shield,AlertTriangle,CheckCircle,XCircle,Download,Settings,RefreshCw,Loader2,FileText,BarChart3,Clock,Play,Square} from "lucide-react"; ; export const SecurityComplianceDashboard = (props) => { const { trackEvent } = useAnalytics({enableTracking: true,enableUserBehaviorTracking: true};);";"; const [activeTab,setActiveTab] = useState("overview"); const [showSettings,setShowSettings] = useState(false); const [copied,setCopied] = useState(false); const {securityEvents,complianceRules,securityMetrics,isMonitoring,isComplianceChecking,startMonitoring,stopMonitoring,addSecurityEvent,updateEventStatus,addComplianceRule,checkCompliance,generateSecurityReport,exportAuditLog,configureSecurity} = useSecurityCompliance(); const handleStartMonitoring = useCallback(() => {startMonitoring(); trackEvent("security","dashboard","monitoring_started")},[startMonitoring,trackEvent]);"; const handleStopMonitoring = useCallback(() => {stopMonitoring(); trackEvent("security","dashboard","monitoring_stopped")},[stopMonitoring,trackEvent]);"; const handleCheckCompliance = useCallback(async () => {await checkCompliance(); trackEvent("security","dashboard","compliance_checked")},[checkCompliance,trackEvent]); const handleGenerateReport = useCallback(() => {const report = generateSecurityReport(); navigator.clipboard.writeText(report); setCopied(true);"; setTimeout(() => setCopied(false),2000);";"; trackEvent("security","dashboard","report_generated")},[generateSecurityReport,trackEvent]); const handleExportAuditLog = useCallback(() => { const auditLog = exportAuditLog(); const blob = new Blob([auditLog],{ type: "application/json" };); const url = URL.createObjectURL(blob); const a = document.createElement("a"); a.href = url;";"; a.download = `security-audit-log-${new Date().toISOString().split("T")[0]}.json`; a.click(); URL.revokeObjectURL(url);";"; trackEvent("security","dashboard","audit_log_exported")},[exportAuditLog,trackEvent]); const handleAddComplianceRule = useCallback(() => { const newRule = { name: "Custom Compliance Rule",category: "custom",description: "Custom compliance requirement",status: "pending_review",requirements: ["Requirement 1","Requirement 2"],violations: [] };"; addComplianceRule(newRule);";"; trackEvent("security","dashboard","compliance_rule_added")},[addComplianceRule,trackEvent]); const getSeverityColor = (props) => { switch (severity) { case critical: return "text-red-600 bg-red-100"; case high: return "text-orange-600 bg-orange-100"; case medium: return "text-yellow-600 bg-yellow-100"; case low: return "text-green-600 bg-green-100"; default: return "text-gray-600 bg-gray-100"} }; const getStatusColor = (props) => { switch (status) { case compliant: return "text-green-600 bg-green-100"; case non_compliant: return "text-red-600 bg-red-100"; case pending_review: return "text-yellow-600 bg-yellow-100"; default: return "text-gray-600 bg-gray-100"} }; const getThreatLevelColor = (props) => { switch (level) { case critical: return "text-red-600 bg-red-100 border-red-200"; case high: return "text-orange-600 bg-orange-100 border-orange-200"; case medium: return "text-yellow-600 bg-yellow-100 border-yellow-200"; case low: return "text-green-600 bg-green-100 border-green-200"; default: return "text-gray-600 bg-gray-100 border-gray-200"} }; return (<div className={`bg-white dark:bg-gray-900 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 ${className}`}> {} <div className="flex items-center justify-between p-4 border-b border-gray-200 dark:border-gray-700">"; <div className="flex items-center space-x-3">"; <div className="p-2 bg-blue-100 dark:bg-blue-900 rounded-lg">"; <Shield className="w-6 h-6 text-blue-600 dark:text-blue-400" />; </div>"; <div>"; <h2 className="text-lg font-semibold text-gray-900 dark:text-white">; Security & Compliance"; </h2>"; <p className="text-sm text-gray-500 dark:text-gray-400">; Real-time monitoring and compliance management; </p> </div> </div>" " " export const SecurityComplianceDashboard = (props) => { const { trackEvent } = useAnalytics({enableTracking: true,enableUserBehaviorTracking: true}) const [activeTab,setActiveTab] = useState("overview") const [showSettings,setShowSettings] = useState(false) const [copied,setCopied] = useState(false) const {securityEvents,complianceRules,securityMetrics,isMonitoring,isComplianceChecking,startMonitoring,stopMonitoring,addSecurityEvent,updateEventStatus,addComplianceRule,checkCompliance,generateSecurityReport,exportAuditLog,configureSecurity} = useSecurityCompliance() const handleStartMonitoring = useCallback(() => {startMonitoring() trackEvent("security",dashboard",monitoring_started")},[startMonitoring,trackEvent]) const handleStopMonitoring = useCallback(() => {stopMonitoring() trackEvent("security",dashboard",monitoring_stopped")},[stopMonitoring,trackEvent]) const handleCheckCompliance = useCallback(async () => {await checkCompliance() trackEvent("security",dashboard",compliance_checked")},[checkCompliance,trackEvent]) const handleGenerateReport = useCallback(() => {const report = generateSecurityReport() navigator.clipboard.writeText(report) setCopied(true) setTimeout(() => setCopied(false),2000) trackEvent("security",dashboard",report_generated")},[generateSecurityReport,trackEvent]) const handleExportAuditLog = useCallback(() => { const auditLog = exportAuditLog() const blob = new Blob([auditLog] { type "application/json" }) const url = URL.createObjectURL(blob) const a = document.createElement("a") a.href = url a.download = "security-audit-log-${new Date().toISOString().split("T")[0]}.json" a.click() URL.revokeObjectURL(url) trackEvent("security",dashboard",audit_log_exported")},[exportAuditLog,trackEvent]) const handleAddComplianceRule = useCallback(() => { const newRule = {} addComplianceRule(newRule) trackEvent("security",dashboard",compliance_rule_added")},[addComplianceRule,trackEvent]) const getSeverityColor = (props) => { switch(severity) { case critical: return "text-red-600 bg-red-100" case high: return "text-orange-600 bg-orange-100" case medium: return "text-yellow-600 bg-yellow-100" case low: return "text-green-600 bg-green-100" default: return "text-gray-600 bg-gray-100"} } const getStatusColor = (props) => { switch(status) { case compliant: return "text-green-600 bg-green-100" case non_compliant: return "text-red-600 bg-red-100" case pending_review: return "text-yellow-600 bg-yellow-100" default: return "text-gray-600 bg-gray-100"} } const getThreatLevelColor = (props) => { switch(level) { case critical: return "text-red-600 bg-red-100 border-red-200" case high: return "text-orange-600 bg-orange-100 border-orange-200" case medium: return "text-yellow-600 bg-yellow-100 border-yellow-200" case low: return "text-green-600 bg-green-100 border-green-200" default: return "text-gray-600 bg-gray-100 border-gray-200"} }" return (" <div className="{"bg-white" dark:bg-gray-900 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 ${className}"}> {}" <div className="flex items-center justify-between p-4 border-b border-gray-200 dark:border-gray-700">" <div className="flex items-center space-x-3">" <div className="p-2 bg-blue-100 dark:bg-blue-900 rounded-lg">" <Shield className="w-6 h-6 text-blue-600 dark:text-blue-400" /> </div> <div>" <h2 className="text-lg font-semibold text-gray-900 dark:text-white"> Security & Compliance </h2>" <p className="text-sm text-gray-500 dark:text-gray-400"> Real-time monitoring and compliance management </p> </div> </div> " <div className="flex items-center space-x-2">" <button onClick="{handleCheckCompliance}" disabled="{isComplianceChecking}" className="flex items-center space-x-2 px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-800 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 disabled:opacity-50">" {isComplianceChecking ? (<Loader2 className="w-4 h-4 animate-spin" />) : (<RefreshCw className="w-4 h-4" />)} <span>Check Compliance</span> </button> " <button onClick="{()" => setShowSettings(!showSettings)} className="p-2 text-gray-500 hover: text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800">" <Settings className="w-5 h-5" /> </button> </div> </div> {}" <div className="p-4 bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 border-b border-gray-200 dark:border-gray-700">" <div className="flex items-center justify-between">" <div className="flex items-center space-x-4">" <div className="flex items-center space-x-2">" <div className="{"w-3" h-3 rounded-full ${isMonitoring ? "bg-green-500" : "bg-red-500"}"} />" <span className="text-sm font-medium text-gray-700 dark:text-gray-300"> {isMonitoring ? "Monitoring Active" : "Monitoring Inactive"} </span> </div> " <div className="flex items-center space-x-2">" <Clock className="w-4 h-4 text-gray-500" />" <span className="text-sm text-gray-600 dark:text-gray-400"> Last Check: {new Date().toLocaleTimeString()} </span> </div> </div> " <div className="flex space-x-2">" {!isMonitoring ? (<button onClick="{handleStartMonitoring}" className="flex items-center space-x-2 px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-lg hover: bg-green-700">" <Play className="w-4 h-4" /> <span>Start Monitoring</span>" </button>) : (<button onClick="{handleStopMonitoring}" className="flex items-center space-x-2 px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700">" <Square className="w-4 h-4" /> <span>Stop Monitoring</span> </button>)} </div> </div> </div> {}" <div className="flex border-b border-gray-200 dark: border-gray-700"> {[" { id: "overview",label: "Overview",icon: BarChart3 } {id: "events",label: "Security Events",icon: AlertTriangle} {id: "compliance",label: "Compliance",icon: CheckCircle} {id: "threats",label: "Threats",icon: Shield} {id: "reports",label: "Reports",icon: FileText}" ].map(({id,label,icon: Icon}) => (<button key="{id}" onClick="{()" => setActiveTab(id)} className="{"flex" items-center space-x-2 px-4 py-3 text-sm font-medium border-b-2 transition-colors ${activeTab === id" ? "border-blue-500 text-blue-600 dark: text-blue-400" : "border-transparent text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200"}"}>" <Icon className="w-4 h-4" /> <span>{label}</span> </button>) ) } </div> {}" <div className="p-4">" <AnimatePresence mode="wait">" {activeTab === "overview" && (<motion.div key="overview" initial = { { opacity: 0,y: 20 }} animate = { { opacity: 1,y: 0 }} exit = { { opacity: 0,y: -20 " }} className="space-y-6"> {}" <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">" <div className="bg-gray-50 dark:bg-gray-800 p-4 rounded-lg">" <div className="flex items-center justify-between"> <div>" <p className="text-sm font-medium text-gray-600 dark:text-gray-400">Total Events</p>" <p className="text-2xl font-bold text-gray-900 dark:text-white">{securityMetrics.totalEvents}</p> </div>" <AlertTriangle className="w-8 h-8 text-orange-500" /> </div> </div> " <div className="bg-gray-50 dark:bg-gray-800 p-4 rounded-lg">" <div className="flex items-center justify-between"> <div>" <p className="text-sm font-medium text-gray-600 dark:text-gray-400">Critical Events</p>" <p className="text-2xl font-bold text-red-600">{securityMetrics.criticalEvents}</p> </div>" <XCircle className="w-8 h-8 text-red-500" /> </div> </div> " <div className="bg-gray-50 dark:bg-gray-800 p-4 rounded-lg">" <div className="flex items-center justify-between"> <div>" <p className="text-sm font-medium text-gray-600 dark:text-gray-400">Compliance Score</p>" <p className="text-2xl font-bold text-green-600">{securityMetrics.complianceScore}%</p> </div>" <CheckCircle className="w-8 h-8 text-green-500" /> </div> </div> " <div className="bg-gray-50 dark:bg-gray-800 p-4 rounded-lg">" <div className="flex items-center justify-between"> <div>" <p className="text-sm font-medium text-gray-600 dark:text-gray-400">Threat Level</p>" <p className="{"text-lg" font-bold ${getThreatLevelColor(securityMetrics.threatLevel)}"}> {securityMetrics.threatLevel.toUpperCase()} </p> </div>" <Shield className="w-8 h-8 text-blue-500" /> </div> </div> </div> {}" <div className="bg-gray-50 dark: bg-gray-800 p-4 rounded-lg">" <h3 className="text-lg font-semibold text-gray-900 dark:text-white mb-4">Recent Security Events</h3>" <div className="space-y-3">" {securityEvents.slice(0,5).map((event) => (<div key="{event.id}" className="flex items-center justify-between p-3 bg-white dark: bg-gray-700 rounded-lg">" <div className="flex items-center space-x-3">" <div className="{"p-2" rounded-lg ${getSeverityColor(event.severity)}"}>" <AlertTriangle className="w-4 h-4" /> </div> <div>" <p className="font-medium text-gray-900 dark: text-white">{event.type.replace("_")}</p>" <p className="text-sm text-gray-500 dark: text-gray-400">{event.details}</p> </div> </div>" <div className="flex items-center space-x-2">" <span className="{"px-2" py-1 text-xs font-medium rounded-full ${getSeverityColor(event.severity)}"}> {event.severity} </span>" <span className="text-sm text-gray-500 dark: text-gray-400"> {event.timestamp.toLocaleTimeString()} </span> </div> </div>) ) } </div> </div> </motion.div>)} " {activeTab === "events" && (<motion.div key="events" initial = { { opacity: 0,y: 20 }} animate = { { opacity: 1,y: 0 }} exit = { { opacity: 0,y: -20 " }} className="space-y-4">" <div className="flex items-center justify-between">" <h3 className="text-lg font-semibold text-gray-900 dark:text-white">Security Events</h3> <button onClick={ () => addSecurityEvent({ type "authentication",severity: "low",details: "Test security event",status: "new" })} className="px-3 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover: bg-blue-700"> Add Test Event </button> </div> " <div className="space-y-3">" {securityEvents.map((event) => (<div key="{event.id}" className="bg-gray-50 dark: bg-gray-800 p-4 rounded-lg">" <div className="flex items-center justify-between mb-3">" <div className="flex items-center space-x-3">" <div className="{"p-2" rounded-lg ${getSeverityColor(event.severity)}"}>" <AlertTriangle className="w-4 h-4" /> </div> <div>" <p className="font-medium text-gray-900 dark: text-white"> {event.type.replace("_").toUpperCase()} </p>" <p className="text-sm text-gray-500 dark: text-gray-400"> {event.timestamp.toLocaleString()} </p> </div> </div>" <div className="flex items-center space-x-2">" <span className="{"px-2" py-1 text-xs font-medium rounded-full ${getSeverityColor(event.severity)}"}> {event.severity} </span> <select value="{event.status}" onChange={(e) => updateEventStatus(event.id,e.target.value) "} className="text-sm border border-gray-300 dark: border-gray-600 rounded px-2 py-1 bg-white dark:bg-gray-700 text-gray-900 dark:text-white">" <option value="new">New</option>" <option value="investigating">Investigating</option>" <option value="resolved">Resolved</option>" <option value="false_positive">False Positive</option> </select> </div> </div>" <p className="text-gray-700 dark:text-gray-300 mb-3">{event.details}</p>" {event.userId && (<div className="flex items-center space-x-4 text-sm text-gray-500 dark:text-gray-400"> <span>User: {event.userId}</span> {event.ipAddress && <span>IP: {event.ipAddress}</span>} {event.resource && <span>Resource: {event.resource}</span>} </div>)} </div>))} </div> </motion.div>)} " {activeTab === "compliance" && (<motion.div key="compliance" initial = { { opacity: 0,y: 20 }} animate = { { opacity: 1,y: 0 }} exit = { { opacity: 0,y: -20 " }} className="space-y-4">" <div className="flex items-center justify-between">" <h3 className="text-lg font-semibold text-gray-900 dark:text-white">Compliance Rules</h3>" <button onClick="{handleAddComplianceRule}" className="px-3 py-2 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700"> Add Rule 