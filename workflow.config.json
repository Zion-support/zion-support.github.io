{
  "name": "zion-tech-group-development-workflow",
  "version": "1.0.0",
  "description": "Intelligent development workflow configuration for Zion Tech Group",
  "workflow": {
    "watchPatterns": [
      "src/**/*.{js,jsx,ts,tsx}",
      "server/src/**/*.{js,ts}",
      "styles/**/*.{css,scss}",
      "public/**/*",
      "components/**/*.{js,jsx,ts,tsx}",
      "pages/**/*.{js,jsx,ts,tsx}",
      "utils/**/*.{js,ts}",
      "types/**/*.{js,ts}"
    ],
    "autoTest": true,
    "autoLint": true,
    "autoBuild": false,
    "autoDeploy": false,
    "testPatterns": [
      "src/**/*.test.{js,jsx,ts,tsx}",
      "tests/**/*.{js,ts}",
      "server/src/**/*.test.{js,ts}",
      "components/**/*.test.{js,jsx,ts,tsx}"
    ],
    "lintPatterns": [
      "src/**/*.{js,jsx,ts,tsx}",
      "server/src/**/*.{js,ts}",
      "components/**/*.{js,jsx,ts,tsx}",
      "pages/**/*.{js,jsx,ts,tsx}",
      "utils/**/*.{js,ts}",
      "types/**/*.{js,ts}"
    ],
    "buildPatterns": [
      "src/**/*.{js,jsx,ts,tsx}",
      "server/src/**/*.{js,ts}",
      "styles/**/*.{css,scss}",
      "public/**/*"
    ],
    "deploymentEnvironments": ["staging", "production"],
    "performance": {
      "autoOptimize": true,
      "bundleAnalysis": true,
      "lighthouseAudit": true,
      "optimizationInterval": 1800000
    },
    "security": {
      "autoScan": true,
      "vulnerabilityCheck": true,
      "dependencyAudit": true,
      "scanInterval": 900000
    },
    "quality": {
      "codeCoverage": true,
      "complexityAnalysis": true,
      "duplicateDetection": true,
      "analysisInterval": 600000
    },
    "monitoring": {
      "healthChecks": true,
      "performanceMetrics": true,
      "errorTracking": true,
      "alerting": true,
      "checkInterval": 30000
    }
  },
  "environments": {
    "development": {
      "port": 3000,
      "serverPort": 5000,
      "autoReload": true,
      "debugMode": true,
      "logLevel": "debug"
    },
    "staging": {
      "port": 3001,
      "serverPort": 5001,
      "autoReload": false,
      "debugMode": false,
      "logLevel": "info"
    },
    "production": {
      "port": 3000,
      "serverPort": 5000,
      "autoReload": false,
      "debugMode": false,
      "logLevel": "warn"
    }
  },
  "automation": {
    "intelligentOrchestrator": {
      "enabled": true,
      "priority": "high",
      "autoRestart": true,
      "healthMonitoring": true
    },
    "codeQualityMonitor": {
      "enabled": true,
      "priority": "high",
      "autoFix": true,
      "reporting": true
    },
    "performanceOptimizer": {
      "enabled": true,
      "priority": "medium",
      "autoOptimize": true,
      "bundleAnalysis": true
    },
    "securityScanner": {
      "enabled": true,
      "priority": "high",
      "autoScan": true,
      "vulnerabilityCheck": true
    },
    "seoOptimizer": {
      "enabled": true,
      "priority": "medium",
      "autoOptimize": true,
      "metaTagAudit": true
    },
    "testGenerator": {
      "enabled": true,
      "priority": "medium",
      "autoGenerate": true,
      "coverageAnalysis": true
    },
    "contentGenerator": {
      "enabled": true,
      "priority": "low",
      "autoGenerate": false,
      "aiAssisted": true
    },
    "edgeCacheWarmer": {
      "enabled": true,
      "priority": "low",
      "autoWarm": true,
      "performanceMonitoring": true
    },
    "repoFitnessMonitor": {
      "enabled": true,
      "priority": "medium",
      "autoAssess": true,
      "healthScoring": true
    }
  },
  "notifications": {
    "enabled": true,
    "channels": ["console", "file", "email"],
    "levels": ["error", "warn", "info"],
    "email": {
      "smtp": "smtp.gmail.com",
      "port": 587,
      "secure": true
    }
  },
  "logging": {
    "level": "info",
    "format": "json",
    "rotation": {
      "enabled": true,
      "maxSize": "10m",
      "maxFiles": 5
    },
    "directories": {
      "logs": "./logs",
      "reports": "./reports",
      "backups": "./backups"
    }
  },
  "integrations": {
    "github": {
      "enabled": true,
      "webhooks": true,
      "autoDeploy": false
    },
    "netlify": {
      "enabled": true,
      "autoDeploy": false,
      "functions": true
    },
    "sentry": {
      "enabled": true,
      "errorTracking": true,
      "performanceMonitoring": true
    },
    "analytics": {
      "enabled": true,
      "googleAnalytics": true,
      "performanceMetrics": true
    }
  }
}
