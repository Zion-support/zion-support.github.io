  publish = "dist"
  command_timeout = "30m"

[build.environment]
  NODE_VERSION = "20"

# Ensure Netlify picks up serverless functions from this directory
[functions]
  directory = "netlify/functions"

# Keep the config minimal to avoid plugin-related build failures

[[redirects]]
  from = "/*"
  to = "/index.html"
  status = 200

# Set basic cache headers for static assets for better performance
[[headers]]
  for = "/assets/*"
  [headers.values]
    Cache-Control = "public, max-age=31536000, immutable"

[[headers]]
  for = "/_next/*"
  [headers.values]
    Cache-Control = "public, max-age=31536000, immutable"

[[headers]]
  for = "/*"
  [headers.values]
    Cache-Control = "public, max-age=300"
