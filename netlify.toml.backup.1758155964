# Netlify build configuration for Vite app
# noop: retrigger netlify build (2025-09-17 18:02 UTC)
[build]
  # Build the root Vite app and publish static assets
  command = "npm run build:netlify"
  publish = "dist"

[build.environment]
  NODE_VERSION = "20"
  NODE_OPTIONS = "--max-old-space-size=6144"
  NETLIFY_USE_NPM = "true"
  CANONICAL_URL = "https://ziontechgroup.com"
  # Prevent Netlify from attempting to checkout Git submodules (none are required)
  GIT_SUBMODULE_STRATEGY = "none"

[functions]
  # Keep functions path relative to repo root
  directory = "netlify/functions"
  node_bundler = "esbuild"
  included_files = ["zion-website/public/**/*", "public/**/*"]

[build.processing]
  skip_processing = true
