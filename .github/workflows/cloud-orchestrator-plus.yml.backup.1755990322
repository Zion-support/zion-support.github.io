name: Cloud Orchestrator Plus

on:
  workflow_dispatch: {}
  schedule:
    - cron: '*/10 * * * *'

permissions:
  contents: write
  actions: read

jobs:
  main:
    name: Main Job
    runs-on: ubuntu-latest
    timeout-minutes: 20
    steps:
      - name: Checkout repository
    permissions:
      contents: write
      pull-requests: write
    steps:
      - name: Checkout
>>>>>>> origin/automation/git-sync/2025-08-13T22-22-32-390Z
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'

      - name: Install dependencies
        run: npm ci --no-audit --no-fund

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

