name: automerge-main
on:
  workflow_dispatch: {}
  schedule:
  - cron: '0 2 * * *'
permissions:
  contents: read
  actions: read
  
concurrency:
  group: automerge-main-\${{ github.ref }}
  cancel-in-progress: false
jobs:
  main:
    name: Automerge Main Job
    runs-on: ubuntu-latest
    timeout-minutes: 20
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: npm
      - name: Install dependencies
        run: npm ci --no-audit --no-fund
