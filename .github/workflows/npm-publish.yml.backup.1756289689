name: NPM Package Check
on:
  push:
    branches:
      - main
    paths-ignore:
      - '**/*.md'
      - '**/*.txt'
      - '.github/**'
jobs:
  check:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
      - name: Use Node.js 20
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'
      - name: Install dependencies
        run: npm ci
      - name: Build project
        run: npm run build
      - name: Run tests (if available)
        run: npm test --if-present
        continue-on-error: true
      - name: Check package.json
        run: |
          echo "Package name: $(npm run --silent echo \$npm_package_name)"
          echo "Package version: $(npm run --silent echo \$npm_package_version)"
          echo "Package private: $(npm run --silent echo \$npm_package_private)"
          if [ "$(npm run --silent echo \$npm_package_private)" = "true" ]; then
            echo "✓ Package is marked as private - no publishing needed"
          else
            echo "⚠ Package is not marked as private"
          fi
