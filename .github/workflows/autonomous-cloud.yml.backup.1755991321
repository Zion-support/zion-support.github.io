name: Autonomous Cloud Ops
name: Autonomous Cloud Automations

on:
  schedule:
    - cron: '*/30 * * * *' # every 30 minutes
name: Autonomous Cloud Ops
on:
  schedule:
    - cron: '*/30 * * * *' # every 30 minutes
  workflow_dispatch: {}

permissions:
  contents: write
  workflow_dispatch:
  push:
    branches: [ main ]


jobs:
  run-automations:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          persist-credentials: true
