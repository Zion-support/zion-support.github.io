jobs:
  merge-open-prs:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Enumerate and merge PRs
        uses: actions/github-script@v7
        with:
          script: |
            const core = require('@actions/core');
            const owner = context.repo.owner;
            const repo = context.repo.repo;

            async function listAllOpenPRs(page = 1, acc = []) {
              const { data } = await github.rest.pulls.list({ owner, repo, state: 'open', per_page: 100, page });
              acc.push(...data);
              if (data.length === 100) return listAllOpenPRs(page + 1, acc);
              return acc;
            }

            function delay(ms) { return new Promise(r => setTimeout(r, ms)); }

            const results = { merged: [], conflicted: [], skippedNonMain: [] };

            const prs = await listAllOpenPRs();
            core.info(`Found ${prs.length} open PRs`);

            for (const pr of prs) {
              if (pr.base.ref !== 'main') { results.skippedNonMain.push(pr.number); continue; }
              // Refresh PR to get mergeable status (GitHub may compute it lazily)
              let details = await github.rest.pulls.get({ owner, repo, pull_number: pr.number });
              if (details.data.mergeable === null) {
                await delay(1500);
                details = await github.rest.pulls.get({ owner, repo, pull_number: pr.number });
              }

              if (details.data.mergeable) {
                try {
                  await github.rest.pulls.merge({ owner, repo, pull_number: pr.number, merge_method: 'squash' });
                  results.merged.push(pr.number);
                } catch (err) {
                  core.warning(`Failed to merge PR #${pr.number}: ${err.message}`);
                  results.conflicted.push(pr.number);
                  // Label and comment
                  try {
                    await github.rest.issues.addLabels({ owner, repo, issue_number: pr.number, labels: ['needs-merge-conflict-resolution'] });
                  } catch {}
                  try {
                    await github.rest.issues.createComment({ owner, repo, issue_number: pr.number, body: 'Auto-merge failed. Please resolve merge conflicts with main.' });
                  } catch {}
                }
              } else {
                results.conflicted.push(pr.number);
                try {
                  await github.rest.issues.addLabels({ owner, repo, issue_number: pr.number, labels: ['needs-merge-conflict-resolution'] });
                } catch {}
                try {
                  await github.rest.issues.createComment({ owner, repo, issue_number: pr.number, body: 'This PR has merge conflicts with main. A manual rebase/merge is required.' });
                } catch {}
              }
            }

            core.summary
              .addHeading('Auto-merge Report')
              .addRaw(`Merged: ${results.merged.length ? results.merged.join(', ') : 'none'}\n`)
              .addRaw(`Conflicted: ${results.conflicted.length ? results.conflicted.join(', ') : 'none'}\n`)
              .addRaw(`Skipped (non-main base): ${results.skippedNonMain.length ? results.skippedNonMain.join(', ') : 'none'}\n`)
              .write();

            core.setOutput('merged', JSON.stringify(results.merged));
            core.setOutput('conflicted', JSON.stringify(results.conflicted));
            core.setOutput('skipped', JSON.stringify(results.skippedNonMain));

