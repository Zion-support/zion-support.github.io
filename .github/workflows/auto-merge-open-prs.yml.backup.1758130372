  push:
    branches:
      - feature/new-content-and-promotions
    paths:
      - .github/workflows/auto-merge-open-prs.yml
  workflow_dispatch: {}

permissions:
  contents: write
  pull-requests: write

jobs:
  auto-merge:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Merge all open PRs into main
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          REPO: ${{ github.repository }}
        run: |
          set -euo pipefail
          echo "Fetching open PRs for $REPO"
          prs=$(curl -sSL -H "Authorization: Bearer ${GITHUB_TOKEN}" \
            -H "Accept: application/vnd.github+json" \
            "https://api.github.com/repos/${REPO}/pulls?state=open&per_page=100")
          count=$(printf '%s' "$prs" | jq 'length')
          echo "Found ${count} open PRs"
          if [ "$count" = "0" ]; then
            echo "No open PRs. Exiting."
            exit 0
          fi

          default_branch=$(curl -sSL -H "Authorization: Bearer ${GITHUB_TOKEN}" \
            -H "Accept: application/vnd.github+json" \
            "https://api.github.com/repos/${REPO}" | jq -r .default_branch)
          echo "Default branch: ${default_branch}"

          for row in $(echo "$prs" | jq -r '.[] | @base64'); do
            _jq() { echo ${row} | base64 --decode | jq -r ${1}; }
            number=$(_jq '.number')
            title=$(_jq '.title')
            headRef=$(_jq '.head.ref')
            baseRef=$(_jq '.base.ref')

            # Only target main (or default branch) PRs
            if [ "$baseRef" != "$default_branch" ]; then
              echo "Skipping PR #${number} (base ${baseRef} != ${default_branch})"
              continue
            fi

            echo "Processing PR #${number}: ${title} (${headRef} -> ${baseRef})"

            # Try merge via API first
            merge_resp=$(curl -sS -X PUT -H "Authorization: Bearer ${GITHUB_TOKEN}" \
              -H "Accept: application/vnd.github+json" \
              -d '{"merge_method":"merge"}' \
              "https://api.github.com/repos/${REPO}/pulls/${number}/merge") || true

            merged=$(echo "$merge_resp" | jq -r '.merged // false')
            message=$(echo "$merge_resp" | jq -r '.message // ""')
            if [ "$merged" = "true" ]; then
              echo "✅ Merged PR #${number}"
              continue
            fi

            echo "Merge via API failed for #${number}: ${message}"
            # Fallback: update branch, then try again
            echo "Attempting to update PR branch ${headRef} with ${baseRef}..."
            update_resp=$(curl -sS -X PUT -H "Authorization: Bearer ${GITHUB_TOKEN}" \
              -H "Accept: application/vnd.github+json" \
              -d '{"base":"'"${baseRef}"'"}' \
              "https://api.github.com/repos/${REPO}/pulls/${number}") || true
            sleep 5

            merge_resp=$(curl -sS -X PUT -H "Authorization: Bearer ${GITHUB_TOKEN}" \
              -H "Accept: application/vnd.github+json" \
              -d '{"merge_method":"merge"}' \
              "https://api.github.com/repos/${REPO}/pulls/${number}/merge") || true
            merged=$(echo "$merge_resp" | jq -r '.merged // false')
            message=$(echo "$merge_resp" | jq -r '.message // ""')
            if [ "$merged" = "true" ]; then
              echo "✅ Merged PR #${number} after update"
              continue
            else
              echo "❌ Could not merge PR #${number}: ${message}"
            fi
          done
