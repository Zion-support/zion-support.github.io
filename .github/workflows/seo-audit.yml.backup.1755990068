name: SEO Audit

on:
  schedule:
    - cron: '7 */6 * * *'
  workflow_dispatch: {}

permissions:
  contents: write

concurrency:
  group: seo-audit-${{ github.ref }}
  cancel-in-progress: true

jobs:
  run:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
