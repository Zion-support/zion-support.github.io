name: Cloud Orchestrator Plus

on:
  schedule:
    - cron: "*/3 * * * *"
  workflow_dispatch: {}

jobs:
  run:
    runs-on: ubuntu-latest
    permissions:
      contents: write
      pull-requests: write
    steps:
      - name: Checkout
