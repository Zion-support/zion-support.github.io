name: Link Checker

on:
  schedule:
    - cron: '0 2 * * *'  # Daily at 2 AM
  workflow_dispatch:
  push:
    branches: [main]

permissions:
  contents: read
  issues: write

jobs:
  check-links:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'

      - name: Install dependencies
        run: npm ci

      - name: Build project
        run: npm run build

      - name: Install linkinator
        run: npm install -g linkinator

      - name: Check internal links
        run: |
          echo "Checking internal links..."
          npx linkinator http://localhost:5000 --recurse --concurrency 10 --skip '.*(logout|signout).*' --format json > internal-links.json || true

      - name: Check external links
        run: |
          echo "Checking external links..."
          # Extract external URLs from the build
          find dist -name "*.html" -exec grep -o 'https://[^"]*' {} \; | sort -u > external-urls.txt
          if [ -s external-urls.txt ]; then
            npx linkinator $(cat external-urls.txt) --concurrency 5 --format json > external-links.json || true
          else
            echo '{"links":[]}' > external-links.json
          fi

      - name: Generate link report
        run: |
          echo "Generating link report..."
          # Combine internal and external link reports
          jq -s '
            reduce .[] as $r ({"links":[]};
              .links += ($r.links // [])
            )
          ' internal-links.json external-links.json > combined-links.json

          # Generate broken links summary
          jq '
            [.links[] | select(.state=="BROKEN") |
              {source:.parent, target:.url, status:(.status // "unknown"), type: "broken"}
            ] | sort_by(.source, .target)
          ' combined-links.json > broken-links.json

          # Count broken links
          broken_count=$(jq 'length' broken-links.json)
          echo "Found $broken_count broken links"

          # Generate markdown report
          if [ "$broken_count" -gt 0 ]; then
            cat > LINK_REPORT.md << EOF
            # Link Check Report - $(date)
            
            ## Summary
            - **Total broken links**: $broken_count
            - **Report generated**: $(date)
            
            ## Broken Links
            
            | Source | Target | Status |
            |--------|--------|--------|
            $(jq -r '.[] | "| " + (.source // "unknown") + " | " + (.target // "unknown") + " | " + (.status // "unknown") + " |"' broken-links.json)
            
            ## Recommendations
            1. Fix all broken internal links
            2. Update or remove broken external links
            3. Implement proper 404 handling for broken routes
            4. Add link validation to CI/CD pipeline
            EOF
          else
            cat > LINK_REPORT.md << EOF
            # Link Check Report - $(date)
            
            ## Summary
            ✅ **No broken links found!**
            
            All links are working correctly.
            EOF
          fi

      - name: Upload link report
        uses: actions/upload-artifact@v4
        with:
          name: link-report
          path: |
            LINK_REPORT.md
            broken-links.json
            combined-links.json
          retention-days: 7

      - name: Create issue for broken links
        if: contains(steps.check-links.outputs.broken_count, '0') == false
        uses: peter-evans/create-issue-from-file@v5
        with:
          title: "🔗 Broken Links Detected - $(date)"
          content-filepath: LINK_REPORT.md
          labels: |
            link-check
            automated
            bug
          assignees: ''