jobs:
  main:
    runs-on: ubuntu-latest
    timeout-minutes: 30
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Run Lighthouse on production URLs (non-blocking on schedule)
        if: ${{ github.event_name == 'schedule' }}
        uses: treosh/lighthouse-ci-action@v12
