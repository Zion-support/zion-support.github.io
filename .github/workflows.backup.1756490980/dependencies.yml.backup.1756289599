name: Dependencies (DISABLED - Migrated to PM2)

on:
  # This workflow is disabled and migrated to PM2 automation
  # The original workflow was handling dependency management
  # Now handled by PM2 processes: dependency-updates, security-audit
  workflow_dispatch: # Only manual triggers allowed
  # All automatic triggers removed

permissions:
  contents: write
  pull-requests: write
  security-events: write

jobs:
  disabled:
    runs-on: ubuntu-latest
    steps:
      - name: Workflow Disabled
        run: |
          echo "This workflow has been disabled and migrated to PM2 automation."
          echo "Dependency management tasks are now handled by:"
          echo "- dependency-updates PM2 process (every 6 hours)"
          echo "- security-audit PM2 process (every 4 hours)"
          echo "PM2 ecosystem.config.cjs contains the full automation configuration."
          exit 0
