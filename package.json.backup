{
  "name": "zion-tech-group-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode production && cp -f _redirects dist/_redirects || true && cp -f public/_headers dist/_headers || true",
    "start": "vite preview",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/AppMinimal.tsx\" \"src/main.tsx\"",
    "lint:fix": "eslint \"src/AppMinimal.tsx\" \"src/main.tsx\" --fix",
    "type-check": "tsc --project tsconfig.typecheck.json --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "cypress run",
    "test:build": "npm run build && npm run test",
    "format": "prettier --write .",
    "automation:accessibility": "node automation/accessibility-checker.cjs",
    "automation:security-audit": "node automation/security-audit.cjs",
    "format:check": "prettier --check .",
    "test:smoke": "jest --config jest.config.smoke.cjs",