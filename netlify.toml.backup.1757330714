[build]
  # Install Python dependencies first, then Node.js dependencies and build
  command = "mise settings set python.compile false && pip install -r requirements.txt && npm ci && npm run build"
  publish = "dist"
  command_timeout = "30m"

[build.environment]
  NODE_VERSION = "20"
