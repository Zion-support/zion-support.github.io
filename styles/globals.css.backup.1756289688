.text-high-contrast-secondary {
  color: var(--text-secondary);
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
}

.text-high-contrast-tertiary {
  color: var(--text-tertiary);
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
}

.text-high-contrast-muted {
  color: var(--text-muted);
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
}

.text-high-contrast-accent {
  color: var(--text-accent);
  text-shadow: 0 0 10px rgba(0, 212, 255, 0.5);
}

.text-high-contrast-success {
  color: var(--text-success);
  text-shadow: 0 0 10px rgba(16, 185, 129, 0.5);
}

.text-high-contrast-warning {
  color: var(--text-warning);
  text-shadow: 0 0 10px rgba(245, 158, 11, 0.5);
}

.text-high-contrast-error {
  color: var(--text-error);
  text-shadow: 0 0 10px rgba(239, 68, 68, 0.5);
}

/* Navigation Link Styles */
.nav-link {
  @apply text-gray-300 hover:text-neon-blue transition-colors duration-300 font-medium relative;
}

.nav-link::after {
  content: '';
  @apply absolute bottom-0 left-0 w-0 h-0.5 bg-gradient-to-r from-neon-blue to-neon-purple transition-all duration-300;
}

.nav-link:hover::after {
  @apply w-full;
}

/* Mobile Navigation Link Styles */
.mobile-nav-link {
  @apply block text-gray-300 hover:text-neon-blue transition-colors duration-300 font-medium py-2;
}

/* Enhanced Button Styles */
.btn-primary {
  @apply px-6 py-3 bg-gradient-to-r from-neon-blue to-neon-purple text-white font-semibold rounded-lg hover:from-neon-purple hover:to-neon-blue transition-all duration-300 shadow-lg hover:shadow-neon-blue/25;
}

.btn-secondary {
  @apply px-6 py-3 bg-transparent border-2 border-neon-blue text-neon-blue font-semibold rounded-lg hover:bg-neon-blue hover:text-white transition-all duration-300;
}

/* Enhanced Card Styles */
.card {
  @apply bg-black/40 backdrop-blur-sm border border-neon-blue/20 rounded-2xl p-6 hover:border-neon-blue/40 transition-all duration-300 hover:bg-black/60;
}

.card-hover {
  @apply transform hover:scale-105 transition-transform duration-300;
}

/* Enhanced Input Styles */
.input-modern {
  @apply px-4 py-3 bg-white/10 border border-neon-blue/20 rounded-lg text-white placeholder-gray-400 focus:outline-none focus:border-neon-blue/40 focus:ring-2 focus:ring-neon-blue/20;
}

/* Enhanced Animation Classes */
.animate-float {
  animation: float 6s ease-in-out infinite;
}

.animate-glow {
  animation: glow 2s ease-in-out infinite alternate;
}

.animate-neon-pulse {
  animation: neon-pulse 2s ease-in-out infinite;
}

.animate-holographic-shift {
  animation: holographic-shift 3s ease infinite;
}

/* Enhanced Background Patterns */
.bg-cyber-pattern {
  background-image: 
    radial-gradient(circle at 25% 25%, rgba(0, 212, 255, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 75% 75%, rgba(139, 92, 246, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 50% 50%, rgba(236, 72, 153, 0.05) 0%, transparent 50%);
}

.bg-matrix-pattern {
  background-image: 
    linear-gradient(90deg, rgba(0, 212, 255, 0.03) 1px, transparent 1px),
    linear-gradient(rgba(0, 212, 255, 0.03) 1px, transparent 1px);
  background-size: 20px 20px;
}

/* Enhanced Scrollbar */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  @apply bg-black/20;
}

::-webkit-scrollbar-thumb {
  @apply bg-neon-blue/30 rounded-full;
}

::-webkit-scrollbar-thumb:hover {
  @apply bg-neon-blue/50;
}

/* Enhanced Selection */
::selection {
  @apply bg-neon-blue/30 text-white;
}

::-moz-selection {
  @apply bg-neon-blue/30 text-white;
}

/* Enhanced Focus States */
.focus-neon:focus {
  @apply outline-none ring-2 ring-neon-blue/50 ring-offset-2 ring-offset-black;
}

/* Enhanced Loading States */
.loading-dots {
  @apply inline-flex space-x-1;
}

.loading-dots > div {
  @apply w-2 h-2 bg-neon-blue rounded-full animate-bounce;
}

.loading-dots > div:nth-child(2) {
  animation-delay: 0.1s;
}

.loading-dots > div:nth-child(3) {
  animation-delay: 0.2s;
}

/* Enhanced Typography */
.text-gradient {
  @apply bg-gradient-to-r from-neon-blue via-neon-purple to-neon-pink bg-clip-text text-transparent;
}

.text-glow {
  @apply text-neon-blue drop-shadow-[0_0_10px_rgba(0,212,255,0.5)];
}

/* Enhanced Spacing Utilities */
.space-y-responsive > * + * {
  @apply mt-4 md:mt-6 lg:mt-8;
}

.space-x-responsive > * + * {
  @apply ml-4 md:ml-6 lg:ml-8;
}

/* Enhanced Responsive Utilities */
.container-responsive {
  @apply container mx-auto px-4 sm:px-6 lg:px-8;
}

.grid-responsive {
  @apply grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 md:gap-6 lg:gap-8;
}

/* Enhanced Hover Effects */
.hover-lift {
  @apply transition-transform duration-300 hover:-translate-y-1;
}

.hover-glow {
  @apply transition-shadow duration-300 hover:shadow-neon-blue/25;
}

.hover-scale {
  @apply transition-transform duration-300 hover:scale-105;
}

/* Enhanced Border Effects */
.border-glow {
  @apply border border-neon-blue/20 hover:border-neon-blue/40 transition-colors duration-300;
}

.border-gradient {
  background: linear-gradient(45deg, var(--neon-blue), var(--neon-purple));
  padding: 1px;
}

.border-gradient > * {
  @apply bg-black rounded-lg;
}

/* Enhanced Background Effects */
.bg-glass {
  @apply bg-white/5 backdrop-blur-md border border-white/10;
}

.bg-neon {
  @apply bg-gradient-to-r from-neon-blue/20 to-neon-purple/20;
}

/* Enhanced Text Effects */
.text-shadow-neon {
  text-shadow: 0 0 10px var(--neon-blue), 0 0 20px var(--neon-blue), 0 0 30px var(--neon-blue);
}

.text-shadow-glow {
  text-shadow: 0 0 10px var(--neon-purple), 0 0 20px var(--neon-purple);
}

/* Enhanced Animation Keyframes */
@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-20px); }
}

@keyframes glow {
  0% { box-shadow: 0 0 20px rgba(0, 212, 255, 0.3); }
  100% { box-shadow: 0 0 30px rgba(0, 212, 255, 0.6); }
}

@keyframes neon-pulse {
  0%, 100% {
    box-shadow: 0 0 5px rgba(0, 212, 255, 0.5), 0 0 10px rgba(0, 212, 255, 0.3), 0 0 15px rgba(0, 212, 255, 0.1);
  }
  50% {
    box-shadow: 0 0 10px rgba(0, 212, 255, 0.8), 0 0 20px rgba(0, 212, 255, 0.5), 0 0 30px rgba(0, 212, 255, 0.3);
  }
}

@keyframes holographic-shift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

@keyframes matrix-rain {
  0% { transform: translateY(-100vh); opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { transform: translateY(100vh); opacity: 0; }
}

@keyframes scan-line {
  0% { transform: translateY(-100%); }
  100% { transform: translateY(100vh); }
}

@keyframes glitch {
  0%, 100% { transform: translate(0); }
  20% { transform: translate(-2px, 2px); }
  40% { transform: translate(-2px, -2px); }
  60% { transform: translate(2px, 2px); }
  80% { transform: translate(2px, -2px); }
}

@keyframes typewriter {
  0% { width: 0; }
  100% { width: 100%; }
}

@keyframes breathe {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@keyframes orbit {
  0% { transform: rotate(0deg) translateX(20px) rotate(0deg); }
  100% { transform: rotate(360deg) translateX(20px) rotate(-360deg); }
}

@keyframes pulse-neon {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes wave {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(20deg); }
  75% { transform: rotate(-20deg); }
}

/* Enhanced Responsive Design */
@media (max-width: 640px) {
  .text-responsive {
    @apply text-sm;
  }
  
  .spacing-responsive {
    @apply space-y-4;
  }
}

@media (min-width: 641px) and (max-width: 1024px) {
  .text-responsive {
    @apply text-base;
  }
  
  .spacing-responsive {
    @apply space-y-6;
  }
}

@media (min-width: 1025px) {
  .text-responsive {
    @apply text-lg;
  }
  
  .spacing-responsive {
    @apply space-y-8;
  }
}

/* Enhanced Accessibility */
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.focus-visible:focus {
  @apply outline-none ring-2 ring-neon-blue/50 ring-offset-2 ring-offset-black;
}

/* Enhanced Print Styles */
@media print {
  .no-print {
    display: none !important;
  }
  
  .print-break {
    page-break-before: always;
  }
}

/* Enhanced Dark Mode Support */
@media (prefers-color-scheme: dark) {
  :root {
    --bg-primary: #000000;
    --bg-secondary: #0a0a0a;
    --bg-tertiary: #1a1a1a;
  }
}

/* Enhanced High Contrast Mode Support */
@media (prefers-contrast: high) {
  :root {
    --neon-blue: #00ffff;
    --neon-purple: #ff00ff;
    --neon-pink: #ff0080;
    --neon-green: #00ff00;
    --neon-orange: #ff8000;
    --neon-red: #ff0000;
    --neon-yellow: #ffff00;
  }
}

/* Enhanced Reduced Motion Support */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
} 
