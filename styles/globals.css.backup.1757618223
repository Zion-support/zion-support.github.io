@tailwind base;
@tailwind components;
@tailwind utilities;

/* Import Modern Design System */
@import './modern-design-system.css';

/* Enhanced Futuristic Design System with Superior Contrast */
:root {
  --neon-blue: #00d4ff;
  --neon-purple: #8b5cf6;
  --neon-pink: #ec4899;
  --neon-green: #10b981;
  --neon-orange: #f59e0b;
  --neon-red: #ef4444;
  --neon-yellow: #eab308;
  --holographic-gradient: linear-gradient(45deg, #00d4ff, #8b5cf6, #ec4899, #10b981);
  --cyber-gradient: linear-gradient(135deg, #0f0f23, #1a1a2e, #16213e, #0f3460);
  --neon-shadow: 0 0 20px rgba(0, 212, 255, 0.5);
  --glow-shadow: 0 0 30px rgba(139, 92, 246, 0.4);
  
  /* Enhanced High Contrast Colors - WCAG AA Compliant */
  --text-primary: #ffffff;
  --text-secondary: #f1f5f9;
  --text-tertiary: #e2e8f0;
  --text-muted: #cbd5e1;
  --text-accent: #00d4ff;
  --text-success: #10b981;
  --text-warning: #f59e0b;
  --text-error: #ef4444;
  --text-info: #3b82f6;
  
  /* Enhanced High Contrast Backgrounds */
  --bg-primary: #0a0a1a;
  --bg-secondary: #0f0f23;
  --bg-tertiary: #1a1a2e;
  --bg-card: rgba(255, 255, 255, 0.12);
  --bg-card-hover: rgba(255, 255, 255, 0.18);
  --bg-overlay: rgba(0, 0, 0, 0.8);
  
  /* Enhanced High Contrast Borders */
  --border-primary: rgba(255, 255, 255, 0.25);
  --border-secondary: rgba(255, 255, 255, 0.15);
  --border-accent: rgba(0, 212, 255, 0.4);
  --border-success: rgba(16, 185, 129, 0.4);
  --border-warning: rgba(245, 158, 11, 0.4);
  --border-error: rgba(239, 68, 68, 0.4);
  
  /* Enhanced Focus States */
  --focus-ring: rgba(0, 212, 255, 0.6);
  --focus-ring-success: rgba(16, 185, 129, 0.6);
  --focus-ring-warning: rgba(245, 158, 11, 0.6);
  --focus-ring-error: rgba(239, 68, 68, 0.6);
  
  /* Enhanced Shadow System */
  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.5);
  --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.6);
  --shadow-lg: 0 10px 15px rgba(0, 0, 0, 0.7);
  --shadow-xl: 0 20px 25px rgba(0, 0, 0, 0.8);
  --shadow-neon: 0 0 20px rgba(0, 212, 255, 0.5);
  --shadow-glow: 0 0 30px rgba(139, 92, 246, 0.4);
}

/* Enhanced High Contrast Text Utilities */
.text-high-contrast {
  color: var(--text-primary);
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);
}

<<<<<<< HEAD
.text-high-contrast-secondary {
  color: var(--text-secondary);
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
}

.text-high-contrast-tertiary {
  color: var(--text-tertiary);
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
}

/* Enhanced Scrollbar */
::-webkit-scrollbar {
  width: 12px;
}

::-webkit-scrollbar-track {
  background: rgba(15, 23, 42, 0.8);
  border-radius: 6px;
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(135deg, rgb(var(--accent-cyan)), rgb(var(--accent-blue)));
  border-radius: 6px;
  border: 2px solid rgba(15, 23, 42, 0.8);
}

input:focus, textarea:focus, select:focus {
  outline: none;
  border-color: var(--neon-blue);
  box-shadow: 0 0 0 3px rgba(0, 212, 255, 0.1);
  background-color: rgba(255, 255, 255, 0.15);
}

input::placeholder, textarea::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

/* Mobile-First Button Styles */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.75rem 1.5rem;
  border-radius: 0.5rem;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.3s ease;
  cursor: pointer;
  min-height: 44px; /* Mobile touch target */
}

.btn:focus {
  outline: 2px solid var(--neon-blue);
  outline-offset: 2px;
}

.btn-secondary {
  background-color: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  color: white;
}

.btn-secondary:hover {
  background-color: rgba(255, 255, 255, 0.2);
  border-color: rgba(255, 255, 255, 0.3);
}

.btn-ghost {
  background-color: transparent;
  border: 1px solid transparent;
  color: white;
}

.btn-ghost:hover {
  background-color: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.2);
}

/* Mobile-First Card Styles */
.card {
  background-color: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 1rem;
  padding: 1.5rem;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  transition: all 0.3s ease;
}

.card:hover {
  background-color: rgba(255, 255, 255, 0.15);
  border-color: rgba(255, 255, 255, 0.3);
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
}

/* Mobile-First Link Styles */
a {
  color: var(--neon-blue);
  text-decoration: none;
  transition: color 0.3s ease;
}

a:hover {
  color: var(--neon-purple);
}

a:focus {
  outline: 2px solid var(--neon-blue);
  outline-offset: 2px;
}

/* Mobile-First Navigation Styles */
nav a {
  color: white;
  text-decoration: none;
  transition: color 0.3s ease;
}

nav a:hover {
  color: var(--neon-blue);
}

nav a:focus {
  outline: 2px solid var(--neon-blue);
  outline-offset: 2px;
}

/* Mobile-First Status Indicators */
.status-active {
  color: var(--neon-green);
  background-color: rgba(16, 185, 129, 0.1);
}

.status-pending {
  color: var(--neon-orange);
  background-color: rgba(245, 158, 11, 0.1);
}

.status-inactive {
  color: var(--text-muted);
  background-color: rgba(203, 213, 225, 0.1);
}

/* Mobile-First Typography */
h1, h2, h3, h4, h5, h6 {
  color: white;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 1rem;
}

p {
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 1rem;
  font-size: 1rem;
}

li {
  color: var(--text-secondary);
  margin-bottom: 0.5rem;
}

code {
  background-color: rgba(255, 255, 255, 0.1);
  padding: 0.25rem 0.5rem;
  border-radius: 0.25rem;
  font-family: 'Courier New', monospace;
  color: var(--neon-green);
}

blockquote {
  border-left: 4px solid var(--neon-blue);
  padding-left: 1rem;
  margin: 1rem 0;
  font-style: italic;
  color: var(--text-secondary);
}

/* Mobile-First Table Styles */
table {
  width: 100%;
  border-collapse: collapse;
}

th {
  background-color: rgba(255, 255, 255, 0.1);
  padding: 1rem;
  text-align: left;
  font-weight: 600;
  color: white;
}

td {
  padding: 1rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  color: var(--text-secondary);
}

/* Mobile-First Modal Styles */
.modal, .overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-content {
  background-color: var(--bg-primary);
  border: 1px solid var(--border-primary);
  border-radius: 1rem;
  padding: 2rem;
  max-width: 90vw;
  max-height: 90vh;
  overflow-y: auto;
}

/* Mobile-First Tooltip Styles */
.tooltip {
  position: relative;
  display: inline-block;
}

.tooltip::after {
  content: attr(data-tooltip);
  position: absolute;
  bottom: 100%;
  left: 50%;
  transform: translateX(-50%);
  background-color: var(--bg-primary);
  color: white;
  padding: 0.5rem;
  border-radius: 0.25rem;
  font-size: 0.875rem;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.tooltip:hover::after {
  opacity: 1;
}

/* Mobile-First Badge Styles */
.badge {
  display: inline-block;
  padding: 0.25rem 0.5rem;
  border-radius: 0.25rem;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
}

.badge-success {
  background-color: rgba(16, 185, 129, 0.2);
  color: var(--neon-green);
}

.badge-warning {
  background-color: rgba(245, 158, 11, 0.2);
  color: var(--neon-orange);
}

.badge-error {
  background-color: rgba(239, 68, 68, 0.2);
  color: var(--neon-red);
}

.badge-info {
  background-color: rgba(59, 130, 246, 0.2);
  color: var(--neon-blue);
}

/* Mobile-First Progress Styles */
.progress {
  width: 100%;
  height: 0.5rem;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 0.25rem;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--neon-blue), var(--neon-purple));
  transition: width 0.3s ease;
}

/* Mobile-First Alert Styles */
.alert {
  padding: 1rem;
  border-radius: 0.5rem;
  margin-bottom: 1rem;
  border: 1px solid;
}

.alert-success {
  background-color: rgba(16, 185, 129, 0.1);
  border-color: var(--neon-green);
  color: var(--neon-green);
}

.alert-warning {
  background-color: rgba(245, 158, 11, 0.1);
  border-color: var(--neon-orange);
  color: var(--neon-orange);
}

.alert-error {
  background-color: rgba(239, 68, 68, 0.1);
  border-color: var(--neon-red);
  color: var(--neon-red);
}

.alert-info {
  background-color: rgba(59, 130, 246, 0.1);
  border-color: var(--neon-blue);
  color: var(--neon-blue);
}

/* Mobile-First Animations */
@keyframes neon-pulse {
  0%, 100% {
    box-shadow: 0 0 5px rgba(0, 212, 255, 0.5);
  }
  50% {
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.8), 0 0 30px rgba(0, 212, 255, 0.6);
  }
}

@keyframes grid-move {
  0% {
    transform: translate(0, 0);
  }
  100% {
    transform: translate(50px, 50px);
  }
}

@keyframes float {
  0%, 100% {
    transform: translateY(0px);
  }
  50% {
    transform: translateY(-20px);
  }
}

@keyframes pulse-glow {
  0%, 100% {
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
  }
  50% {
    text-shadow: 0 0 10px currentColor, 0 0 20px currentColor, 0 0 30px currentColor, 0 0 40px currentColor;
  }
}

@keyframes scan-line {
  0% {
    transform: translateY(-100%);
  }
  100% {
    transform: translateY(100vh);
  }
}

/* Mobile-First Utility Classes */
.neon-glow {
  animation: neon-pulse 2s ease-in-out infinite;
}

.holographic-bg {
  background: var(--holographic-gradient);
  background-size: 400% 400%;
  animation: holographic-shift 3s ease infinite;
}

.cyber-bg {
  background: var(--cyber-gradient);
  position: relative;
  overflow: hidden;
}

.cyber-bg::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--holographic-gradient);
  background-size: 400% 400%;
  animation: holographic-shift 3s ease infinite;
  opacity: 0.1;
  pointer-events: none;
}

.neon-text {
  animation: neon-text-glow 2s ease-in-out infinite;
}

.cyber-float {
  animation: cyber-float 6s ease-in-out infinite;
}

.hover-lift:hover {
  transform: translateY(-8px) scale(1.02);
}

.hover-glow {
  transition: box-shadow var(--animation-duration) var(--animation-timing);
}

.hover-glow:hover {
  box-shadow: 0 20px 40px rgba(0, 212, 255, 0.2);
}

/* Enhanced Loading States */
.loading-pulse {
  animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

/* Enhanced Responsive Design */
@media (max-width: 768px) {
  .card-futuristic {
    padding: 16px;
    border-radius: 16px;
  }
  
  .btn-futuristic {
    padding: 12px 24px;
    border-radius: 12px;
  }
  
  .input-futuristic {
    padding: 10px 14px;
    border-radius: 10px;
  }
}

/* Enhanced Accessibility */
@media (prefers-reduced-motion: reduce) {
  * {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* Enhanced Focus States */
.focus-visible:focus {
  outline: 2px solid var(--neon-cyan);
  outline-offset: 2px;
  box-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
}

/* Enhanced Dark Mode Support */
@media (prefers-color-scheme: dark) {
  :root {
    --neon-cyan: #00d4ff;
    --neon-purple: #a855f7;
  }
}

/* Enhanced Print Styles */
@media print {
  .btn-futuristic,
  .card-futuristic {
    box-shadow: none;
    border: 1px solid #ccc;
  }
  
  .text-gradient {
    color: #000;
    background: none;
  }
}

/* Enhanced Performance Optimizations */
.will-change-transform {
  will-change: transform;
}

/* Smooth Scrolling */
html {
  scroll-behavior: smooth;
}

/* Focus Styles for Accessibility */
.focus-visible:focus {
  outline: 2px solid var(--primary-color);
  outline-offset: 2px;
}

/* Skip Link Styles */
.skip-link {
  position: absolute;
  width: 2px;
  height: 2px;
  background: var(--neon-blue);
  border-radius: 50%;
  animation: particle-drift 8s linear infinite;
  opacity: 0.6;
}

.matrix-rain {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  pointer-events: none;
}

.matrix-rain::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, var(--neon-green), transparent);
  animation: matrix-rain 3s linear infinite;
  opacity: 0.1;
}

/* Mobile-First Glass Effects */
.glass {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.glass-dark {
  background: rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

/* Mobile-First Border Effects */
.neon-border {
  border: 1px solid var(--neon-blue);
  box-shadow: 0 0 10px rgba(0, 212, 255, 0.3);
}

.neon-border-purple {
  border: 1px solid var(--neon-purple);
  box-shadow: 0 0 10px rgba(139, 92, 246, 0.3);
}

/* Mobile-First Container Classes */
.container-responsive {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1rem;
}

.container-fluid {
  width: 100%;
  padding: 0 1rem;
}

.container-narrow {
  width: 100%;
  max-width: 800px;
  margin: 0 auto;
  padding: 0 1rem;
}

.container-wide {
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 1rem;
}

/* Mobile-First Responsive Text Classes */
.text-responsive-xs {
  font-size: clamp(0.75rem, 2vw, 0.875rem);
}

.text-responsive-sm {
  font-size: clamp(0.875rem, 2.5vw, 1rem);
}

.text-responsive-base {
  font-size: clamp(1rem, 3vw, 1.125rem);
}

.text-responsive-lg {
  font-size: clamp(1.125rem, 3.5vw, 1.25rem);
}

.text-responsive-xl {
  font-size: clamp(1.25rem, 4vw, 1.5rem);
}

.text-responsive-2xl {
  font-size: clamp(1.5rem, 5vw, 1.875rem);
}

.text-responsive-3xl {
  font-size: clamp(1.875rem, 6vw, 2.25rem);
}

.text-responsive-4xl {
  font-size: clamp(2.25rem, 7vw, 3rem);
}

.text-responsive-5xl {
  font-size: clamp(3rem, 8vw, 4rem);
}

/* Mobile-First Spacing Classes */
.section-padding {
  padding: 2rem 0;
}

.section-padding-sm {
  padding: 1rem 0;
}

.section-padding-lg {
  padding: 4rem 0;
}

.content-padding {
  padding: 1rem;
}

.content-padding-sm {
  padding: 0.5rem;
}

.content-padding-lg {
  padding: 2rem;
}

/* Mobile-First Grid Classes */
.grid-responsive-1 {
  display: grid;
  grid-template-columns: repeat(1, 1fr);
  gap: 1rem;
}

.grid-responsive-2 {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1rem;
}

.grid-responsive-3 {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1rem;
}

.grid-responsive-4 {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1rem;
}

.grid-responsive-5 {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1rem;
}

.grid-responsive-6 {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 1rem;
}

/* Mobile-First Display Classes */
.mobile-only {
  display: block;
}

.tablet-up {
  display: none;
}

.desktop-up {
  display: none;
}

.large-desktop-up {
  display: none;
}

.mobile-tablet {
  display: block;
}

.tablet-desktop {
  display: none;
}

/* Mobile-First Aspect Ratio Classes */
.aspect-responsive-square {
  aspect-ratio: 1;
}

.aspect-responsive-video {
  aspect-ratio: 16 / 9;
}

/* Mobile-First Animation Classes */
.animate-fade-in-up {
  animation: fadeInUp 0.6s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Mobile-First Gradient Text */
.gradient-text {
  background: linear-gradient(45deg, var(--neon-blue), var(--neon-purple), var(--neon-pink));
  background-size: 200% 200%;
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: holographic-shift 3s ease infinite;
}

/* Mobile-First Scrollbar Styles */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.1);
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(135deg, var(--primary-blue), var(--primary-purple));
}

/* Mobile-First Safe Area Classes */
.safe-area-top {
  padding-top: env(safe-area-inset-top);
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-area-left {
  padding-left: env(safe-area-inset-left);
}

.safe-area-right {
  padding-right: env(safe-area-inset-right);
}

/* Mobile-First Touch Target Classes */
.touch-target {
  min-height: 44px;
  min-width: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Mobile-First Focus Classes */
.focus-responsive {
  outline: none;
  transition: all 0.3s ease;
}

.card-hover {
  @apply hover:bg-gray-700/50 hover:shadow-2xl hover:shadow-cyan-500/25 transform hover:-translate-y-1;
}

/* Enhanced Inputs */
.input {
  @apply w-full px-4 py-3 bg-gray-800/50 border border-gray-700/50 rounded-xl text-white 
         placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500/50 
         transition-all duration-300;
}

.input-primary {
  @apply px-4 py-3 bg-gray-800/50 border border-gray-700/50 rounded-xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500/50 transition-all duration-200;
}

/* Enhanced Links */
.link {
  @apply text-cyan-400 hover:text-cyan-300 transition-colors duration-300;
}

.link-underline {
  @apply relative text-cyan-400 hover:text-cyan-300 transition-colors duration-300;
}

.link-underline::after {
  content: '';
  @apply absolute bottom-0 left-0 w-0 h-0.5 bg-cyan-400 transition-all duration-300;
}

.link-underline:hover::after {
  @apply w-full;
}

/* Enhanced Typography */
.heading-1 {
  @apply text-4xl md:text-5xl lg:text-6xl font-bold leading-tight;
}

.heading-2 {
  @apply text-3xl md:text-4xl lg:text-5xl font-bold leading-tight;
}

.heading-3 {
  @apply text-2xl md:text-3xl font-bold leading-tight;
}

.text-gradient {
  @apply bg-gradient-to-r from-cyan-400 to-blue-600 bg-clip-text text-transparent;
}

/* Enhanced Spacing */
.section-padding {
  @apply py-16 md:py-20 lg:py-24;
}

.container-padding {
  @apply px-4 sm:px-6 lg:px-8;
}

/* Enhanced Grid */
.grid-auto-fit {
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
}

.grid-auto-fill {
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
}

/* Enhanced Shadows */
.shadow-glow {
  box-shadow: 0 0 20px rgba(6, 182, 212, 0.3);
}

.shadow-glow-lg {
  box-shadow: 0 0 40px rgba(6, 182, 212, 0.4);
}

.shadow-glow-xl {
  box-shadow: 0 0 60px rgba(6, 182, 212, 0.5);
}

/* Enhanced Transitions */
.transition-smooth {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.transition-bounce {
  transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

/* Enhanced Focus States */
.focus-ring {
  @apply focus:outline-none focus:ring-2 focus:ring-cyan-500/50 focus:ring-offset-2 focus:ring-offset-gray-900;
}

/* Enhanced Hover States */
.hover-lift {
  @apply hover:transform hover:-translate-y-1 hover:shadow-lg transition-all duration-300;
}

.hover-scale {
  @apply hover:transform hover:scale-105 transition-all duration-300;
}

/* Enhanced Loading States */
.loading-dots {
  display: inline-block;
}

.loading-dots::after {
  content: '';
  animation: loading-dots 1.5s infinite;
}

@keyframes loading-dots {
  0%, 20% {
    content: '';
  }
  40% {
    content: '.';
  }
  60% {
    content: '..';
  }
  80%, 100% {
    content: '...';
  }
}

/* Enhanced Responsive Design */
@media (max-width: 640px) {
  .container-padding {
    @apply px-4;
