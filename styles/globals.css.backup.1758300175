  --neon-blue: #3b82f6;
  --neon-orange: #f59e0b;
  --neon-red: #ef4444;
  --neon-yellow: #eab308;
}

/* High Contrast Mode */
@media (prefers-contrast: high) {
  .card-futuristic {
    border-width: 2px;
  }
  
  .btn-futuristic {
    border: 2px solid currentColor;
