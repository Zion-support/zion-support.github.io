  background: linear-gradient(135deg, var(--neon-purple), var(--neon-pink));
}

.btn-futuristic:active {
  transform: translateY(0);
  box-shadow: 0 4px 15px rgba(0, 212, 255, 0.3);
}

/* Futuristic Glow Effects */
.glow-cyan {
