  ring-color: var(--neon-purple);
  ring-offset: 2px;
  ring-offset-color: #000000;
}

/* Smooth Transitions */
.transition-smooth {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.transition-bounce {
  transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

/* Responsive Utilities */
@media (max-width: 640px) {
  .mobile-hidden {
    display: none;
  }
  
  /* Gradient Presets */
  --gradient-cyberpunk: linear-gradient(135deg, #00ffff 0%, #8b5cf6 50%, #ec4899 100%);
  --gradient-quantum: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 50%, #06b6d4 100%);
  --gradient-holographic: linear-gradient(135deg, #ff6b6b 0%, #4ecdc4 50%, #45b7d1 100%);
}

/* Light Theme Variables */
.light {
  --text-primary: #111827;
  --text-secondary: #374151;
  --bg-primary: #ffffff;
  --bg-secondary: #f9fafb;
  --accent: #06b6d4;
