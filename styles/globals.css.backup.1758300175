  background-size: 200px 100%;
  animation: shimmer 1.5s infinite;
}

/* Floating Animation */
.float-animation {
  animation: float 6s ease-in-out infinite;
}

/* Pulse Glow */
@keyframes pulse-glow {
  0%, 100% {
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.5);
  }
