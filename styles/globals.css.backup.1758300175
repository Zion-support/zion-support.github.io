  padding: 12px 16px;
  color: white;
  transition: all 0.3s ease;
  backdrop-filter: blur(10px);
}

input:focus, textarea:focus, select:focus {
  outline: none;
  border-color: var(--neon-cyan);
  box-shadow: 0 0 20px rgba(0, 255, 255, 0.3);
}

/* Enhanced Tables */
table {
  border-collapse: separate;
  border-spacing: 0;
  width: 100%;
}

th, td {
  padding: 12px;
  text-align: left;
  border-bottom: 1px solid rgba(0, 255, 255, 0.2);
}

th {
  background: rgba(0, 255, 255, 0.1);
  font-weight: 600;
  color: var(--neon-cyan);
}

tr:hover {
  background: rgba(0, 255, 255, 0.05);
}

/* Enhanced Lists */
ul, ol {
  padding-left: 20px;
}

li {
  margin-bottom: 8px;
  position: relative;
}

ul li::before {
  content: '▶';
  color: var(--neon-cyan);
  position: absolute;
  left: -20px;
  animation: listPulse 2s ease-in-out infinite;
}

@keyframes listPulse {
  0%, 100% {
    opacity: 0.7;
  }
  50% {
    opacity: 1;
  }
}

/* Enhanced Code Blocks */
code {
  background: rgba(0, 0, 0, 0.5);
  border: 1px solid rgba(0, 255, 255, 0.3);
  border-radius: 4px;
  padding: 2px 6px;
  font-family: 'Fira Code', 'Monaco', 'Consolas', monospace;
  color: var(--neon-cyan);
}

pre {
  background: rgba(0, 0, 0, 0.7);
  border: 1px solid rgba(0, 255, 255, 0.3);
  border-radius: 8px;
  padding: 16px;
  overflow-x: auto;
}

pre code {
  background: none;
  border: none;
  padding: 0;
}

/* Enhanced Navigation */
.nav-futuristic {
  background: rgba(0, 0, 0, 0.8);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(0, 255, 255, 0.2);
}

.nav-futuristic .nav-link {
  position: relative;
  padding: 8px 16px;
  transition: all 0.3s ease;
}

.nav-futuristic .nav-link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 0;
  height: 2px;
  background: var(--neon-cyan);
  transition: all 0.3s ease;
  transform: translateX(-50%);
}

.nav-futuristic .nav-link:hover::after {
  width: 100%;
}

/* Enhanced Sidebar */
.sidebar-futuristic {
  background: rgba(0, 0, 0, 0.9);
  backdrop-filter: blur(20px);
  border-right: 1px solid rgba(0, 255, 255, 0.2);
}

.sidebar-futuristic .sidebar-item {
  padding: 12px 16px;
  margin: 4px 8px;
  border-radius: 8px;
  transition: all 0.3s ease;
  cursor: pointer;
}

.sidebar-futuristic .sidebar-item:hover {
  background: rgba(0, 255, 255, 0.1);
  transform: translateX(5px);
}

/* Enhanced Modals */
.modal-futuristic {
  background: rgba(0, 0, 0, 0.95);
  backdrop-filter: blur(30px);
  border: 1px solid rgba(0, 255, 255, 0.3);
  border-radius: 16px;
  box-shadow: var(--holographic-shadow);
}

.modal-futuristic .modal-header {
  border-bottom: 1px solid rgba(0, 255, 255, 0.2);
  padding: 20px 24px;
}

.particle-holographic {
  position: absolute;
  top: 0;
  left: 0;
  width: 4px;
  height: 100%;
  background: var(--neon-cyan);
}

.alert-futuristic.success::before {
  background: var(--neon-green);
}

.alert-futuristic.warning::before {
  background: var(--neon-yellow);
}

.alert-futuristic.error::before {
  background: var(--neon-red);
}

/* Enhanced Progress Bars */
.progress-futuristic {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 8px;
  height: 8px;
  overflow: hidden;
  position: relative;
}

.progress-futuristic .progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--neon-cyan), var(--neon-purple));
  border-radius: 8px;
  transition: width 0.3s ease;
  position: relative;
}

.progress-futuristic .progress-bar::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: progressShine 2s ease-in-out infinite;
}

@keyframes progressShine {
  0% {
    transform: translateX(-100%);
  }
  100% {
    transform: translateX(100%);
  }
}

/* Enhanced Tooltips */
.tooltip-futuristic {
  position: relative;
  display: inline-block;
}

.tooltip-futuristic .tooltip-text {
  visibility: hidden;
  background: rgba(0, 0, 0, 0.9);
  backdrop-filter: blur(20px);
  color: white;
  text-align: center;
  border: 1px solid rgba(0, 255, 255, 0.3);
  border-radius: 8px;
  padding: 8px 12px;
  position: absolute;
  z-index: 1000;
  bottom: 125%;
  left: 50%;
  transform: translateX(-50%);
  opacity: 0;
  transition: opacity 0.3s ease;
  white-space: nowrap;
}

.tooltip-futuristic .tooltip-text::after {
  content: '';
  position: absolute;
  top: 100%;
  left: 50%;
  margin-left: -5px;
  border-width: 5px;
  border-style: solid;
  border-color: rgba(0, 255, 255, 0.3) transparent transparent transparent;
}

.tooltip-futuristic:hover .tooltip-text {
  visibility: visible;
  opacity: 1;
}

/* Enhanced Loading Spinners */
.spinner-futuristic {
  width: 40px;
  height: 40px;
  border: 3px solid rgba(0, 255, 255, 0.3);
  border-top: 3px solid var(--neon-cyan);
  border-radius: 50%;
  animation: particleFloat 8s ease-in-out infinite reverse;
}

@keyframes particleFloat {
  0%, 100% {
    transform: translateY(0px) translateX(0px);
    opacity: 0;
  }
  25% {
    opacity: 1;
  }
  50% {
    transform: translateY(-100px) translateX(50px);
    opacity: 0.8;
  }
  75% {
    opacity: 0.5;
  }
}

/* Enhanced Typography */
.font-quantum {
  font-family: 'Orbitron', 'Inter', monospace;
  letter-spacing: 0.1em;
}

.font-holographic {
  font-family: 'Rajdhani', 'Inter', sans-serif;
  font-weight: 600;
  letter-spacing: 0.05em;
