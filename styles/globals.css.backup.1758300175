}

.glow-pulse {
  animation: glow-pulse 2s ease-in-out infinite;
}

@keyframes glow-pulse {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

.neon-flicker {
  animation: neon-flicker 0.5s infinite alternate;
}

@keyframes neon-flicker {
  0% { opacity: 1; }
  100% { opacity: 0.8; }
}

/* Responsive Design Enhancements */
@media (max-width: 768px) {
  .mobile-optimized {
    font-size: 0.9rem;
    line-height: 1.4;
  }
  
  .float,
  .pulse-glow,
  .gradient-animate {
    animation: none;
  }
}

