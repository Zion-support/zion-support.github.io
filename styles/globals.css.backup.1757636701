/* Enhanced Dark Mode Support */
@media (prefers-color-scheme: dark) {
  :root {
    --neon-cyan: #00d4ff;
    --neon-purple: #a855f7;
  }
}

/* Enhanced Print Styles */
@media print {
  .btn-futuristic,
  .card-futuristic {
    box-shadow: none;
    border: 1px solid #ccc;
  }
  
  .text-gradient {
    color: #000;
    background: none;
  }
}

/* Enhanced Performance Optimizations */
.will-change-transform {
  will-change: transform;
}

/* Smooth Scrolling */
html {
  scroll-behavior: smooth;
}

body {
  color: rgb(var(--foreground-rgb));
  background: linear-gradient(
      to bottom,
      transparent,
      rgb(var(--background-end-rgb))
    )
    rgb(var(--background-start-rgb));
}

@layer utilities {
  .text-balance {
    text-wrap: balance;
  }
  
  html {
    scroll-behavior: auto;
  }
}

/* Header Styles */
.header {
  position: sticky;
  top: 0;
  z-index: 50;
  background: var(--header-bg);
  backdrop-filter: blur(10px);
  color: white;
  border-bottom: 1px solid var(--header-border);
  transition: var(--transition-smooth);
}

.header.scrolled {
  background: rgba(11, 18, 32, 0.98);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}

.header-nav {
  max-width: 1400px;
  margin: 0 auto;
  padding: 12px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.header-logo {
  font-weight: 800;
  letter-spacing: 0.3px;
  font-size: 1.25rem;
  background: var(--gradient-primary);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-decoration: none;
}

.header-nav-links {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
}

.header-nav-link {
  padding: 8px 12px;
  border-radius: 6px;
  opacity: 0.9;
  transition: var(--transition-smooth);
  text-decoration: none;
  color: white;
}

.header-nav-link:hover {
  opacity: 1;
  background: rgba(255, 255, 255, 0.1);
  transform: translateY(-1px);
}

.header-nav-link:focus-visible {
  background: rgba(255, 255, 255, 0.15);
}

.header-nav-cta {
  font-weight: 600;
  background: var(--gradient-primary);
  color: white;
  padding: 8px 16px;
  border-radius: 8px;
  transition: var(--transition-smooth);
  text-decoration: none;
  position: relative;
  overflow: hidden;
}

.header-nav-cta:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-glow);
}

.header-nav-cta:focus-visible {
  box-shadow: var(--shadow-glow);
}

.mobile-menu-button {
  display: none;
  background: none;
  border: none;
  color: white;
  cursor: pointer;
  padding: 8px;
  border-radius: 6px;
  transition: var(--transition-smooth);
}

.mobile-menu-button:hover {
  background: rgba(255, 255, 255, 0.1);
}

.mobile-menu-button:focus-visible {
  background: rgba(255, 255, 255, 0.15);
  outline: 2px solid #3b82f6;
  outline-offset: 2px;
}

.hamburger-icon {
  width: 24px;
  height: 24px;
  stroke: currentColor;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.mobile-menu {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: var(--header-bg);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--header-border);
  padding: 20px;
  transform: translateY(-10px);
  opacity: 0;
  transition: var(--transition-smooth);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}

.mobile-menu.open {
  display: flex;
  flex-direction: column;
  gap: 12px;
  transform: translateY(0);
  opacity: 1;
}

/* Footer Styles */
.footer {
  background: var(--gradient-footer);
  color: white;
  margin-top: 60px;
  border-top: 1px solid var(--header-border);
}

.footer-content {
  max-width: 1400px;
  margin: 0 auto;
  padding: 40px 20px;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 32px;
}

.footer-logo {
  font-weight: 800;
  font-size: 1.25rem;
  background: var(--gradient-primary);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.footer-section h3 {
  font-weight: 700;
  font-size: 1.1rem;
  margin-bottom: 12px;
}

.footer-section p {
  opacity: 0.8;
  line-height: 1.6;
  margin-bottom: 12px;
}

.footer-section a,
.footer-link {
  opacity: 0.8;
  text-decoration: none;
  color: white;
  display: block;
  margin-bottom: 8px;
  transition: var(--transition-smooth);
  border-radius: 4px;
  padding: 4px 0;
}

.footer-section a:hover,
.footer-link:hover {
  opacity: 1;
  transform: translateX(4px);
}

.footer-section a:focus-visible,
.footer-link:focus-visible {
  opacity: 1;
  background: rgba(255, 255, 255, 0.1);
  outline: 2px solid #3b82f6;
  outline-offset: 2px;
}

.footer-cta-button {
  background: var(--gradient-primary);
  color: white;
  padding: 10px 16px;
  border-radius: 8px;
  text-align: center;
  text-decoration: none;
  font-weight: 600;
  display: block;
  margin-bottom: 8px;
  transition: var(--transition-smooth);
  position: relative;
  overflow: hidden;
}

.footer-cta-button:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-glow);
}

.footer-cta-button:focus-visible {
  box-shadow: var(--shadow-glow);
  outline: 2px solid #3b82f6;
  outline-offset: 2px;
}

.footer-cta-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: white;
  padding: 10px 16px;
  border-radius: 8px;
  text-align: center;
  text-decoration: none;
  font-weight: 600;
  display: block;
  transition: var(--transition-smooth);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.footer-cta-secondary:hover {
  background: rgba(255, 255, 255, 0.2);
  transform: translateY(-1px);
  border-color: rgba(255, 255, 255, 0.3);
}

.footer-cta-secondary:focus-visible {
  background: rgba(255, 255, 255, 0.2);
  outline: 2px solid #3b82f6;
  outline-offset: 2px;
}

.footer-bottom {
  border-top: 1px solid var(--header-border);
  padding: 20px;
  text-align: center;
}

.footer-bottom small {
  opacity: 0.7;
}

.footer-bottom a {
  color: #93c5fd;
  margin-left: 8px;
  text-decoration: none;
}

.footer-bottom a:hover {
  text-decoration: underline;
}

/* Responsive Design */
@media (max-width: 768px) {
  .header-nav-links {
    display: none;
  }
  
  .mobile-menu-button {
    display: block;
  }
  
  .footer-content {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  
  .hero-stats {
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
}

@media (max-width: 480px) {
  .hero-stats {
    grid-template-columns: 1fr;
    gap: 1rem;
  }
}

/* Focus styles for accessibility */
.header-nav-link:focus,
.header-nav-cta:focus,
.mobile-menu-button:focus,
.footer-section a:focus,
.footer-cta-button:focus,
.footer-cta-secondary:focus {
  outline: 2px solid #3b82f6;
  outline-offset: 2px;
}

/* Loading states */
.loading {
  opacity: 0.6;
  pointer-events: none;
}

.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: loading 1.5s infinite;
}

@keyframes loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}