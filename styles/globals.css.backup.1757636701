@tailwind base;
@tailwind components;
@tailwind utilities;

/* Enhanced Futuristic Design System with Superior Contrast */
:root {
  --header-bg: rgba(11, 18, 32, 0.95);
  --header-border: rgba(255, 255, 255, 0.1);
  --gradient-primary: linear-gradient(135deg, #3b82f6, #8b5cf6);
  --gradient-footer: linear-gradient(135deg, #0b1220, #1e293b);
  --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  --shadow-glow: 0 0 20px rgba(59, 130, 246, 0.3);
}

* {
  box-sizing: border-box;
  padding: 0;
  margin: 0;
}

html,
body {
  max-width: 100vw;
  overflow-x: hidden;
}

/* Enhanced Scrollbar */
::-webkit-scrollbar {
  width: 12px;
}

::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 6px;
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(135deg, var(--neon-cyan), var(--neon-purple));
  border-radius: 6px;
  border: 2px solid rgba(0, 0, 0, 0.1);
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(135deg, var(--neon-purple), var(--neon-pink));
  transform: scale(1.1);
}

/* Enhanced Selection Styles */
::selection {
  background: rgba(0, 212, 255, 0.4);
  color: #ffffff;
  text-shadow: 0 0 10px rgba(0, 212, 255, 0.8);
}

::-moz-selection {
  background: rgba(0, 212, 255, 0.4);
  color: #ffffff;
  text-shadow: 0 0 10px rgba(0, 212, 255, 0.8);
}

/* Enhanced Typography */
.text-gradient {
  background: var(--gradient-primary);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: gradient-shift 3s ease-in-out infinite;
}

.text-gradient-cyan {
  background: linear-gradient(135deg, var(--neon-cyan), var(--neon-blue));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.text-gradient-purple {
  background: linear-gradient(135deg, var(--neon-purple), var(--neon-pink));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.text-gradient-glow {
  background: var(--gradient-primary);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 0 20px rgba(0, 212, 255, 0.5));
}

/* Enhanced Button Styles */
.btn-futuristic {
  position: relative;
  background: var(--gradient-primary);
  border: none;
  border-radius: 16px;
  color: white;
  font-weight: 600;
  padding: 14px 28px;
  cursor: pointer;
  overflow: hidden;
  transition: all var(--animation-duration) var(--animation-timing);
  box-shadow: 0 8px 25px rgba(0, 212, 255, 0.3);
  transform: translateY(0);
}

.btn-futuristic:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 35px rgba(0, 212, 255, 0.4);
}

.btn-futuristic:active {
  transform: translateY(-2px);
}

.btn-futuristic::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s;
}

.btn-futuristic:hover::before {
  left: 100%;
}

/* Enhanced Card Styles */
.card-futuristic {
  background: rgba(17, 24, 39, 0.8);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(0, 212, 255, 0.2);
  border-radius: 20px;
  padding: 24px;
  transition: all var(--animation-duration) var(--animation-timing);
  position: relative;
  overflow: hidden;
}

.card-futuristic::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: var(--gradient-primary);
  transform: scaleX(0);
  transition: transform var(--animation-duration) var(--animation-timing);
}

.card-futuristic:hover::before {
  transform: scaleX(1);
}

.card-futuristic:hover {
  border-color: rgba(0, 212, 255, 0.4);
  box-shadow: 0 20px 40px rgba(0, 212, 255, 0.1);
  transform: translateY(-8px);
}

/* Enhanced Input Styles */
.input-futuristic {
  background: rgba(17, 24, 39, 0.6);
  border: 2px solid rgba(0, 212, 255, 0.2);
  border-radius: 12px;
  padding: 12px 16px;
  color: white;
  transition: all var(--animation-duration) var(--animation-timing);
  backdrop-filter: blur(10px);
}

.input-futuristic:focus {
  outline: none;
  border-color: var(--neon-cyan);
  box-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
  background: rgba(17, 24, 39, 0.8);
}

.input-futuristic::placeholder {
  color: rgba(156, 163, 175, 0.6);
}

/* Enhanced Navigation Styles */
.nav-futuristic {
  background: rgba(0, 0, 0, 0.8);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(0, 212, 255, 0.2);
}

.nav-link {
  position: relative;
  color: rgba(156, 163, 175, 0.8);
  transition: color var(--animation-duration) var(--animation-timing);
}

.nav-link::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 0;
  height: 2px;
  background: var(--gradient-primary);
  transition: width var(--animation-duration) var(--animation-timing);
}

.nav-link:hover {
  color: white;
}

.nav-link:hover::after {
  width: 100%;
}

/* Enhanced Background Effects */
.bg-futuristic {
  background: radial-gradient(circle at 20% 50%, rgba(120, 119, 198, 0.15), transparent 50%),
              radial-gradient(circle at 80% 20%, rgba(255, 119, 198, 0.15), transparent 50%),
              radial-gradient(circle at 40% 80%, rgba(120, 219, 255, 0.15), transparent 50%);
}

.bg-grid {
  background-image: 
    linear-gradient(rgba(0, 212, 255, 0.1) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 212, 255, 0.1) 1px, transparent 1px);
  background-size: 50px 50px;
  animation: grid-move 20s linear infinite;
}

/* Enhanced Animations */
@keyframes gradient-shift {
  0%, 100% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
}

@keyframes grid-move {
  0% {
    transform: translate(0, 0);
  }
  100% {
    transform: translate(50px, 50px);
  }
}

@keyframes float {
  0%, 100% {
    transform: translateY(0px);
  }
  50% {
    transform: translateY(-20px);
  }
}

@keyframes pulse-glow {
  0%, 100% {
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.3);
  }
  50% {
    box-shadow: 0 0 40px rgba(0, 212, 255, 0.6);
  }
}

@keyframes neon-flicker {
  0%, 19.999%, 22%, 62.999%, 64%, 64.999%, 70%, 100% {
    opacity: 0.99;
    filter: drop-shadow(0 0 1px rgba(0, 212, 255, 0.8)) 
            drop-shadow(0 0 15px rgba(0, 212, 255, 0.6)) 
            drop-shadow(0 0 25px rgba(0, 212, 255, 0.4));
  }
  20%, 21.999%, 63%, 63.999%, 65%, 69.999% {
    opacity: 0.4;
    filter: none;
  }
}

/* Enhanced Component Classes */
.glass-effect {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.neon-border {
  border: 2px solid transparent;
  background: linear-gradient(45deg, var(--neon-cyan), var(--neon-purple)) border-box;
  -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: destination-out;
  mask-composite: exclude;
}

.neon-glow {
  box-shadow: 0 0 20px rgba(0, 212, 255, 0.3),
              0 0 40px rgba(0, 212, 255, 0.2),
              0 0 60px rgba(0, 212, 255, 0.1);
}

.neon-text {
  text-shadow: 0 0 10px currentColor,
               0 0 20px currentColor,
               0 0 30px currentColor;
}

