/* Enhanced High Contrast Mode */
@media (prefers-contrast: high) {
  :root {
    --accent-cyan: 0, 255, 255;
    --accent-blue: 0, 0, 255;
    --accent-purple: 128, 0, 128;
  }
}

/* Enhanced Dark Mode Support */
@media (prefers-color-scheme: dark) {
  :root {
    --background-start-rgb: 10, 15, 30;
    --background-end-rgb: 20, 25, 40;
  }
}

/* Enhanced Reduced Motion Support */
@media (prefers-reduced-motion: reduce) {
  .animate-float,
  .animate-pulse-glow,
  .animate-neon-flicker,
  .animate-matrix-rain,
  .animate-hologram-scan,
  .animate-quantum-pulse,
  .animate-space-drift,
  .animate-cyber-wave {
    animation: none;
  }
}
