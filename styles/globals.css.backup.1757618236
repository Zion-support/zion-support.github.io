  color: white;
}

.btn-ghost:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.2);
  transform: translateY(-2px);
} 

/* Star slow pulse animation */
@keyframes pulse-slow { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }
.animate-pulse-slow { animation: pulse-slow 1.5s ease-in-out infinite; }

.gradient-text-purple {
  @apply bg-gradient-to-r from-purple-400 to-pink-500 bg-clip-text text-transparent;
}

.gradient-text-green {
  @apply bg-gradient-to-r from-green-400 to-emerald-500 bg-clip-text text-transparent;
}

/* Background Patterns */
.bg-pattern-dots {
  background-image: radial-gradient(circle, var(--border-accent) 1px, transparent 1px);
  background-size: 20px 20px;
}

.bg-pattern-grid {
  background-image: 
    linear-gradient(var(--border-accent) 1px, transparent 1px),
    linear-gradient(90deg, var(--border-accent) 1px, transparent 1px);
  background-size: 20px 20px;
}

/* Animation Classes */
.animate-float {
  animation: float 6s ease-in-out infinite;
}

.animate-glow {
  animation: glow 2s ease-in-out infinite alternate;
}

/* Focus Styles */
.focus-ring {
  @apply focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:ring-offset-2 focus:ring-offset-black;
}

.focus-ring-cyan {
  @apply focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:ring-offset-2 focus:ring-offset-black;
}

/* Button Styles */
.btn-primary {
  @apply px-6 py-3 bg-gradient-to-r from-cyan-500 to-blue-600 text-white font-semibold rounded-xl hover:from-cyan-600 hover:to-blue-700 transition-all duration-300 transform hover:scale-105 shadow-lg shadow-cyan-500/25 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:ring-offset-2 focus:ring-offset-black;
}

/* Responsive Typography */
@media (max-width: 640px) {
  .text-responsive {
    font-size: clamp(1rem, 4vw, 1.5rem);
  }
  
  .text-responsive-lg {
    font-size: clamp(1.5rem, 6vw, 2.5rem);
  }
  
  .text-responsive-xl {
    font-size: clamp(2rem, 8vw, 3.5rem);
  }
}

.btn-ghost {
  @apply px-6 py-3 text-gray-300 hover:text-white transition-colors duration-200 font-medium focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:ring-offset-2 focus:ring-offset-black rounded-lg;
}

.loading-dots {
  @apply flex items-center space-x-2;
}

.loading-dots > div {
  @apply w-2 h-2 bg-cyan-400 rounded-full animate-bounce;
}

/* Input Styles */
.input-primary {
  @apply px-4 py-3 bg-gray-800/50 border border-gray-700/50 rounded-xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500/50 transition-all duration-200;
}

.form-input:focus {
  @apply bg-white/10 border-cyan-400/50;
}

.form-label {
  @apply block text-sm font-medium text-gray-300 mb-2;
}

.form-error {
  @apply text-red-400 text-sm mt-1;
}

.form-success {
  @apply text-green-400 text-sm mt-1;
}

/* Utility Classes */
.backdrop-blur-xl {
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
}

.glass-effect {
  @apply bg-white/5 backdrop-blur-xl border border-white/10;
}

.text-shadow {
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
}

.text-shadow-lg {
  text-shadow: 0 4px 8px rgba(0, 0, 0, 0.5);
}

/* Print Styles */
@media print {
  .no-print {
    display: none !important;
  }
  
  body {
    background: white !important;
    color: black !important;
  }
  
  * {
    box-shadow: none !important;
    text-shadow: none !important;
  }
}

/* High DPI Display Support */
@media (-webkit-min-device-pixel-ratio: 2), (min-resolution: 192dpi) {
  .high-dpi {
    image-rendering: -webkit-optimize-contrast;
    image-rendering: crisp-edges;
  }
}

/* Dark Mode Support (if user prefers) */
@media (prefers-color-scheme: dark) {
  :root {
    --bg-primary: #000000;
    --bg-secondary: #111827;
  }
}

/* Light Mode Support (if user prefers) */
@media (prefers-color-scheme: light) {
  :root {
    --bg-primary: #ffffff;
    --bg-secondary: #f3f4f6;
    --text-primary: #000000;
    --text-secondary: #374151;
    --text-muted: #6b7280;
  }
}

/* Reduced Motion Support */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}

/* High Contrast Support */
@media (prefers-contrast: high) {
  :root {
    --border-primary: #ffffff;
    --border-accent: #ffff00;
  }
  
  * {
    border-width: 2px !important;
  }
}
