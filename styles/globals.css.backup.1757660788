/* Import Modern Design System */
@import './modern-design-system.css';

/* Enhanced Futuristic Design System with Superior Contrast */
:root {
  --neon-blue: #00d4ff;
  --neon-purple: #8b5cf6;
  --neon-pink: #ec4899;
  --neon-green: #10b981;
  --neon-orange: #f59e0b;
  --neon-red: #ef4444;
  --neon-yellow: #eab308;
  --holographic-gradient: linear-gradient(45deg, #00d4ff, #8b5cf6, #ec4899, #10b981);
  --cyber-gradient: linear-gradient(135deg, #0f0f23, #1a1a2e, #16213e, #0f3460);
  --neon-shadow: 0 0 20px rgba(0, 212, 255, 0.5);
  --glow-shadow: 0 0 30px rgba(139, 92, 246, 0.4);
  
  /* Enhanced High Contrast Colors - WCAG AA Compliant */
  --text-primary: #ffffff;
  --text-secondary: #f1f5f9;
  --text-tertiary: #e2e8f0;
  --text-muted: #cbd5e1;
  --text-accent: #00d4ff;
  --text-success: #10b981;
  --text-warning: #f59e0b;
  --text-error: #ef4444;
  --text-info: #3b82f6;
  
  /* Enhanced High Contrast Backgrounds */
  --bg-primary: #0a0a1a;
  --bg-secondary: #0f0f23;
  --bg-tertiary: #1a1a2e;
  --bg-card: rgba(255, 255, 255, 0.12);
  --bg-card-hover: rgba(255, 255, 255, 0.18);
  --bg-overlay: rgba(0, 0, 0, 0.8);
  
  /* Enhanced High Contrast Borders */
  --border-primary: rgba(255, 255, 255, 0.25);
  --border-secondary: rgba(255, 255, 255, 0.15);
  --border-accent: rgba(0, 212, 255, 0.4);
  --border-success: rgba(16, 185, 129, 0.4);
  --border-warning: rgba(245, 158, 11, 0.4);
  --border-error: rgba(239, 68, 68, 0.4);
  
  /* Enhanced Focus States */
  --focus-ring: rgba(0, 212, 255, 0.6);
  --focus-ring-success: rgba(16, 185, 129, 0.6);
  --focus-ring-warning: rgba(245, 158, 11, 0.6);
  --focus-ring-error: rgba(239, 68, 68, 0.6);
  
  /* Enhanced Shadow System */
  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.5);
  --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.6);
  --shadow-lg: 0 10px 15px rgba(0, 0, 0, 0.7);
  --shadow-xl: 0 20px 25px rgba(0, 0, 0, 0.8);
  --shadow-neon: 0 0 20px rgba(0, 212, 255, 0.5);
  --shadow-glow: 0 0 30px rgba(139, 92, 246, 0.4);
}

/* Enhanced High Contrast Text Utilities */
.text-high-contrast {
  color: var(--text-primary);
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);
}

.text-high-contrast-secondary {
  color: var(--text-secondary);
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
}

.text-high-contrast-tertiary {
  color: var(--text-tertiary);
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
}

.text-high-contrast-muted {
  color: var(--text-muted);
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
}

.text-high-contrast-accent {
  color: var(--text-accent);
  text-shadow: 0 0 10px rgba(0, 212, 255, 0.5);
}

.text-high-contrast-success {
  color: var(--text-success);
  text-shadow: 0 0 10px rgba(16, 185, 129, 0.5);
}

.text-high-contrast-warning {
  color: var(--text-warning);
  text-shadow: 0 0 10px rgba(245, 158, 11, 0.5);
}

.text-high-contrast-error {
  color: var(--text-error);
  text-shadow: 0 0 10px rgba(239, 68, 68, 0.5);
}

.text-high-contrast-info {
  color: var(--text-info);
  text-shadow: 0 0 10px rgba(59, 130, 246, 0.5);
}

/* Enhanced High Contrast Background Utilities */
.bg-high-contrast-primary {
  background-color: var(--bg-primary);
}

.bg-high-contrast-secondary {
  background-color: var(--bg-secondary);
}

.bg-high-contrast-tertiary {
  background-color: var(--bg-tertiary);
}

.bg-high-contrast-card {
  background-color: var(--bg-card);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.bg-high-contrast-card-hover {
  background-color: var(--bg-card-hover);
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);
}

.bg-high-contrast-overlay {
  background-color: var(--bg-overlay);
  backdrop-filter: blur(5px);
  -webkit-backdrop-filter: blur(5px);
}

/* Enhanced High Contrast Border Utilities */
.border-high-contrast-primary {
  border-color: var(--border-primary);
}

.border-high-contrast-secondary {
  border-color: var(--border-secondary);
}

.border-high-contrast-accent {
  border-color: var(--border-accent);
}

.border-high-contrast-success {
  border-color: var(--border-success);
}

.border-high-contrast-warning {
  border-color: var(--border-warning);
}

.border-high-contrast-error {
  border-color: var(--border-error);
}

/* Enhanced Focus States */
.focus-high-contrast {
  outline: 2px solid var(--focus-ring);
  outline-offset: 2px;
}

.focus-high-contrast-success {
  outline: 2px solid var(--focus-ring-success);
  outline-offset: 2px;
}

.focus-high-contrast-warning {
  outline: 2px solid var(--focus-ring-warning);
  outline-offset: 2px;
}

.focus-high-contrast-error {
  outline: 2px solid var(--focus-ring-error);
  outline-offset: 2px;
}

/* Enhanced Shadow Utilities */
.shadow-high-contrast {
  box-shadow: var(--shadow-md);
}

.shadow-high-contrast-lg {
  box-shadow: var(--shadow-lg);
}

.shadow-high-contrast-xl {
  box-shadow: var(--shadow-xl);
}

.shadow-neon-high-contrast {
  box-shadow: var(--shadow-neon);
}

.shadow-glow-high-contrast {
  box-shadow: var(--shadow-glow);
}

/* Mobile-First Responsive Text Colors */
.text-gray-300 {
  color: #d1d5db;
}

.text-gray-400 {
  color: #9ca3af;
}

.text-gray-500 {
  color: #6b7280;
}

.text-gray-600 {
  color: #4b5563;
}

.text-gray-700 {
  color: #374151;
}

.text-gray-800 {
  color: #1f2937;
}

.text-gray-900 {
  color: #111827;
}

/* Mobile-First Form Elements */
input, textarea, select {
  background-color: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 0.5rem;
  padding: 0.75rem 1rem;
  color: white;
  font-size: 1rem;
  transition: all 0.3s ease;
}

input:focus, textarea:focus, select:focus {
  outline: none;
  border-color: var(--neon-blue);
  box-shadow: 0 0 0 3px rgba(0, 212, 255, 0.1);
  background-color: rgba(255, 255, 255, 0.15);
}

input::placeholder, textarea::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

/* Mobile-First Button Styles */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.75rem 1.5rem;
  border-radius: 0.5rem;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.3s ease;
  cursor: pointer;
  min-height: 44px; /* Mobile touch target */
}

.btn:focus {
  outline: 2px solid var(--neon-blue);
  outline-offset: 2px;
}

.btn-secondary {
  background-color: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  color: white;
}

.btn-secondary:hover {
  background-color: rgba(255, 255, 255, 0.2);
  border-color: rgba(255, 255, 255, 0.3);
}

.btn-ghost {
  background-color: transparent;
  border: 1px solid transparent;
  color: white;
}

.btn-ghost:hover {
  background-color: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.2);
}

/* Mobile-First Card Styles */
.card {
  background-color: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 1rem;
  padding: 1.5rem;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  transition: all 0.3s ease;
}

.card:hover {
  background-color: rgba(255, 255, 255, 0.15);
  border-color: rgba(255, 255, 255, 0.3);
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
}

/* Mobile-First Link Styles */
a {
  color: var(--neon-blue);
  text-decoration: none;
  transition: color 0.3s ease;
}

a:hover {
  color: var(--neon-purple);
}

a:focus {
  outline: 2px solid var(--neon-blue);
  outline-offset: 2px;
}

/* Mobile-First Navigation Styles */
nav a {
  color: white;
  text-decoration: none;
  transition: color 0.3s ease;
}

nav a:hover {
  color: var(--neon-blue);
}

nav a:focus {
  outline: 2px solid var(--neon-blue);
  outline-offset: 2px;
}

/* Mobile-First Status Indicators */
.status-active {
  color: var(--neon-green);
  background-color: rgba(16, 185, 129, 0.1);
}

.status-pending {
  color: var(--neon-orange);
  background-color: rgba(245, 158, 11, 0.1);
}

.status-inactive {
  color: var(--text-muted);
  background-color: rgba(203, 213, 225, 0.1);
}

/* Mobile-First Typography */
h1, h2, h3, h4, h5, h6 {
  color: white;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 1rem;
}

p {
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 1rem;
  font-size: 1rem;
}

li {
  color: var(--text-secondary);
  margin-bottom: 0.5rem;
}

code {
  background-color: rgba(255, 255, 255, 0.1);
  padding: 0.25rem 0.5rem;
  border-radius: 0.25rem;
  font-family: 'Courier New', monospace;
  color: var(--neon-green);
}

blockquote {
  border-left: 4px solid var(--neon-blue);
  padding-left: 1rem;
  margin: 1rem 0;
  font-style: italic;
  color: var(--text-secondary);
}

/* Mobile-First Table Styles */
table {
  width: 100%;
  border-collapse: collapse;
}

th {
  background-color: rgba(255, 255, 255, 0.1);
  padding: 1rem;
  text-align: left;
  font-weight: 600;
  color: white;
}

td {
  padding: 1rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  color: var(--text-secondary);
}

/* Mobile-First Modal Styles */
.modal, .overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-content {
  background-color: var(--bg-primary);
  border: 1px solid var(--border-primary);
  border-radius: 1rem;
  padding: 2rem;
  max-width: 90vw;
  max-height: 90vh;
  overflow-y: auto;
}

/* Mobile-First Tooltip Styles */
.tooltip {
  position: relative;
  display: inline-block;
}

.tooltip::after {
  content: attr(data-tooltip);
  position: absolute;
  bottom: 100%;
  left: 50%;
  transform: translateX(-50%);
  background-color: var(--bg-primary);
  color: white;
  padding: 0.5rem;
  border-radius: 0.25rem;
  font-size: 0.875rem;
  white-space: nowrap;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.tooltip:hover::after {
  opacity: 1;
}

/* Mobile-First Badge Styles */
.badge {
  display: inline-block;
  padding: 0.25rem 0.5rem;
  border-radius: 0.25rem;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
}

.badge-success {
  background-color: rgba(16, 185, 129, 0.2);
  color: var(--neon-green);
}

.badge-warning {
  background-color: rgba(245, 158, 11, 0.2);
  color: var(--neon-orange);
}

.badge-error {
  background-color: rgba(239, 68, 68, 0.2);
  color: var(--neon-red);
}

.badge-info {
  background-color: rgba(59, 130, 246, 0.2);
  color: var(--neon-blue);
}

/* Mobile-First Progress Styles */
.progress {
  width: 100%;
  height: 0.5rem;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 0.25rem;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--neon-blue), var(--neon-purple));
  transition: width 0.3s ease;
}

/* Mobile-First Alert Styles */
.alert {
  padding: 1rem;
  border-radius: 0.5rem;
  margin-bottom: 1rem;
  border: 1px solid;
}

.alert-success {
  background-color: rgba(16, 185, 129, 0.1);
  border-color: var(--neon-green);
  color: var(--neon-green);
}

.alert-warning {
  background-color: rgba(245, 158, 11, 0.1);
  border-color: var(--neon-orange);
  color: var(--neon-orange);
}

.alert-error {
  background-color: rgba(239, 68, 68, 0.1);
  border-color: var(--neon-red);
  color: var(--neon-red);
}

.alert-info {
  background-color: rgba(59, 130, 246, 0.1);
  border-color: var(--neon-blue);
  color: var(--neon-blue);
}

/* Mobile-First Animations */
@keyframes neon-pulse {
  0%, 100% {
    box-shadow: 0 0 5px rgba(0, 212, 255, 0.5);
  }
  50% {
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.8), 0 0 30px rgba(0, 212, 255, 0.6);
  }
}

@keyframes holographic-shift {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

@keyframes cyber-float {
  0%, 100% {
    transform: translateY(0px) rotate(0deg);
  }
  25% {
    transform: translateY(-10px) rotate(1deg);
  }
  50% {
    transform: translateY(-20px) rotate(0deg);
  }
  75% {
    transform: translateY(-10px) rotate(-1deg);
  }
}

@keyframes particle-drift {
  0% {
    transform: translateX(-100px) translateY(0px);
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    transform: translateX(calc(100vw + 100px)) translateY(-100px);
    opacity: 0;
  }
}

@keyframes matrix-rain {
  0% {
    transform: translateY(-100vh);
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 1;
  }
  100% {
    transform: translateY(100vh);
    opacity: 0;
  }
}

@keyframes neon-text-glow {
  0%, 100% {
    text-shadow: 0 0 5px currentColor, 0 0 10px currentColor, 0 0 15px currentColor;
  }
  50% {
    text-shadow: 0 0 10px currentColor, 0 0 20px currentColor, 0 0 30px currentColor, 0 0 40px currentColor;
  }
}

@keyframes scan-line {
  0% {
    transform: translateY(-100%);
  }
  100% {
    transform: translateY(100vh);
  }
}

/* Mobile-First Utility Classes */
.neon-glow {
  animation: neon-pulse 2s ease-in-out infinite;
}

.holographic-bg {
  background: var(--holographic-gradient);
  background-size: 400% 400%;
  animation: holographic-shift 3s ease infinite;
}

.cyber-bg {
  background: var(--cyber-gradient);
  position: relative;
  overflow: hidden;
}

.cyber-bg::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--holographic-gradient);
  background-size: 400% 400%;
  animation: holographic-shift 3s ease infinite;
  opacity: 0.1;
  pointer-events: none;
}

.neon-text {
  animation: neon-text-glow 2s ease-in-out infinite;
}

.cyber-float {
  animation: cyber-float 6s ease-in-out infinite;
}

.particle {
  position: absolute;
  width: 2px;
  height: 2px;
  background: var(--neon-blue);
  border-radius: 50%;
  animation: particle-drift 8s linear infinite;
  opacity: 0.6;
}

.matrix-rain {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  pointer-events: none;
}

.matrix-rain::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, var(--neon-green), transparent);
  animation: matrix-rain 3s linear infinite;
  opacity: 0.1;
}

/* Mobile-First Glass Effects */
.glass {
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.glass-dark {
  background: rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

/* Mobile-First Border Effects */
.neon-border {
  border: 1px solid var(--neon-blue);
  box-shadow: 0 0 10px rgba(0, 212, 255, 0.3);
}

.neon-border-purple {
  border: 1px solid var(--neon-purple);
  box-shadow: 0 0 10px rgba(139, 92, 246, 0.3);
}

/* Mobile-First Container Classes */
.container-responsive {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1rem;
}

.container-fluid {
  width: 100%;
  padding: 0 1rem;
}

.container-narrow {
  width: 100%;
  max-width: 800px;
  margin: 0 auto;
  padding: 0 1rem;
}

.container-wide {
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 1rem;
}

/* Mobile-First Responsive Text Classes */
.text-responsive-xs {
  font-size: clamp(0.75rem, 2vw, 0.875rem);
}

.text-responsive-sm {
  font-size: clamp(0.875rem, 2.5vw, 1rem);
}

.text-responsive-base {
  font-size: clamp(1rem, 3vw, 1.125rem);
}

.text-responsive-lg {
  font-size: clamp(1.125rem, 3.5vw, 1.25rem);
}

.text-responsive-xl {
  font-size: clamp(1.25rem, 4vw, 1.5rem);
}

.text-responsive-2xl {
  font-size: clamp(1.5rem, 5vw, 1.875rem);
}

.text-responsive-3xl {
  font-size: clamp(1.875rem, 6vw, 2.25rem);
}

.text-responsive-4xl {
  font-size: clamp(2.25rem, 7vw, 3rem);
}

.text-responsive-5xl {
  font-size: clamp(3rem, 8vw, 4rem);
}

/* Mobile-First Spacing Classes */
.section-padding {
  padding: 2rem 0;
}

.section-padding-sm {
  padding: 1rem 0;
}

.section-padding-lg {
  padding: 4rem 0;
}

.content-padding {
  padding: 1rem;
}

.content-padding-sm {
  padding: 0.5rem;
}

.content-padding-lg {
  padding: 2rem;
}

/* Mobile-First Grid Classes */
.grid-responsive-1 {
  display: grid;
  grid-template-columns: repeat(1, 1fr);
  gap: 1rem;
}

.grid-responsive-2 {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1rem;
}

.grid-responsive-3 {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1rem;
}

.grid-responsive-4 {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1rem;
}

.grid-responsive-5 {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1rem;
}

.grid-responsive-6 {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 1rem;
}

/* Mobile-First Display Classes */
.mobile-only {
  display: block;
}

.tablet-up {
  display: none;
}

.desktop-up {
  display: none;
}

.large-desktop-up {
  display: none;
}

.mobile-tablet {
  display: block;
}

.tablet-desktop {
  display: none;
}

/* Mobile-First Aspect Ratio Classes */
.aspect-responsive-square {
  aspect-ratio: 1;
}

.aspect-responsive-video {
  aspect-ratio: 16 / 9;
}

/* Mobile-First Animation Classes */
.animate-fade-in-up {
  animation: fadeInUp 0.6s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Mobile-First Gradient Text */
.gradient-text {
  background: linear-gradient(45deg, var(--neon-blue), var(--neon-purple), var(--neon-pink));
  background-size: 200% 200%;
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  animation: holographic-shift 3s ease infinite;
}

