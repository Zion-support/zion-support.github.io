/* Mobile-First Safe Area Classes */
.safe-area-top {
  padding-top: env(safe-area-inset-top);
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-area-left {
  padding-left: env(safe-area-inset-left);
}

.safe-area-right {
  padding-right: env(safe-area-inset-right);
}

/* Mobile-First Touch Target Classes */
.touch-target {
  min-height: 44px;
  min-width: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Mobile-First Focus Classes */
.focus-responsive {
  outline: none;
  transition: all 0.3s ease;
}

.focus-responsive:focus {
  outline: 2px solid var(--neon-blue);
  outline-offset: 2px;
}

/* Mobile-First Hover Classes */
@media (hover: hover) {
  .hover-responsive {
    transition: all 0.3s ease;
  }

  .hover-responsive:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
  }
}

/* Mobile-First Print Styles */
@media print {
  .print-hidden {
    display: none !important;
  }

  .print-visible {
    display: block !important;
  }
}

/* Mobile-First Media Queries */
@media (min-width: 768px) {
  .mobile-only {
    display: none;
  }

  .tablet-up {
    display: block;
  }

  .mobile-tablet {
    display: block;
  }
}

@media (min-width: 1024px) {
  .tablet-up {
    display: block;
  }

  .desktop-up {
    display: block;
  }

  .mobile-tablet {
    display: none;
  }

  .tablet-desktop {
    display: block;
  }
}

@media (min-width: 1280px) {
  .large-desktop-up {
    display: block;
  }
}

/* Mobile-First Focus Visible */
.focus-visible {
  outline: none;
}

.focus-visible:focus {
  outline: 2px solid var(--neon-blue);
  outline-offset: 2px;
}

