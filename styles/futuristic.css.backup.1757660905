/* Futuristic animations and effects */

@keyframes floatSlow {
  0% { transform: translateY(0px) translateX(0px) scale(1); }
  50% { transform: translateY(-12px) translateX(6px) scale(1.02); }
  100% { transform: translateY(0px) translateX(0px) scale(1); }
}

@keyframes pulseGlow {
  0%, 100% { opacity: 0.55; filter: blur(24px); }
  50% { opacity: 0.9; filter: blur(32px); }
}

@keyframes drift {
  0% { transform: translate(-10%, -10%) rotate(0deg); }
  50% { transform: translate(10%, 10%) rotate(180deg); }
  100% { transform: translate(-10%, -10%) rotate(360deg); }
}

@keyframes starTwinkle {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

.futuristic-bg {
  position: fixed;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}

.futuristic-bg .blob {
  position: absolute;
  border-radius: 9999px;
  filter: blur(40px);
  opacity: 0.6;
  animation: pulseGlow 7s ease-in-out infinite;
}

.futuristic-bg .blob.blob-1 {
  width: 420px; height: 420px;
  background: radial-gradient(circle at 30% 30%, rgba(0,255,170,0.6), transparent 60%),
              radial-gradient(circle at 70% 70%, rgba(0,140,255,0.5), transparent 60%);
  top: -80px; left: -80px;
  animation-delay: 0.2s;
}

.futuristic-bg .blob.blob-2 {
  width: 520px; height: 520px;
  background: radial-gradient(circle at 20% 60%, rgba(255,0,200,0.5), transparent 60%),
              radial-gradient(circle at 80% 30%, rgba(255,180,0,0.4), transparent 60%);
  bottom: -120px; right: -120px;
  animation-delay: 0.6s;
}

.futuristic-bg .drift {
  position: absolute;
  width: 1600px; height: 1600px;
  background: conic-gradient(from 0deg, rgba(255,255,255,0.05), rgba(0,255,170,0.07), rgba(0,140,255,0.07), rgba(255,0,200,0.07), rgba(255,255,255,0.05));
  top: -400px; left: -400px;
  filter: blur(100px);
  animation: drift 60s linear infinite;
}

.futuristic-bg .stars {
  position: absolute;
  inset: 0;
  background-image: radial-gradient(2px 2px at 20% 40%, rgba(255,255,255,0.8) 50%, transparent),
                    radial-gradient(1.5px 1.5px at 60% 70%, rgba(255,255,255,0.8) 50%, transparent),
                    radial-gradient(1px 1px at 80% 20%, rgba(255,255,255,0.8) 50%, transparent),
                    radial-gradient(1.5px 1.5px at 40% 85%, rgba(255,255,255,0.8) 50%, transparent);
  opacity: 0.6;
  animation: starTwinkle 3s ease-in-out infinite;
}

.neon-card {
  position: relative;
  border-radius: 16px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: 0 0 0 1px rgba(255,255,255,0.05) inset;
  backdrop-filter: blur(12px);
}

.neon-card::before {
  content: "";
  position: absolute;
  inset: -2px;
  border-radius: 18px;
  background: linear-gradient(120deg, rgba(0,255,170,0.6), rgba(0,140,255,0.6), rgba(255,0,200,0.5));
  z-index: -1;
  filter: blur(16px);
  opacity: 0.4;
  transition: opacity 300ms ease;
}

.neon-card:hover::before { opacity: 0.8; }

.glitch {
  position: relative;
  animation: floatSlow 8s ease-in-out infinite;
  text-shadow: 0 0 12px rgba(0,255,170,0.5), 0 0 24px rgba(0,140,255,0.35);
}

.glitch::before, .glitch::after {
  content: attr(data-text);
  position: absolute;
  left: 0; top: 0;
  filter: blur(0.5px);
  opacity: 0.6;
}

.glitch::before { transform: translate(1px, 0); color: rgba(0,255,170,0.8); }
.glitch::after { transform: translate(-1px, 0); color: rgba(0,140,255,0.8); }
