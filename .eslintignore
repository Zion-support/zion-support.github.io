# Source backups/disabled
src_backup/
src_backup_temp/
src.broken/
src.corrupted/
src-disabled/
src.disabled/
src.pages.disabled/

# Temp directories
temp-backup/
temp_backup/
temp_broken_files/
temp_components/
temp_conflicts/
temp-disabled/
temp_exclude/

# Additional noisy or non-primary directories
ts_files_backup/
utils/
types/
zion-os/
zion-website/
zion-ai-assistant/

# Misc backups
lib_backup/
lib.broken/
lib.disabled/

# Catch-all patterns for backups/disabled variants
**/*.backup*
**/*.backups*/
**/*.corrupted*/
**/*.disabled*/

# Additional exclusions to avoid linting corrupted or out-of-scope code
