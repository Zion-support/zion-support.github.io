# Logs and reports
*.log
logs/
automation/logs/
optimization-reports/
link-reports/
log-analysis-reports/
maintenance-reports/
improvement-reports/

# Generated files and snapshots
**/*.generated.*
*.backup.*
*.disabled.*
*.corrupted.*
*.broken.*
zion.app/recovered-content/**

# Archived/disabled and backup folders
pages._archive_corrupted/
