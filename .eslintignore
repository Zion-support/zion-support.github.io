# Ignore large/generated or archived directories with known syntax issues
node_modules/
.next/
dist/
build/
backups/
backup/
backup-merge-conflicts/
backup-problematic-files/
recovered-branches/
corrupted_backup/
api.disabled/
api.disabled.temp/
app-disabled/
app_backup/
apps.backup/

# Exclude most component suites and APIs that are archived/experimental
components/
components.disabled/
components.disabled_full/
components-disabled/
components-disabled_full/

# Exclude problematic page backups
pages.disabled/
pages.disabled_full/
pages.disabled_auto/
pages_backup_before_cleanup/
pages.corrupted.*/
pages.broken/

# Catch-all patterns for backups/disabled variants
**/*.backup*
**/*.backups*/
**/*.corrupted*/
**/*.disabled*/
