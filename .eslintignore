# Always ignore dependencies and build outputs
node_modules/
.next/
dist/
build/
coverage/
out/
*.log
*.tmp
backups/
backup/
backup-merge-conflicts/
backup-problematic-files/
recovered-branches/
corrupted_backup/
api.disabled/
api.disabled.temp/
app-disabled/
app_backup/
apps.backup/

# Exclude most component suites and APIs that are archived/experimental
components/
components.disabled/
components.disabled_full/
components-disabled/
components-disabled_full/

# Exclude problematic page backups
pages-disabled/
pages.disabled/
pages_disabled/
pages.disabled_full/
pages.disabled_auto/
pages_backup/
pages_backup_before_cleanup/
pages_backup_conflict/
pages_backup_conflicts/
pages._archive_corrupted/
pages.broken/
pages.corrupted.*/
pages_minimal/
pages.old/
pages-quarantine/
