# Always ignore dependencies and build outputs
node_modules/
.next/
node_modules/
coverage/
dist/
build/
coverage/

# Ignore backups and temp artifacts
**/backup*/
**/backups/**
**/*.backup.*
**/*.cleanup-backup.*
**/.temp_backup_components/**
**/temp_backup/**
**/temp_exclude/**
**/recovered-branches/**
**/apps.backup/**
**/components.disabled*/**
**/pages.disabled*/**
**/pages.bak/**
**/pages_backup*/**
**/src_backup*/**
**/src.disabled/**
**/tests.disabled/**
**/test_build/**

# Ignore non-app workspaces and archives
zion-os*/
