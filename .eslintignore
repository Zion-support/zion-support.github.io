temp_working/
tests.disabled/
lib_backup/
hooks.disabled/
backup/
backups/
**/backup/**

# Large/generated app folders
zion-os.disabled/
zion-os/.next/
apps/**/.next/

# Static vendor bundles not meant for linting
**/static/**/*.js
**/static/**/*.jsx

# Netlify functions (serverless functions with different linting rules)
netlify/functions/

