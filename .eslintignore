api.disabled.temp/

recovered-branches/
.temp_backup_components/
temp_backup/
temp_exclude/
ts_files_backup/
corrupted_backup/
zion-os*/
components.disabled*/

# Reports, logs, artifacts
automation_logs/
automation-backup/
automation_backup/
automation-reports/
artifacts/
*.txt
*.md

