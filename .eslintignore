# Ignore build outputs and dependencies
.next/
node_modules/
dist/
build/
out/
coverage/

# Ignore backups, disabled, and legacy directories
backup/
backups/
backup-merge-conflicts/
backup-problematic-files/
**/*.backup*
**/*.conflict*

app_backup/
app-disabled/
apps.backup/
apps_backup/

components.disabled/
components.disabled_full/
components-disabled/
components-disabled_full/

src.disabled/
src_disabled/
src-backup/
src_backup/

blog-disabled/
blog-disabled-all/

api-backup/
api.disabled/
api.disabled.temp/

# Temporary and experimental directories
-temp*/
temp*/
__mocks__/
__tests__/

# Scripts and automation not part of runtime app
automation/
automation_backup/
**/scripts/**

# Misc large data/reports
artifacts/
*.md
*.json

# Specific noisy paths
components/**
