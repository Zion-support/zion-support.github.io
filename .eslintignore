# Ignore backups, temp, disabled, and non-source directories
node_modules/
.next/
dist/
out/
coverage/
build/
public/build/
automation/

# Backups and temp
.backup*/
**/*backup*/
backup*/
backups*/
backup-merge-conflicts/
backup-problematic-files/
.temp_backup_components/
src_backup*/
*.disabled/
*/.disabled/
*disabled*/
recovered-branches/
automation/backups/

data_backup/

# Monorepo extra apps and large content
server/
zion-os/
zion-os.disabled/
zion-ai-assistant/
zion-website/
zion_academy/
zion.app/

# Temp and generated content
temp*/
temp_components/
temp_disabled/
temp_working/
__tests__/
tests/
__mocks__/

test*/

# Broad utility and types folders that are not part of lint scope
utils/
types/

# Specific noisy folders
services_backup/
src.disabled/
apps.backup/
components.apps/
components.disabled/
components.disabled_full/
pages.disabled*/
pages.broken/
pages.bak/

# Static assets and HTML dumps
site.html
sitemap.xml

# Scripts and experiment sandboxes
simulator/
workflow_templates/

# Temporary broad exclusion for broken components
components/**
src.broken/
src.pages.disabled/
*.tsbuildinfo
